# ================================================
# DRONE CONFIGURATOR API - ENVIRONMENT VARIABLES
# ================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to Git (it's in .gitignore)

# ================================================
# DATABASE CONFIGURATION
# ================================================
DB_HOST=drone-configurator-db.cxa0c8wu0du4.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=drone_configurator
DB_USER=new_app_user
DB_PASSWORD=Sujith2007
DB_SSL_MODE=Require

# Full connection string (auto-generated from above, or override)
# ConnectionStrings__PostgresDb=Host=${DB_HOST};Port=${DB_PORT};Database=${DB_NAME};Username=${DB_USER};Password=${DB_PASSWORD};Ssl Mode=${DB_SSL_MODE}

# ================================================
# JWT CONFIGURATION
# ================================================
# IMPORTANT: Generate a secure random key (min 32 characters)
# Example: openssl rand -base64 32
JWT_SECRET_KEY=REPLACE_WITH_SECURE_RANDOM_KEY_MIN_32_CHARS_LONG

# JWT Issuer (your app name)
JWT_ISSUER=DroneConfigurator

# JWT Audience (who can use the token)
JWT_AUDIENCE=DroneConfiguratorClient

# Token expiration times (in minutes/days)
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7

# ================================================
# CORS CONFIGURATION
# ================================================
# For production, specify exact origins instead of *
CORS_ALLOWED_ORIGINS=*

# ================================================
# ENVIRONMENT
# ================================================
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:5000
# Options: Development, Staging, Production

# ================================================
# LOGGING
# ================================================
LOG_LEVEL=Information
# Options: Trace, Debug, Information, Warning, Error, Critical

# ================================================
# AWS CONFIGURATION (for production deployment)
# ================================================
AWS_REGION=us-east-1
AWS_SECRETS_MANAGER_DB_SECRET=drone-config/db-password
AWS_SECRETS_MANAGER_JWT_SECRET=drone-config/jwt-secret

# ================================================
# SERVER CONFIGURATION
# ================================================
ASPNETCORE_URLS=http://localhost:5000;https://localhost:5001
