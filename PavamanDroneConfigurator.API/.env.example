# ============================================
# Drone Configurator API - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================

# ===================
# DATABASE SETTINGS
# ===================
# Option 1: Individual variables (recommended for clarity)
DB_HOST=your-database-host.rds.amazonaws.com
DB_PORT=5432
DB_NAME=drone_configurator
DB_USER=your_db_user
DB_PASSWORD=your_secure_db_password
DB_SSL_MODE=Require

# Option 2: Full connection string (alternative)
# ConnectionStrings__PostgresDb=Host=...;Port=5432;Database=...;Username=...;Password=...;Ssl Mode=Require

# ===================
# JWT AUTHENTICATION
# ===================
# REQUIRED: Generate a secure random key (minimum 32 characters)
# Example: openssl rand -base64 48
JWT_SECRET_KEY=REPLACE_WITH_SECURE_RANDOM_KEY_MINIMUM_32_CHARACTERS

# Optional: Override JWT settings
JWT_ISSUER=DroneConfigurator
JWT_AUDIENCE=DroneConfiguratorClient

# ===================
# ADMIN USER
# ===================
# Optional: Set admin email and password for initial setup
# If not set, a secure random password will be generated
ADMIN_EMAIL=admin@droneconfig.local
ADMIN_PASSWORD=REPLACE_WITH_SECURE_ADMIN_PASSWORD

# ===================
# AWS SETTINGS
# ===================
# S3 bucket configuration
AWS_S3_BUCKET_NAME=drone-config-param-logs
AWS_S3_REGION=ap-south-1

# AWS Secrets Manager (optional - for production)
AWS_SECRETS_MANAGER_DB_SECRET=drone-configurator/postgres
AWS_SECRETS_MANAGER_JWT_SECRET=drone-configurator/jwt-secret

# ===================
# SES EMAIL SETTINGS
# ===================
# REQUIRED: SES sender email (must be verified in AWS SES)
SES__SenderEmail=noreply@kft.com

# ===================
# SECURITY SETTINGS
# ===================
# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5000,https://localhost:5001

# Environment
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:5000

# Enable sensitive data logging (ONLY for debugging)
ENABLE_SENSITIVE_LOGGING=false

# ===================
# CORS SETTINGS
# ===================
# Comma-separated list of allowed origins (for production)
# Leave empty to use default restrictive settings
ALLOWED_ORIGINS=http://localhost:5000,https://your-domain.com

# ===================
# DEVELOPMENT SETTINGS
# ===================
# Only enable in development environments
ENABLE_SENSITIVE_LOGGING=false
ASPNETCORE_ENVIRONMENT=Production
