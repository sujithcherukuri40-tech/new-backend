{
  "ConnectionStrings": {
    "PostgresDb": ""
  },
  "Jwt": {
    "Issuer": "DroneConfigurator",
    "Audience": "DroneConfiguratorClient",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7,
    "SecretKey": ""
  },
  "AWS": {
    "Secrets": {
      "DatabaseSecret": "drone-configurator/postgres",
      "JwtSecret": "drone-configurator/jwt-secret"
    },
    "S3": {
      "BucketName": "drone-config-param-logs",
      "Region": "ap-south-1"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "PavamanDroneConfigurator.API": "Debug"
    }
  },
  "AllowedHosts": "*",
  "Security": {
    "RateLimiting": {
      "PermitLimit": 100,
      "WindowSeconds": 60,
      "QueueLimit": 10
    },
    "PasswordPolicy": {
      "MinimumLength": 12,
      "RequireSpecialCharacter": true,
      "RequireUppercase": true,
      "RequireLowercase": true,
      "RequireDigit": true
    },
    "AccountLockout": {
      "MaxFailedAttempts": 5,
      "LockoutDurationMinutes": 15
    }
  }
}
