<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- ???????????????????????????????????????????????????????????????????????????????????????????
         PAVAMAN DRONE CONFIGURATOR - PROFESSIONAL THEME SYSTEM
         macOS-inspired, Mission Planner-grade professional design
         
         ?? ALL UI ELEMENTS MUST REFERENCE THESE VARIABLES - NO HARDCODED COLORS
    ??????????????????????????????????????????????????????????????????????????????????????????? -->

    <!-- ???????????????????????????????????????????????????????????????????????????????????????????
         COLOR PALETTE - PROFESSIONAL BLUE THEME
    ??????????????????????????????????????????????????????????????????????????????????????????? -->
    
    <!-- Primary Colors -->
    <Color x:Key="PrimaryColor">#2563EB</Color>
    <Color x:Key="PrimaryHoverColor">#1D4ED8</Color>
    <Color x:Key="PrimaryPressedColor">#1E40AF</Color>
    <Color x:Key="PrimaryLightColor">#DBEAFE</Color>
    
    <!-- Secondary Colors -->
    <Color x:Key="SecondaryColor">#64748B</Color>
    <Color x:Key="SecondaryHoverColor">#475569</Color>
    <Color x:Key="SecondaryLightColor">#F1F5F9</Color>
    
    <!-- Accent Colors -->
    <Color x:Key="AccentColor">#38BDF8</Color>
    <Color x:Key="AccentHoverColor">#0EA5E9</Color>
    <Color x:Key="AccentLightColor">#E0F2FE</Color>
    
    <!-- Semantic Colors -->
    <Color x:Key="SuccessColor">#22C55E</Color>
    <Color x:Key="SuccessHoverColor">#16A34A</Color>
    <Color x:Key="SuccessLightColor">#DCFCE7</Color>
    <Color x:Key="SuccessDarkColor">#166534</Color>
    
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="WarningHoverColor">#D97706</Color>
    <Color x:Key="WarningLightColor">#FEF3C7</Color>
    <Color x:Key="WarningDarkColor">#92400E</Color>
    
    <Color x:Key="ErrorColor">#EF4444</Color>
    <Color x:Key="ErrorHoverColor">#DC2626</Color>
    <Color x:Key="ErrorLightColor">#FEE2E2</Color>
    <Color x:Key="ErrorDarkColor">#991B1B</Color>
    
    <Color x:Key="InfoColor">#3B82F6</Color>
    <Color x:Key="InfoLightColor">#DBEAFE</Color>
    
    <!-- Background Colors -->
    <Color x:Key="BackgroundColor">#F8FAFC</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="CardColor">#FFFFFF</Color>
    <Color x:Key="SidebarColor">#1E3A8A</Color>
    <Color x:Key="SidebarHoverColor">#1E40AF</Color>
    <Color x:Key="SidebarActiveColor">#3B82F6</Color>
    
    <!-- Overlay Colors -->
    <Color x:Key="OverlayColor">#80000000</Color>
    <Color x:Key="OverlayLightColor">#40000000</Color>
    
    <!-- Text Colors -->
    <Color x:Key="TextPrimaryColor">#0F172A</Color>
    <Color x:Key="TextSecondaryColor">#475569</Color>
    <Color x:Key="TextMutedColor">#94A3B8</Color>
    <Color x:Key="TextInverseColor">#FFFFFF</Color>
    <Color x:Key="TextLinkColor">#2563EB</Color>
    
    <!-- Border & Divider Colors -->
    <Color x:Key="BorderColor">#E2E8F0</Color>
    <Color x:Key="BorderHoverColor">#CBD5E1</Color>
    <Color x:Key="BorderFocusColor">#3B82F6</Color>
    <Color x:Key="DividerColor">#E2E8F0</Color>
    
    <!-- State Colors -->
    <Color x:Key="HoverColor">#F1F5F9</Color>
    <Color x:Key="FocusColor">#3B82F6</Color>
    <Color x:Key="DisabledColor">#E2E8F0</Color>
    <Color x:Key="DisabledTextColor">#9CA3AF</Color>
    
    <!-- Connection Status Colors -->
    <Color x:Key="ConnectedColor">#22C55E</Color>
    <Color x:Key="ConnectingColor">#F59E0B</Color>
    <Color x:Key="DisconnectedColor">#EF4444</Color>
    
    <!-- Shadow Colors -->
    <Color x:Key="ShadowColor">#10000000</Color>
    <Color x:Key="ShadowMediumColor">#20000000</Color>
    <Color x:Key="ShadowHeavyColor">#30000000</Color>

    <!-- ???????????????????????????????????????????????????????????????????????????????????????????
         SOLID COLOR BRUSHES
    ??????????????????????????????????????????????????????????????????????????????????????????? -->
    
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource PrimaryHoverColor}"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="{StaticResource PrimaryPressedColor}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}"/>
    
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="SecondaryHoverBrush" Color="{StaticResource SecondaryHoverColor}"/>
    <SolidColorBrush x:Key="SecondaryLightBrush" Color="{StaticResource SecondaryLightColor}"/>
    
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource AccentLightColor}"/>
    
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="SuccessLightBrush" Color="{StaticResource SuccessLightColor}"/>
    <SolidColorBrush x:Key="SuccessDarkBrush" Color="{StaticResource SuccessDarkColor}"/>
    
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="WarningLightBrush" Color="{StaticResource WarningLightColor}"/>
    <SolidColorBrush x:Key="WarningDarkBrush" Color="{StaticResource WarningDarkColor}"/>
    
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="ErrorLightBrush" Color="{StaticResource ErrorLightColor}"/>
    <SolidColorBrush x:Key="ErrorDarkBrush" Color="{StaticResource ErrorDarkColor}"/>
    
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>
    <SolidColorBrush x:Key="InfoLightBrush" Color="{StaticResource InfoLightColor}"/>
    
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}"/>
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="{StaticResource SidebarHoverColor}"/>
    <SolidColorBrush x:Key="SidebarActiveBrush" Color="{StaticResource SidebarActiveColor}"/>
    
    <SolidColorBrush x:Key="OverlayBrush" Color="{StaticResource OverlayColor}"/>
    <SolidColorBrush x:Key="OverlayLightBrush" Color="{StaticResource OverlayLightColor}"/>
    
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="TextInverseBrush" Color="{StaticResource TextInverseColor}"/>
    <SolidColorBrush x:Key="TextLinkBrush" Color="{StaticResource TextLinkColor}"/>
    
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderHoverBrush" Color="{StaticResource BorderHoverColor}"/>
    <SolidColorBrush x:Key="BorderFocusBrush" Color="{StaticResource BorderFocusColor}"/>
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource DividerColor}"/>
    
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource HoverColor}"/>
    <SolidColorBrush x:Key="FocusBrush" Color="{StaticResource FocusColor}"/>
    <SolidColorBrush x:Key="DisabledBrush" Color="{StaticResource DisabledColor}"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="{StaticResource DisabledTextColor}"/>
    
    <SolidColorBrush x:Key="ConnectedBrush" Color="{StaticResource ConnectedColor}"/>
    <SolidColorBrush x:Key="ConnectingBrush" Color="{StaticResource ConnectingColor}"/>
    <SolidColorBrush x:Key="DisconnectedBrush" Color="{StaticResource DisconnectedColor}"/>

    <!-- ???????????????????????????????????????????????????????????????????????????????????????????
         TYPOGRAPHY SYSTEM
    ??????????????????????????????????????????????????????????????????????????????????????????? -->
    
    <!-- Font Families -->
    <FontFamily x:Key="PrimaryFont">Inter, Segoe UI, San Francisco, Helvetica Neue, Arial</FontFamily>
    <FontFamily x:Key="MonospaceFont">JetBrains Mono, Cascadia Code, Consolas, monospace</FontFamily>
    
    <!-- Font Sizes -->
    <x:Double x:Key="FontSizeXS">11</x:Double>
    <x:Double x:Key="FontSizeSM">12</x:Double>
    <x:Double x:Key="FontSizeBase">13</x:Double>
    <x:Double x:Key="FontSizeMD">14</x:Double>
    <x:Double x:Key="FontSizeLG">16</x:Double>
    <x:Double x:Key="FontSizeXL">18</x:Double>
    <x:Double x:Key="FontSize2XL">20</x:Double>
    <x:Double x:Key="FontSize3XL">24</x:Double>
    <x:Double x:Key="FontSize4XL">32</x:Double>
    
    <!-- Line Heights -->
    <x:Double x:Key="LineHeightTight">1.25</x:Double>
    <x:Double x:Key="LineHeightNormal">1.5</x:Double>
    <x:Double x:Key="LineHeightRelaxed">1.75</x:Double>

    <!-- ???????????????????????????????????????????????????????????????????????????????????????????
         SPACING SYSTEM (8px grid)
    ??????????????????????????????????????????????????????????????????????????????????????????? -->
    
    <x:Double x:Key="Space0">0</x:Double>
    <x:Double x:Key="Space1">4</x:Double>
    <x:Double x:Key="Space2">8</x:Double>
    <x:Double x:Key="Space3">12</x:Double>
    <x:Double x:Key="Space4">16</x:Double>
    <x:Double x:Key="Space5">20</x:Double>
    <x:Double x:Key="Space6">24</x:Double>
    <x:Double x:Key="Space8">32</x:Double>
    <x:Double x:Key="Space10">40</x:Double>
    <x:Double x:Key="Space12">48</x:Double>
    <x:Double x:Key="Space16">64</x:Double>
    
    <Thickness x:Key="SpacingXS">4</Thickness>
    <Thickness x:Key="SpacingSM">8</Thickness>
    <Thickness x:Key="SpacingMD">12</Thickness>
    <Thickness x:Key="SpacingBase">16</Thickness>
    <Thickness x:Key="SpacingLG">24</Thickness>
    <Thickness x:Key="SpacingXL">32</Thickness>
    <Thickness x:Key="Spacing2XL">48</Thickness>
    
    <!-- Padding Presets -->
    <Thickness x:Key="CardPadding">24</Thickness>
    <Thickness x:Key="CardPaddingCompact">16</Thickness>
    <Thickness x:Key="InputPadding">12,10</Thickness>
    <Thickness x:Key="ButtonPadding">24,12</Thickness>
    <Thickness x:Key="ButtonPaddingCompact">16,8</Thickness>
    <Thickness x:Key="ButtonPaddingLarge">32,14</Thickness>
    <Thickness x:Key="DialogPadding">32</Thickness>
    <Thickness x:Key="PagePadding">32,24</Thickness>

    <!-- ???????????????????????????????????????????????????????????????????????????????????????????
         CORNER RADIUS
    ??????????????????????????????????????????????????????????????????????????????????????????? -->
    
    <CornerRadius x:Key="RadiusNone">0</CornerRadius>
    <CornerRadius x:Key="RadiusSM">4</CornerRadius>
    <CornerRadius x:Key="RadiusMD">6</CornerRadius>
    <CornerRadius x:Key="RadiusBase">8</CornerRadius>
    <CornerRadius x:Key="RadiusLG">12</CornerRadius>
    <CornerRadius x:Key="RadiusXL">16</CornerRadius>
    <CornerRadius x:Key="RadiusFull">9999</CornerRadius>

    <!-- ???????????????????????????????????????????????????????????????????????????????????????????
         BOX SHADOWS
    ??????????????????????????????????????????????????????????????????????????????????????????? -->
    
    <BoxShadows x:Key="ShadowSM">0 1 2 0 #10000000</BoxShadows>
    <BoxShadows x:Key="ShadowBase">0 1 3 0 #10000000, 0 1 2 -1 #10000000</BoxShadows>
    <BoxShadows x:Key="ShadowMD">0 4 6 -1 #10000000, 0 2 4 -2 #10000000</BoxShadows>
    <BoxShadows x:Key="ShadowLG">0 10 15 -3 #10000000, 0 4 6 -4 #10000000</BoxShadows>
    <BoxShadows x:Key="ShadowXL">0 20 25 -5 #10000000, 0 8 10 -6 #10000000</BoxShadows>
    <BoxShadows x:Key="ShadowCard">0 1 3 0 #10000000</BoxShadows>
    <BoxShadows x:Key="ShadowCardHover">0 4 6 -1 #15000000</BoxShadows>
    <BoxShadows x:Key="ShadowDialog">0 25 50 -12 #25000000</BoxShadows>
    <BoxShadows x:Key="ShadowSidebar">2 0 8 0 #15000000</BoxShadows>

    <!-- ???????????????????????????????????????????????????????????????????????????????????????????
         ANIMATION DURATIONS
    ??????????????????????????????????????????????????????????????????????????????????????????? -->
    
    <x:Double x:Key="DurationFast">0.15</x:Double>
    <x:Double x:Key="DurationBase">0.2</x:Double>
    <x:Double x:Key="DurationSlow">0.3</x:Double>
    <x:Double x:Key="DurationSlower">0.5</x:Double>

    <!-- ???????????????????????????????????????????????????????????????????????????????????????????
         ICON SIZES
    ??????????????????????????????????????????????????????????????????????????????????????????? -->
    
    <x:Double x:Key="IconSizeXS">12</x:Double>
    <x:Double x:Key="IconSizeSM">16</x:Double>
    <x:Double x:Key="IconSizeBase">20</x:Double>
    <x:Double x:Key="IconSizeMD">24</x:Double>
    <x:Double x:Key="IconSizeLG">32</x:Double>
    <x:Double x:Key="IconSizeXL">48</x:Double>
    <x:Double x:Key="IconSize2XL">64</x:Double>

    <!-- ???????????????????????????????????????????????????????????????????????????????????????????
         COMPONENT SIZES
    ??????????????????????????????????????????????????????????????????????????????????????????? -->
    
    <x:Double x:Key="InputHeightSM">32</x:Double>
    <x:Double x:Key="InputHeightBase">40</x:Double>
    <x:Double x:Key="InputHeightLG">48</x:Double>
    
    <x:Double x:Key="ButtonHeightSM">32</x:Double>
    <x:Double x:Key="ButtonHeightBase">40</x:Double>
    <x:Double x:Key="ButtonHeightLG">48</x:Double>
    
    <x:Double x:Key="SidebarWidth">260</x:Double>
    <x:Double x:Key="DialogMinWidth">400</x:Double>
    <x:Double x:Key="DialogMaxWidth">560</x:Double>
    <x:Double x:Key="CardMaxWidth">800</x:Double>

    <!-- ???????????????????????????????????????????????????????????????????????????????????????????
         STATUS DOT SIZES
    ??????????????????????????????????????????????????????????????????????????????????????????? -->
    
    <x:Double x:Key="StatusDotSM">8</x:Double>
    <x:Double x:Key="StatusDotBase">12</x:Double>
    <x:Double x:Key="StatusDotLG">16</x:Double>

</ResourceDictionary>
