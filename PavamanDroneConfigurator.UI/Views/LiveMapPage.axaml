<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:PavamanDroneConfigurator.UI.Controls"
             xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels"
             xmlns:converters="using:PavamanDroneConfigurator.UI.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
             x:Class="PavamanDroneConfigurator.UI.Views.LiveMapPage"
             x:DataType="vm:LiveMapPageViewModel"
             Background="#0A0E1A">

    <UserControl.Resources>
        <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>

        <!-- Translucent overlay button -->
        <Style Selector="Button.overlay-btn">
            <Setter Property="Background" Value="#CC0F172A"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2D3748"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style Selector="Button.overlay-btn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#CC1E2D3D"/>
        </Style>
        <Style Selector="Button.overlay-btn:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#CC2D3D50"/>
        </Style>

    </UserControl.Styles>

    <!-- Root grid: map + Avalonia overlays stacked in same cell -->
    <Grid>

        <!-- ── Live Map (WebView2) ── -->
        <controls:GoogleMapView x:Name="MapView" ClipToBounds="True"/>

        <!-- ── Top-right toolbar overlay ──
             Minimal two-button bar (Live Camera + MAVLink Logs) anchored to the top-right.
             Height ≈52dp; SetViewportInsets reserves this space in code-behind. -->
        <Border VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Background="Transparent"
                Padding="12,8">

            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">

                <!-- 🎥 Live Camera button (always visible) -->
                <Button Classes="overlay-btn"
                        Command="{Binding ToggleCameraCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="🎥" FontSize="14"/>
                        <TextBlock Text="Live Camera" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- 📊 MAVLink Logs button -->
                <Button Classes="overlay-btn"
                        Command="{Binding OpenLogsCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="📊" FontSize="14"/>
                        <TextBlock Text="MAVLink Logs" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Border>

        <!-- ── Camera feed overlay panel ──
             Floats over the map at top-right when IsCameraVisible = true.
             Compact 16:9 card (~320×200) positioned directly below the toolbar buttons.
             Toggled by ToggleCameraCommand; stream is started/stopped alongside. -->
        <Border IsVisible="{Binding IsCameraVisible}"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,60,12,0"
                Width="320" Height="200"
                Background="#E60A0E1A"
                CornerRadius="10"
                BorderBrush="#2D3748"
                BorderThickness="1"
                ClipToBounds="True">

            <Grid RowDefinitions="Auto,*,Auto">

                <!-- Header row -->
                <Border Grid.Row="0"
                        Background="#CC111827"
                        Padding="10,7"
                        BorderBrush="#1E2433"
                        BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="🎥 Live Camera"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#E2E8F0" VerticalAlignment="Center"/>
                            <!-- Streaming dot -->
                            <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                     Fill="{Binding IsVideoStreaming,
                                            Converter={StaticResource BoolToColorConverter},
                                            ConverterParameter='#22c55e|#64748B'}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="✕"
                                Command="{Binding ToggleCameraCommand}"
                                Background="Transparent"
                                Foreground="#64748B"
                                Padding="4,2"
                                BorderThickness="0"
                                FontSize="13"/>
                    </Grid>
                </Border>

                <!-- Video frame area -->
                <Border Grid.Row="1" Background="#0D1117">
                    <Grid>
                        <!-- Not streaming: show placeholder -->
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Spacing="10"
                                    IsVisible="{Binding !IsVideoStreaming}">
                            <TextBlock Text="📷" FontSize="36"
                                       HorizontalAlignment="Center" Opacity="0.4"/>
                            <TextBlock Text="{Binding VideoStreamStatus}"
                                       FontSize="11" Foreground="#64748B"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap" TextAlignment="Center"
                                       MaxWidth="260"/>
                        </StackPanel>

                        <!-- Streaming: show active indicator -->
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Spacing="10"
                                    IsVisible="{Binding IsVideoStreaming}">
                            <TextBlock Text="📡" FontSize="36" HorizontalAlignment="Center"/>
                            <TextBlock Text="Stream Active"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#22c55e" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding VideoStreamUrl}"
                                       FontSize="10" Foreground="#64748B"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- LIVE badge (top-left overlay when streaming) -->
                        <Border IsVisible="{Binding IsVideoStreaming}"
                                HorizontalAlignment="Left" VerticalAlignment="Top"
                                Margin="8,6" Background="#BB22c55e"
                                CornerRadius="4" Padding="5,2">
                            <TextBlock Text="● LIVE"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="White"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Stream URL input -->
                <Border Grid.Row="2"
                        Background="#CC111827"
                        Padding="10,8"
                        BorderBrush="#1E2433"
                        BorderThickness="0,1,0,0">
                    <TextBox Text="{Binding VideoStreamUrl}"
                             Watermark="rtsp://…"
                             FontSize="11"
                             IsEnabled="{Binding !IsVideoStreaming}"
                             Background="#0D1117"
                             Foreground="#E2E8F0"
                             BorderBrush="#2D3748"
                             BorderThickness="1"
                             CornerRadius="6"
                             Padding="8,5"/>
                </Border>

            </Grid>
        </Border>

    </Grid>
</UserControl>
