<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:PavamanDroneConfigurator.UI.Controls"
             xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels"
             xmlns:converters="using:PavamanDroneConfigurator.UI.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
             x:Class="PavamanDroneConfigurator.UI.Views.LiveMapPage"
             x:DataType="vm:LiveMapPageViewModel"
             Background="#0A0E1A">

    <UserControl.Resources>
        <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>

        <!-- Translucent overlay button -->
        <Style Selector="Button.overlay-btn">
            <Setter Property="Background" Value="#CC0F172A"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2D3748"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style Selector="Button.overlay-btn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#CC1E2D3D"/>
        </Style>
        <Style Selector="Button.overlay-btn:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#CC2D3D50"/>
        </Style>

        <!-- Compact control button for camera/spray panels -->
        <Style Selector="Button.ctrl-btn">
            <Setter Property="Background" Value="#CC1A2332"/>
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2D3748"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinWidth" Value="32"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.ctrl-btn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#CC2A3A4D"/>
        </Style>
        <Style Selector="Button.ctrl-btn:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#CC3A4D63"/>
        </Style>

    </UserControl.Styles>

    <!-- Root grid: map + Avalonia overlays stacked in same cell -->
    <Grid>

        <!-- ── Live Map (WebView2) ── -->
        <controls:GoogleMapView x:Name="MapView" ClipToBounds="True"/>

        <!-- ── Top-right toolbar overlay ──
             Minimal toolbar (Live Camera + Spray + MAVLink Logs) anchored to the top-right.
             Height ≈52dp; SetViewportInsets reserves this space in code-behind. -->
        <Border VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Background="Transparent"
                Padding="12,8">

            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">

                <!-- 🎥 Live Camera button -->
                <Button Classes="overlay-btn"
                        Command="{Binding ToggleCameraCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="🎥" FontSize="14"/>
                        <TextBlock Text="Live Camera" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- 📊 MAVLink Logs button -->
                <Button Classes="overlay-btn"
                        Command="{Binding OpenLogsCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="📊" FontSize="14"/>
                        <TextBlock Text="MAVLink Logs" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════════
             CAMERA FEED POPUP  –  Bottom-left floating overlay
             Shows live drone camera feed with "WAITING FOR VIDEO" placeholder.
             Includes camera controls (gimbal, photo, record).
             ═══════════════════════════════════════════════════════════════════ -->
        <Border IsVisible="{Binding IsCameraVisible}"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="12,0,0,12"
                Width="480" Height="340"
                Background="#E60A0E1A"
                CornerRadius="10"
                BorderBrush="#2D3748"
                BorderThickness="1"
                ClipToBounds="True">

            <Grid RowDefinitions="Auto,*,Auto,Auto">

                <!-- ── Header bar ── -->
                <Border Grid.Row="0"
                        Background="#CC111827"
                        Padding="10,7"
                        BorderBrush="#1E2433"
                        BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="🎥 Live Camera"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#E2E8F0" VerticalAlignment="Center"/>
                            <!-- Streaming status dot -->
                            <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                     Fill="{Binding IsVideoStreaming,
                                            Converter={StaticResource BoolToColorConverter},
                                            ConverterParameter='#22c55e|#64748B'}"/>
                            <TextBlock Text="{Binding GimbalStatus}"
                                       FontSize="10" Foreground="#64748B"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="✕"
                                Command="{Binding ToggleCameraCommand}"
                                Background="Transparent"
                                Foreground="#64748B"
                                Padding="4,2"
                                BorderThickness="0"
                                FontSize="13"/>
                    </Grid>
                </Border>

                <!-- ── Video frame area ── -->
                <Border Grid.Row="1" Background="#000000">
                    <Grid>
                        <!-- Live video frame (rendered from FrameReceived) -->
                        <Image Source="{Binding CurrentVideoFrame}"
                               Stretch="Uniform"
                               IsVisible="{Binding IsVideoStreaming}"/>

                        <!-- Loading indicator while stream initializes -->
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Spacing="10"
                                    IsVisible="{Binding IsStreamLoading}">
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <TextBlock Text="⏳" FontSize="28" HorizontalAlignment="Center"/>
                                <TextBlock Text="CONNECTING..."
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="#94A3B8"
                                           HorizontalAlignment="Center"
                                           LetterSpacing="2"/>
                                <TextBlock Text="{Binding VideoStreamStatus}"
                                           FontSize="11" Foreground="#475569"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap" TextAlignment="Center"
                                           MaxWidth="380"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Camera not connected state (drone not connected) -->
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Spacing="8"
                                    IsVisible="{Binding !IsConnected}">
                            <TextBlock Text="📷" FontSize="32" HorizontalAlignment="Center"
                                       Foreground="#64748B"/>
                            <TextBlock Text="Camera not connected"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="#94A3B8"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Error state: stream error while connected -->
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Spacing="8">
                            <StackPanel.IsVisible>
                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                    <Binding Path="IsConnected"/>
                                    <Binding Path="HasStreamError"/>
                                </MultiBinding>
                            </StackPanel.IsVisible>
                            <TextBlock Text="⚠" FontSize="28" HorizontalAlignment="Center"
                                       Foreground="#EF4444"/>
                            <TextBlock Text="{Binding StreamErrorMessage}"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="#EF4444"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding VideoStreamStatus}"
                                       FontSize="11" Foreground="#475569"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap" TextAlignment="Center"
                                       MaxWidth="380"/>
                            <Button Content="↻ Retry"
                                    Command="{Binding RetryStreamCommand}"
                                    HorizontalAlignment="Center"
                                    Background="#1E2433"
                                    Foreground="#E2E8F0"
                                    Padding="16,6"
                                    CornerRadius="6"
                                    BorderThickness="1"
                                    BorderBrush="#2D3748"
                                    FontSize="12"
                                    Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Connected, not streaming, not loading, no error: show "WAITING FOR VIDEO" -->
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Spacing="8">
                            <StackPanel.IsVisible>
                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                    <Binding Path="IsConnected"/>
                                    <Binding Path="!IsVideoStreaming"/>
                                    <Binding Path="!IsStreamLoading"/>
                                    <Binding Path="!HasStreamError"/>
                                </MultiBinding>
                            </StackPanel.IsVisible>
                            <TextBlock Text="WAITING FOR VIDEO"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="#94A3B8"
                                       HorizontalAlignment="Center"
                                       LetterSpacing="2"/>
                            <TextBlock Text="{Binding VideoStreamStatus}"
                                       FontSize="11" Foreground="#475569"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap" TextAlignment="Center"
                                       MaxWidth="380"/>
                        </StackPanel>

                        <!-- LIVE badge (top-left overlay when streaming) -->
                        <Border IsVisible="{Binding IsVideoStreaming}"
                                HorizontalAlignment="Left" VerticalAlignment="Top"
                                Margin="8,6" Background="#BB22c55e"
                                CornerRadius="4" Padding="5,2">
                            <TextBlock Text="● LIVE"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="White"/>
                        </Border>

                        <!-- REC badge (top-right overlay when recording) -->
                        <Border IsVisible="{Binding IsRecording}"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,6,8,0" Background="#BBEF4444"
                                CornerRadius="4" Padding="5,2">
                            <TextBlock Text="● REC"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="White"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- ── Camera Controls Row ── -->
                <Border Grid.Row="2"
                        Background="#CC111827"
                        Padding="8,6"
                        BorderBrush="#1E2433"
                        BorderThickness="0,1,0,0">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <!-- Gimbal controls -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                            <Button Classes="ctrl-btn" Content="⬆" ToolTip.Tip="Tilt Up"
                                    Command="{Binding GimbalTiltUpCommand}"/>
                            <Button Classes="ctrl-btn" Content="⬇" ToolTip.Tip="Tilt Down"
                                    Command="{Binding GimbalTiltDownCommand}"/>
                            <Button Classes="ctrl-btn" Content="⬅" ToolTip.Tip="Pan Left"
                                    Command="{Binding GimbalPanLeftCommand}"/>
                            <Button Classes="ctrl-btn" Content="➡" ToolTip.Tip="Pan Right"
                                    Command="{Binding GimbalPanRightCommand}"/>
                            <Button Classes="ctrl-btn" Content="⊙" ToolTip.Tip="Center Gimbal"
                                    Command="{Binding GimbalCenterCommand}"/>
                            <Button Classes="ctrl-btn" Content="⏬" ToolTip.Tip="Look Straight Down"
                                    Command="{Binding GimbalLookDownCommand}"/>
                        </StackPanel>

                        <!-- Camera actions -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                            <Button Classes="ctrl-btn" ToolTip.Tip="Take Photo"
                                    Command="{Binding TakePhotoCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="📷" FontSize="12"/>
                                    <TextBlock Text="{Binding PhotoCount}" FontSize="11"
                                               Foreground="#94A3B8" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="ctrl-btn" ToolTip.Tip="Toggle Recording"
                                    Command="{Binding ToggleRecordingCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                             Fill="{Binding IsRecording,
                                                    Converter={StaticResource BoolToColorConverter},
                                                    ConverterParameter='#EF4444|#64748B'}"/>
                                    <TextBlock Text="{Binding RecordingTime}" FontSize="11"
                                               Foreground="#CBD5E1" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── Stream URL input ── -->
                <Border Grid.Row="3"
                        Background="#CC111827"
                        Padding="8,6"
                        BorderBrush="#1E2433"
                        BorderThickness="0,1,0,0">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0"
                                 Text="{Binding VideoStreamUrl}"
                                 Watermark="rtsp://…"
                                 FontSize="11"
                                 IsEnabled="{Binding !IsVideoStreaming}"
                                 Background="#0D1117"
                                 Foreground="#E2E8F0"
                                 BorderBrush="#2D3748"
                                 BorderThickness="1"
                                 CornerRadius="6"
                                 Padding="8,5"/>
                        <Button Grid.Column="1" Classes="ctrl-btn"
                                Margin="6,0,0,0"
                                Command="{Binding ToggleVideoStreamCommand}">
                            <TextBlock Text="{Binding IsVideoStreaming,
                                       Converter={StaticResource BoolToColorConverter},
                                       ConverterParameter='⏹|▶'}"
                                       FontSize="14"/>
                        </Button>
                    </Grid>
                </Border>

            </Grid>
        </Border>

    </Grid>
</UserControl>
