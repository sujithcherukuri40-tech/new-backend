<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels"
             xmlns:controls="using:PavamanDroneConfigurator.UI.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
             x:Class="PavamanDroneConfigurator.UI.Views.LiveMapPage"
             x:DataType="vm:LiveMapPageViewModel"
             Background="#0A0E1A">

    <Design.DataContext>
        <vm:LiveMapPageViewModel/>
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="Border.glass-panel">
            <Setter Property="Background" Value="#73000818"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderBrush" Value="#2EFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Border.glass-chip">
            <Setter Property="Background" Value="#4A001020"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="BorderBrush" Value="#38FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
        <Style Selector="Border.telemetry-strip">
            <Setter Property="Background" Value="#73000818"/>
            <Setter Property="CornerRadius" Value="16,16,0,0"/>
            <Setter Property="BorderBrush" Value="#2EFFFFFF"/>
            <Setter Property="BorderThickness" Value="1,1,1,0"/>
        </Style>
        <Style Selector="Button.floating-btn">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#8000E5C9"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#1F001020"/>
            <Setter Property="Foreground" Value="#E9FDFB"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>
        <Style Selector="Button.floating-btn:pointerover">
            <Setter Property="Background" Value="#2A00E5C9"/>
        </Style>
        <Style Selector="TextBlock.hud-label">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Foreground" Value="#A8C9D8"/>
            <Setter Property="FontFamily" Value="Rajdhani"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.hud-value">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Share Tech Mono"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.telem-label">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Foreground" Value="#A8C9D8"/>
            <Setter Property="FontFamily" Value="Rajdhani"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.telem-value">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="#F3FCFF"/>
            <Setter Property="FontFamily" Value="Share Tech Mono"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.top-action-btn">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#7F00E5C9"/>
            <Setter Property="Background" Value="#22001020"/>
            <Setter Property="Foreground" Value="#E9FDFB"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Rajdhani"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.top-action-btn:pointerover">
            <Setter Property="Background" Value="#3300E5C9"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="*,Auto">
        <Grid Grid.RowSpan="2">
            <controls:GoogleMapView x:Name="MapView" ClipToBounds="True"/>
        </Grid>

        <Border Classes="glass-panel" HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="14,14,14,0" Padding="12,10" IsVisible="{Binding IsConnected}">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Border Classes="glass-chip">
                    <StackPanel Spacing="2">
                        <TextBlock Text="SATS" Classes="hud-label"/>
                        <TextBlock Text="{Binding SatelliteCount}" Classes="hud-value"/>
                    </StackPanel>
                </Border>
                <Border Classes="glass-chip">
                    <StackPanel Spacing="2">
                        <TextBlock Text="MODE" Classes="hud-label"/>
                        <TextBlock Text="{Binding FlightMode}" Classes="hud-value"/>
                    </StackPanel>
                </Border>
                <Border Classes="glass-chip">
                    <StackPanel Spacing="2">
                        <TextBlock Text="CONNECTION" Classes="hud-label"/>
                        <TextBlock Text="{Binding ConnectionStatus}" Classes="hud-value"/>
                    </StackPanel>
                </Border>
                <Border Classes="glass-chip">
                    <StackPanel Spacing="2">
                        <TextBlock Text="LIVE" Classes="hud-label"/>
                        <TextBlock Text="{Binding LiveStatusText}" Classes="hud-value"/>
                    </StackPanel>
                </Border>
                <Button Classes="top-action-btn" Command="{Binding ToggleSprayCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="&#x1F4A7;"/>
                        <TextBlock Text="SPRAY"/>
                    </StackPanel>
                </Button>
                <Button Classes="top-action-btn" Command="{Binding ShowPlotTabCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="&#x1F4DD;"/>
                        <TextBlock Text="MAV MSG"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <Border HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,14,92"
                Background="Transparent" IsVisible="{Binding IsConnected}">
            <StackPanel Orientation="Vertical" Spacing="9">
                <Button Classes="floating-btn" Click="ZoomIn_Click" ToolTip.Tip="Zoom In">
                    <TextBlock Text="+" FontSize="20" FontWeight="Bold"/>
                </Button>
                <Button Classes="floating-btn" Click="ZoomOut_Click" ToolTip.Tip="Zoom Out">
                    <TextBlock Text="&#x2212;" FontSize="20" FontWeight="Bold"/>
                </Button>
                <Button Classes="floating-btn" Command="{Binding ChangeMapTypeCommand}" ToolTip.Tip="Map Type">
                    <TextBlock Text="&#x1F5FA;" FontSize="17"/>
                </Button>
                <Button Classes="floating-btn" Command="{Binding RecenterMapCommand}" ToolTip.Tip="Center on Drone">
                    <TextBlock Text="&#x25CE;" FontSize="18"/>
                </Button>
                <Button Classes="floating-btn" Command="{Binding OpenCameraViewCommand}" ToolTip.Tip="Camera Quick Action">
                    <TextBlock Text="&#x1F4F7;" FontSize="17"/>
                </Button>
                <Button Classes="floating-btn" Command="{Binding RefreshTelemetryCommand}" ToolTip.Tip="Refresh Telemetry">
                    <TextBlock Text="&#x21BB;" FontSize="17"/>
                </Button>
                <Border Classes="glass-chip" Padding="10,6">
                    <TextBlock Text="{Binding MapTypeLabel}" Classes="hud-label"/>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Classes="telemetry-strip" Padding="12,10,12,14" IsVisible="{Binding IsConnected}">
            <StackPanel Spacing="10">
                <Border Height="2">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                            <GradientStop Offset="0" Color="#5500E5C9"/>
                            <GradientStop Offset="0.5" Color="#FF00E5C9"/>
                            <GradientStop Offset="1" Color="#5500E5C9"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                    <UniformGrid Grid.Column="0" Columns="4" ColumnSpacing="10">
                        <StackPanel Spacing="2">
                            <TextBlock Text="ALT" Classes="telem-label"/>
                            <TextBlock Text="{Binding Altitude, StringFormat='{}{0:F1} m'}" Classes="telem-value"/>
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="SPEED" Classes="telem-label"/>
                            <TextBlock Text="{Binding GroundSpeed, StringFormat='{}{0:F1} m/s'}" Classes="telem-value"/>
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="WAYPOINT" Classes="telem-label"/>
                            <TextBlock Text="{Binding WaypointStatus}" Classes="telem-value"/>
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="TIME" Classes="telem-label"/>
                            <TextBlock Text="{Binding FlightTime}" Classes="telem-value"/>
                        </StackPanel>
                    </UniformGrid>

                    <UniformGrid Grid.Column="1" Columns="4" ColumnSpacing="10">
                        <StackPanel Spacing="2">
                            <TextBlock Text="AREA" Classes="telem-label"/>
                            <TextBlock Text="{Binding AreaSprayedAcres, StringFormat='{}{0:F2} ac'}" Classes="telem-value"/>
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="DISTANCE" Classes="telem-label"/>
                            <TextBlock Text="{Binding TotalFlightDistance, StringFormat='{}{0:F2} km'}" Classes="telem-value"/>
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="FLOW" Classes="telem-label"/>
                            <TextBlock Text="{Binding FlowRate, StringFormat='{}{0:F1} L/min'}" Classes="telem-value"/>
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="CONSUMED" Classes="telem-label"/>
                            <TextBlock Text="{Binding TotalConsumedLiters, StringFormat='{}{0:F1} L'}" Classes="telem-value"/>
                        </StackPanel>
                    </UniformGrid>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
