<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:PavamanDroneConfigurator.UI.Controls"
             xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels"
             xmlns:converters="using:PavamanDroneConfigurator.UI.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
             x:Class="PavamanDroneConfigurator.UI.Views.LiveMapPage"
             x:DataType="vm:LiveMapPageViewModel"
             Background="#0A0E1A">

    <UserControl.Resources>
        <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>

        <!-- Translucent overlay button -->
        <Style Selector="Button.overlay-btn">
            <Setter Property="Background" Value="#CC0F172A"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2D3748"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style Selector="Button.overlay-btn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#CC1E2D3D"/>
        </Style>
        <Style Selector="Button.overlay-btn:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#CC2D3D50"/>
        </Style>

        <!-- Compact control button for camera/spray panels -->
        <Style Selector="Button.ctrl-btn">
            <Setter Property="Background" Value="#CC1A2332"/>
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2D3748"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinWidth" Value="32"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.ctrl-btn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#CC2A3A4D"/>
        </Style>
        <Style Selector="Button.ctrl-btn:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#CC3A4D63"/>
        </Style>

    </UserControl.Styles>

    <!-- Root grid: map + Avalonia overlays stacked in same cell -->
    <Grid>

        <!-- ── Live Map (WebView2) ── -->
        <controls:GoogleMapView x:Name="MapView" ClipToBounds="True"/>

        <!-- ── Top-right toolbar overlay ──
             Minimal toolbar (Live Camera + Spray + MAVLink Logs) anchored to the top-right.
             Height ≈52dp; SetViewportInsets reserves this space in code-behind. -->
        <Border VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Background="Transparent"
                Padding="12,8">

            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">

                <!-- 🎥 Live Camera button -->
                <Button Classes="overlay-btn"
                        Command="{Binding ToggleCameraCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="🎥" FontSize="14"/>
                        <TextBlock Text="Live Camera" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- 📊 MAVLink Logs button -->
                <Button Classes="overlay-btn"
                        Command="{Binding OpenLogsCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="📊" FontSize="14"/>
                        <TextBlock Text="MAVLink Logs" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Border>

    </Grid>
</UserControl>
