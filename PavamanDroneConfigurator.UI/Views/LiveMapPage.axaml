<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels"
             xmlns:controls="using:PavamanDroneConfigurator.UI.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
             x:Class="PavamanDroneConfigurator.UI.Views.LiveMapPage"
             x:DataType="vm:LiveMapPageViewModel"
             Background="#0F172A">

    <Design.DataContext>
        <vm:LiveMapPageViewModel/>
    </Design.DataContext>

    <UserControl.Styles>
        <!-- Dark glass panel -->
        <Style Selector="Border.glass-panel">
            <Setter Property="Background" Value="#E61E293B"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#40FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        
        <!-- Status pill -->
        <Style Selector="Border.status-pill">
            <Setter Property="Background" Value="#50FFFFFF"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>
        
        <!-- Control button styles -->
        <Style Selector="Button.floating-btn">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#40FFFFFF"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#E61E293B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        
        <Style Selector="Button.floating-btn:pointerover">
            <Setter Property="Background" Value="#E63B82F6"/>
        </Style>

        <Style Selector="Button.floating-btn-active">
            <Setter Property="Background" Value="#E63B82F6"/>
        </Style>
        
        <!-- View mode button -->
        <Style Selector="Button.view-mode-btn">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#40FFFFFF"/>
            <Setter Property="Background" Value="#901E293B"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        
        <Style Selector="Button.view-mode-btn:pointerover">
            <Setter Property="Background" Value="#B03B82F6"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <Style Selector="Button.view-mode-btn-active">
            <Setter Property="Background" Value="#E63B82F6"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <!-- Telemetry styles -->
        <Style Selector="TextBlock.telem-label">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        
        <Style Selector="TextBlock.telem-value">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        
        <Style Selector="TextBlock.telem-value-lg">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        
        <Style Selector="TextBlock.telem-unit">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
        </Style>
    </UserControl.Styles>

    <!-- Main Grid: Row 0=TopBar, Row 1=Map area, Row 2=BottomBar -->
    <Grid RowDefinitions="Auto,*,Auto">
        
        <!-- ===================== -->
        <!-- TOP STATUS BAR (Row 0) -->
        <!-- ===================== -->
        <Border Grid.Row="0"
                Classes="glass-panel"
                Margin="8,8,8,4"
                Padding="12,8"
                IsVisible="{Binding IsConnected}">
            <Grid ColumnDefinitions="Auto,*,Auto">
                
                <!-- Left: Connection + GPS Status -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                    <Border Classes="status-pill"
                            Background="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#4022C55E|#40EF4444'}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="8" Height="8" 
                                     Fill="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#22C55E|#EF4444'}"/>
                            <TextBlock Text="{Binding ConnectionStatus}" 
                                       FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Classes="status-pill">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="??" FontSize="11"/>
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="White">
                                <Run Text="{Binding SatelliteCount}"/><Run Text=" sats"/>
                            </TextBlock>
                            <TextBlock Text="•" Foreground="#64748B" Margin="3,0"/>
                            <TextBlock Text="{Binding GpsFixType}" FontSize="10" Foreground="#94A3B8"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
                <!-- Center: Flight Mode + Armed Status -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                    <Border Classes="status-pill">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="?" FontSize="12"/>
                            <TextBlock Text="{Binding FlightMode}" FontSize="12" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Border>
                    
                    <Border CornerRadius="6" Padding="10,5"
                            Background="{Binding IsArmed, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#EF4444|#22C55E'}">
                        <TextBlock Text="{Binding ArmedStatus}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                    </Border>
                </StackPanel>
                
                <!-- Right: Battery + Live indicator -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <Border Classes="status-pill">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="??" FontSize="12"/>
                            <StackPanel>
                                <TextBlock FontSize="12" FontWeight="Bold" Foreground="White">
                                    <Run Text="{Binding BatteryVoltage, StringFormat='{}{0:F1}'}"/>V
                                </TextBlock>
                                <TextBlock FontSize="9" Foreground="#94A3B8">
                                    <Run Text="{Binding BatteryCurrent, StringFormat='{}{0:F1}'}"/>A
                                </TextBlock>
                            </StackPanel>
                            <Border Width="1" Height="20" Background="#374151" Margin="3,0"/>
                            <TextBlock Text="{Binding BatteryStatus}" FontSize="12" FontWeight="Bold" 
                                       Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- LIVE Indicator -->
                    <Border Background="#E61E293B"
                            CornerRadius="12"
                            Padding="8,4"
                            IsVisible="{Binding IsReceivingTelemetry}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="6" Height="6" Fill="#22C55E">
                                <Ellipse.Styles>
                                    <Style Selector="Ellipse">
                                        <Style.Animations>
                                            <Animation Duration="0:0:1" IterationCount="Infinite">
                                                <KeyFrame Cue="0%"><Setter Property="Opacity" Value="1"/></KeyFrame>
                                                <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.3"/></KeyFrame>
                                                <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1"/></KeyFrame>
                                            </Animation>
                                        </Style.Animations>
                                    </Style>
                                </Ellipse.Styles>
                            </Ellipse>
                            <TextBlock Text="LIVE" FontSize="9" FontWeight="Bold" Foreground="#22C55E"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===================== -->
        <!-- MIDDLE CONTENT AREA (Row 1) - Map and right buttons only -->
        <!-- ===================== -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="8,4">
            
            <!-- CENTER: MAP AREA with view mode buttons overlaid -->
            <Grid Grid.Column="0">
                <!-- CesiumMapView fills this area -->
                <controls:CesiumMapView x:Name="CesiumMap" ClipToBounds="True"/>
                
                <!-- View Mode Buttons (overlaid at bottom center of map) -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,12"
                            Spacing="6"
                            IsVisible="{Binding IsConnected}">
                    <Button Command="{Binding SetViewModeTopDownCommand}"
                            Classes.view-mode-btn-active="{Binding IsTopDownView}"
                            Classes="view-mode-btn">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="?" FontSize="12"/>
                            <TextBlock Text="Top Down"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding SetViewModeChase3DCommand}"
                            Classes.view-mode-btn-active="{Binding IsChase3DView}"
                            Classes="view-mode-btn">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="?" FontSize="12"/>
                            <TextBlock Text="3D Chase"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding SetViewModeFreeRoamCommand}"
                            Classes.view-mode-btn-active="{Binding IsFreeRoamView}"
                            Classes="view-mode-btn">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="?" FontSize="12"/>
                            <TextBlock Text="Free Roam"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
            
            <!-- RIGHT CONTROL BUTTONS -->
            <StackPanel Grid.Column="1"
                        VerticalAlignment="Top"
                        Margin="4,0,0,0"
                        Spacing="6">
                <Button Classes="floating-btn" ToolTip.Tip="Zoom In" Click="ZoomIn_Click">
                    <TextBlock Text="+" FontSize="18"/>
                </Button>
                <Button Classes="floating-btn" ToolTip.Tip="Zoom Out" Click="ZoomOut_Click">
                    <TextBlock Text="?" FontSize="18"/>
                </Button>
                <Button Classes="floating-btn"
                        Command="{Binding RecenterMapCommand}"
                        ToolTip.Tip="Center on Drone">
                    <TextBlock Text="?" FontSize="16"/>
                </Button>
                <Button Command="{Binding ToggleFollowDroneCommand}"
                        ToolTip.Tip="Toggle Follow"
                        Classes.floating-btn-active="{Binding FollowDrone}"
                        Classes="floating-btn">
                    <TextBlock Text="?" FontSize="14"/>
                </Button>
                <Button Classes="floating-btn"
                        Command="{Binding ChangeMapTypeCommand}"
                        ToolTip.Tip="Map Type">
                    <TextBlock Text="?" FontSize="14"/>
                </Button>
                <Button Classes="floating-btn"
                        Command="{Binding ClearFlightPathCommand}"
                        ToolTip.Tip="Clear Path">
                    <TextBlock Text="DEL" FontSize="9"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ===================== -->
        <!-- BOTTOM TELEMETRY BAR (Row 2) -->
        <!-- ===================== -->
        <Border Grid.Row="2"
                Classes="glass-panel"
                Margin="8,4,8,8"
                Padding="16,10"
                IsVisible="{Binding IsConnected}">
            <Grid ColumnDefinitions="*,*,*,*,*,*,*,*">
                
                <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="2">
                    <TextBlock Text="ALT" Classes="telem-label" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="2">
                        <TextBlock Text="{Binding Altitude, StringFormat='{}{0:F1}'}" Classes="telem-value"/>
                        <TextBlock Text="m" Classes="telem-unit" VerticalAlignment="Bottom"/>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Grid.Column="1" HorizontalAlignment="Center" Spacing="2">
                    <TextBlock Text="SPEED" Classes="telem-label" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="2">
                        <TextBlock Text="{Binding GroundSpeed, StringFormat='{}{0:F1}'}" Classes="telem-value"/>
                        <TextBlock Text="m/s" Classes="telem-unit" VerticalAlignment="Bottom"/>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="2">
                    <TextBlock Text="V/S" Classes="telem-label" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="2">
                        <TextBlock Text="{Binding VerticalSpeed, StringFormat='{}{0:F1}'}" Classes="telem-value"/>
                        <TextBlock Text="m/s" Classes="telem-unit" VerticalAlignment="Bottom"/>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Grid.Column="3" HorizontalAlignment="Center" Spacing="2">
                    <TextBlock Text="HDG" Classes="telem-label" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="2">
                        <TextBlock Text="{Binding Heading, StringFormat='{}{0:F0}'}" Classes="telem-value"/>
                        <TextBlock Text="°" Classes="telem-unit" VerticalAlignment="Bottom"/>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Grid.Column="4" HorizontalAlignment="Center" Spacing="2">
                    <TextBlock Text="WAYPOINT" Classes="telem-label" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding WaypointStatus}" Classes="telem-value" HorizontalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Grid.Column="5" HorizontalAlignment="Center" Spacing="2">
                    <TextBlock Text="TIME" Classes="telem-label" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding FlightTime}" Classes="telem-value" HorizontalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Grid.Column="6" HorizontalAlignment="Center" Spacing="2">
                    <TextBlock Text="DISTANCE" Classes="telem-label" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="2">
                        <TextBlock Text="{Binding TotalFlightDistance, StringFormat='{}{0:F2}'}" Classes="telem-value"/>
                        <TextBlock Text="km" Classes="telem-unit" VerticalAlignment="Bottom"/>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Grid.Column="7" HorizontalAlignment="Center" Spacing="2">
                    <TextBlock Text="CONSUMED" Classes="telem-label" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="2">
                        <TextBlock Text="{Binding TotalConsumedLiters, StringFormat='{}{0:F1}'}" Classes="telem-value"/>
                        <TextBlock Text="L" Classes="telem-unit" VerticalAlignment="Bottom"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===================== -->
        <!-- DISCONNECTED OVERLAY (Spans all rows) -->
        <!-- ===================== -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#F0101827"
                IsVisible="{Binding !IsConnected}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24">
                <Border Width="100" Height="100" CornerRadius="50"
                        Background="#1E293B" BorderBrush="#334155" BorderThickness="2">
                    <Border CornerRadius="50" ClipToBounds="True" Margin="16">
                        <Image Source="avares://PavamanDroneConfigurator.UI/Assets/Images/KFT Logo.png" Stretch="Uniform"/>
                    </Border>
                </Border>
                
                <StackPanel Spacing="8" HorizontalAlignment="Center">
                    <TextBlock Text="Live Map View" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Connect to your drone to view real-time telemetry" 
                               FontSize="13" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                </StackPanel>
                
                <Border Classes="glass-panel" Padding="14,10" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="??" FontSize="14"/>
                        <TextBlock Text="Navigate to Connection page to establish link" FontSize="12" Foreground="#CBD5E1"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
