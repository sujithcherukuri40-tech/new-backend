<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels"
             xmlns:conv="using:PavamanDroneConfigurator.UI.Converters"
             x:Class="PavamanDroneConfigurator.UI.Views.RcCalibrationPage"
             x:DataType="vm:RcCalibrationPageViewModel">

    <UserControl.Resources>
        <conv:BoolToStringConverter x:Key="CalibrationButtonTextConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Card Style -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="BoxShadow" Value="0 1 3 0 #10000000"/>
        </Style>

        <!-- Section Title -->
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Section Subtitle -->
        <Style Selector="TextBlock.section-subtitle">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <!-- Field Label -->
        <Style Selector="TextBlock.field-label">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Width" Value="90"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- PWM Value -->
        <Style Selector="TextBlock.pwm-value">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Width" Value="50"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Channel Progress Bar -->
        <Style Selector="ProgressBar.channel-bar">
            <Setter Property="Height" Value="12"/>
            <Setter Property="Minimum" Value="800"/>
            <Setter Property="Maximum" Value="2200"/>
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#3B82F6"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>

        <!-- Thin Channel Bar for Monitor -->
        <Style Selector="ProgressBar.channel-bar-thin">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Minimum" Value="800"/>
            <Setter Property="Maximum" Value="2200"/>
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="CornerRadius" Value="3"/>
        </Style>

        <!-- Primary Button -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="#2563EB"/>
        </Style>

        <Style Selector="Button.primary:disabled">
            <Setter Property="Background" Value="#9CA3AF"/>
            <Setter Property="Opacity" Value="0.6"/>
        </Style>

        <!-- Secondary Button -->
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.secondary:pointerover">
            <Setter Property="Background" Value="#F9FAFB"/>
        </Style>

        <!-- Status Banner -->
        <Style Selector="Border.status-required">
            <Setter Property="Background" Value="#FEF3C7"/>
            <Setter Property="BorderBrush" Value="#F59E0B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,12"/>
        </Style>

        <Style Selector="Border.status-progress">
            <Setter Property="Background" Value="#DBEAFE"/>
            <Setter Property="BorderBrush" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,12"/>
        </Style>

        <Style Selector="Border.status-complete">
            <Setter Property="Background" Value="#D1FAE5"/>
            <Setter Property="BorderBrush" Value="#10B981"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,12"/>
        </Style>

        <!-- ComboBox -->
        <Style Selector="ComboBox">
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24" Spacing="24" MaxWidth="1000">

            <!-- Header -->
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="8">
                    <TextBlock Text="RC Calibration" FontSize="28" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Calibrate radio control channels and configure attitude mapping" 
                               FontSize="14" Foreground="#6B7280"/>
                </StackPanel>
                
                <Button Grid.Column="1" 
                        Classes="secondary" 
                        Command="{Binding RefreshCommand}"
                        VerticalAlignment="Center">
                    <TextBlock Text="Refresh"/>
                </Button>
            </Grid>

            <!-- Loading Indicator -->
            <Border Classes="card" IsVisible="{Binding IsBusy}">
                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="#3B82F6"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#6B7280"/>
                </StackPanel>
            </Border>

            <!-- Not Connected Warning -->
            <Border Classes="status-required" IsVisible="{Binding !IsConnected}">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="?" FontWeight="SemiBold" Foreground="#92400E" VerticalAlignment="Center"/>
                    <TextBlock Text="Connect to flight controller to calibrate radio" FontSize="13" Foreground="#A16207" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- RC Not Connected Warning -->
            <Border Classes="status-required" IsVisible="{Binding !IsRcConnected}">
                <Border.IsVisible>
                    <Binding Path="IsConnectedButRcNotConnected"/>
                </Border.IsVisible>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="?" FontWeight="SemiBold" Foreground="#92400E" VerticalAlignment="Center"/>
                    <StackPanel Spacing="4">
                        <TextBlock Text="RC Receiver Not Connected" FontWeight="SemiBold" Foreground="#92400E"/>
                        <TextBlock Text="{Binding RcConnectionStatus}" FontSize="13" Foreground="#A16207"/>
                        <TextBlock Text="Turn on your transmitter and verify the receiver is properly connected to the flight controller" 
                                   FontSize="12" Foreground="#A16207" TextWrapping="Wrap" MaxWidth="700"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- RC Connection OK Status -->
            <Border Classes="status-complete" IsVisible="{Binding IsRcConnected}">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="?" FontWeight="SemiBold" Foreground="#047857" VerticalAlignment="Center"/>
                    <StackPanel Spacing="2">
                        <TextBlock Text="RC Receiver Connected" FontWeight="SemiBold" Foreground="#047857"/>
                        <TextBlock Text="{Binding RcConnectionStatus}" FontSize="13" Foreground="#059669"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- RC Calibration Section -->
            <Border Classes="card" IsVisible="{Binding IsConnected}">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Radio Calibration" Classes="section-title"/>
                        <TextBlock Text="Move all sticks to their extreme positions during calibration" Classes="section-subtitle"/>
                    </StackPanel>

                    <!-- Status Banner -->
                    <Border Classes.status-required="{Binding CalibrationRequired}"
                            Classes.status-progress="{Binding IsCalibrating}"
                            Classes.status-complete="{Binding !CalibrationRequired}"
                            IsVisible="{Binding !IsCalibrating}">
                        <TextBlock Text="{Binding CalibrationStatusText}" 
                                   FontWeight="SemiBold" 
                                   Foreground="{Binding CalibrationRequired, Converter={x:Static conv:BoolToColorConverter.Instance}, ConverterParameter=#92400E|#047857}"/>
                    </Border>

                    <Border Classes="status-progress" IsVisible="{Binding IsCalibrating}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <ProgressBar IsIndeterminate="True" Width="24" Height="24"/>
                            <TextBlock Text="Calibration in progress - Move all sticks to extremes" 
                                       FontWeight="SemiBold" Foreground="#1E40AF" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Main Attitude Channels -->
                    <StackPanel Spacing="12" Margin="0,8,0,0">
                        
                        <!-- Roll -->
                        <Grid ColumnDefinitions="90,*,50">
                            <TextBlock Grid.Column="0" Text="Roll" Classes="field-label"/>
                            <ProgressBar Grid.Column="1" Classes="channel-bar" Value="{Binding RollValue}" Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="2" Text="{Binding RollValue}" Classes="pwm-value"/>
                        </Grid>

                        <!-- Pitch -->
                        <Grid ColumnDefinitions="90,*,50">
                            <TextBlock Grid.Column="0" Text="Pitch" Classes="field-label"/>
                            <ProgressBar Grid.Column="1" Classes="channel-bar" Value="{Binding PitchValue}" Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="2" Text="{Binding PitchValue}" Classes="pwm-value"/>
                        </Grid>

                        <!-- Yaw -->
                        <Grid ColumnDefinitions="90,*,50">
                            <TextBlock Grid.Column="0" Text="Yaw" Classes="field-label"/>
                            <ProgressBar Grid.Column="1" Classes="channel-bar" Value="{Binding YawValue}" Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="2" Text="{Binding YawValue}" Classes="pwm-value"/>
                        </Grid>

                        <!-- Throttle -->
                        <Grid ColumnDefinitions="90,*,50">
                            <TextBlock Grid.Column="0" Text="Throttle" Classes="field-label"/>
                            <ProgressBar Grid.Column="1" Classes="channel-bar" Value="{Binding ThrottleValue}" Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="2" Text="{Binding ThrottleValue}" Classes="pwm-value"/>
                        </Grid>
                    </StackPanel>

                    <!-- Calibrate Button -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Classes="primary" 
                                Command="{Binding CalibrateCommand}"
                                IsEnabled="{Binding IsConnected}">
                            <TextBlock Text="{Binding IsCalibrating, Converter={StaticResource CalibrationButtonTextConverter}, ConverterParameter='Complete Calibration|Start Calibration'}"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Attitude Channel Mapping -->
            <Border Classes="card" IsVisible="{Binding IsConnected}">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Attitude Channel Mapping" Classes="section-title"/>
                        <TextBlock Text="Assign control functions to RC channels" Classes="section-subtitle"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="*,24,*" RowDefinitions="Auto,16,Auto">
                        
                        <!-- Throttle -->
                        <StackPanel Grid.Column="0" Grid.Row="0" Spacing="6">
                            <TextBlock Text="Throttle" FontSize="13" FontWeight="Medium" Foreground="#374151"/>
                            <ComboBox ItemsSource="{Binding ChannelOptions}"
                                      SelectedItem="{Binding SelectedThrottleChannel}"
                                      DisplayMemberBinding="{Binding Label}"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <!-- Roll -->
                        <StackPanel Grid.Column="2" Grid.Row="0" Spacing="6">
                            <TextBlock Text="Roll" FontSize="13" FontWeight="Medium" Foreground="#374151"/>
                            <ComboBox ItemsSource="{Binding ChannelOptions}"
                                      SelectedItem="{Binding SelectedRollChannel}"
                                      DisplayMemberBinding="{Binding Label}"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <!-- Pitch -->
                        <StackPanel Grid.Column="0" Grid.Row="2" Spacing="6">
                            <TextBlock Text="Pitch" FontSize="13" FontWeight="Medium" Foreground="#374151"/>
                            <ComboBox ItemsSource="{Binding ChannelOptions}"
                                      SelectedItem="{Binding SelectedPitchChannel}"
                                      DisplayMemberBinding="{Binding Label}"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <!-- Yaw -->
                        <StackPanel Grid.Column="2" Grid.Row="2" Spacing="6">
                            <TextBlock Text="Yaw" FontSize="13" FontWeight="Medium" Foreground="#374151"/>
                            <ComboBox ItemsSource="{Binding ChannelOptions}"
                                      SelectedItem="{Binding SelectedYawChannel}"
                                      DisplayMemberBinding="{Binding Label}"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Grid>

                    <!-- Update Button -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Classes="primary" 
                                Command="{Binding UpdateMappingCommand}"
                                IsEnabled="{Binding IsConnected}">
                            <TextBlock Text="Update Mapping"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Channel Monitor -->
            <Border Classes="card" IsVisible="{Binding IsConnected}">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Channel Monitor" Classes="section-title"/>
                        <TextBlock Text="Live RC input values" Classes="section-subtitle"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="*,32,*">
                        
                        <!-- Left Column: Channels 1-8 -->
                        <StackPanel Grid.Column="0" Spacing="8">
                            <Grid ColumnDefinitions="80,*,40">
                                <TextBlock Grid.Column="0" Text="Channel 1" FontSize="12" Foreground="#374151" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" Classes="channel-bar-thin" Value="{Binding Channel1Value}" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding Channel1Value}" FontSize="12" Foreground="#6B7280" TextAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid ColumnDefinitions="80,*,40">
                                <TextBlock Grid.Column="0" Text="Channel 2" FontSize="12" Foreground="#374151" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" Classes="channel-bar-thin" Value="{Binding Channel2Value}" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding Channel2Value}" FontSize="12" Foreground="#6B7280" TextAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid ColumnDefinitions="80,*,40">
                                <TextBlock Grid.Column="0" Text="Channel 3" FontSize="12" Foreground="#374151" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" Classes="channel-bar-thin" Value="{Binding Channel3Value}" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding Channel3Value}" FontSize="12" Foreground="#6B7280" TextAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid ColumnDefinitions="80,*,40">
                                <TextBlock Grid.Column="0" Text="Channel 4" FontSize="12" Foreground="#374151" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" Classes="channel-bar-thin" Value="{Binding Channel4Value}" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding Channel4Value}" FontSize="12" Foreground="#6B7280" TextAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid ColumnDefinitions="80,*,40">
                                <TextBlock Grid.Column="0" Text="Channel 5" FontSize="12" Foreground="#374151" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" Classes="channel-bar-thin" Value="{Binding Channel5Value}" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding Channel5Value}" FontSize="12" Foreground="#6B7280" TextAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid ColumnDefinitions="80,*,40">
                                <TextBlock Grid.Column="0" Text="Channel 6" FontSize="12" Foreground="#374151" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" Classes="channel-bar-thin" Value="{Binding Channel6Value}" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding Channel6Value}" FontSize="12" Foreground="#6B7280" TextAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid ColumnDefinitions="80,*,40">
                                <TextBlock Grid.Column="0" Text="Channel 7" FontSize="12" Foreground="#374151" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" Classes="channel-bar-thin" Value="{Binding Channel7Value}" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding Channel7Value}" FontSize="12" Foreground="#6B7280" TextAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid ColumnDefinitions="80,*,40">
                                <TextBlock Grid.Column="0" Text="Channel 8" FontSize="12" Foreground="#374151" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" Classes="channel-bar-thin" Value="{Binding Channel8Value}" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding Channel8Value}" FontSize="12" Foreground="#6B7280" TextAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>

                        <!-- Right Column: Channels 9-16 -->
                        <StackPanel Grid.Column="2" Spacing="8">
                            <Grid ColumnDefinitions="80,*,40">
                                <TextBlock Grid.Column="0" Text="Channel 9" FontSize="12" Foreground="#374151" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" Classes="channel-bar-thin" Value="{Binding Channel9Value}" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding Channel9Value}" FontSize="12" Foreground="#6B7280" TextAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid ColumnDefinitions="80,*,40">
                                <TextBlock Grid.Column="0" Text="Channel 10" FontSize="12" Foreground="#374151" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" Classes="channel-bar-thin" Value="{Binding Channel10Value}" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding Channel10Value}" FontSize="12" Foreground="#6B7280" TextAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid ColumnDefinitions="80,*,40">
                                <TextBlock Grid.Column="0" Text="Channel 11" FontSize="12" Foreground="#374151" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" Classes="channel-bar-thin" Value="{Binding Channel11Value}" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding Channel11Value}" FontSize="12" Foreground="#6B7280" TextAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid ColumnDefinitions="80,*,40">
                                <TextBlock Grid.Column="0" Text="Channel 12" FontSize="12" Foreground="#374151" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" Classes="channel-bar-thin" Value="{Binding Channel12Value}" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding Channel12Value}" FontSize="12" Foreground="#6B7280" TextAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid ColumnDefinitions="80,*,40">
                                <TextBlock Grid.Column="0" Text="Channel 13" FontSize="12" Foreground="#374151" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" Classes="channel-bar-thin" Value="{Binding Channel13Value}" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding Channel13Value}" FontSize="12" Foreground="#6B7280" TextAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid ColumnDefinitions="80,*,40">
                                <TextBlock Grid.Column="0" Text="Channel 14" FontSize="12" Foreground="#374151" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" Classes="channel-bar-thin" Value="{Binding Channel14Value}" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding Channel14Value}" FontSize="12" Foreground="#6B7280" TextAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid ColumnDefinitions="80,*,40">
                                <TextBlock Grid.Column="0" Text="Channel 15" FontSize="12" Foreground="#374151" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" Classes="channel-bar-thin" Value="{Binding Channel15Value}" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding Channel15Value}" FontSize="12" Foreground="#6B7280" TextAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid ColumnDefinitions="80,*,40">
                                <TextBlock Grid.Column="0" Text="Channel 16" FontSize="12" Foreground="#374151" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" Classes="channel-bar-thin" Value="{Binding Channel16Value}" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding Channel16Value}" FontSize="12" Foreground="#6B7280" TextAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Info Footer -->
            <Border Background="#EFF6FF" CornerRadius="8" Padding="16" IsVisible="{Binding IsConnected}">
                <StackPanel Spacing="4">
                    <TextBlock Text="PDRL Compliance" FontSize="13" FontWeight="SemiBold" Foreground="#1E40AF"/>
                    <TextBlock Text="All main control channels (Roll, Pitch, Yaw, Throttle) must be properly calibrated before flight. Move sticks to all extremes during calibration." 
                               FontSize="12" Foreground="#3B82F6" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
