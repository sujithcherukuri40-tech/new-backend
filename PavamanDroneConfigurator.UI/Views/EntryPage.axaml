<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels"
        mc:Ignorable="d" d:DesignWidth="650" d:DesignHeight="420"
        x:Class="PavamanDroneConfigurator.UI.Views.EntryPage"
        x:DataType="vm:EntryPageViewModel"
        Title="Pavaman Drone Configurator"
        Width="650"
        Height="420"
        MinWidth="600"
        MinHeight="400"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Icon="avares://PavamanDroneConfigurator.UI/Assets/Images/logo.ico"
        Background="#F8FAFC">

    <Window.Styles>
        <Style Selector="Window">
            <Setter Property="FontFamily" Value="Inter, Segoe UI, San Francisco, Helvetica Neue, Arial"/>
        </Style>

        <!-- Primary Action Button (Cyan) -->
        <Style Selector="Button.btn-primary">
            <Setter Property="Background" Value="#38BDF8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.btn-primary:pointerover">
            <Setter Property="Background" Value="#0EA5E9"/>
        </Style>
        <Style Selector="Button.btn-primary:pressed">
            <Setter Property="Background" Value="#0284C7"/>
        </Style>

        <!-- Secondary Action Button (Amber/Orange) -->
        <Style Selector="Button.btn-secondary">
            <Setter Property="Background" Value="#F59E0B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.btn-secondary:pointerover">
            <Setter Property="Background" Value="#D97706"/>
        </Style>
        <Style Selector="Button.btn-secondary:pressed">
            <Setter Property="Background" Value="#B45309"/>
        </Style>

        <!-- Exit Button (Outline) -->
        <Style Selector="Button.btn-exit">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.btn-exit:pointerover">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
        </Style>

        <!-- Action Card Style -->
        <Style Selector="Border.action-card">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="24,20"/>
        </Style>
        
        <Style Selector="Border.action-card:pointerover">
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
        </Style>
    </Window.Styles>

    <!-- Main Grid Layout - No ScrollViewer -->
    <Grid RowDefinitions="Auto,*,Auto" Margin="32,24,32,24">
        
        <!-- Header Section -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Spacing="4">
            
            <!-- Logo -->
            <Border Width="56"
                    Height="56"
                    CornerRadius="14"
                    Background="#E0F2FE"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,10">
                <Image Source="avares://PavamanDroneConfigurator.UI/Assets/Images/logo.ico"
                       Stretch="Uniform"
                       Margin="8"/>
            </Border>
            
            <!-- Title -->
            <TextBlock Text="Pavaman Drone Configurator"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#0F172A"
                       HorizontalAlignment="Center"/>
            
            <!-- Subtitle -->
            <TextBlock Text="Choose an option to get started"
                       FontSize="13"
                       Foreground="#64748B"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Main Content - Side by Side Cards -->
        <Grid Grid.Row="1" 
              ColumnDefinitions="*,*" 
              ColumnSpacing="20"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              MaxWidth="480"
              Margin="0,20,0,20">
            
            <!-- Flash Firmware Card (Left) -->
            <Border Grid.Column="0" Classes="action-card">
                <StackPanel Spacing="14">
                    
                    <!-- Icon -->
                    <Border Width="48"
                            Height="48"
                            CornerRadius="12"
                            Background="#FEF3C7"
                            HorizontalAlignment="Center">
                        <PathIcon Data="M9 16h6v-6h4l-7-7-7 7h4zm-4 2h14v2H5z"
                                  Width="22" Height="22"
                                  Foreground="#F59E0B"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>
                    
                    <!-- Title -->
                    <TextBlock Text="Flash Firmware"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#0F172A"
                               HorizontalAlignment="Center"/>
                    
                    <!-- Action Button -->
                    <Button Classes="btn-secondary"
                            Content="Flash Firmware"
                            Command="{Binding FlashFirmwareCommand}"/>
                </StackPanel>
            </Border>
            
            <!-- Connect to Drone Card (Right) -->
            <Border Grid.Column="1" Classes="action-card">
                <StackPanel Spacing="14">
                    
                    <!-- Icon -->
                    <Border Width="48"
                            Height="48"
                            CornerRadius="12"
                            Background="#E0F2FE"
                            HorizontalAlignment="Center">
                        <PathIcon Data="M21 14h-1V7a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v7H3a1 1 0 0 0-1 1v2a2 2 0 0 0 2 2h2v-2H4v-1h16v1h-2v2h2a2 2 0 0 0 2-2v-2a1 1 0 0 0-1-1zM6 7h12v7H6V7zm6 12a1 1 0 1 0 0-2 1 1 0 0 0 0 2z"
                                  Width="22" Height="22"
                                  Foreground="#38BDF8"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>
                    
                    <!-- Title -->
                    <TextBlock Text="Connect to Drone"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#0F172A"
                               HorizontalAlignment="Center"/>
                    
                    <!-- Action Button -->
                    <Button Classes="btn-primary"
                            Content="Connect to Drone"
                            Command="{Binding ConnectToDroneCommand}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Footer Section -->
        <StackPanel Grid.Row="2" HorizontalAlignment="Center" Spacing="8">
            
            <!-- Exit Button -->
            <Button Classes="btn-exit"
                    Content="Exit Application"
                    Command="{Binding ExitCommand}"
                    HorizontalAlignment="Center"/>
            
            <!-- Version Info -->
            <TextBlock Text="v1.0.0 • Pavaman Technologies"
                       FontSize="10"
                       Foreground="#94A3B8"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
