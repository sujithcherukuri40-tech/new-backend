<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels"
             xmlns:models="using:PavamanDroneConfigurator.Core.Models"
             xmlns:controls="using:PavamanDroneConfigurator.UI.Controls"
             xmlns:interfaces="using:PavamanDroneConfigurator.Core.Interfaces"
             x:Class="PavamanDroneConfigurator.UI.Views.LogAnalyzerPage"
             x:DataType="vm:LogAnalyzerPageViewModel">

    <UserControl.Resources>
        <vm:BoolToYesNoConverter x:Key="BoolToStringConverter"/>
        <vm:BoolToSuccessColorConverter x:Key="BoolToColorConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- LIGHT THEME STYLES -->
        <Style Selector="TextBlock.SectionTitle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#333333"/>
        </Style>
        
        <Style Selector="Button.ToolbarButton">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        
        <Style Selector="Button.ToolbarButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#E8E8E8"/>
        </Style>
        
        <Style Selector="Button.ToolbarButton:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#DDDDDD"/>
        </Style>

        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Foreground" Value="#666666"/>
        </Style>

        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="#007ACC"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        
        <Style Selector="Border.Panel">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        
        <Style Selector="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
        </Style>
        
        <!-- DARK THEME STYLES FOR EVENTS TAB -->
        <Style Selector="Border.EventsPanel">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        
        <Style Selector="TextBlock.EventsHeader">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
        </Style>
        
        <Style Selector="Button.EventsButton">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        
        <Style Selector="Button.EventsButtonSecondary">
            <Setter Property="Background" Value="#475569"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        
        <Style Selector="ComboBox.EventsComboBox">
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#475569"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="MinWidth" Value="120"/>
        </Style>
        
        <Style Selector="Border.StatCard">
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="MinWidth" Value="140"/>
        </Style>
        
        <Style Selector="Border.StatCardTotal">
            <Setter Property="Background" Value="#334155"/>
        </Style>
        
        <Style Selector="Border.StatCardError">
            <Setter Property="Background" Value="#7F1D1D"/>
        </Style>
        
        <Style Selector="Border.StatCardWarning">
            <Setter Property="Background" Value="#78350F"/>
        </Style>
        
        <Style Selector="Border.StatCardInfo">
            <Setter Property="Background" Value="#1E3A5F"/>
        </Style>
        
        <!-- Severity Badge Styles -->
        <Style Selector="Border.SeverityBadge">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        
        <Style Selector="Border.SeverityError">
            <Setter Property="Background" Value="#DC2626"/>
        </Style>
        
        <Style Selector="Border.SeverityWarning">
            <Setter Property="Background" Value="#F59E0B"/>
        </Style>
        
        <Style Selector="Border.SeverityInfo">
            <Setter Property="Background" Value="#3B82F6"/>
        </Style>
        
        <Style Selector="Border.SeverityCritical">
            <Setter Property="Background" Value="#991B1B"/>
        </Style>
        
        <!-- DataGrid Dark Theme -->
        <Style Selector="DataGrid.EventsDataGrid">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="RowBackground" Value="#1E293B"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#334155"/>
        </Style>
        
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        
        <Style Selector="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        
        <Style Selector="DataGridRow:pointerover /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="#334155"/>
        </Style>
        
        <Style Selector="DataGridCell">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        
        <!-- Pagination Button Styles -->
        <Style Selector="Button.PaginationButton">
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="MinWidth" Value="36"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        
        <Style Selector="Button.PaginationButton:disabled">
            <Setter Property="Opacity" Value="0.5"/>
        </Style>
        
        <Style Selector="Button.PaginationButtonActive">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Background="#F5F5F5">
        
        <!-- TOP TOOLBAR -->
        <Border Grid.Row="0" Background="White" Padding="8" BorderBrush="#E1E1E1" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                    <Button Classes="ToolbarButton" Content="📂 Load Log" Command="{Binding BrowseLocalFileCommand}"/>
                    <Button Classes="ToolbarButton" Content="📡 From FC" Command="{Binding OpenDownloadDialogCommand}" 
                            IsEnabled="{Binding IsConnected}"/>
                    <Separator Width="2" Background="#E1E1E1" Margin="12,4"/>
                    <Button Classes="ToolbarButton" Content="📄 Export CSV" Command="{Binding ExportToCsvCommand}"
                            IsEnabled="{Binding IsLogLoaded}"/>
                    <Button Classes="ToolbarButton" Content="🗺 Export KML" Command="{Binding ExportToKmlCommand}"
                            IsEnabled="{Binding HasGpsData}"/>
                </StackPanel>
                
                <TextBlock Grid.Column="1" Text="{Binding LoadedLogInfo}" Foreground="#666666" 
                           FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#888888" FontSize="11" 
                               VerticalAlignment="Center" Margin="0,0,16,0"
                               IsVisible="{Binding !IsBusy}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT WITH TABS -->
        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}" Background="#FAFAFA">
            
            <!-- OVERVIEW TAB -->
            <TabItem Header="Overview">
                <ScrollViewer>
                    <Grid ColumnDefinitions="*,*" Margin="20">
                        <!-- Left: Log Info -->
                        <Border Grid.Column="0" Classes="Panel" Padding="20" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Log Information" Classes="SectionTitle" Margin="0,0,0,20"/>
                                
                                <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="File:" Foreground="#666666" Margin="0,0,0,8"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LogFileName}" Foreground="#333333" 
                                               TextWrapping="Wrap" Margin="0,0,0,8"/>
                                    
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Size:" Foreground="#666666" Margin="0,0,0,8"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LogFileSize}" Foreground="#333333" Margin="0,0,0,8"/>
                                    
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Duration:" Foreground="#666666" Margin="0,0,0,8"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LogDuration}" Foreground="#333333" Margin="0,0,0,8"/>
                                    
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Messages:" Foreground="#666666" Margin="0,0,0,8"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LogMessageCount}" Foreground="#333333" Margin="0,0,0,8"/>
                                    
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Message Types:" Foreground="#666666" Margin="0,0,0,8"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding LogMessageTypes}" Foreground="#333333" Margin="0,0,0,8"/>
                                </Grid>
                                

                                <TextBlock Text="Data Availability" Classes="SectionTitle" Margin="0,20,0,12"/>
                                <StackPanel Orientation="Horizontal" Spacing="20">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="GPS:" Foreground="#666666"/>
                                        <TextBlock Text="{Binding HasGpsData, Converter={StaticResource BoolToStringConverter}}" 
                                                   Foreground="{Binding HasGpsData, Converter={StaticResource BoolToColorConverter}}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="Attitude:" Foreground="#666666"/>
                                        <TextBlock Text="{Binding HasAttitudeData, Converter={StaticResource BoolToStringConverter}}"
                                                   Foreground="{Binding HasAttitudeData, Converter={StaticResource BoolToColorConverter}}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="Vibration:" Foreground="#666666"/>
                                        <TextBlock Text="{Binding HasVibeData, Converter={StaticResource BoolToStringConverter}}"
                                                   Foreground="{Binding HasVibeData, Converter={StaticResource BoolToColorConverter}}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <!-- Right: Event Summary -->
                        <Border Grid.Column="1" Classes="Panel" Padding="20" Margin="10,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Event Summary" Classes="SectionTitle" Margin="0,0,0,20"/>
                                
                                <Border Background="#FAFAFA"  Padding="20" Margin="0,0,0,20" BorderBrush="#E1E1E1" BorderThickness="1"
                                        IsVisible="{Binding EventSummary, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <Grid ColumnDefinitions="*,*,*,*">
                                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding EventSummary.InfoCount, FallbackValue=0}" FontSize="28" FontWeight="Bold"
                                                       Foreground="#3B82F6" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Info" Foreground="#666666" FontSize="11" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding EventSummary.WarningCount, FallbackValue=0}" FontSize="28" FontWeight="Bold"
                                                       Foreground="#F59E0B" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Warnings" Foreground="#666666" FontSize="11" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding EventSummary.ErrorCount, FallbackValue=0}" FontSize="28" FontWeight="Bold"
                                                       Foreground="#EF4444" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Errors" Foreground="#666666" FontSize="11" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding EventSummary.CriticalCount, FallbackValue=0}" FontSize="28" FontWeight="Bold"
                                                       Foreground="#DC2626" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Critical" Foreground="#666666" FontSize="11" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                

                                <!-- No Log Loaded Placeholder -->
                                <StackPanel IsVisible="{Binding !IsLogLoaded}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,48,0,0">
                                    <TextBlock Text="No log file loaded" Foreground="#999999" FontSize="16" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Click 'Load Log' to open a DataFlash log file" Foreground="#BBBBBB" FontSize="12" 
                                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>
            
            <!-- PLOT TAB -->
            <TabItem Header="Plot">
                <Grid RowDefinitions="*,Auto,300">
                    
                    <!-- Graph Area (Top) -->
                    <Grid Grid.Row="0">
                        <controls:LogGraphControl x:Name="GraphControl"
                                                   GraphData="{Binding CurrentGraph}"
                                                   IsVisible="{Binding HasGraphData}"/>
                        
                        <!-- No Data Message -->
                        <StackPanel IsVisible="{Binding !HasGraphData}"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="Select fields to graph"
                                       Foreground="#999999"
                                       FontSize="16"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Use the field tree on the right to add data series"
                                       Foreground="#BBBBBB"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Splitter -->
                    <GridSplitter Grid.Row="1"
                                  Background="#E1E1E1"
                                  Height="4"
                                  HorizontalAlignment="Stretch"/>
                    
                    <!-- Map Area (Bottom) -->
                    <Grid Grid.Row="2">
                        <!-- Map Header with Controls -->
                        <Border Background="White"
                                BorderBrush="#E1E1E1"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="4">
                            <Grid RowDefinitions="Auto,*">
                                <!-- Header Bar -->
                                <Border Grid.Row="0"
                                        Background="#F5F5F5"
                                        Padding="12,8"
                                        BorderBrush="#E1E1E1"
                                        BorderThickness="0,0,0,1">
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                                        <TextBlock Grid.Column="0"
                                                   Text="GPS Track &amp; Events"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   VerticalAlignment="Center"
                                                   Foreground="#333333"/>
                                        
                                        <!-- Event Count Badge -->
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Left"
                                                    Margin="12,0,0,0"
                                                    IsVisible="{Binding HasGpsData}">
                                            <Border Background="#EF4444"
                                                    CornerRadius="10"
                                                    Padding="8,2"
                                                    Margin="0,0,8,0"
                                                    IsVisible="{Binding CriticalMapEvents.Count}">
                                                <TextBlock Text="{Binding CriticalMapEvents.Count}"
                                                           Foreground="White"
                                                           FontSize="11"
                                                           FontWeight="Bold"/>
                                            </Border>
                                            <TextBlock Text="Critical Events"
                                                       Foreground="#666666"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       IsVisible="{Binding CriticalMapEvents.Count}"/>
                                        </StackPanel>
                                        
                                        <!-- GPS Points Count -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding GpsTrack.Count, StringFormat='{}{0:N0} GPS points'}"
                                                   Foreground="#666666"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"
                                                   IsVisible="{Binding HasGpsData}"/>
                                        
                                        <!-- Zoom to Fit Button -->
                                        <Button Grid.Column="3"
                                                Content="🎯 Fit"
                                                Padding="8,4"
                                                Margin="0,0,8,0"
                                                Classes="ToolbarButton"
                                                IsVisible="{Binding HasGpsData}"
                                                ToolTip.Tip="Zoom to fit GPS track"/>
                                        
                                        <!-- Toggle Map Button -->
                                        <ToggleButton Grid.Column="4"
                                                      Content="📍 Map"
                                                      Padding="8,4"
                                                      IsChecked="{Binding ShowMap}"
                                                      Classes="ToolbarButton"
                                                      IsVisible="{Binding HasGpsData}"/>
                                    </Grid>
                                </Border>
                                
                                <!-- Map Display -->
                                <Grid Grid.Row="1" IsVisible="{Binding ShowMap}">
                                    <controls:LogMapControl TrackPoints="{Binding GpsTrackPoints}"
                                                            CriticalEvents="{Binding CriticalMapEvents}"
                                                            CenterLatitude="{Binding MapCenterLat}"
                                                            CenterLongitude="{Binding MapCenterLng}"
                                                            IsVisible="{Binding HasGpsData}"/>
                                    
                                    <!-- No GPS Data Message -->
                                    <StackPanel IsVisible="{Binding !HasGpsData}"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center">
                                        <TextBlock Text="No GPS data available"
                                                   Foreground="#999999"
                                                   FontSize="16"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="Load a log file with GPS data to view the track and events"
                                                   Foreground="#BBBBBB"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
            
            <!-- MAP TAB -->
            <TabItem Header="Map">
                <Grid>
                    <controls:LogMapControl
                        TrackPoints="{Binding GpsTrackPoints}"
                        CriticalEvents="{Binding CriticalMapEvents}"
                        CenterLatitude="{Binding MapCenterLat}"
                        CenterLongitude="{Binding MapCenterLng}"
                        IsVisible="{Binding HasGpsData}"/>
                    
                    <!-- No GPS Data Message -->
                    <StackPanel IsVisible="{Binding !HasGpsData}" 
                                VerticalAlignment="Center" 
                                HorizontalAlignment="Center">
                        <TextBlock Text="No GPS data available" 
                                   Foreground="#999999" 
                                   FontSize="16" 
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Load a log file with GPS data to view the track" 
                                   Foreground="#BBBBBB" 
                                   FontSize="12" 
                                   HorizontalAlignment="Center" 
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            
            <!-- ENHANCED EVENTS TAB -->
            <TabItem Header="Events">
                <Grid RowDefinitions="Auto,Auto,3*,1*,Auto" Background="#0F172A">
                    
                    <!-- Filter Bar -->
                    <Border Grid.Row="0" Background="#1E293B" Padding="16,12" BorderBrush="#334155" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto">
                            <!-- Time Range -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" Margin="0,0,20,0">
                                <TextBlock Text="Time Range:" Foreground="#94A3B8" VerticalAlignment="Center" FontSize="12"/>
                                <ComboBox Classes="EventsComboBox" 
                                          ItemsSource="{Binding TimeRangeOptions}"
                                          SelectedIndex="{Binding SelectedTimeRangeIndex}"/>
                            </StackPanel>
                            
                            <!-- Severity Filter -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="0,0,20,0">
                                <TextBlock Text="Severity:" Foreground="#94A3B8" VerticalAlignment="Center" FontSize="12"/>
                                <ComboBox Classes="EventsComboBox"
                                          ItemsSource="{Binding AvailableSeverities}"
                                          SelectedItem="{Binding SelectedSeverityFilter}"/>
                            </StackPanel>
                            
                            <!-- Event Type Filter -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" Margin="0,0,20,0">
                                <TextBlock Text="Event Type:" Foreground="#94A3B8" VerticalAlignment="Center" FontSize="12"/>
                                <ComboBox Classes="EventsComboBox"
                                          ItemsSource="{Binding AvailableEventTypes}"
                                          SelectedItem="{Binding SelectedEventTypeFilter}"
                                          MinWidth="150"/>
                            </StackPanel>
                            
                            <!-- Source Filter -->
                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" Margin="0,0,20,0">
                                <TextBlock Text="Source:" Foreground="#94A3B8" VerticalAlignment="Center" FontSize="12"/>
                                <ComboBox Classes="EventsComboBox"
                                          ItemsSource="{Binding AvailableSources}"
                                          SelectedItem="{Binding SelectedSourceFilter}"/>
                            </StackPanel>
                            
                            <!-- Search Box -->
                            <TextBox Grid.Column="4" Text="{Binding EventSearchText}" 
                                     Watermark="🔍 Search events..." 
                                     Background="#334155" Foreground="#E2E8F0" 
                                     BorderBrush="#475569" Padding="10,8"
                                     Margin="0,0,16,0" FontSize="12"/>
                            
                            <!-- Filter Button -->
                            <Button Grid.Column="5" Classes="EventsButton" Content="Filter" 
                                    Command="{Binding ApplyEventsFilterCommand}" Margin="0,0,8,0"/>
                            
                            <!-- Clear Button -->
                            <Button Grid.Column="6" Classes="EventsButtonSecondary" Content="Clear" 
                                    Command="{Binding ClearEventsFilterCommand}"/>
                        </Grid>
                    </Border>
                    
                    <!-- Summary Stats Row -->
                    <Border Grid.Row="1" Background="#1E293B" Padding="16,16" BorderBrush="#334155" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <!-- Total Events -->
                            <Border Classes="StatCard StatCardTotal">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="📊" FontSize="16" VerticalAlignment="Center"/>
                                    <StackPanel>
                                        <TextBlock Text="Total Events" Foreground="#94A3B8" FontSize="11"/>
                                        <TextBlock Text="{Binding EventDisplaySummary.TotalEventsDisplay, FallbackValue=0}" 
                                                   Foreground="#E2E8F0" FontSize="18" FontWeight="Bold"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            
                            <!-- Errors -->
                            <Border Classes="StatCard StatCardError">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="❌" FontSize="16" Foreground="#FCA5A5" VerticalAlignment="Center"/>
                                    <StackPanel>
                                        <TextBlock Text="Errors" Foreground="#FCA5A5" FontSize="11"/>
                                        <TextBlock Text="{Binding EventDisplaySummary.ErrorCountDisplay, FallbackValue=0}" 
                                                   Foreground="White" FontSize="18" FontWeight="Bold"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            
                            <!-- Warnings -->
                            <Border Classes="StatCard StatCardWarning">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="⚠" FontSize="16" Foreground="#FCD34D" VerticalAlignment="Center"/>
                                    <StackPanel>
                                        <TextBlock Text="Warnings" Foreground="#FCD34D" FontSize="11"/>
                                        <TextBlock Text="{Binding EventDisplaySummary.WarningCountDisplay, FallbackValue=0}" 
                                                   Foreground="White" FontSize="18" FontWeight="Bold"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            
                            <!-- Info Events -->
                            <Border Classes="StatCard StatCardInfo">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="ℹ" FontSize="16" Foreground="#93C5FD" VerticalAlignment="Center"/>
                                    <StackPanel>
                                        <TextBlock Text="Info Events" Foreground="#93C5FD" FontSize="11"/>
                                        <TextBlock Text="{Binding EventDisplaySummary.InfoCountDisplay, FallbackValue=0}" 
                                                   Foreground="White" FontSize="18" FontWeight="Bold"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            
                            <!-- Spacer -->
                            <Border Width="1"/>
                            
                            <!-- Export Buttons -->
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="16,0,0,0">
                                <Button Classes="EventsButtonSecondary" Content="📄 CSV" 
                                        Command="{Binding ExportEventsToCsvCommand}"
                                        IsEnabled="{Binding HasFilteredEvents}"
                                        ToolTip.Tip="Export events to CSV"/>
                                <Button Classes="EventsButtonSecondary" Content="🗺 KML" 
                                        Command="{Binding ExportToKmlCommand}"
                                        IsEnabled="{Binding HasGpsData}"
                                        ToolTip.Tip="Export GPS track to KML"/>
                                <Button Classes="EventsButtonSecondary" Content="📋 JSON" 
                                        Command="{Binding ExportEventsToJsonCommand}"
                                        IsEnabled="{Binding HasFilteredEvents}"
                                        ToolTip.Tip="Export events to JSON"/>
                            </StackPanel>
                            
                            <!-- Auto Refresh -->
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="16,0,0,0">
                                <TextBlock Text="Auto-refresh:" Foreground="#94A3B8" VerticalAlignment="Center" FontSize="11"/>
                                <ComboBox Classes="EventsComboBox" MinWidth="100"
                                          ItemsSource="{Binding AutoRefreshOptions}"
                                          SelectedIndex="{Binding SelectedAutoRefreshIndex}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <!-- Events List with ScrollViewer (replacing DataGrid) -->
                    <Grid Grid.Row="2">
                        <!-- Table Header -->
                        <Border Background="#0F172A"
                                BorderBrush="#334155"
                                BorderThickness="0,0,0,1"
                                Padding="16,10"
                                VerticalAlignment="Top"
                                ZIndex="1">
                            <Grid ColumnDefinitions="1.3*,1*,1.5*,1.2*,3*,1.2*,0.4*">
                                <TextBlock Grid.Column="0" Text="Timestamp" Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="Severity" Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Grid.Column="2" Text="Event Type" Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Grid.Column="3" Text="Source" Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Grid.Column="4" Text="Message" Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Grid.Column="5" Text="User / Host" Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Grid.Column="6" Text="" Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12"/>
                            </Grid>
                        </Border>

                        <!-- Events Scrollable List -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Margin="0,41,0,0"
                                      IsVisible="{Binding HasFilteredEvents}">
                            <ItemsControl ItemsSource="{Binding FilteredEvents}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="interfaces:LogEvent">
                                        <Border Background="#1E293B"
                                                BorderBrush="#334155"
                                                BorderThickness="0,0,0,1"
                                                Padding="16,12"
                                                Cursor="Hand">
                                            <Border.Styles>
                                                <Style Selector="Border:pointerover">
                                                    <Setter Property="Background" Value="#334155"/>
                                                </Style>
                                            </Border.Styles>
                                            
                                            <Grid ColumnDefinitions="1.3*,1*,1.5*,1.2*,3*,1.2*,0.4*">
                                                <!-- Timestamp -->
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding TimestampDisplay}"
                                                           Foreground="#E2E8F0"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"/>

                                                <!-- Severity Badge -->
                                                <Panel Grid.Column="1">
                                                    <!-- Error Badge -->
                                                    <Border Background="#DC2626" Padding="8,4" CornerRadius="4" HorizontalAlignment="Left"
                                                            IsVisible="{Binding Severity, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static interfaces:LogEventSeverity.Error}}">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <TextBlock Text="✗" Foreground="White" FontSize="10"/>
                                                            <TextBlock Text="Error" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </Border>
                                                    

                                                    <!-- Warning Badge -->
                                                    <Border Background="#F59E0B" Padding="8,4" CornerRadius="4" HorizontalAlignment="Left"
                                                            IsVisible="{Binding Severity, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static interfaces:LogEventSeverity.Warning}}">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <TextBlock Text="⚠" Foreground="White" FontSize="10"/>
                                                            <TextBlock Text="Warning" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </Border>
                                                    

                                                    <!-- Info Badge -->
                                                    <Border Background="#3B82F6" Padding="8,4" CornerRadius="4" HorizontalAlignment="Left"
                                                            IsVisible="{Binding Severity, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static interfaces:LogEventSeverity.Info}}">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <TextBlock Text="ℹ" Foreground="White" FontSize="10"/>
                                                            <TextBlock Text="Info" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </Border>
                                                    

                                                    <!-- Critical Badge -->
                                                    <Border Background="#991B1B" Padding="8,4" CornerRadius="4" HorizontalAlignment="Left"
                                                            IsVisible="{Binding Severity, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static interfaces:LogEventSeverity.Critical}}">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <TextBlock Text="🔥" Foreground="White" FontSize="10"/>
                                                            <TextBlock Text="Critical" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Panel>

                                                <!-- Event Type -->
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Title}" 
                                                           Foreground="#E2E8F0"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"/>

                                                <!-- Source -->
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding Type}"
                                                           Foreground="#94A3B8"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"/>

                                                <!-- Message -->
                                                <TextBlock Grid.Column="4"
                                                           Text="{Binding Description}"
                                                           Foreground="#E2E8F0"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"
                                                           VerticalAlignment="Center"/>

                                                <!-- User/Host -->
                                                <TextBlock Grid.Column="5"
                                                           Text="{Binding Details}"
                                                           Foreground="#94A3B8"
                                                           FontSize="11"
                                                           VerticalAlignment="Center"/>

                                                <!-- Jump to Event Button -->
                                                <Button Grid.Column="6"
                                                        Content="→"
                                                        Background="Transparent"
                                                        Foreground="#64748B"
                                                        Command="{Binding $parent[UserControl].((vm:LogAnalyzerPageViewModel)DataContext).JumpToEventCommand}"
                                                        CommandParameter="{Binding}"
                                                        Padding="8,4"
                                                        FontSize="10"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center"
                                                        ToolTip.Tip="View in graph"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                    
                    <!-- Raw Log Data Preview Section -->
                    <Border Grid.Row="3" Background="#1E293B" BorderBrush="#334155" BorderThickness="0,1,0,0"
                            IsVisible="{Binding HasRawLogData}">
                        <Grid RowDefinitions="Auto,Auto,*">
                            <Border Grid.Row="0" Background="#0F172A" Padding="12,8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Raw Log Data Preview" Foreground="#E2E8F0" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding RawDataRowCount}" Foreground="#64748B" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            
                            <!-- Table Header -->
                            <Border Grid.Row="1" Background="#0F172A" BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="12,8">
                                <Grid ColumnDefinitions="0.5*,1*,1.2*,3*">
                                    <TextBlock Grid.Column="0" Text="Index" Foreground="#94A3B8" FontWeight="SemiBold" FontSize="11"/>
                                    <TextBlock Grid.Column="1" Text="Type" Foreground="#94A3B8" FontWeight="SemiBold" FontSize="11"/>
                                    <TextBlock Grid.Column="2" Text="Timestamp" Foreground="#94A3B8" FontWeight="SemiBold" FontSize="11"/>
                                    <TextBlock Grid.Column="3" Text="Data" Foreground="#94A3B8" FontWeight="SemiBold" FontSize="11"/>
                                </Grid>
                            </Border>
                            
                            <!-- Raw Data List -->
                            <ScrollViewer Grid.Row="2" MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding RawLogMessages}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="12,8">
                                                <Grid ColumnDefinitions="0.5*,1*,1.2*,3*">
                                                    <TextBlock Grid.Column="0" Text="{Binding Index}" Foreground="#94A3B8" FontSize="11"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding TypeName}" Foreground="#E2E8F0" FontSize="11"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Timestamp}" Foreground="#94A3B8" FontSize="11"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding FieldsDisplay}" Foreground="#E2E8F0" FontSize="11" TextWrapping="Wrap"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                    
                    <!-- Pagination Footer -->
                    <Border Grid.Row="4" Background="#1E293B" Padding="16,12" BorderBrush="#334155" BorderThickness="0,1,0,0">
                        <Grid ColumnDefinitions="*,Auto">
                            <!-- Showing X to Y of Z -->
                            <TextBlock Grid.Column="0" 
                                       Text="{Binding EventPagination.DisplayText, FallbackValue='No events loaded'}"
                                       Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
                            
                            <!-- Pagination Controls -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                <Button Classes="PaginationButton" Content="Previous" 
                                        Command="{Binding GoToPreviousEventPageCommand}"
                                        IsEnabled="{Binding EventPagination.CanGoToPreviousPage}"/>
                                
                                <!-- Page Numbers -->
                                <Button Classes="PaginationButton PaginationButtonActive" Content="1" 
                                        IsVisible="{Binding EventPagination.TotalPages, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                
                                <Button Classes="PaginationButton" Content="2" 
                                        IsVisible="{Binding EventPagination.TotalPages, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                
                                <Button Classes="PaginationButton" Content="3" 
                                        IsVisible="{Binding EventPagination.TotalPages, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                
                                <TextBlock Text="..." Foreground="#64748B" VerticalAlignment="Center" Margin="4,0"
                                           IsVisible="{Binding EventPagination.TotalPages, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                
                                <Button Classes="PaginationButton" 
                                        Content="{Binding EventPagination.TotalPages, FallbackValue=1}"
                                        IsVisible="{Binding EventPagination.TotalPages, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                
                                <Button Classes="PaginationButton" Content="Next" 
                                        Command="{Binding GoToNextEventPageCommand}"
                                        IsEnabled="{Binding EventPagination.CanGoToNextPage}"
                                        FontSize="14"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- No Events Placeholder - when log is loaded but no events found -->
                    <Border Grid.Row="2" Background="#0F172A" IsVisible="{Binding ShowNoEventsMessage}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="✓" FontSize="48" Foreground="#22C55E" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                            <TextBlock Text="No events present in this log" Foreground="#64748B" FontSize="18" 
                                       HorizontalAlignment="Center" FontWeight="SemiBold"/>
                            <TextBlock Text="The log file was analyzed but no events, warnings, or errors were detected." 
                                       Foreground="#475569" FontSize="13" 
                                       HorizontalAlignment="Center" Margin="0,8,0,0" TextWrapping="Wrap" MaxWidth="400"/>
                            <TextBlock Text="This may indicate a normal flight with no issues." Foreground="#475569" FontSize="12" 
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- No Log Loaded Placeholder -->
                    <Border Grid.Row="2" Background="#0F172A" IsVisible="{Binding !IsLogLoaded}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="📋" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                            <TextBlock Text="No log file loaded" Foreground="#64748B" FontSize="18" 
                                       HorizontalAlignment="Center" FontWeight="SemiBold"/>
                            <TextBlock Text="Load a log file to view events" Foreground="#475569" FontSize="13" 
                                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            <Button Content="📂 Load Log" Classes="EventsButton" 
                                    Command="{Binding BrowseLocalFileCommand}"
                                    Margin="0,24,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
            
            <!-- PARAMS TAB -->
            <TabItem Header="Parameters">
                <Grid RowDefinitions="Auto,*,Auto" Background="White">
                    <!-- Search Header -->
                    <Border Grid.Row="0" Background="#F8F8F8" Padding="12" BorderBrush="#E1E1E1" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBox Grid.Column="0" Text="{Binding ParameterSearchText}" Watermark="🔍 Search parameters..." 
                                     Width="300" Background="White" Foreground="#333333" BorderThickness="1" 
                                     BorderBrush="#DDDDDD" Padding="8,6" FontSize="12"/>
                            <TextBlock Grid.Column="1" Text="{Binding LogParameters.Count, StringFormat={}{0} parameters from log}" 
                                       Foreground="#666666" FontSize="11" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </Grid>
                    </Border>
                    
                    <!-- Parameters List (replacing DataGrid) -->
                    <Grid Grid.Row="1">
                        <!-- Table Header -->
                        <Border Background="#F8F8F8"
                                BorderBrush="#E1E1E1"
                                BorderThickness="0,0,0,1"
                                Padding="12,10"
                                VerticalAlignment="Top"
                                ZIndex="1">
                            <Grid ColumnDefinitions="1.8*,1*,3*,1.2*,0.7*">
                                <TextBlock Grid.Column="0" Text="Parameter" Foreground="#666666" FontWeight="Bold" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="Value" Foreground="#666666" FontWeight="Bold" FontSize="12"/>
                                <TextBlock Grid.Column="2" Text="Description" Foreground="#666666" FontWeight="Bold" FontSize="12"/>
                                <TextBlock Grid.Column="3" Text="Range" Foreground="#666666" FontWeight="Bold" FontSize="12"/>
                                <TextBlock Grid.Column="4" Text="Units" Foreground="#666666" FontWeight="Bold" FontSize="12"/>
                            </Grid>
                        </Border>

                        <!-- Parameters Scrollable List -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,41,0,0">
                            <ItemsControl ItemsSource="{Binding FilteredLogParameters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="White"
                                                BorderBrush="#E1E1E1"
                                                BorderThickness="0,0,0,1"
                                                Padding="12,10"
                                                Cursor="Hand">
                                            <Border.Styles>
                                                <Style Selector="Border:pointerover">
                                                    <Setter Property="Background" Value="#F5F5F5"/>
                                                </Style>
                                            </Border.Styles>
                                            
                                            <Grid ColumnDefinitions="1.8*,1*,3*,1.2*,0.7*">
                                                <!-- Parameter Name -->
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Name}"
                                                           Foreground="#333333"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>

                                                <!-- Value -->
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding ValueDisplay}"
                                                           Foreground="#007ACC"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>

                                                <!-- Description -->
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Description}"
                                                           Foreground="#666666"
                                                           FontSize="11"
                                                           TextWrapping="Wrap"
                                                           VerticalAlignment="Center"/>

                                                <!-- Range -->
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding Range}"
                                                           Foreground="#888888"
                                                           FontSize="11"
                                                           VerticalAlignment="Center"/>

                                                <!-- Units -->
                                                <TextBlock Grid.Column="4"
                                                           Text="{Binding Units}"
                                                           Foreground="#888888"
                                                           FontSize="11"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                    
                    <!-- Parameter Details Panel -->
                    <Border Grid.Row="2" Background="#F8F8F8" Padding="16" BorderBrush="#E1E1E1" BorderThickness="0,1,0,0"
                            IsVisible="{Binding SelectedLogParameter, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Grid ColumnDefinitions="*,*">
                            <!-- Left: Basic Info -->
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="{Binding SelectedLogParameter.Name}" FontSize="14" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding SelectedLogParameter.Description}" TextWrapping="Wrap" Foreground="#666666" FontSize="11" Margin="0,0,0,12"/>
                                <StackPanel Orientation="Horizontal" Spacing="20">
                                    <StackPanel>
                                        <TextBlock Text="Value" Foreground="#888888" FontSize="10"/>
                                        <TextBlock Text="{Binding SelectedLogParameter.ValueDisplay}" Foreground="#333333" FontSize="12" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Range" Foreground="#888888" FontSize="10"/>
                                        <TextBlock Text="{Binding SelectedLogParameter.Range}" Foreground="#333333" FontSize="11"/>
                                    </StackPanel>
                                    <StackPanel IsVisible="{Binding SelectedLogParameter.Units, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                        <TextBlock Text="Units" Foreground="#888888" FontSize="10"/>
                                        <TextBlock Text="{Binding SelectedLogParameter.Units}" Foreground="#333333" FontSize="11"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Group" Foreground="#888888" FontSize="10"/>
                                        <TextBlock Text="{Binding SelectedLogParameter.Group}" Foreground="#333333" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                            
                            <!-- Right: Options -->
                            <Border Grid.Column="1" Background="White" Padding="12" CornerRadius="4" BorderBrush="#DDDDDD" BorderThickness="1"
                                    IsVisible="{Binding SelectedLogParameter.HasOptions}">
                                <StackPanel>
                                    <TextBlock Text="Valid Options" Foreground="#666666" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <ScrollViewer MaxHeight="120">
                                        <ItemsControl ItemsSource="{Binding SelectedLogParameter.OptionsDisplay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" Foreground="#333333" FontSize="10" Margin="0,2"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- STATUS BAR -->
        <Border Grid.Row="2" Background="#007ACC" Padding="12,6">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Foreground="White" FontSize="12"/>
                <ProgressBar Grid.Column="1" Value="{Binding LoadProgress}" Maximum="100" Width="120" Height="6" 
                             IsVisible="{Binding IsAnalyzing}" Margin="12,0,0,0" />
            </Grid>
        </Border>

        <!-- DOWNLOAD DIALOG OVERLAY -->
        <Border Grid.RowSpan="3" Background="#CC000000" IsVisible="{Binding IsDownloadDialogOpen}">
            <Border Background="White" MaxWidth="900" MaxHeight="600" Padding="24"
                    HorizontalAlignment="Center" VerticalAlignment="Center" BorderBrush="#DDDDDD" BorderThickness="1">
                <Grid RowDefinitions="Auto,Auto,*,Auto">
                    <TextBlock Grid.Row="0" Text="Log Files on Flight Controller" Foreground="#333333" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
                    
                    <!-- Table Header -->
                    <Border Grid.Row="1" Background="#F8F8F8" BorderBrush="#E1E1E1" BorderThickness="0,0,0,1" Padding="12,10">
                        <Grid ColumnDefinitions="0.4*,0.5*,3*,1*">
                            <TextBlock Grid.Column="0" Text="" Foreground="#666666" FontWeight="Bold" FontSize="12"/>
                            <TextBlock Grid.Column="1" Text="ID" Foreground="#666666" FontWeight="Bold" FontSize="12"/>
                            <TextBlock Grid.Column="2" Text="File Name" Foreground="#666666" FontWeight="Bold" FontSize="12"/>
                            <TextBlock Grid.Column="3" Text="Size" Foreground="#666666" FontWeight="Bold" FontSize="12"/>
                        </Grid>
                    </Border>
                    
                    <!-- Log Files List -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding LogFiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White"
                                            BorderBrush="#E1E1E1"
                                            BorderThickness="0,0,0,1"
                                            Padding="12,10"
                                            Cursor="Hand">
                                        <Border.Styles>
                                            <Style Selector="Border:pointerover">
                                                <Setter Property="Background" Value="#F5F5F5"/>
                                            </Style>
                                        </Border.Styles>
                                        
                                        <Grid ColumnDefinitions="0.4*,0.5*,3*,1*">
                                            <!-- Checkbox -->
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsSelected}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"/>

                                            <!-- Log ID -->
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding LogId}"
                                                       Foreground="#333333"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"/>

                                            <!-- File Name -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding FileName}"
                                                       Foreground="#333333"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>

                                            <!-- File Size -->
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding FileSizeDisplay}"
                                                       Foreground="#666666"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12" Margin="0,16,0,0">
                        <Button Classes="ToolbarButton" Content="Cancel" Width="120" Command="{Binding CloseDownloadDialogCommand}"/>
                        <Button Classes="ToolbarButton" Content="Refresh" Width="120" Command="{Binding RefreshLogsCommand}"/>
                        <Button Classes="ToolbarButton" Content="Download" Width="120" Command="{Binding DownloadSelectedCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
        
        <!-- SINGLE LOADING OVERLAY (replaces both previous overlays) -->
        <Border Grid.RowSpan="3" 
                Background="#E6F8FAFC" 
                IsVisible="{Binding IsBusy}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" 
                        HorizontalAlignment="Center"
                        Spacing="16">
                <!-- Modern Spinner -->
                <controls:LoadingSpinner/>
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="14"
                           Foreground="#475569"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           MaxWidth="300"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
