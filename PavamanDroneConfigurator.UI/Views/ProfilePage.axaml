<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels"
             xmlns:converters="using:PavamanDroneConfigurator.UI.Converters"
             x:Class="PavamanDroneConfigurator.UI.Views.ProfilePage"
             x:DataType="vm:ProfilePageViewModel">

    <UserControl.Styles>
        <!-- Profile Card Styles -->
        <Style Selector="Border.profile-card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BoxShadow" Value="0 2 8 0 #10000000"/>
            <Setter Property="Padding" Value="24"/>
        </Style>

        <Style Selector="TextBlock.profile-header">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#111827"/>
        </Style>

        <Style Selector="TextBlock.profile-label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#6B7280"/>
        </Style>

        <Style Selector="TextBlock.profile-value">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <Style Selector="Border.status-badge">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style Selector="Border.status-approved">
            <Setter Property="Background" Value="#DCFCE7"/>
        </Style>

        <Style Selector="Border.status-pending">
            <Setter Property="Background" Value="#FEF3C7"/>
        </Style>

        <Style Selector="Border.role-badge">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style Selector="Border.role-admin">
            <Setter Property="Background" Value="#DBEAFE"/>
        </Style>

        <Style Selector="Border.role-user">
            <Setter Property="Background" Value="#F3F4F6"/>
        </Style>

        <Style Selector="Button.logout-button">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.logout-button:pointerover">
            <Setter Property="Background" Value="#DC2626"/>
        </Style>

        <Style Selector="Button.logout-button:disabled">
            <Setter Property="Background" Value="#9CA3AF"/>
            <Setter Property="Cursor" Value="Default"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="24" MaxWidth="1200">
            <!-- Header -->
            <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,32">
                <TextBlock Text="?? Profile &amp; Settings"
                           Classes="profile-header"/>
                <TextBlock Text="Manage your account and preferences"
                           FontSize="14"
                           Foreground="#6B7280"/>
            </StackPanel>

            <!-- User Profile Card -->
            <Border Grid.Row="1" Classes="profile-card" Margin="0,0,0,24">
                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                    <!-- Profile Header with Avatar -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,24">
                        <!-- Avatar Circle -->
                        <Border Width="80" Height="80" 
                                CornerRadius="40" 
                                Background="#3B82F6"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding UserFullName, Converter={x:Static converters:InitialsConverter.Instance}}"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Name and Email -->
                        <StackPanel VerticalAlignment="Center" Spacing="4">
                            <TextBlock Text="{Binding UserFullName}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#111827"/>
                            <TextBlock Text="{Binding UserEmail}"
                                       FontSize="14"
                                       Foreground="#6B7280"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Logout Button -->
                    <Button Grid.Row="0" Grid.Column="1"
                            Classes="logout-button"
                            Content="?? Logout"
                            Command="{Binding LogoutCommand}"
                            IsEnabled="{Binding !IsLoggingOut}"
                            VerticalAlignment="Top"/>

                    <!-- Divider -->
                    <Border Grid.Row="1" Grid.ColumnSpan="2" 
                            Height="1" 
                            Background="#E5E7EB" 
                            Margin="0,0,0,24"/>

                    <!-- User Details Grid -->
                    <Grid Grid.Row="2" Grid.ColumnSpan="2" 
                          RowDefinitions="Auto,Auto,Auto,Auto"
                          ColumnDefinitions="*,*,*">
                        
                        <!-- Role -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="8" Margin="0,0,16,24">
                            <TextBlock Text="Role" Classes="profile-label"/>
                            <Border Classes="role-badge"
                                    Classes.role-admin="{Binding IsAdmin}"
                                    Classes.role-user="{Binding !IsAdmin}">
                                <TextBlock Text="{Binding UserRole}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#111827"/>
                            </Border>
                        </StackPanel>

                        <!-- Status -->
                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="8" Margin="0,0,16,24">
                            <TextBlock Text="Account Status" Classes="profile-label"/>
                            <Border Classes="status-badge"
                                    Classes.status-approved="{Binding UserStatus, Converter={x:Static converters:StringContainsConverter.Instance}, ConverterParameter=Approved}"
                                    Classes.status-pending="{Binding UserStatus, Converter={x:Static converters:StringContainsConverter.Instance}, ConverterParameter=Pending}">
                                <TextBlock Text="{Binding UserStatus}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding UserStatus, Converter={x:Static converters:StatusColorConverter.Instance}}"/>
                            </Border>
                        </StackPanel>

                        <!-- Account Created -->
                        <StackPanel Grid.Row="0" Grid.Column="2" Spacing="8" Margin="0,0,0,24">
                            <TextBlock Text="Member Since" Classes="profile-label"/>
                            <TextBlock Text="{Binding AccountCreatedDate}"
                                       Classes="profile-value"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Configuration Profiles Section -->
            <Border Grid.Row="2" Classes="profile-card" Margin="0,0,0,24">
                <Grid RowDefinitions="Auto,Auto,*,Auto">
                    <!-- Section Header -->
                    <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,20">
                        <TextBlock Text="?? Configuration Profiles"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#111827"/>
                        <TextBlock Text="Save and manage drone configuration profiles"
                                   FontSize="13"
                                   Foreground="#6B7280"/>
                    </StackPanel>

                    <!-- Toolbar -->
                    <Border Grid.Row="1"
                            Background="#F9FAFB"
                            Padding="12"
                            CornerRadius="8"
                            Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button Content="?? Refresh Profiles" 
                                    Command="{Binding LoadProfilesCommand}"
                                    Background="#3B82F6"
                                    Foreground="White"
                                    CornerRadius="6"
                                    Padding="12,8"
                                    BorderThickness="0"
                                    Cursor="Hand"/>
                            <TextBlock Text="{Binding StatusMessage}" 
                                       VerticalAlignment="Center"
                                       Foreground="#6B7280"
                                       FontSize="13"/>
                        </StackPanel>
                    </Border>

                    <!-- Profiles List -->
                    <ListBox Grid.Row="2" 
                             ItemsSource="{Binding Profiles}" 
                             SelectedItem="{Binding SelectedProfile}"
                             Background="Transparent"
                             BorderThickness="1"
                             BorderBrush="#E5E7EB"
                             CornerRadius="8"
                             Padding="8"
                             MinHeight="200"
                             Margin="0,0,0,16">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,8"
                                        CornerRadius="6"
                                        Background="Transparent">
                                    <TextBlock Text="{Binding}"
                                               FontSize="14"
                                               Foreground="#111827"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- New Profile Section -->
                    <Border Grid.Row="3"
                            Background="#F9FAFB"
                            Padding="16"
                            CornerRadius="8">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Create New Profile" 
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"/>
                            <TextBox Text="{Binding NewProfileName}"
                                     Watermark="Enter profile name..."
                                     Padding="12"
                                     CornerRadius="6"
                                     BorderBrush="#D1D5DB"
                                     BorderThickness="1"/>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Button Content="?? Save Profile" 
                                        Command="{Binding SaveProfileCommand}"
                                        Background="#10B981"
                                        Foreground="White"
                                        CornerRadius="6"
                                        Padding="16,10"
                                        BorderThickness="0"
                                        Cursor="Hand"/>
                                <Button Content="?? Load Selected" 
                                        Command="{Binding LoadProfileCommand}"
                                        Background="#3B82F6"
                                        Foreground="White"
                                        CornerRadius="6"
                                        Padding="16,10"
                                        BorderThickness="0"
                                        Cursor="Hand"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- CRM-Style Admin Panel Section (Only visible for admins) -->
            <Border Grid.Row="3" 
                    IsVisible="{Binding IsAdmin}"
                    Background="White"
                    CornerRadius="16"
                    BoxShadow="0 4 16 0 #10000000"
                    Padding="32"
                    Margin="0,0,0,24">
                <Grid RowDefinitions="Auto,Auto,Auto,*">
                    <!-- CRM Header -->
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,24">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="👥 User Management CRM"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#111827"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="Manage users, roles, and access control"
                                       FontSize="14"
                                       Foreground="#6B7280"/>
                        </StackPanel>
                        
                        <!-- Action Buttons -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                            <Button Content="🔄 Refresh"
                                    Command="{Binding AdminPanel.RefreshCommand}"
                                    Background="#3B82F6"
                                    Foreground="White"
                                    CornerRadius="8"
                                    Padding="16,10"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    BorderThickness="0"
                                    Cursor="Hand"/>
                        </StackPanel>
                    </Grid>

                    <!-- CRM Statistics Cards -->
                    <Grid Grid.Row="1" ColumnDefinitions="*,*,*" Margin="0,0,0,24">
                        <!-- Total Users Card -->
                        <Border Grid.Column="0" 
                                Background="#F0F9FF"
                                CornerRadius="12"
                                Padding="20"
                                Margin="0,0,8,0">
                            <StackPanel Spacing="8">
                                <TextBlock Text="👤 TOTAL USERS"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#0369A1"/>
                                <TextBlock Text="{Binding AdminPanel.TotalCount}"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="#0C4A6E"/>
                                <TextBlock Text="registered accounts"
                                           FontSize="12"
                                           Foreground="#0369A1"/>
                            </StackPanel>
                        </Border>

                        <!-- Pending Approvals Card -->
                        <Border Grid.Column="1" 
                                Background="#FEF3C7"
                                CornerRadius="12"
                                Padding="20"
                                Margin="4,0">
                            <StackPanel Spacing="8">
                                <TextBlock Text="⏳ PENDING APPROVAL"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#D97706"/>
                                <TextBlock Text="{Binding AdminPanel.PendingCount}"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="#92400E"/>
                                <TextBlock Text="awaiting review"
                                           FontSize="12"
                                           Foreground="#D97706"/>
                            </StackPanel>
                        </Border>

                        <!-- Active Users Card -->
                        <Border Grid.Column="2" 
                                Background="#DCFCE7"
                                CornerRadius="12"
                                Padding="20"
                                Margin="8,0,0,0">
                            <StackPanel Spacing="8">
                                <TextBlock Text="✓ ACTIVE USERS"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#16A34A"/>
                                <TextBlock FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="#166534">
                                    <Run Text="{Binding AdminPanel.TotalCount}"/>
                                    <Run Text="-" FontSize="24"/>
                                    <Run Text="{Binding AdminPanel.PendingCount}"/>
                                </TextBlock>
                                <TextBlock Text="approved accounts"
                                           FontSize="12"
                                           Foreground="#16A34A"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Status Bar -->
                    <Border Grid.Row="2"
                            Background="#F9FAFB"
                            CornerRadius="8"
                            Padding="16,12"
                            Margin="0,0,0,16">
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Grid.Column="0"
                                       Text="📊 Status:"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#374151"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding AdminPanel.StatusMessage}"
                                       FontSize="13"
                                       Foreground="#6B7280"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- CRM Data Table -->
                    <Border Grid.Row="3"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="12"
                            Background="#FAFAFA"
                            ClipToBounds="True">
                        <Grid RowDefinitions="Auto,*">
                            <!-- Table Header (Fixed) -->
                            <Border Grid.Row="0"
                                    Background="#F3F4F6"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="0,0,0,2">
                                <Grid ColumnDefinitions="40,200,260,120,140,140,*"
                                      Height="48"
                                      Margin="0">
                                    <TextBlock Grid.Column="0" 
                                               Text="#" 
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="#6B7280"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" 
                                               Text="FULL NAME" 
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="#6B7280"
                                               VerticalAlignment="Center"
                                               Margin="16,0"/>
                                    <TextBlock Grid.Column="2" 
                                               Text="EMAIL ADDRESS" 
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="#6B7280"
                                               VerticalAlignment="Center"
                                               Margin="16,0"/>
                                    <TextBlock Grid.Column="3" 
                                               Text="STATUS" 
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="#6B7280"
                                               VerticalAlignment="Center"
                                               Margin="16,0"/>
                                    <TextBlock Grid.Column="4" 
                                               Text="ROLE" 
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="#6B7280"
                                               VerticalAlignment="Center"
                                               Margin="16,0"/>
                                    <TextBlock Grid.Column="5" 
                                               Text="CREATED" 
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="#6B7280"
                                               VerticalAlignment="Center"
                                               Margin="16,0"/>
                                    <TextBlock Grid.Column="6" 
                                               Text="ACTIONS" 
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="#6B7280"
                                               VerticalAlignment="Center"
                                               Margin="16,0"/>
                                </Grid>
                            </Border>

                            <!-- Scrollable User List -->
                            <ScrollViewer Grid.Row="1" 
                                          MaxHeight="500"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding AdminPanel.Users}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="White"
                                                    BorderBrush="#E5E7EB"
                                                    BorderThickness="0,0,0,1">
                                                <Border.Styles>
                                                    <Style Selector="Border:pointerover">
                                                        <Setter Property="Background" Value="#F9FAFB"/>
                                                    </Style>
                                                </Border.Styles>
                                                <Grid ColumnDefinitions="40,200,260,120,140,140,*"
                                                      MinHeight="64"
                                                      Margin="0">
                                                    
                                                    <!-- Row Number -->
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Id}"
                                                               FontSize="12"
                                                               Foreground="#9CA3AF"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"/>

                                                    <!-- Full Name with Avatar -->
                                                    <StackPanel Grid.Column="1" 
                                                                Orientation="Horizontal" 
                                                                Spacing="12"
                                                                VerticalAlignment="Center"
                                                                Margin="16,0">
                                                        <Border Width="36" Height="36"
                                                                CornerRadius="18"
                                                                Background="#3B82F6">
                                                            <TextBlock Text="{Binding FullName, Converter={x:Static converters:InitialsConverter.Instance}}"
                                                                       FontSize="12"
                                                                       FontWeight="Bold"
                                                                       Foreground="White"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding FullName}"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#111827"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>

                                                    <!-- Email -->
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding Email}"
                                                               FontSize="13"
                                                               Foreground="#6B7280"
                                                               VerticalAlignment="Center"
                                                               Margin="16,0"/>

                                                    <!-- Status Badge -->
                                                    <Border Grid.Column="3"
                                                            CornerRadius="6"
                                                            Padding="10,6"
                                                            Margin="16,0,0,0"
                                                            Width="100"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Center"
                                                            Background="{Binding IsApproved, Converter={x:Static converters:AdminPanelConverters.StatusBackgroundConverter}}">
                                                        <TextBlock Text="{Binding StatusText}"
                                                                   FontSize="11"
                                                                   FontWeight="Bold"
                                                                   Foreground="{Binding StatusColor}"
                                                                   HorizontalAlignment="Center"/>
                                                    </Border>

                                                    <!-- Role Dropdown -->
                                                    <ComboBox Grid.Column="4"
                                                              ItemsSource="{Binding AvailableRoles}"
                                                              SelectedItem="{Binding SelectedRole}"
                                                              VerticalAlignment="Center"
                                                              Margin="16,0"
                                                              Padding="10,6"
                                                              FontSize="13"
                                                              BorderBrush="#D1D5DB"
                                                              Background="White"/>

                                                    <!-- Created Date -->
                                                    <TextBlock Grid.Column="5"
                                                               Text="{Binding CreatedAt, StringFormat='{}{0:MMM dd, yyyy}'}"
                                                               FontSize="13"
                                                               Foreground="#6B7280"
                                                               VerticalAlignment="Center"
                                                               Margin="16,0"/>

                                                    <!-- Action Buttons -->
                                                    <StackPanel Grid.Column="6"
                                                                Orientation="Horizontal"
                                                                Spacing="8"
                                                                VerticalAlignment="Center"
                                                                Margin="16,0">
                                                        <!-- Approve/Revoke Button -->
                                                        <Button Content="{Binding ApprovalButtonText}"
                                                                Command="{Binding $parent[ItemsControl].((vm:ProfilePageViewModel)DataContext).AdminPanel.ApproveUserCommand}"
                                                                CommandParameter="{Binding}"
                                                                Padding="12,8"
                                                                FontSize="12"
                                                                FontWeight="SemiBold"
                                                                CornerRadius="6"
                                                                BorderThickness="0"
                                                                Cursor="Hand"
                                                                MinWidth="85"
                                                                Background="{Binding IsApproved, Converter={x:Static converters:AdminPanelConverters.ApprovalButtonColorConverter}}"
                                                                Foreground="White"/>

                                                        <!-- Update Role Button -->
                                                        <Button Content="💾 Save"
                                                                Command="{Binding $parent[ItemsControl].((vm:ProfilePageViewModel)DataContext).AdminPanel.UpdateRoleCommand}"
                                                                CommandParameter="{Binding}"
                                                                Background="#2196F3"
                                                                Foreground="White"
                                                                Padding="12,8"
                                                                FontSize="12"
                                                                FontWeight="SemiBold"
                                                                CornerRadius="6"
                                                                BorderThickness="0"
                                                                Cursor="Hand"
                                                                MinWidth="75"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
