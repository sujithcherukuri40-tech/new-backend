<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels"
             x:Class="PavamanDroneConfigurator.UI.Views.ProfilePage"
             x:DataType="vm:ProfilePageViewModel"
             Background="{DynamicResource BackgroundBrush}">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="{DynamicResource PagePadding}" MaxWidth="800" Spacing="24">
            
            <!-- PAGE HEADER -->
            <StackPanel Spacing="8">
                <TextBlock Text="Profile &amp; Settings" Classes="page-title"/>
                <TextBlock Text="Manage your account and preferences" Classes="page-subtitle"/>
            </StackPanel>

            <!-- USER INFO CARD -->
            <Border Classes="card-elevated">
                <StackPanel Spacing="20">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <!-- User Avatar -->
                        <Border Width="64" Height="64" 
                                CornerRadius="{DynamicResource RadiusFull}"
                                Background="{DynamicResource PrimaryBrush}">
                            <TextBlock Text="{Binding UserInitials, FallbackValue=U}" 
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="4">
                            <TextBlock Text="{Binding UserFullName}" 
                                       FontSize="{DynamicResource FontSizeXL}"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding UserEmail}" 
                                       FontSize="{DynamicResource FontSizeBase}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <Border Height="1" Background="{DynamicResource DividerBrush}"/>
                    
                    <!-- User Details Grid -->
                    <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto" 
                          RowSpacing="16" ColumnSpacing="24">
                        
                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                            <TextBlock Text="Role" Classes="caption"/>
                            <Border Classes="badge-info" HorizontalAlignment="Left">
                                <TextBlock Text="{Binding UserRole}" 
                                           FontSize="{DynamicResource FontSizeSM}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryBrush}"/>
                            </Border>
                        </StackPanel>
                        
                        <StackPanel Grid.Row="0" Grid.Column="2" Spacing="2">
                            <TextBlock Text="Status" Classes="caption"/>
                            <Border Classes="badge-success" HorizontalAlignment="Left">
                                <TextBlock Text="{Binding UserStatus}" 
                                           FontSize="{DynamicResource FontSizeSM}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SuccessDarkBrush}"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Logout Button -->
                    <Button Content="Logout"
                            Classes="btn-danger"
                            HorizontalAlignment="Left"
                            Command="{Binding LogoutCommand}"
                            IsEnabled="{Binding CanLogout}"/>
                </StackPanel>
            </Border>

            <!-- CONFIGURATION PROFILES CARD -->
            <Border Classes="card">
                <StackPanel Spacing="20">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Configuration Profiles" Classes="section-title" Margin="0"/>
                            <TextBlock Text="Save and load drone configuration profiles" Classes="caption"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Refresh"
                                Classes="btn-secondary"
                                Padding="16,10"
                                Command="{Binding LoadProfilesCommand}"/>
                    </Grid>
                    
                    <!-- Status Message -->
                    <Border Classes="alert-info" IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="{Binding StatusMessage}" 
                                   FontSize="{DynamicResource FontSizeBase}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Border>
                    
                    <!-- Empty State -->
                    <Border Background="{DynamicResource SecondaryLightBrush}"
                            CornerRadius="{DynamicResource RadiusBase}"
                            Padding="32"
                            HorizontalAlignment="Stretch">
                        <StackPanel Spacing="12" HorizontalAlignment="Center">
                            <Border Width="48" Height="48" 
                                    CornerRadius="24" 
                                    Background="{DynamicResource PrimaryLightBrush}"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="-" 
                                           FontSize="24" 
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryBrush}"
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="No profiles found" 
                                       FontSize="{DynamicResource FontSizeMD}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Connect to a drone to save configuration profiles" 
                                       FontSize="{DynamicResource FontSizeSM}"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- APPLICATION SETTINGS CARD -->
            <Border Classes="card">
                <StackPanel Spacing="16">
                    <TextBlock Text="Application Settings" Classes="section-title"/>
                    
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="16">
                        <!-- Theme Setting -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                            <TextBlock Text="Theme" Classes="body" FontWeight="SemiBold"/>
                            <TextBlock Text="Choose your preferred color theme" Classes="caption"/>
                        </StackPanel>
                        <ComboBox Grid.Row="0" Grid.Column="1" 
                                  Classes="input"
                                  Width="160"
                                  SelectedIndex="0">
                            <ComboBoxItem>Light</ComboBoxItem>
                            <ComboBoxItem>Dark</ComboBoxItem>
                            <ComboBoxItem>System</ComboBoxItem>
                        </ComboBox>
                        
                        <!-- Auto-connect Setting -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2">
                            <TextBlock Text="Auto-connect" Classes="body" FontWeight="SemiBold"/>
                            <TextBlock Text="Automatically connect to last used drone" Classes="caption"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Row="1" Grid.Column="1" 
                                      IsChecked="{Binding EnableAutoConnect}"
                                      OnContent="On" 
                                      OffContent="Off"/>
                        
                        <!-- Telemetry Logging -->
                        <StackPanel Grid.Row="2" Grid.Column="0" Spacing="2">
                            <TextBlock Text="Telemetry Logging" Classes="body" FontWeight="SemiBold"/>
                            <TextBlock Text="Save telemetry data for analysis" Classes="caption"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Row="2" Grid.Column="1" 
                                      IsChecked="{Binding EnableTelemetryLogging}"
                                      OnContent="On" 
                                      OffContent="Off"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Bottom Spacing -->
            <Panel Height="24"/>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>
