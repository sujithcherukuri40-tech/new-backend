<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels"
             x:Class="PavamanDroneConfigurator.UI.Views.ProfilePage"
             x:DataType="vm:ProfilePageViewModel"
             Background="#F9FAFB">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32" MaxWidth="800" Spacing="24">
            
            <!-- Header -->
            <StackPanel Spacing="8">
                <TextBlock Text="Profile &amp; Settings"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#111827"/>
                <TextBlock Text="Manage your account and preferences"
                           FontSize="14"
                           Foreground="#6B7280"/>
            </StackPanel>

            <!-- User Info Card -->
            <Border Background="White" 
                    CornerRadius="12" 
                    Padding="24"
                    BoxShadow="0 2 8 0 #10000000">
                <StackPanel Spacing="16">
                    
                    <!-- User Details -->
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="12" ColumnSpacing="16">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" FontWeight="SemiBold" Foreground="#6B7280"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding UserFullName}" Foreground="#111827"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Email:" FontWeight="SemiBold" Foreground="#6B7280"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding UserEmail}" Foreground="#111827"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Role:" FontWeight="SemiBold" Foreground="#6B7280"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding UserRole}" Foreground="#111827"/>
                        
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Status:" FontWeight="SemiBold" Foreground="#6B7280"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding UserStatus}" Foreground="#111827"/>
                    </Grid>
                    
                    <!-- Logout Button -->
                    <Button Content="Logout"
                            Background="#EF4444"
                            Foreground="White"
                            Padding="24,12"
                            CornerRadius="8"
                            HorizontalAlignment="Left"
                            Command="{Binding LogoutCommand}"
                            IsEnabled="{Binding CanLogout}"/>
                </StackPanel>
            </Border>

            <!-- Configuration Profiles Card -->
            <Border Background="White" 
                    CornerRadius="12" 
                    Padding="24"
                    BoxShadow="0 2 8 0 #10000000">
                <StackPanel Spacing="16">
                    <TextBlock Text="Configuration Profiles"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#111827"/>
                    
                    <Button Content="Refresh Profiles"
                            Background="#3B82F6"
                            Foreground="White"
                            Padding="16,10"
                            CornerRadius="6"
                            HorizontalAlignment="Left"
                            Command="{Binding LoadProfilesCommand}"/>
                    
                    <TextBlock Text="{Binding StatusMessage}" 
                               Foreground="#6B7280"
                               FontSize="13"/>
                </StackPanel>
            </Border>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>
