<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels.Admin"
             x:Class="PavamanDroneConfigurator.UI.Views.Admin.ParamLogsPage"
             x:DataType="vm:ParamLogsViewModel">

    <UserControl.Styles>
        <!-- Card Style -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
        </Style>
        
        <!-- Filter Card -->
        <Style Selector="Border.filter-card">
            <Setter Property="Background" Value="{DynamicResource SurfaceLightBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        
        <!-- Log Row -->
        <Style Selector="Button.log-row">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <Style Selector="Button.log-row:pointerover">
            <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
        </Style>
        
        <!-- Action Button -->
        <Style Selector="Button.action-btn">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <Style Selector="Button.action-btn-secondary">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource BackgroundBrush}">
        
        <!-- Header -->
        <Border Grid.Row="0" Padding="32,24">
            <StackPanel Spacing="8">
                <TextBlock Text="?? Parameter Change Logs"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryBrush}"/>
                <TextBlock Text="View and filter parameter changes made by users"
                           FontSize="14"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
        
        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" Padding="32,0,32,24">
            <Grid ColumnDefinitions="*,400" ColumnSpacing="24">
                
                <!-- Left: Log List -->
                <StackPanel Grid.Column="0" Spacing="20">
                    
                    <!-- Filter Card -->
                    <Border Classes="filter-card">
                        <Grid RowDefinitions="Auto,Auto" RowSpacing="16">
                            
                            <!-- Filter Title -->
                            <TextBlock Grid.Row="0"
                                       Text="?? Filters"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            
                            <!-- Filter Controls -->
                            <Grid Grid.Row="1" 
                                  ColumnDefinitions="*,*,*,*,Auto,Auto" 
                                  ColumnSpacing="12">
                                
                                <!-- User Filter -->
                                <StackPanel Grid.Column="0" Spacing="6">
                                    <TextBlock Text="User" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <ComboBox ItemsSource="{Binding AvailableUsers}"
                                              SelectedItem="{Binding SelectedUserId}"
                                              MinWidth="140"
                                              CornerRadius="6"
                                              PlaceholderText="All Users"/>
                                </StackPanel>
                                
                                <!-- Drone Filter -->
                                <StackPanel Grid.Column="1" Spacing="6">
                                    <TextBlock Text="Drone ID" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <ComboBox ItemsSource="{Binding AvailableDrones}"
                                              SelectedItem="{Binding SelectedDroneId}"
                                              MinWidth="140"
                                              CornerRadius="6"
                                              PlaceholderText="All Drones"/>
                                </StackPanel>
                                
                                <!-- From Date -->
                                <StackPanel Grid.Column="2" Spacing="6">
                                    <TextBlock Text="From Date" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <CalendarDatePicker SelectedDate="{Binding FromDate}"
                                                        MinWidth="140"/>
                                </StackPanel>
                                
                                <!-- To Date -->
                                <StackPanel Grid.Column="3" Spacing="6">
                                    <TextBlock Text="To Date" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <CalendarDatePicker SelectedDate="{Binding ToDate}"
                                                        MinWidth="140"/>
                                </StackPanel>
                                
                                <!-- Apply Button -->
                                <Button Grid.Column="4"
                                        Classes="action-btn"
                                        Command="{Binding ApplyFiltersCommand}"
                                        VerticalAlignment="Bottom"
                                        Content="Apply"/>
                                
                                <!-- Clear Button -->
                                <Button Grid.Column="5"
                                        Classes="action-btn-secondary"
                                        Command="{Binding ClearFiltersCommand}"
                                        VerticalAlignment="Bottom"
                                        Content="Clear"/>
                            </Grid>
                        </Grid>
                    </Border>
                    
                    <!-- Status Bar -->
                    <Border Background="{DynamicResource InfoLightBrush}"
                            BorderBrush="{DynamicResource InfoBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16,10"
                            IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Border>
                    
                    <!-- Loading State -->
                    <Border Classes="card"
                            IsVisible="{Binding IsLoading}">
                        <StackPanel Spacing="16" HorizontalAlignment="Center" Margin="40">
                            <TextBlock Text="Loading parameter logs..."
                                       FontSize="16"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Empty State -->
                    <Border Classes="card"
                            IsVisible="{Binding HasNoLogs}">
                        <StackPanel Spacing="16" HorizontalAlignment="Center" Margin="40">
                            <TextBlock Text="??"
                                       FontSize="48"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="No Parameter Logs Found"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Parameter changes will appear here when users modify drone parameters."
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       MaxWidth="400"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Log List -->
                    <Border Classes="card"
                            IsVisible="{Binding !HasNoLogs}"
                            Padding="0">
                        <StackPanel>
                            <!-- Header Row -->
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    Padding="16,12"
                                    CornerRadius="12,12,0,0">
                                <Grid ColumnDefinitions="*,120,120,120,80">
                                    <TextBlock Grid.Column="0" Text="User" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="Drone ID" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="2" Text="Date" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="3" Text="Time" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="4" Text="Size" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </Grid>
                            </Border>
                            
                            <!-- Log Items -->
                            <ItemsControl ItemsSource="{Binding ParamLogs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Classes="log-row"
                                                Command="{Binding $parent[ItemsControl].((vm:ParamLogsViewModel)DataContext).ViewLogCommand}"
                                                CommandParameter="{Binding}">
                                            <Grid ColumnDefinitions="*,120,120,120,80">
                                                <!-- User -->
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                                    <Border Background="{DynamicResource PrimaryLightBrush}"
                                                            CornerRadius="4"
                                                            Padding="6,3">
                                                        <TextBlock Text="??" FontSize="12"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding UserId}"
                                                               FontWeight="Medium"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                </StackPanel>
                                                
                                                <!-- Drone ID -->
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding DroneId}"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                
                                                <!-- Date -->
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd}'}"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                
                                                <!-- Time -->
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextMutedBrush}"/>
                                                
                                                <!-- Size -->
                                                <TextBlock Grid.Column="4"
                                                           Text="{Binding SizeDisplay}"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextMutedBrush}"/>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            
                            <!-- Pagination -->
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    Padding="16,12"
                                    CornerRadius="0,0,12,12">
                                <Grid ColumnDefinitions="*,Auto,*">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding TotalCount, StringFormat='Total: {0} log(s)'}"
                                               VerticalAlignment="Center"
                                               FontSize="13"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                        <Button Content="? Previous"
                                                Classes="action-btn-secondary"
                                                Command="{Binding PreviousPageCommand}"
                                                IsEnabled="{Binding HasPreviousPage}"
                                                Padding="12,8"/>
                                        <TextBlock Text="{Binding CurrentPage, StringFormat='Page {0}'}"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Margin="8,0"/>
                                        <TextBlock Text="{Binding TotalPages, StringFormat='of {0}'}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <Button Content="Next ?"
                                                Classes="action-btn-secondary"
                                                Command="{Binding NextPageCommand}"
                                                IsEnabled="{Binding HasNextPage}"
                                                Padding="12,8"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
                <!-- Right: Log Details Panel -->
                <Border Grid.Column="1"
                        Classes="card"
                        IsVisible="{Binding HasSelectedLog}">
                    <StackPanel Spacing="16">
                        <!-- Header -->
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="?? Log Details"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding SelectedLog.FileName}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="?"
                                    Background="Transparent"
                                    Foreground="{DynamicResource TextMutedBrush}"
                                    Padding="8"
                                    Command="{Binding CloseLogDetailsCommand}"/>
                        </Grid>
                        
                        <!-- Log Info -->
                        <Border Background="{DynamicResource SurfaceBrush}"
                                CornerRadius="8"
                                Padding="12">
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="80,*">
                                    <TextBlock Text="User:" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SelectedLog.UserId}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </Grid>
                                <Grid ColumnDefinitions="80,*">
                                    <TextBlock Text="Drone:" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SelectedLog.DroneId}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </Grid>
                                <Grid ColumnDefinitions="80,*">
                                    <TextBlock Text="Time:" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SelectedLog.TimestampDisplay}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        
                        <!-- Download Button -->
                        <Button Classes="action-btn"
                                HorizontalAlignment="Stretch"
                                Command="{Binding DownloadLogCommand}"
                                CommandParameter="{Binding SelectedLog}">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <TextBlock Text="?" FontSize="14"/>
                                <TextBlock Text="Download CSV"/>
                            </StackPanel>
                        </Button>
                        
                        <!-- Changes List -->
                        <TextBlock Text="Parameter Changes"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Margin="0,8,0,0"/>
                        
                        <!-- Loading Content -->
                        <TextBlock Text="Loading..."
                                   IsVisible="{Binding IsLoadingContent}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   HorizontalAlignment="Center"/>
                        
                        <!-- Changes Table -->
                        <Border Background="{DynamicResource SurfaceBrush}"
                                CornerRadius="8"
                                Padding="0"
                                IsVisible="{Binding !IsLoadingContent}">
                            <StackPanel>
                                <!-- Header -->
                                <Border Background="{DynamicResource SecondaryLightBrush}"
                                        Padding="12,8"
                                        CornerRadius="8,8,0,0">
                                    <Grid ColumnDefinitions="*,60,60">
                                        <TextBlock Text="Parameter" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="Old" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextAlignment="Right"/>
                                        <TextBlock Grid.Column="2" Text="New" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource SuccessBrush}" TextAlignment="Right"/>
                                    </Grid>
                                </Border>
                                
                                <!-- Changes -->
                                <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding SelectedLogChanges}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="12,8"
                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                        BorderThickness="0,0,0,1">
                                                    <Grid ColumnDefinitions="*,60,60">
                                                        <TextBlock Text="{Binding ParamName}"
                                                                   FontSize="12"
                                                                   FontWeight="Medium"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   ToolTip.Tip="{Binding ParamName}"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding OldValue}"
                                                                   FontSize="12"
                                                                   TextAlignment="Right"
                                                                   Foreground="{DynamicResource TextMutedBrush}"/>
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding NewValue}"
                                                                   FontSize="12"
                                                                   TextAlignment="Right"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource SuccessBrush}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
                
                <!-- Placeholder when no log selected -->
                <Border Grid.Column="1"
                        Classes="card"
                        IsVisible="{Binding !HasSelectedLog}">
                    <StackPanel Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                        <TextBlock Text="??"
                                   FontSize="40"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Select a Log"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="Click on a log entry to view its details"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
