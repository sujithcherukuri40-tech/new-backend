<UserControl xmlns="https://github.com/avaloniaui"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels.Admin"
         x:Class="PavamanDroneConfigurator.UI.Views.Admin.ParamLogsPage"
         x:DataType="vm:ParamLogsViewModel">

<UserControl.Styles>
    <!-- Glassmorphic Card -->
    <Style Selector="Border.glass-card">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#08FFFFFF" Offset="0"/>
                    <GradientStop Color="#04FFFFFF" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#20FFFFFF" Offset="0"/>
                    <GradientStop Color="#08FFFFFF" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="BoxShadow" Value="0 8 32 0 #15000000, 0 2 8 0 #08000000"/>
    </Style>
        
    <!-- Modern Table Row -->
    <Style Selector="Button.log-row">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.2"/>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
            </Transitions>
        </Setter>
    </Style>
        
    <Style Selector="Button.log-row:pointerover">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                    <GradientStop Color="#08667EEA" Offset="0"/>
                    <GradientStop Color="#04667EEA" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="RenderTransform" Value="scale(1.01)"/>
    </Style>
        
    <!-- Gradient Primary Button -->
    <Style Selector="Button.btn-gradient">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                    <GradientStop Color="#667EEA" Offset="0"/>
                    <GradientStop Color="#764BA2" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="BoxShadow" Value="0 4 16 0 #30667EEA"/>
        <Setter Property="Transitions">
            <Transitions>
                <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.3"/>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
            </Transitions>
        </Setter>
    </Style>
        
    <Style Selector="Button.btn-gradient:pointerover">
        <Setter Property="BoxShadow" Value="0 6 24 0 #50667EEA"/>
        <Setter Property="RenderTransform" Value="translateY(-2px)"/>
    </Style>
        
    <!-- Ghost Button -->
    <Style Selector="Button.btn-ghost">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="BorderBrush" Value="#20FFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
            </Transitions>
        </Setter>
    </Style>
        
    <Style Selector="Button.btn-ghost:pointerover">
        <Setter Property="BorderBrush" Value="#40FFFFFF"/>
    </Style>
        
    <!-- Search Box -->
    <Style Selector="TextBox.search-box">
        <Setter Property="Background" Value="#08FFFFFF"/>
        <Setter Property="BorderBrush" Value="#15FFFFFF"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="Padding" Value="40,12,12,12"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
                <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.3"/>
            </Transitions>
        </Setter>
    </Style>
        
    <Style Selector="TextBox.search-box:focus">
        <Setter Property="BorderBrush" Value="#667EEA"/>
        <Setter Property="BoxShadow" Value="0 0 0 3 #20667EEA"/>
    </Style>
</UserControl.Styles>


    <!-- Background with subtle gradient -->
    <Grid RowDefinitions="Auto,*">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#0F0F1E" Offset="0"/>
                <GradientStop Color="#1A1A2E" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        
        <!-- Header with gradient text -->
        <Border Grid.Row="0" Padding="32,24">
            <StackPanel Spacing="8">
                <TextBlock FontSize="32" FontWeight="Bold">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                            <GradientStop Color="#667EEA" Offset="0"/>
                            <GradientStop Color="#764BA2" Offset="0.5"/>
                            <GradientStop Color="#F093FB" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                    <Run Text="Parameter Change Logs"/>
                </TextBlock>
                <TextBlock Text="Track and monitor parameter modifications across your fleet"
                           FontSize="14"
                           Foreground="#80FFFFFF"
                           FontWeight="Light"/>
            </StackPanel>
        </Border>
        
        
        
        <!-- Main Content with modern spacing -->
        <Grid Grid.Row="1" Margin="32,0,32,32" ColumnDefinitions="*,420" ColumnSpacing="24">
            
            <!-- Left: Search + Filters + Table -->
            <StackPanel Grid.Column="0" Spacing="20">
                
                <!-- Search Bar -->
                <Border Classes="glass-card" Padding="0">
                    <Grid>
                        <TextBox Classes="search-box"
                                 Watermark="Search logs by user, drone ID, or date..."
                                 FontSize="14"/>
                        <!-- Search Icon -->
                        <Path Data="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
                              Fill="#60FFFFFF"
                              Width="20" Height="20"
                              Stretch="Uniform"
                              Margin="14,0,0,0"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Center"
                              IsHitTestVisible="False"/>
                    </Grid>
                </Border>
                
                <!-- Filters Card -->
                <Border Classes="glass-card">
                    <StackPanel Spacing="16">
                        <!-- Header -->
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Filters"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="White"/>
                            <Path Grid.Column="1"
                                  Data="M3 17v2h6v-2H3zM3 5v2h10V5H3zm10 16v-2h8v-2h-8v-2h-2v6h2zM7 9v2H3v2h4v2h2V9H7zm14 4v-2H11v2h10zm-6-4h2V7h4V5h-4V3h-2v6z"
                                  Fill="#80FFFFFF"
                                  Width="20" Height="20"
                                  Stretch="Uniform"/>
                        </Grid>
                        
                        <!-- Filter Controls -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowDefinitions="Auto,Auto" RowSpacing="12">
                            <!-- User Filter -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                                <TextBlock Text="User" 
                                           FontSize="12" 
                                           Foreground="#A0FFFFFF"
                                           FontWeight="Medium"/>
                                <ComboBox ItemsSource="{Binding AvailableUsers}"
                                          SelectedItem="{Binding SelectedUserId}"
                                          HorizontalAlignment="Stretch"
                                          PlaceholderText="All Users"
                                          CornerRadius="8"/>
                            </StackPanel>
                            
                            <!-- Drone ID Filter -->
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="6">
                                <TextBlock Text="Drone ID" 
                                           FontSize="12" 
                                           Foreground="#A0FFFFFF"
                                           FontWeight="Medium"/>
                                <ComboBox ItemsSource="{Binding AvailableDrones}"
                                          SelectedItem="{Binding SelectedDroneId}"
                                          HorizontalAlignment="Stretch"
                                          PlaceholderText="All Drones"
                                          CornerRadius="8"/>
                            </StackPanel>
                            
                            <!-- From Date -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Spacing="6">
                                <TextBlock Text="From Date" 
                                           FontSize="12" 
                                           Foreground="#A0FFFFFF"
                                           FontWeight="Medium"/>
                                <CalendarDatePicker SelectedDate="{Binding FromDate}" 
                                                    HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            
                            <!-- To Date -->
                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="6">
                                <TextBlock Text="To Date" 
                                           FontSize="12" 
                                           Foreground="#A0FFFFFF"
                                           FontWeight="Medium"/>
                                <CalendarDatePicker SelectedDate="{Binding ToDate}" 
                                                    HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Grid>
                        
                        <!-- Action Buttons -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,0">
                            <Button Grid.Column="0"
                                    Classes="btn-gradient"
                                    Command="{Binding ApplyFiltersCommand}"
                                    HorizontalAlignment="Stretch"
                                    Content="Apply Filters"/>
                            
                            <Button Grid.Column="1"
                                    Classes="btn-ghost"
                                    Command="{Binding ClearFiltersCommand}"
                                    HorizontalAlignment="Stretch"
                                    Content="Clear"/>
                        </Grid>
                    </StackPanel>
                </Border>
                
                
                <!-- Status Message -->
                <Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        Padding="16,12"
                        CornerRadius="12"
                        BoxShadow="0 4 16 0 #10667EEA">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                            <GradientStop Color="#10667EEA" Offset="0"/>
                            <GradientStop Color="#08764BA2" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Foreground="White"/>
                </Border>
                
                <!-- Loading State -->
                <Border Classes="glass-card" 
                        IsVisible="{Binding IsLoading}" 
                        Padding="48"
                        HorizontalAlignment="Center">
                    <StackPanel Spacing="16" HorizontalAlignment="Center">
                        <ProgressBar IsIndeterminate="True"
                                     Width="200"
                                     Height="4"
                                     Foreground="#667EEA"
                                     CornerRadius="2"/>
                        <TextBlock Text="Loading parameter logs..."
                                   FontSize="14"
                                   Foreground="#A0FFFFFF"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                
                <!-- Empty State with Icon -->
                <Border Classes="glass-card" 
                        IsVisible="{Binding HasNoLogs}" 
                        Padding="64">
                    <StackPanel Spacing="20" HorizontalAlignment="Center">
                        <!-- Empty Icon -->
                        <Border Width="80" Height="80"
                                CornerRadius="40"
                                HorizontalAlignment="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                    <GradientStop Color="#15667EEA" Offset="0"/>
                                    <GradientStop Color="#08764BA2" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Path Data="M13,9H11V7H13M13,17H11V11H13M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2Z"
                                  Fill="#667EEA"
                                  Width="40" Height="40"
                                  Stretch="Uniform"/>
                        </Border>
                        
                        <StackPanel Spacing="8">
                            <TextBlock Text="No Parameter Logs Found"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Foreground="White"/>
                            <TextBlock Text="Parameter changes will appear here when users modify drone parameters."
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Foreground="#80FFFFFF"
                                       TextWrapping="Wrap"
                                       MaxWidth="400"
                                       LineHeight="22"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- Log Table -->
                <Border Classes="card" IsVisible="{Binding !HasNoLogs}" Padding="0">
                    <StackPanel>
                        <!-- Table Header -->
                        <Border Background="{DynamicResource SurfaceBrush}"
                                Padding="12,10"
                                CornerRadius="8,8,0,0">
                            <Grid ColumnDefinitions="150,*,90,70,50">
                                <TextBlock Grid.Column="0" Text="User" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="Drone ID" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="2" Text="Date" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="3" Text="Time" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="4" Text="Size" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Grid>
                        </Border>
                        
                        <!-- Table Rows -->
                        <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ParamLogs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Classes="log-row"
                                                Command="{Binding $parent[ItemsControl].((vm:ParamLogsViewModel)DataContext).ViewLogCommand}"
                                                CommandParameter="{Binding}">
                                            <Grid ColumnDefinitions="150,*,90,70,50">
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding UserDisplay}"
                                                           FontWeight="Medium"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip.Tip="{Binding UserId}"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding DroneId}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip.Tip="{Binding DroneId}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd}'}"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextMutedBrush}"/>
                                                <TextBlock Grid.Column="4"
                                                           Text="{Binding SizeDisplay}"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextMutedBrush}"/>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        
                        <!-- Pagination -->
                        <Border Background="{DynamicResource SurfaceBrush}"
                                Padding="12,10"
                                CornerRadius="0,0,8,8"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,1,0,0">
                            <Grid ColumnDefinitions="*,Auto,*">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding TotalCount, StringFormat='Total: {0} log(s)'}"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                    <Button Content="Previous"
                                            Classes="btn-secondary"
                                            Command="{Binding PreviousPageCommand}"
                                            IsEnabled="{Binding HasPreviousPage}"
                                            Padding="12,6"/>
                                    <TextBlock VerticalAlignment="Center" Margin="8,0">
                                        <Run Text="Page "/>
                                        <Run Text="{Binding CurrentPage}"/>
                                        <Run Text=" of "/>
                                        <Run Text="{Binding TotalPages}"/>
                                    </TextBlock>
                                    <Button Content="Next"
                                            Classes="btn-secondary"
                                            Command="{Binding NextPageCommand}"
                                            IsEnabled="{Binding HasNextPage}"
                                            Padding="12,6"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
            
            <!-- Right: Details Panel -->
            <Border Grid.Column="1" Classes="card">
                <Grid>
                    <!-- No Selection -->
                    <StackPanel IsVisible="{Binding !HasSelectedLog}"
                                Spacing="8"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <TextBlock Text="Select a Log"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="Click on a log entry to view details"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                    </StackPanel>
                    
                    <!-- Log Details -->
                    <StackPanel IsVisible="{Binding HasSelectedLog}" Spacing="16">
                    <!-- Header -->
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Log Details"
                                       FontSize="14"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedLog.FileName}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="X"
                                Background="Transparent"
                                Foreground="{DynamicResource TextMutedBrush}"
                                Padding="8,4"
                                Command="{Binding CloseLogDetailsCommand}"/>
                    </Grid>
                    
                    <!-- Info -->
                    <Border Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="6"
                            Padding="12">
                        <StackPanel Spacing="6">
                            <Grid ColumnDefinitions="70,*">
                                <TextBlock Text="User:" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedLog.UserDisplay}" 
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip.Tip="{Binding SelectedLog.UserId}"/>
                            </Grid>
                            <Grid ColumnDefinitions="70,*">
                                <TextBlock Text="Drone ID:" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedLog.DroneId}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip.Tip="{Binding SelectedLog.DroneId}"/>
                            </Grid>
                            <Grid ColumnDefinitions="70,*">
                                <TextBlock Text="Time:" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedLog.TimestampDisplay}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                    <!-- Download -->
                    <Button Classes="btn-primary"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Command="{Binding DownloadLogCommand}"
                            CommandParameter="{Binding SelectedLog}"
                            Content="Download CSV"/>
                    
                    <!-- Changes -->
                    <TextBlock Text="Parameter Changes"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Margin="0,8,0,0"/>
                    
                    <TextBlock Text="Loading..."
                               IsVisible="{Binding IsLoadingContent}"
                               Foreground="{DynamicResource TextMutedBrush}"
                               HorizontalAlignment="Center"/>
                    
                    <!-- No Changes Message -->
                    <Border Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="6"
                            Padding="16"
                            IsVisible="{Binding HasNoChanges}">
                        <TextBlock Text="No parameter changes in this log"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   HorizontalAlignment="Center"/>
                    </Border>
                    
                    <!-- Changes Table -->
                    <Border Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="6"
                            Padding="0"
                            IsVisible="{Binding HasChangesToShow}">
                        <StackPanel>
                            <!-- Changes Header -->
                            <Border Background="{DynamicResource SecondaryLightBrush}"
                                    Padding="10,6"
                                    CornerRadius="6,6,0,0">
                                <Grid ColumnDefinitions="*,70,70">
                                    <TextBlock Text="Parameter" FontWeight="SemiBold" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="Old" FontWeight="SemiBold" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="2" Text="New" FontWeight="SemiBold" FontSize="10" Foreground="{DynamicResource SuccessBrush}" TextAlignment="Right"/>
                                </Grid>
                            </Border>
                            
                            <!-- Changes List -->
                            <ScrollViewer MaxHeight="280" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding SelectedLogChanges}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,6"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="0,0,0,1">
                                                <Grid ColumnDefinitions="*,70,70">
                                                    <TextBlock Text="{Binding ParamName}"
                                                               FontSize="11"
                                                               FontWeight="Medium"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip.Tip="{Binding ParamName}"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding OldValue}"
                                                               FontSize="11"
                                                               TextAlignment="Right"
                                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding NewValue}"
                                                               FontSize="11"
                                                               TextAlignment="Right"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource SuccessBrush}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            
                            <!-- Changes Count -->
                            <Border Background="{DynamicResource SecondaryLightBrush}"
                                    Padding="10,6"
                                    CornerRadius="0,0,6,6">
                                <TextBlock Text="{Binding SelectedLogChanges.Count, StringFormat='Total: {0} change(s)'}"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
