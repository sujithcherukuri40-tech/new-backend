<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels.Admin"
             x:Class="PavamanDroneConfigurator.UI.Views.Admin.ParamLogsPage"
             x:DataType="vm:ParamLogsViewModel">

    <UserControl.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        
        <Style Selector="Border.filter-card">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        
        <Style Selector="Button.log-row">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <Style Selector="Button.log-row:pointerover">
            <Setter Property="Background" Value="#10000000"/>
        </Style>
        
        <Style Selector="Button.btn-primary">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <Style Selector="Button.btn-secondary">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource BackgroundBrush}">
        
        <!-- Header -->
        <Border Grid.Row="0" Padding="24,20" Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Spacing="4">
                <TextBlock Text="Parameter Change Logs"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="View and filter parameter changes made by users"
                           FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
        
        
        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="24,20" ColumnDefinitions="*,380" ColumnSpacing="20">
            
            <!-- Left: Log List -->
            <StackPanel Grid.Column="0" Spacing="16">
                
                <!-- Filter Card -->
                <Border Classes="filter-card">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Filters"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        
                        <!-- Row 1: User and Drone ID -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="User" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                <ComboBox ItemsSource="{Binding AvailableUsers}"
                                          SelectedItem="{Binding SelectedUserId}"
                                          HorizontalAlignment="Stretch"
                                          PlaceholderText="All Users"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Drone ID" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                <ComboBox ItemsSource="{Binding AvailableDrones}"
                                          SelectedItem="{Binding SelectedDroneId}"
                                          HorizontalAlignment="Stretch"
                                          PlaceholderText="All Drones"/>
                            </StackPanel>
                        </Grid>
                        
                        <!-- Row 2: Dates and Buttons -->
                        <Grid ColumnDefinitions="*,*,Auto,Auto" ColumnSpacing="12">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="From Date" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                <CalendarDatePicker SelectedDate="{Binding FromDate}" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="To Date" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                <CalendarDatePicker SelectedDate="{Binding ToDate}" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            
                            <Button Grid.Column="2" Classes="btn-primary"
                                    Command="{Binding ApplyFiltersCommand}"
                                    VerticalAlignment="Bottom"
                                    Content="Apply"/>
                            
                            <Button Grid.Column="3" Classes="btn-secondary"
                                    Command="{Binding ClearFiltersCommand}"
                                    VerticalAlignment="Bottom"
                                    Content="Clear"/>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- Status Message -->
                <Border Background="{DynamicResource InfoLightBrush}"
                        CornerRadius="6"
                        Padding="12,8"
                        IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </Border>
                
                
                <!-- Loading -->
                <Border Classes="card" IsVisible="{Binding IsLoading}" Padding="40">
                    <TextBlock Text="Loading parameter logs..."
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Border>
                
                <!-- Empty State -->
                <Border Classes="card" IsVisible="{Binding HasNoLogs}" Padding="40">
                    <StackPanel Spacing="12" HorizontalAlignment="Center">
                        <TextBlock Text="No Parameter Logs Found"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Parameter changes will appear here when users modify drone parameters."
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   MaxWidth="400"/>
                    </StackPanel>
                </Border>
                
                <!-- Log Table -->
                <Border Classes="card" IsVisible="{Binding !HasNoLogs}" Padding="0">
                    <StackPanel>
                        <!-- Table Header -->
                        <Border Background="{DynamicResource SurfaceBrush}"
                                Padding="12,10"
                                CornerRadius="8,8,0,0">
                            <Grid ColumnDefinitions="150,*,90,70,50">
                                <TextBlock Grid.Column="0" Text="User" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="Drone ID" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="2" Text="Date" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="3" Text="Time" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="4" Text="Size" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Grid>
                        </Border>
                        
                        <!-- Table Rows -->
                        <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ParamLogs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Classes="log-row"
                                                Command="{Binding $parent[ItemsControl].((vm:ParamLogsViewModel)DataContext).ViewLogCommand}"
                                                CommandParameter="{Binding}">
                                            <Grid ColumnDefinitions="150,*,90,70,50">
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding UserDisplay}"
                                                           FontWeight="Medium"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip.Tip="{Binding UserId}"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding DroneId}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip.Tip="{Binding DroneId}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd}'}"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextMutedBrush}"/>
                                                <TextBlock Grid.Column="4"
                                                           Text="{Binding SizeDisplay}"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextMutedBrush}"/>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        
                        <!-- Pagination -->
                        <Border Background="{DynamicResource SurfaceBrush}"
                                Padding="12,10"
                                CornerRadius="0,0,8,8"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,1,0,0">
                            <Grid ColumnDefinitions="*,Auto,*">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding TotalCount, StringFormat='Total: {0} log(s)'}"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                    <Button Content="Previous"
                                            Classes="btn-secondary"
                                            Command="{Binding PreviousPageCommand}"
                                            IsEnabled="{Binding HasPreviousPage}"
                                            Padding="12,6"/>
                                    <TextBlock VerticalAlignment="Center" Margin="8,0">
                                        <Run Text="Page "/>
                                        <Run Text="{Binding CurrentPage}"/>
                                        <Run Text=" of "/>
                                        <Run Text="{Binding TotalPages}"/>
                                    </TextBlock>
                                    <Button Content="Next"
                                            Classes="btn-secondary"
                                            Command="{Binding NextPageCommand}"
                                            IsEnabled="{Binding HasNextPage}"
                                            Padding="12,6"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
            
            <!-- Right: Details Panel -->
            <Border Grid.Column="1" Classes="card">
                <Grid>
                    <!-- No Selection -->
                    <StackPanel IsVisible="{Binding !HasSelectedLog}"
                                Spacing="8"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <TextBlock Text="Select a Log"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="Click on a log entry to view details"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                    </StackPanel>
                    
                    <!-- Log Details -->
                    <StackPanel IsVisible="{Binding HasSelectedLog}" Spacing="16">
                    <!-- Header -->
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Log Details"
                                       FontSize="14"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedLog.FileName}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="X"
                                Background="Transparent"
                                Foreground="{DynamicResource TextMutedBrush}"
                                Padding="8,4"
                                Command="{Binding CloseLogDetailsCommand}"/>
                    </Grid>
                    
                    <!-- Info -->
                    <Border Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="6"
                            Padding="12">
                        <StackPanel Spacing="6">
                            <Grid ColumnDefinitions="70,*">
                                <TextBlock Text="User:" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedLog.UserDisplay}" 
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip.Tip="{Binding SelectedLog.UserId}"/>
                            </Grid>
                            <Grid ColumnDefinitions="70,*">
                                <TextBlock Text="Drone ID:" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedLog.DroneId}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip.Tip="{Binding SelectedLog.DroneId}"/>
                            </Grid>
                            <Grid ColumnDefinitions="70,*">
                                <TextBlock Text="Time:" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedLog.TimestampDisplay}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                    <!-- Download -->
                    <Button Classes="btn-primary"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Command="{Binding DownloadLogCommand}"
                            CommandParameter="{Binding SelectedLog}"
                            Content="Download CSV"/>
                    
                    <!-- Changes -->
                    <TextBlock Text="Parameter Changes"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Margin="0,8,0,0"/>
                    
                    <TextBlock Text="Loading..."
                               IsVisible="{Binding IsLoadingContent}"
                               Foreground="{DynamicResource TextMutedBrush}"
                               HorizontalAlignment="Center"/>
                    
                    <!-- No Changes Message -->
                    <Border Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="6"
                            Padding="16"
                            IsVisible="{Binding HasNoChanges}">
                        <TextBlock Text="No parameter changes in this log"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   HorizontalAlignment="Center"/>
                    </Border>
                    
                    <!-- Changes Table -->
                    <Border Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="6"
                            Padding="0"
                            IsVisible="{Binding HasChangesToShow}">
                        <StackPanel>
                            <!-- Changes Header -->
                            <Border Background="{DynamicResource SecondaryLightBrush}"
                                    Padding="10,6"
                                    CornerRadius="6,6,0,0">
                                <Grid ColumnDefinitions="*,70,70">
                                    <TextBlock Text="Parameter" FontWeight="SemiBold" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="Old" FontWeight="SemiBold" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="2" Text="New" FontWeight="SemiBold" FontSize="10" Foreground="{DynamicResource SuccessBrush}" TextAlignment="Right"/>
                                </Grid>
                            </Border>
                            
                            <!-- Changes List -->
                            <ScrollViewer MaxHeight="280" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding SelectedLogChanges}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,6"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="0,0,0,1">
                                                <Grid ColumnDefinitions="*,70,70">
                                                    <TextBlock Text="{Binding ParamName}"
                                                               FontSize="11"
                                                               FontWeight="Medium"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip.Tip="{Binding ParamName}"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding OldValue}"
                                                               FontSize="11"
                                                               TextAlignment="Right"
                                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding NewValue}"
                                                               FontSize="11"
                                                               TextAlignment="Right"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource SuccessBrush}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            
                            <!-- Changes Count -->
                            <Border Background="{DynamicResource SecondaryLightBrush}"
                                    Padding="10,6"
                                    CornerRadius="0,0,6,6">
                                <TextBlock Text="{Binding SelectedLogChanges.Count, StringFormat='Total: {0} change(s)'}"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
