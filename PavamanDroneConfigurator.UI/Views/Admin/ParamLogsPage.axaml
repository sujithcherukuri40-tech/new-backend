<UserControl xmlns="https://github.com/avaloniaui"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels.Admin"
         x:Class="PavamanDroneConfigurator.UI.Views.Admin.ParamLogsPage"
         x:DataType="vm:ParamLogsViewModel">

<UserControl.Styles>
    <!-- Glassmorphic Card -->
    <Style Selector="Border.glass-card">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="#E5E7EB"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="BoxShadow" Value="0 4 6 -1 #10000000, 0 2 4 -1 #06000000"/>
    </Style>
        
    <!-- Modern Table Row -->
    <Style Selector="Button.log-row">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.2"/>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
            </Transitions>
        </Setter>
    </Style>
        
    <Style Selector="Button.log-row:pointerover">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                    <GradientStop Color="#08667EEA" Offset="0"/>
                    <GradientStop Color="#04667EEA" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="RenderTransform" Value="scale(1.01)"/>
    </Style>
        
    <!-- Gradient Primary Button -->
    <Style Selector="Button.btn-gradient">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                    <GradientStop Color="#667EEA" Offset="0"/>
                    <GradientStop Color="#764BA2" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
            </Transitions>
        </Setter>
    </Style>
    
    <Style Selector="Button.btn-gradient:pointerover">
        <Setter Property="RenderTransform" Value="translateY(-2px)"/>
        <Setter Property="Opacity" Value="0.9"/>
    </Style>
        
    <!-- Ghost Button -->
    <Style Selector="Button.btn-ghost">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#6B7280"/>
        <Setter Property="BorderBrush" Value="#D1D5DB"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
            </Transitions>
        </Setter>
    </Style>
    
    <Style Selector="Button.btn-ghost:pointerover">
        <Setter Property="BorderBrush" Value="#9CA3AF"/>
        <Setter Property="Foreground" Value="#374151"/>
    </Style>
        
    <!-- Search Box -->
    <Style Selector="TextBox.search-box">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="#E5E7EB"/>
        <Setter Property="Foreground" Value="#1F2937"/>
        <Setter Property="Padding" Value="40,12,12,12"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
            </Transitions>
        </Setter>
    </Style>
    
    <Style Selector="TextBox.search-box:focus">
        <Setter Property="BorderBrush" Value="#667EEA"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>
    
    <!-- Secondary Button for pagination -->
    <Style Selector="Button.btn-secondary">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="#374151"/>
        <Setter Property="BorderBrush" Value="#D1D5DB"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    
    <Style Selector="Button.btn-secondary:pointerover">
        <Setter Property="BorderBrush" Value="#9CA3AF"/>
        <Setter Property="Background" Value="#F9FAFB"/>
    </Style>
    
    <!-- Primary Button for download -->
    <Style Selector="Button.btn-primary">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                    <GradientStop Color="#667EEA" Offset="0"/>
                    <GradientStop Color="#764BA2" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

</UserControl.Styles>





    <!-- Responsive Grid Layout -->
    <Grid RowDefinitions="*">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#F9FAFB" Offset="0"/>
                <GradientStop Color="#F3F4F6" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        
        <!-- Responsive Main Content -->
        <ScrollViewer Grid.Row="0" 
                      VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="24,24">
            <Grid ColumnDefinitions="*,400" ColumnSpacing="20" MaxWidth="1600">
            
            <!-- Left: Search + Filters + Table -->
            <StackPanel Grid.Column="0" Spacing="20">
                
                <!-- Search Bar -->
                <Border Classes="glass-card" Padding="0">
                    <Grid>
                        <TextBox Classes="search-box"
                                 Text="{Binding SearchText, Mode=TwoWay}"
                                 Watermark="Search logs by user, drone ID, or date..."
                                 FontSize="14"/>
                        <!-- Search Icon -->
                        <Path Data="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
                              Fill="#9CA3AF"
                              Width="20" Height="20"
                              Stretch="Uniform"
                              Margin="14,0,0,0"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Center"
                              IsHitTestVisible="False"/>
                    </Grid>
                </Border>
                
                
                <!-- Filters Card with Refresh Button -->
                <Border Classes="glass-card">
                    <StackPanel Spacing="16">
                        <!-- Header with Refresh -->
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <TextBlock Text="Filters"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       VerticalAlignment="Center"/>
                            
                            <Button Grid.Column="1"
                                    Command="{Binding ApplyFiltersCommand}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="8"
                                    ToolTip.Tip="Refresh logs"
                                    Margin="0,0,8,0"
                                    IsDefault="False">
                                <Path Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"
                                      Fill="#667EEA"
                                      Width="20" Height="20"
                                      Stretch="Uniform"/>
                            </Button>
                            
                            <Path Grid.Column="2"
                                  Data="M3 17v2h6v-2H3zM3 5v2h10V5H3zm10 16v-2h8v-2h-8v-2h-2v6h2zM7 9v2H3v2h4v2h2V9H7zm14 4v-2H11v2h10zm-6-4h2V7h4V5h-4V3h-2v6z"
                                  Fill="#6B7280"
                                  Width="20" Height="20"
                                  Stretch="Uniform"/>
                        </Grid>
                        
                        <!-- Filter Controls -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowDefinitions="Auto,Auto" RowSpacing="12">
                            <!-- User Filter -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                                <TextBlock Text="User" 
                                           FontSize="12" 
                                           Foreground="#6B7280"
                                           FontWeight="Medium"/>
                                <ComboBox ItemsSource="{Binding AvailableUsers}"
                                          SelectedItem="{Binding SelectedUserId}"
                                          HorizontalAlignment="Stretch"
                                          PlaceholderText="All Users"
                                          CornerRadius="8">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="13"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            
                            <!-- Drone ID Filter -->
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="6">
                                <TextBlock Text="Drone ID" 
                                           FontSize="12" 
                                           Foreground="#6B7280"
                                           FontWeight="Medium"/>
                                <ComboBox ItemsSource="{Binding AvailableDrones}"
                                          SelectedItem="{Binding SelectedDroneId}"
                                          HorizontalAlignment="Stretch"
                                          PlaceholderText="All Drones"
                                          CornerRadius="8">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="13"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            
                            <!-- From Date -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Spacing="6">
                                <TextBlock Text="From Date" 
                                           FontSize="12" 
                                           Foreground="#6B7280"
                                           FontWeight="Medium"/>
                                <CalendarDatePicker SelectedDate="{Binding FromDate}" 
                                                    HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            
                            <!-- To Date -->
                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="6">
                                <TextBlock Text="To Date" 
                                           FontSize="12" 
                                           Foreground="#6B7280"
                                           FontWeight="Medium"/>
                                <CalendarDatePicker SelectedDate="{Binding ToDate}" 
                                                    HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Grid>
                        
                        <!-- Action Buttons -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,0">
                            <Button Grid.Column="0"
                                    Classes="btn-gradient"
                                    Command="{Binding ApplyFiltersCommand}"
                                    HorizontalAlignment="Stretch"
                                    Content="Apply Filters"
                                    IsDefault="False"/>
                            
                            <Button Grid.Column="1"
                                    Classes="btn-ghost"
                                    Command="{Binding ClearFiltersCommand}"
                                    HorizontalAlignment="Stretch"
                                    Content="Clear"
                                    IsDefault="False"/>
                        </Grid>
                    </StackPanel>
                </Border>
                
                
                
                <!-- Status Message -->
                <Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        Padding="16,12"
                        CornerRadius="12"
                        Background="#EEF2FF"
                        BorderBrush="#C7D2FE"
                        BorderThickness="1">
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Foreground="#3730A3"/>
                </Border>
                
                <!-- Loading State -->
                <Border Classes="glass-card" 
                        IsVisible="{Binding IsLoading}" 
                        Padding="48"
                        HorizontalAlignment="Center">
                    <StackPanel Spacing="16" HorizontalAlignment="Center">
                        <ProgressBar IsIndeterminate="True"
                                     Width="200"
                                     Height="4"
                                     Foreground="#667EEA"
                                     CornerRadius="2"/>
                        <TextBlock Text="Loading parameter logs..."
                                   FontSize="14"
                                   Foreground="#6B7280"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                
                <!-- Empty State with Icon -->
                <Border Classes="glass-card" 
                        IsVisible="{Binding HasNoLogs}" 
                        Padding="64">
                    <StackPanel Spacing="20" HorizontalAlignment="Center">
                        <!-- Empty Icon -->
                        <Border Width="80" Height="80"
                                CornerRadius="40"
                                Background="#F3F4F6"
                                HorizontalAlignment="Center">
                            <Path Data="M13,9H11V7H13M13,17H11V11H13M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2Z"
                                  Fill="#667EEA"
                                  Width="40" Height="40"
                                  Stretch="Uniform"/>
                        </Border>
                        
                        <StackPanel Spacing="8">
                            <TextBlock Text="No Parameter Logs Found"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Foreground="#111827"/>
                            <TextBlock Text="Parameter changes will appear here when users modify drone parameters."
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Foreground="#6B7280"
                                       TextWrapping="Wrap"
                                       MaxWidth="400"
                                       LineHeight="22"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                
                
                
                <!-- Log Table with Proper Scrolling -->
                <Border Classes="glass-card" IsVisible="{Binding !HasNoLogs}" Padding="0">
                    <Grid RowDefinitions="Auto,*,Auto">
                        <!-- Table Header -->
                        <Border Grid.Row="0" 
                                Padding="16,12" 
                                CornerRadius="16,16,0,0" 
                                Background="#F9FAFB" 
                                BorderBrush="#E5E7EB" 
                                BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="150,*,100,80,60">
                                <TextBlock Grid.Column="0" Text="User" FontWeight="SemiBold" FontSize="12" Foreground="#374151"/>
                                <TextBlock Grid.Column="1" Text="Drone ID" FontWeight="SemiBold" FontSize="12" Foreground="#374151"/>
                                <TextBlock Grid.Column="2" Text="Date" FontWeight="SemiBold" FontSize="12" Foreground="#374151"/>
                                <TextBlock Grid.Column="3" Text="Time" FontWeight="SemiBold" FontSize="12" Foreground="#374151"/>
                                <TextBlock Grid.Column="4" Text="Size" FontWeight="SemiBold" FontSize="12" Foreground="#374151"/>
                            </Grid>
                        </Border>
                        
                        <!-- Scrollable Table Rows -->
                        <ScrollViewer Grid.Row="1"
                                      MinHeight="300"
                                      MaxHeight="500" 
                                      VerticalScrollBarVisibility="Auto" 
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding ParamLogs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Classes="log-row"
                                                Command="{Binding $parent[ItemsControl].((vm:ParamLogsViewModel)DataContext).ViewLogCommand}"
                                                CommandParameter="{Binding}">
                                            <Grid ColumnDefinitions="150,*,100,80,60">
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding UserDisplay}"
                                                           FontWeight="Medium"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip.Tip="{Binding UserId}"
                                                           Foreground="#111827"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding DroneId}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip.Tip="{Binding DroneId}"
                                                           Foreground="#6B7280"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd}'}"
                                                           VerticalAlignment="Center"
                                                           Foreground="#6B7280"/>
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                                                           VerticalAlignment="Center"
                                                           Foreground="#9CA3AF"/>
                                                <TextBlock Grid.Column="4"
                                                           Text="{Binding SizeDisplay}"
                                                           VerticalAlignment="Center"
                                                           Foreground="#9CA3AF"/>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        
                        
                        
                        
                        <!-- Pagination -->
                        <Border Grid.Row="2"
                                Padding="16,12" 
                                CornerRadius="0,0,16,16" 
                                Background="#F9FAFB" 
                                BorderBrush="#E5E7EB" 
                                BorderThickness="0,1,0,0">
                            <Grid ColumnDefinitions="*,Auto,*">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding TotalCount, StringFormat='Total: {0} log(s)'}"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Foreground="#6B7280"/>
                                
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                    <Button Content="Previous"
                                            Classes="btn-secondary"
                                            Command="{Binding PreviousPageCommand}"
                                            IsEnabled="{Binding HasPreviousPage}"
                                            Padding="12,6"/>
                                    <TextBlock VerticalAlignment="Center" Margin="8,0" Foreground="#374151">
                                        <Run Text="Page "/>
                                        <Run Text="{Binding CurrentPage}"/>
                                        <Run Text=" of "/>
                                        <Run Text="{Binding TotalPages}"/>
                                    </TextBlock>
                                    <Button Content="Next"
                                            Classes="btn-secondary"
                                            Command="{Binding NextPageCommand}"
                                            IsEnabled="{Binding HasNextPage}"
                                            Padding="12,6"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>
            
            
            
            <!-- Right: Details Panel -->
            <Border Grid.Column="1" Classes="glass-card">
                <Grid>
                    <!-- No Selection - Empty State -->
                    <StackPanel IsVisible="{Binding !HasSelectedLog}"
                                Spacing="16"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <!-- Icon -->
                        <Border Width="64" Height="64"
                                CornerRadius="32"
                                Background="#F3F4F6"
                                HorizontalAlignment="Center">
                            <Path Data="M19,3H5C3.89,3 3,3.89 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.89 20.1,3 19,3M19,5V19H5V5H19Z"
                                  Fill="#667EEA"
                                  Width="32" Height="32"
                                  Stretch="Uniform"/>
                        </Border>
                        
                        <StackPanel Spacing="6">
                            <TextBlock Text="Select a Log"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Foreground="#111827"/>
                            <TextBlock Text="Click on a log entry to view details"
                                       FontSize="13"
                                       HorizontalAlignment="Center"
                                       Foreground="#6B7280"/>
                        </StackPanel>
                    </StackPanel>
                    
                    
                    <!-- Log Details -->
                    <StackPanel IsVisible="{Binding HasSelectedLog}" Spacing="20">
                        <!-- Header -->
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Log Details"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#111827"/>
                                <TextBlock Text="{Binding SelectedLog.FileName}"
                                           FontSize="11"
                                           Foreground="#6B7280"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="8"
                                    ToolTip.Tip="Close details"
                                    Command="{Binding CloseLogDetailsCommand}">
                                <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                                      Fill="#9CA3AF"
                                      Width="18"
                                      Height="18"
                                      Stretch="Uniform"/>
                            </Button>
                        </Grid>
                        
                        <!-- Info Card -->
                        <Border CornerRadius="12" Padding="16" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1">
                            <StackPanel Spacing="12">
                                <Grid ColumnDefinitions="80,*">
                                    <TextBlock Text="User:" FontWeight="Medium" Foreground="#6B7280"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SelectedLog.UserDisplay}" 
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip.Tip="{Binding SelectedLog.UserId}"
                                               Foreground="#111827"/>
                                </Grid>
                                <Grid ColumnDefinitions="80,*">
                                    <TextBlock Text="Drone ID:" FontWeight="Medium" Foreground="#6B7280"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SelectedLog.DroneId}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip.Tip="{Binding SelectedLog.DroneId}"
                                               Foreground="#111827"/>
                                </Grid>
                                <Grid ColumnDefinitions="80,*">
                                    <TextBlock Text="Time:" FontWeight="Medium" Foreground="#6B7280"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SelectedLog.TimestampDisplay}" Foreground="#111827"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    
                        
                    
                        
                        <!-- Download Button -->
                        <Button Classes="btn-primary"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Command="{Binding DownloadLogCommand}"
                                CommandParameter="{Binding SelectedLog}"
                                Content="Download CSV"/>
                        
                        <!-- Changes Section -->
                        <TextBlock Text="Parameter Changes"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Foreground="#111827"
                                   Margin="0,8,0,0"/>
                        
                        <!-- Loading State -->
                        <TextBlock Text="Loading..."
                                   IsVisible="{Binding IsLoadingContent}"
                                   Foreground="#6B7280"
                                   HorizontalAlignment="Center"/>
                        
                        <!-- No Changes Message -->
                        <Border CornerRadius="12"
                                Padding="20"
                                Background="#F9FAFB"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                IsVisible="{Binding HasNoChanges}">
                            <TextBlock Text="No parameter changes in this log"
                                       FontSize="13"
                                       Foreground="#6B7280"
                                       HorizontalAlignment="Center"/>
                        </Border>
                        
                        
                        <!-- Changes Table -->
                        <Border CornerRadius="12"
                                Padding="0"
                                Background="White"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                IsVisible="{Binding HasChangesToShow}">
                            <Grid RowDefinitions="Auto,*,Auto">
                                <!-- Changes Header -->
                                <Border Grid.Row="0"
                                        Padding="12,10" 
                                        CornerRadius="12,12,0,0" 
                                        Background="#F9FAFB" 
                                        BorderBrush="#E5E7EB" 
                                        BorderThickness="0,0,0,1">
                                    <Grid ColumnDefinitions="*,70,70">
                                        <TextBlock Text="Parameter" FontWeight="SemiBold" FontSize="11" Foreground="#374151"/>
                                        <TextBlock Grid.Column="1" Text="Old" FontWeight="SemiBold" FontSize="11" Foreground="#374151" TextAlignment="Right"/>
                                        <TextBlock Grid.Column="2" Text="New" FontWeight="SemiBold" FontSize="11" Foreground="#10B981" TextAlignment="Right"/>
                                    </Grid>
                                </Border>
                            
                                
                                
                                <!-- Changes List with proper scrolling -->
                                <ScrollViewer Grid.Row="1"
                                              MinHeight="200"
                                              MaxHeight="300" 
                                              VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding SelectedLogChanges}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="12,10"
                                                        BorderBrush="#F3F4F6"
                                                        BorderThickness="0,0,0,1">
                                                    <Grid ColumnDefinitions="*,70,70">
                                                        <TextBlock Text="{Binding ParamName}"
                                                                   FontSize="12"
                                                                   FontWeight="Medium"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   ToolTip.Tip="{Binding ParamName}"
                                                                   Foreground="#111827"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding OldValue}"
                                                                   FontSize="12"
                                                                   TextAlignment="Right"
                                                                   Foreground="#9CA3AF"/>
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding NewValue}"
                                                                   FontSize="12"
                                                                   TextAlignment="Right"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#10B981"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                
                                <!-- Changes Count -->
                                <Border Grid.Row="2"
                                        Padding="12,10" 
                                        CornerRadius="0,0,12,12" 
                                        Background="#F9FAFB" 
                                        BorderBrush="#E5E7EB" 
                                        BorderThickness="0,1,0,0">
                                    <TextBlock Text="{Binding SelectedLogChanges.Count, StringFormat='Total: {0} change(s)'}"
                                               FontSize="11"
                                               Foreground="#6B7280"/>
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
