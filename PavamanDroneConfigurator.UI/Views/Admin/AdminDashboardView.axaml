<UserControl xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels.Admin"
x:Class="PavamanDroneConfigurator.UI.Views.Admin.AdminDashboardView"
x:DataType="vm:AdminDashboardViewModel"
Background="#F9FAFB">
    

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32" MaxWidth="1400" Spacing="24">
            
            <!-- Header -->
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="8">
                    <TextBlock Text="Admin Dashboard"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#111827"/>
                    <TextBlock Text="User management and system overview"
                               FontSize="14"
                               Foreground="#6B7280"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Refresh"
                        Background="#3B82F6"
                        Foreground="White"
                        Padding="20,12"
                        CornerRadius="8"
                        FontWeight="SemiBold"
                        Command="{Binding RefreshCommand}"
                        VerticalAlignment="Center"/>
            </Grid>

            <!-- Stats Cards -->
            <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="16">
                <!-- Total Users -->
                <Border Background="White" CornerRadius="12" Padding="20" BoxShadow="0 2 8 0 #10000000">
                    <StackPanel>
                        <TextBlock Text="Total Users" FontSize="13" Foreground="#6B7280"/>
                        <TextBlock Text="{Binding TotalCount}" FontSize="36" FontWeight="Bold" Foreground="#111827" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <!-- Pending -->
                <Border Grid.Column="1" Background="#FFFBEB" CornerRadius="12" Padding="20" BoxShadow="0 2 8 0 #10000000">
                    <StackPanel>
                        <TextBlock Text="Pending" FontSize="13" Foreground="#92400E"/>
                        <TextBlock Text="{Binding PendingCount}" FontSize="36" FontWeight="Bold" Foreground="#F59E0B" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <!-- Approved -->
                <Border Grid.Column="2" Background="#ECFDF5" CornerRadius="12" Padding="20" BoxShadow="0 2 8 0 #10000000">
                    <StackPanel>
                        <TextBlock Text="Approved" FontSize="13" Foreground="#065F46"/>
                        <TextBlock Text="{Binding ApprovedCount}" FontSize="36" FontWeight="Bold" Foreground="#10B981" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <!-- Admins -->
                <Border Grid.Column="3" Background="#EEF2FF" CornerRadius="12" Padding="20" BoxShadow="0 2 8 0 #10000000">
                    <StackPanel>
                        <TextBlock Text="Admins" FontSize="13" Foreground="#3730A3"/>
                        <TextBlock Text="{Binding AdminCount}" FontSize="36" FontWeight="Bold" Foreground="#6366F1" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <!-- Regular Users -->
                <Border Grid.Column="4" Background="#F0F9FF" CornerRadius="12" Padding="20" BoxShadow="0 2 8 0 #10000000">
                    <StackPanel>
                        <TextBlock Text="Users" FontSize="13" Foreground="#0369A1"/>
                        <TextBlock Text="{Binding UserCount}" FontSize="36" FontWeight="Bold" Foreground="#0EA5E9" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Storage Stats Row -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="16" Margin="0,16,0,0">
                <!-- Total S3 Storage -->
                <Border Grid.Column="0" Background="#FEF3C7" CornerRadius="12" Padding="20" BoxShadow="0 2 8 0 #10000000">
                    <StackPanel>
                        <TextBlock Text="Total S3 Storage" FontSize="13" Foreground="#92400E"/>
                        <TextBlock Text="{Binding S3UsedStorage}" FontSize="28" FontWeight="Bold" Foreground="#F59E0B" Margin="0,8,0,0"/>
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                            <TextBlock Text="Firmwares:" FontSize="11" Foreground="#92400E"/>
                            <TextBlock Text="{Binding TotalFirmwareFiles}" FontSize="11" FontWeight="SemiBold" Foreground="#D97706"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2,0,0">
                            <TextBlock Text="Param Logs:" FontSize="11" Foreground="#92400E"/>
                            <TextBlock Text="{Binding TotalParamLogs}" FontSize="11" FontWeight="SemiBold" Foreground="#D97706"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- S3 Usage Percentage -->
                <Border Grid.Column="1" Background="#F3E8FF" CornerRadius="12" Padding="20" BoxShadow="0 2 8 0 #10000000">
                    <StackPanel>
                        <TextBlock Text="S3 Bucket Limit" FontSize="13" Foreground="#6B21A8"/>
                        <TextBlock Text="No Limit" FontSize="28" FontWeight="Bold" Foreground="#A855F7" Margin="0,8,0,0"/>
                        <TextBlock Text="AWS S3 scales automatically" FontSize="11" Foreground="#7C3AED" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- Quick Actions -->
                <Border Grid.Column="2" Background="#DBEAFE" CornerRadius="12" Padding="20" BoxShadow="0 2 8 0 #10000000">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Quick Actions" FontSize="13" Foreground="#1E40AF" FontWeight="SemiBold"/>
                        <Button Content="Manage Firmwares" 
                                Background="#3B82F6" 
                                Foreground="White" 
                                Padding="12,8" 
                                CornerRadius="6"
                                FontSize="12"
                                HorizontalAlignment="Stretch"
                                Command="{Binding NavigateToFirmwareManagementCommand}"/>
                        <Button Content="View Param Logs" 
                                Background="#0EA5E9" 
                                Foreground="White" 
                                Padding="12,8" 
                                CornerRadius="6"
                                FontSize="12"
                                HorizontalAlignment="Stretch"
                                Command="{Binding NavigateToParamLogsCommand}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Toolbar -->
            <Border Background="White" CornerRadius="12" Padding="16" BoxShadow="0 2 8 0 #10000000">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBox Watermark="Search by name or email..."
                                 Text="{Binding SearchText, Mode=TwoWay}"
                                 Width="300"
                                 CornerRadius="8"
                                 Padding="12,10"
                                 FontSize="14"/>
                        <ComboBox SelectedIndex="{Binding StatusFilter}"
                                  Width="150"
                                  CornerRadius="8"
                                  Padding="12,8">
                            <ComboBoxItem Content="All Status"/>
                            <ComboBoxItem Content="Approved"/>
                            <ComboBoxItem Content="Pending"/>
                        </ComboBox>
                        <ComboBox SelectedIndex="{Binding RoleFilter}"
                                  Width="150"
                                  CornerRadius="8"
                                  Padding="12,8">
                            <ComboBoxItem Content="All Roles"/>
                            <ComboBoxItem Content="Admin"/>
                            <ComboBoxItem Content="User"/>
                        </ComboBox>
                        <Button Content="Clear Filters"
                                Background="#F3F4F6"
                                Foreground="#374151"
                                Padding="16,10"
                                CornerRadius="8"
                                Command="{Binding ClearFiltersCommand}"/>
                    </StackPanel>
                    
                    <TextBlock Grid.Column="1" 
                               Text="{Binding StatusMessage}" 
                               Foreground="#6B7280"
                               FontSize="13"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Users Table -->
            <Border Background="White" CornerRadius="12" BoxShadow="0 2 8 0 #10000000" ClipToBounds="True">
                <StackPanel>
                    <!-- Header -->
                    <Border Background="#F8FAFC" Padding="20,14" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="1.5*,2*,0.8*,0.8*,1.2*,1.2*,1.8*">
                            <TextBlock Grid.Column="0" Text="NAME" FontWeight="Bold" FontSize="11" Foreground="#64748B" LetterSpacing="0.5"/>
                            <TextBlock Grid.Column="1" Text="EMAIL" FontWeight="Bold" FontSize="11" Foreground="#64748B" LetterSpacing="0.5"/>
                            <TextBlock Grid.Column="2" Text="STATUS" FontWeight="Bold" FontSize="11" Foreground="#64748B" LetterSpacing="0.5"/>
                            <TextBlock Grid.Column="3" Text="ROLE" FontWeight="Bold" FontSize="11" Foreground="#64748B" LetterSpacing="0.5"/>
                            <TextBlock Grid.Column="4" Text="JOINED" FontWeight="Bold" FontSize="11" Foreground="#64748B" LetterSpacing="0.5"/>
                            <TextBlock Grid.Column="5" Text="LAST LOGIN" FontWeight="Bold" FontSize="11" Foreground="#64748B" LetterSpacing="0.5"/>
                            <TextBlock Grid.Column="6" Text="ACTIONS" FontWeight="Bold" FontSize="11" Foreground="#64748B" LetterSpacing="0.5"/>
                        </Grid>
                    </Border>
                    
                    <!-- User Rows -->
                    <ItemsControl ItemsSource="{Binding FilteredUsers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="20,16">
                                    <Grid ColumnDefinitions="1.5*,2*,0.8*,0.8*,1.2*,1.2*,1.8*">
                                        <!-- Name -->
                                        <TextBlock Grid.Column="0" 
                                                   Text="{Binding FullName}" 
                                                   FontWeight="SemiBold" 
                                                   FontSize="14"
                                                   Foreground="#1E293B"
                                                   VerticalAlignment="Center"/>
                                        
                                        <!-- Email -->
                                        <TextBlock Grid.Column="1" 
                                                   Text="{Binding Email}" 
                                                   Foreground="#64748B" 
                                                   FontSize="13"
                                                   VerticalAlignment="Center"/>
                                        
                                        <!-- Status Badge -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding StatusText}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding StatusColor}"
                                                   VerticalAlignment="Center"/>
                                        
                                        <!-- Role Selector -->
                                        <ComboBox Grid.Column="3"
                                                  SelectedItem="{Binding SelectedRole, Mode=TwoWay}"
                                                  ItemsSource="{Binding AvailableRoles}"
                                                  Width="85"
                                                  FontSize="12"
                                                  CornerRadius="6"
                                                  Padding="8,6"
                                                  VerticalAlignment="Center"/>
                                        
                                        <!-- Joined Date -->
                                        <TextBlock Grid.Column="4" 
                                                   Text="{Binding CreatedAt, StringFormat='{}{0:MMM dd, yyyy}'}" 
                                                   Foreground="#64748B"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"/>
                                        
                                        <!-- Last Login -->
                                        <TextBlock Grid.Column="5" 
                                                   Text="{Binding LastLoginDisplay}" 
                                                   Foreground="#64748B"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"/>
                                        
                                        <!-- Actions -->
                                        <StackPanel Grid.Column="6" 
                                                    Orientation="Horizontal" 
                                                    Spacing="8"
                                                    VerticalAlignment="Center">
                                            <!-- Approve/Revoke Button -->
                                            <Button Content="{Binding ApprovalButtonText}"
                                                    Background="#3B82F6"
                                                    Foreground="White"
                                                    Padding="14,8"
                                                    CornerRadius="6"
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    BorderThickness="0"
                                                    Command="{Binding $parent[UserControl].((vm:AdminDashboardViewModel)DataContext).ApproveUserCommand}"
                                                    CommandParameter="{Binding}"/>
                                            
                                            <!-- Delete Button -->
                                            <Button Background="#FEF2F2"
                                                    Padding="10,8"
                                                    CornerRadius="6"
                                                    BorderThickness="0"
                                                    ToolTip.Tip="Delete User"
                                                    Command="{Binding $parent[UserControl].((vm:AdminDashboardViewModel)DataContext).DeleteUserCommand}"
                                                    CommandParameter="{Binding}">
                                                <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                                                      Fill="#DC2626"
                                                      Width="16"
                                                      Height="16"
                                                      Stretch="Uniform"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <!-- Empty State -->
                    <Border Padding="60" IsVisible="{Binding ShowEmptyState}">
                        <StackPanel HorizontalAlignment="Center" Spacing="16">
                            <TextBlock Text="??" FontSize="64" HorizontalAlignment="Center" Opacity="0.4"/>
                            <TextBlock Text="No users found" FontSize="18" FontWeight="SemiBold" Foreground="#64748B" HorizontalAlignment="Center"/>
                            <TextBlock Text="Try adjusting your search or filter criteria" FontSize="14" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                            <Button Content="Clear All Filters"
                                    Command="{Binding ClearFiltersCommand}"
                                    Background="#3B82F6"
                                    Foreground="White"
                                    Padding="20,10"
                                    CornerRadius="8"
                                    HorizontalAlignment="Center"
                                    Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Loading Overlay -->
            <Border Background="#F0F9FAFB" 
                    CornerRadius="12"
                    Padding="60"
                    IsVisible="{Binding IsBusy}">
                <StackPanel HorizontalAlignment="Center" Spacing="16">
                    <ProgressBar IsIndeterminate="True" Width="250" Height="4" Foreground="#3B82F6"/>
                    <TextBlock Text="Loading users..." FontSize="14" Foreground="#64748B" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>