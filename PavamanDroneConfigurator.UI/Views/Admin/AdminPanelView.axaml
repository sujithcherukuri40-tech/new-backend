<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels.Admin"
             xmlns:converters="using:Avalonia.Data.Converters"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
             x:Class="PavamanDroneConfigurator.UI.Views.Admin.AdminPanelView"
             x:DataType="vm:AdminPanelViewModel">

    <UserControl.Styles>
        <!-- macOS-style Card -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BoxShadow" Value="0 2 8 0 #10000000"/>
        </Style>

        <!-- Status Badge -->
        <Style Selector="Border.badge-approved">
            <Setter Property="Background" Value="#DCFCE7"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <Style Selector="Border.badge-pending">
            <Setter Property="Background" Value="#FEF3C7"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <Style Selector="Border.badge-admin">
            <Setter Property="Background" Value="#DBEAFE"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <Style Selector="Border.badge-user">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <!-- Action Button -->
        <Style Selector="Button.action-approve">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.action-approve:pointerover">
            <Setter Property="Background" Value="#059669"/>
        </Style>

        <Style Selector="Button.action-disapprove">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.action-disapprove:pointerover">
            <Setter Property="Background" Value="#DC2626"/>
        </Style>

        <Style Selector="Button.action-secondary">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.action-secondary:pointerover">
            <Setter Property="Background" Value="#E5E7EB"/>
        </Style>

        <!-- ComboBox Style -->
        <Style Selector="ComboBox.role-select">
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" Margin="24">
        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="12" Margin="0,0,0,24">
            <TextBlock Text="👥 User Management"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="#111827"/>
            
            <TextBlock Text="Manage user access requests, roles, and permissions"
                       FontSize="14"
                       Foreground="#6B7280"/>
        </StackPanel>

        <!-- Content -->
        <Border Grid.Row="1" Classes="card" Padding="0">
            <Grid RowDefinitions="Auto,Auto,*,Auto">
                <!-- Toolbar with Search and Filters -->
                <Border Grid.Row="0" 
                        Background="#F9FAFB" 
                        Padding="16"
                        CornerRadius="8,8,0,0"
                        BorderBrush="#E5E7EB"
                        BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <!-- Refresh Button -->
                        <Button Grid.Column="0"
                                Content="🔄 Refresh"
                                Classes="action-secondary"
                                Command="{Binding RefreshCommand}"
                                Margin="0,0,12,0"/>
                        
                        <!-- Search and Filter Section -->
                        <StackPanel Grid.Column="1" 
                                    Orientation="Horizontal" 
                                    Spacing="12"
                                    HorizontalAlignment="Left">
                            <!-- Search Box -->
                            <TextBox Watermark="🔍 Search by name or email..."
                                     Text="{Binding SearchText, Mode=TwoWay}"
                                     Width="250"
                                     CornerRadius="6"
                                     Padding="10,6"
                                     FontSize="13"
                                     BorderBrush="#D1D5DB"
                                     BorderThickness="1"/>
                            
                            <!-- Status Filter -->
                            <ComboBox SelectedIndex="{Binding StatusFilter, Mode=TwoWay}"
                                      Width="130"
                                      Classes="role-select">
                                <ComboBoxItem Content="All Status"/>
                                <ComboBoxItem Content="✅ Approved"/>
                                <ComboBoxItem Content="⏳ Pending"/>
                            </ComboBox>
                            
                            <!-- Role Filter -->
                            <ComboBox SelectedIndex="{Binding RoleFilter, Mode=TwoWay}"
                                      Width="130"
                                      Classes="role-select">
                                <ComboBoxItem Content="All Roles"/>
                                <ComboBoxItem Content="👑 Admin"/>
                                <ComboBoxItem Content="👤 User"/>
                            </ComboBox>
                            
                            <!-- Clear Filters Button -->
                            <Button Content="✖ Clear"
                                    Classes="action-secondary"
                                    Command="{Binding ClearFiltersCommand}"
                                    FontSize="12"
                                    Padding="10,6"/>
                        </StackPanel>
                        
                        <!-- Stats -->
                        <StackPanel Grid.Column="2" 
                                    Orientation="Horizontal" 
                                    Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="Total:" 
                                           VerticalAlignment="Center" 
                                           Foreground="#6B7280"
                                           FontSize="13"/>
                                <TextBlock Text="{Binding FilteredUsers.Count}" 
                                           FontWeight="SemiBold" 
                                           Foreground="#111827" 
                                           VerticalAlignment="Center"
                                           FontSize="14"/>
                            </StackPanel>

                            <Border Width="1" Background="#E5E7EB"/>

                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="⏳ Pending:" 
                                           VerticalAlignment="Center" 
                                           Foreground="#F59E0B"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding PendingCount}" 
                                           FontWeight="Bold" 
                                           Foreground="#F59E0B" 
                                           VerticalAlignment="Center"
                                           FontSize="14"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Status Message -->
                <Border Grid.Row="1"
                        Background="#EFF6FF"
                        Padding="12"
                        BorderBrush="#BFDBFE"
                        BorderThickness="0,0,0,1"
                        IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="13"
                               Foreground="#1E40AF"/>
                </Border>

                <!-- Users DataGrid -->
                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding FilteredUsers}"
                          MinHeight="400"
                          AutoGenerateColumns="False"
                          CanUserResizeColumns="True"
                          CanUserSortColumns="True"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          Background="Transparent"
                          RowBackground="White">

                    <DataGrid.Columns>
                        <!-- Full Name -->
                        <DataGridTextColumn Header="Full Name"
                                            Binding="{Binding FullName}"
                                            Width="200"
                                            FontWeight="SemiBold"
                                            Foreground="#111827"/>

                        <!-- Email -->
                        <DataGridTextColumn Header="Email"
                                            Binding="{Binding Email}"
                                            Width="220"
                                            Foreground="#6B7280"/>

                        <!-- Status -->
                        <DataGridTemplateColumn Header="Status" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Classes.badge-approved="{Binding IsApproved}"
                                            Classes.badge-pending="{Binding !IsApproved}"
                                            HorizontalAlignment="Left"
                                            Padding="8,4"
                                            CornerRadius="4">
                                        <TextBlock Text="{Binding StatusText}"
                                                   FontSize="12" 
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding StatusColor}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Role Selection -->
                        <DataGridTemplateColumn Header="👑 Role" Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="4">
                                        <ComboBox Classes="role-select"
                                                  SelectedItem="{Binding SelectedRole, Mode=TwoWay}"
                                                  ItemsSource="{Binding AvailableRoles}"
                                                  HorizontalAlignment="Stretch"
                                                  MinWidth="110"
                                                  Background="#FFFFFF"
                                                  BorderBrush="#3B82F6"
                                                  BorderThickness="1.5"
                                                  FontWeight="SemiBold">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Text="{Binding}" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Created Date -->
                        <DataGridTextColumn Header="Registered"
                                            Binding="{Binding CreatedAt, StringFormat='{}{0:MMM dd, yyyy}'}"
                                            Width="120"
                                            Foreground="#6B7280"/>

                        <!-- Last Login -->
                        <DataGridTextColumn Header="Last Login"
                                            Binding="{Binding LastLoginAt, StringFormat='{}{0:MMM dd, yyyy}'}"
                                            Width="120"
                                            Foreground="#6B7280"/>

                        <!-- Actions -->
                        <DataGridTemplateColumn Header="Actions" Width="*" MinWidth="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="4,4">
                                        <!-- Approve/Disapprove Button -->
                                        <Button Classes.action-approve="{Binding !IsApproved}"
                                                Classes.action-disapprove="{Binding IsApproved}"
                                                Content="{Binding ApprovalButtonText}"
                                                Command="{Binding $parent[UserControl].((vm:AdminPanelViewModel)DataContext).ApproveUserCommand}"
                                                CommandParameter="{Binding}"/>
                                   
                                        <!-- Update Role Button -->
                                        <Button Content="Update Role"
                                                Classes="action-secondary"
                                                Command="{Binding $parent[UserControl].((vm:AdminPanelViewModel)DataContext).UpdateRoleCommand}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State Overlay -->
                <Border Grid.Row="2"
                        Background="White"
                        IsVisible="{Binding ShowEmptyState}">
                    <StackPanel VerticalAlignment="Center" 
                                HorizontalAlignment="Center"
                                Spacing="16"
                                Margin="40">
                        <TextBlock Text="👥"
                                   FontSize="48"
                                   HorizontalAlignment="Center"
                                   Opacity="0.3"/>
                        <TextBlock Text="No Users Found"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#6B7280"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="There are no users matching your current filters. Try adjusting your search or clearing filters."
                                   FontSize="14"
                                   Foreground="#9CA3AF"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   MaxWidth="400"
                                   TextWrapping="Wrap"/>
                        <Button Content="Clear Filters"
                                Command="{Binding ClearFiltersCommand}"
                                Classes="action-secondary"
                                HorizontalAlignment="Center"
                                Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Loading Overlay -->
                <Border Grid.Row="2"
                        Background="#CCF9FAFB"
                        IsVisible="{Binding IsBusy}">
                    <StackPanel VerticalAlignment="Center" 
                                HorizontalAlignment="Center"
                                Spacing="16">
                        <ProgressBar IsIndeterminate="True"
                                     Width="200"
                                     Height="4"
                                     Foreground="#3B82F6"/>
                        <TextBlock Text="Loading users..."
                                   FontSize="14"
                                   Foreground="#6B7280"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Footer -->
                <Border Grid.Row="3"
                        Background="#F9FAFB"
                        Padding="16"
                        CornerRadius="0,0,8,8"
                        BorderBrush="#E5E7EB"
                        BorderThickness="0,1,0,0">
                    <TextBlock FontSize="12" Foreground="#6B7280">
                        <Run Text="💡 Tip:"/>
                        <Run Text="Select a role from the dropdown before approving new users. The button will show 'Approve as [Role]'. Approved users can login immediately with their assigned role."/>
                    </TextBlock>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
