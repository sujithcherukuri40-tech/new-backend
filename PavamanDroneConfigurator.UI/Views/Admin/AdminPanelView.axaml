<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels.Admin"
             x:Class="PavamanDroneConfigurator.UI.Views.Admin.AdminPanelView"
             x:DataType="vm:AdminPanelViewModel"
             Background="#F9FAFB">

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <StackPanel Spacing="16">
            <TextBlock Text="?? User Management"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#111827"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Please use the Dashboard for user management."
                       FontSize="14"
                       Foreground="#6B7280"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Navigate to Admin ? Dashboard"
                       FontSize="13"
                       Foreground="#3B82F6"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
