<UserControl xmlns="https://github.com/avaloniaui"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels.Admin"
         xmlns:converters="using:PavamanDroneConfigurator.UI.Converters"
         x:Class="PavamanDroneConfigurator.UI.Views.Admin.FirmwareManagementPage"
         x:DataType="vm:FirmwareManagementViewModel">

<UserControl.Resources>
    <converters:VehicleTypeToIconConverter x:Key="VehicleTypeToIconConverter"/>
    <converters:VehicleTypeToBadgeColorConverter x:Key="VehicleTypeToBadgeColorConverter"/>
</UserControl.Resources>

    <UserControl.Styles>
        <!-- Admin Card Style -->
        <Style Selector="Border.admin-card">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="BoxShadow" Value="0 2 8 0 #10000000"/>
        </Style>
        
        <!-- Data Grid Style -->
        <Style Selector="DataGrid">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserReorderColumns" Value="True"/>
            <Setter Property="CanUserResizeColumns" Value="True"/>
        </Style>
        
        <!-- Action Button Style -->
        <Style Selector="Button.action-btn">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        
        <Style Selector="Button.action-btn.edit">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <Style Selector="Button.action-btn.delete">
            <Setter Property="Background" Value="{DynamicResource ErrorBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <Style Selector="Button.action-btn.download">
            <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">
        
        <!-- Page Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" Margin="32,24,32,20">
            <StackPanel Grid.Column="0">
                <TextBlock Text="&#x1F680; Pavaman Firmware Management"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryBrush}"/>
                <TextBlock Text="Upload, manage, and deploy custom Pavaman firmware to cloud"
                           FontSize="14"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,6,0,0"/>
            </StackPanel>
            
            <!-- Stats Cards -->
            <Border Grid.Column="1"
                    Background="{DynamicResource SuccessLightBrush}"
                    CornerRadius="10"
                    Padding="16,12"
                    Margin="0,0,12,0">
                <StackPanel Spacing="4">
                    <TextBlock Text="Total Firmwares"
                               FontSize="11"
                               Foreground="{DynamicResource SuccessDarkBrush}"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalFirmwareCount}"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{DynamicResource SuccessBrush}"/>
                </StackPanel>
            </Border>
            
            <Border Grid.Column="2"
                    Background="{DynamicResource InfoLightBrush}"
                    CornerRadius="10"
                    Padding="16,12">
                <StackPanel Spacing="4">
                    <TextBlock Text="Storage Used"
                               FontSize="11"
                               Foreground="{DynamicResource InfoDarkBrush}"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalStorageUsed}"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{DynamicResource InfoBrush}"/>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" Padding="32,0,32,24">
            <StackPanel Spacing="24">
                
                <!-- Upload New Firmware Card -->
                <Border Classes="admin-card">
                    <StackPanel Spacing="20">
                        <StackPanel Spacing="8">
                            <TextBlock Text="&#x1F4E4; Upload New Firmware"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Upload custom Pavaman firmware to make it available for all users"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                        
                        <!-- Upload Form -->
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="16" ColumnSpacing="16">
                            
                            <!-- Firmware Name -->
                            <TextBlock Grid.Column="0" Grid.Row="0"
                                       Text="Firmware Name"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            
                            <!-- Version -->
                            <TextBlock Grid.Column="1" Grid.Row="0"
                                       Text="Version *"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            
                            <!-- Firmware Name Input -->
                            <TextBox Grid.Column="0" Grid.Row="1"
                                     Text="{Binding NewFirmwareName}"
                                     Watermark="e.g., Pavaman AgriCopter"
                                     Height="44"
                                     CornerRadius="8"
                                     Padding="12"/>
                            
                            <!-- Version Input -->
                            <TextBox Grid.Column="1" Grid.Row="1"
                                     Text="{Binding NewFirmwareVersion}"
                                     Watermark="e.g., 1.0.0"
                                     Height="44"
                                     CornerRadius="8"
                                     Padding="12"/>
                            
                            <!-- Description -->
                            <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2" Spacing="12">
                                <TextBlock Text="Description"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBox Text="{Binding NewFirmwareDescription}"
                                         Watermark="Optional description..."
                                         Height="44"
                                         CornerRadius="8"
                                         Padding="12"/>
                            </StackPanel>
                        </Grid>
                        
                        <!-- File Selector -->
                        <StackPanel Spacing="12">
                            <TextBlock Text="Firmware File *"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBox Grid.Column="0"
                                             Text="{Binding SelectedFirmwareFileName}"
                                             IsReadOnly="True"
                                             Watermark="No file selected..."
                                             Height="52"
                                             CornerRadius="8,0,0,8"
                                             Padding="16"
                                             FontSize="14"/>
                                    <Button Grid.Column="1"
                                            Content="Browse Files"
                                            Background="{DynamicResource SecondaryBrush}"
                                            Foreground="White"
                                            Height="52"
                                            Padding="24,0"
                                            CornerRadius="0,8,8,0"
                                            BorderThickness="0"
                                            FontWeight="Bold"
                                            Click="BrowseFirmware_Click"/>
                                </Grid>
                            </StackPanel>
                        
                        <!-- Upload Progress -->
                        <StackPanel Spacing="8" IsVisible="{Binding IsUploading}">
                            <ProgressBar Value="{Binding UploadProgress}"
                                         Height="8"
                                         CornerRadius="4"
                                         Foreground="{DynamicResource SuccessBrush}"/>
                            <TextBlock Text="{Binding UploadStatusText}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                        
                        <!-- Upload Button -->
                        <Button Content="&#x2601; Upload to Cloud"
                                Background="{DynamicResource PrimaryBrush}"
                                Foreground="White"
                                Height="48"
                                CornerRadius="10"
                                FontSize="15"
                                FontWeight="Bold"
                                BorderThickness="0"
                                HorizontalAlignment="Stretch"
                                Command="{Binding UploadFirmwareCommand}"
                                IsEnabled="{Binding CanUpload}">
                            <Button.Styles>
                                <Style Selector="Button:pointerover">
                                    <Setter Property="Background" Value="{DynamicResource PrimaryDarkBrush}"/>
                                </Style>
                            </Button.Styles>
                        </Button>
                    </StackPanel>
                </Border>
                
                <!-- Existing Firmwares List -->
                <Border Classes="admin-card">
                    <StackPanel Spacing="20">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="8">
                                <TextBlock Text="&#x1F4C2; Uploaded Firmwares"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Manage all custom Pavaman firmwares available in the cloud"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                            
                            <!-- Refresh Button -->
                            <Button Grid.Column="1"
                                    Classes="action-btn"
                                    Background="{DynamicResource SecondaryBrush}"
                                    Foreground="White"
                                    Command="{Binding RefreshFirmwaresCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <PathIcon Data="M17.65 6.35A7.958 7.958 0 0 0 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08A5.99 5.99 0 0 1 12 18c-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"
                                              Width="14" Height="14"
                                              Foreground="White"/>
                                    <TextBlock Text="Refresh"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                        
                        <!-- Status Message -->
                        <Border Background="{DynamicResource InfoLightBrush}"
                                CornerRadius="8"
                                Padding="16,12"
                                IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                Margin="0,0,0,12">
                            <TextBlock Text="{Binding StatusMessage}"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"/>
                        </Border>
                        
                        <!-- Loading State -->
                        <Border Background="{DynamicResource InfoLightBrush}"
                                CornerRadius="8"
                                Padding="24,20"
                                IsVisible="{Binding IsLoadingFirmwares}">
                            <StackPanel Spacing="12" HorizontalAlignment="Center">
                                <TextBlock Text="&#x23F3; Loading firmwares..."
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource InfoBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Firmware Cards Grid -->
                        <ItemsControl ItemsSource="{Binding Firmwares}"
                                      IsVisible="{Binding !IsLoadingFirmwares}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Firmware Card -->
                                    <Border Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="20"
                                            Margin="0,0,16,16"
                                            Width="360"
                                            BoxShadow="0 2 8 0 #10000000">
                                        <Border.Styles>
                                            <Style Selector="Border:pointerover">
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                <Setter Property="BoxShadow" Value="0 4 12 0 #20000000"/>
                                            </Style>
                                        </Border.Styles>
                                        
                                        <StackPanel Spacing="16">
                                            <!-- Header with Vehicle Icon and Type -->
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <!-- Vehicle Icon based on type -->
                                                <Border Grid.Column="0"
                                                        Background="{DynamicResource PrimaryLightBrush}"
                                                        CornerRadius="12"
                                                        Padding="10"
                                                        Width="56"
                                                        Height="56">
                                                    <Image Source="{Binding VehicleType, Converter={StaticResource VehicleTypeToIconConverter}}"
                                                           Stretch="Uniform"/>
                                                </Border>
                                                
                                                <!-- Vehicle Type Badge -->
                                                <Border Grid.Column="2"
                                                        Background="{Binding VehicleType, Converter={StaticResource VehicleTypeToBadgeColorConverter}}"
                                                        CornerRadius="8"
                                                        Padding="12,6"
                                                        VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding VehicleType}"
                                                               FontSize="11"
                                                               FontWeight="Bold"
                                                               Foreground="White"/>
                                                </Border>
                                            </Grid>
                                            
                                            <!-- Firmware Name and Version -->
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding FirmwareName}"
                                                           FontSize="18"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxLines="1"/>
                                                <TextBlock Text="{Binding FirmwareVersion, StringFormat='Version {0}'}"
                                                           FontSize="13"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                            
                                            <!-- Description -->
                                            <TextBlock Text="{Binding FirmwareDescription}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap"
                                                       MaxLines="2"
                                                       TextTrimming="CharacterEllipsis"
                                                       IsVisible="{Binding FirmwareDescription, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                            
                                            <!-- Metadata Grid -->
                                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" RowSpacing="8" ColumnSpacing="12">
                                                <!-- File Size -->
                                                <StackPanel Grid.Column="0" Grid.Row="0" Spacing="2">
                                                    <TextBlock Text="File Size"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    <TextBlock Text="{Binding SizeDisplay}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                </StackPanel>
                                                
                                                <!-- Upload Date -->
                                                <StackPanel Grid.Column="1" Grid.Row="0" Spacing="2">
                                                    <TextBlock Text="Uploaded"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    <TextBlock Text="{Binding LastModified, StringFormat='{}{0:MMM dd, yyyy}'}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                </StackPanel>
                                                
                                                <!-- File Name -->
                                                <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Spacing="2">
                                                    <TextBlock Text="File Name"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    <TextBlock Text="{Binding FileName}"
                                                               FontSize="11"
                                                               FontFamily="Consolas"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Grid>
                                            
                                            <!-- Separator -->
                                            <Border Height="1" 
                                                    Background="{DynamicResource BorderBrush}"/>
                                            
                                            <!-- Action Buttons -->
                                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                                <!-- Download Button -->
                                                <Button Grid.Column="0"
                                                        Classes="action-btn download"
                                                        Height="36"
                                                        HorizontalAlignment="Stretch"
                                                        Command="{Binding $parent[UserControl].((vm:FirmwareManagementViewModel)DataContext).DownloadFirmwareCommand}"
                                                        CommandParameter="{Binding}">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <PathIcon Data="M19 12v7H5v-7H3v7c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2v-7h-2zm-6 .67l2.59-2.58L17 11.5l-5 5-5-5 1.41-1.41L11 12.67V3h2v9.67z"
                                                                  Width="14" Height="14"
                                                                  Foreground="White"/>
                                                        <TextBlock Text="Download" FontSize="12"/>
                                                    </StackPanel>
                                                </Button>
                                                
                                                <!-- Edit Button (Optional) -->
                                                <Button Grid.Column="1"
                                                        Width="36"
                                                        Height="36"
                                                        Classes="action-btn edit"
                                                        ToolTip.Tip="Edit Metadata"
                                                        Command="{Binding $parent[UserControl].((vm:FirmwareManagementViewModel)DataContext).EditFirmwareCommand}"
                                                        CommandParameter="{Binding}">
                                                    <PathIcon Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34a.9959.9959 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"
                                                              Width="16" Height="16"
                                                              Foreground="White"/>
                                                </Button>
                                                
                                                <!-- Delete Button -->
                                                <Button Grid.Column="2"
                                                        Width="36"
                                                        Height="36"
                                                        Classes="action-btn delete"
                                                        ToolTip.Tip="Delete Firmware"
                                                        Command="{Binding $parent[UserControl].((vm:FirmwareManagementViewModel)DataContext).DeleteFirmwareCommand}"
                                                        CommandParameter="{Binding}">
                                                    <PathIcon Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"
                                                              Width="16" Height="16"
                                                              Foreground="White"/>
                                                </Button>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <!-- Empty State -->
                        <Border Background="{DynamicResource WarningLightBrush}"
                                CornerRadius="8"
                                Padding="24,20"
                                IsVisible="{Binding HasNoFirmwares}">
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <TextBlock Text="&#x1F4E6;"
                                           FontSize="48"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="No firmwares uploaded yet"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource WarningDarkBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Upload your first custom firmware using the form above"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
                
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
