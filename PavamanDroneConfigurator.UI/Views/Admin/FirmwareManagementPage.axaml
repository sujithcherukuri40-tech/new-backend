<UserControl xmlns="https://github.com/avaloniaui"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels.Admin"
         xmlns:converters="using:PavamanDroneConfigurator.UI.Converters"
         x:Class="PavamanDroneConfigurator.UI.Views.Admin.FirmwareManagementPage"
         x:DataType="vm:FirmwareManagementViewModel">

<UserControl.Resources>
    <converters:VehicleTypeToIconConverter x:Key="VehicleTypeToIconConverter"/>
    <converters:VehicleTypeToBadgeColorConverter x:Key="VehicleTypeToBadgeColorConverter"/>
</UserControl.Resources>

    <UserControl.Styles>
        <!-- â•â• CLAYMORPHISM DESIGN SYSTEM â•â• -->

        <!-- Card (main sections) -->
        <Style Selector="Border.clay-card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="BoxShadow" Value="0 2 8 0 #10000000"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <!-- Firmware Card -->
        <Style Selector="Border.clay-firmware-card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BoxShadow" Value="0 1 6 0 #0C000000"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="6"/>
        </Style>
        <Style Selector="Border.clay-firmware-card:pointerover">
            <Setter Property="BoxShadow" Value="0 4 16 0 #16000000"/>
            <Setter Property="BorderBrush" Value="#C7D2FE"/>
        </Style>

        <!-- Download Button -->
        <Style Selector="Button.clay-download">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.clay-download:pointerover">
            <Setter Property="Background" Value="#059669"/>
        </Style>

        <!-- Delete Button (icon) -->
        <Style Selector="Button.clay-delete">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.clay-delete:pointerover">
            <Setter Property="Background" Value="#DC2626"/>
        </Style>

        <!-- Primary Button (upload etc.) -->
        <Style Selector="Button.clay-primary">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.clay-primary:pointerover">
            <Setter Property="Background" Value="#2563EB"/>
        </Style>
        <Style Selector="Button.clay-primary:disabled /template/ ContentPresenter">
            <Setter Property="Opacity" Value="0.45"/>
        </Style>

        <!-- Assign Button -->
        <Style Selector="Button.clay-assign">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Padding" Value="24,0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.clay-assign:pointerover">
            <Setter Property="Background" Value="#2563EB"/>
        </Style>
        <Style Selector="Button.clay-assign:disabled /template/ ContentPresenter">
            <Setter Property="Opacity" Value="0.4"/>
        </Style>

        <!-- Remove Button (text, in rows) -->
        <Style Selector="Button.clay-remove">
            <Setter Property="Background" Value="#FEE2E2"/>
            <Setter Property="Foreground" Value="#DC2626"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.clay-remove:pointerover">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Meta label / value -->
        <Style Selector="TextBlock.meta-label">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="LetterSpacing" Value="0.5"/>
        </Style>
        <Style Selector="TextBlock.meta-value">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#111827"/>
        </Style>

        <!-- Section title -->
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Assigned firmware row -->
        <Style Selector="Border.assigned-row">
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BoxShadow" Value="0 1 4 0 #10000000"/>
        </Style>

        <!-- Vehicle badge -->
        <Style Selector="Border.vehicle-badge">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" Background="#F9FAFB">

        <!-- â•â• PAGE HEADER â•â• -->
        <Border Grid.Row="0"
                Background="White"
                BoxShadow="0 2 16 0 #10000000"
                Padding="32,18,32,18">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="KFT Firmware Management"
                               FontSize="24"
                               FontWeight="ExtraBold"
                               Foreground="#1E1B4B"/>
                    <TextBlock Text="Upload, manage, and assign KFT firmware to users"
                               FontSize="13"
                               Foreground="#6B7280"/>
                </StackPanel>

                <!-- Firmwares stat -->
                <Border Grid.Column="1"
                        CornerRadius="12"
                        Padding="18,12"
                        Margin="0,0,14,0"
                        Background="#EEF2FF"
                        BoxShadow="0 2 8 0 #10000000">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Firmwares" FontSize="11" FontWeight="SemiBold" Foreground="#6C63FF"/>
                        <TextBlock Text="{Binding TotalFirmwareCount}" FontSize="24" FontWeight="ExtraBold" Foreground="#4338CA"/>
                    </StackPanel>
                </Border>

                <!-- Storage stat -->
                <Border Grid.Column="2"
                        CornerRadius="12"
                        Padding="18,12"
                        Background="#ECFDF5"
                        BoxShadow="0 2 8 0 #10000000">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Storage" FontSize="11" FontWeight="SemiBold" Foreground="#059669"/>
                        <TextBlock Text="{Binding TotalStorageUsed}" FontSize="24" FontWeight="ExtraBold" Foreground="#065F46"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- â•â• MAIN CONTENT â•â• -->
        <ScrollViewer Grid.Row="1" Padding="24,16,24,56"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="0">

                <!-- â”€â”€ UPLOAD FIRMWARE CARD â”€â”€ -->
                <Border Classes="clay-card">
                    <StackPanel Spacing="20">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border CornerRadius="12" Background="#EDE9FE" Width="40" Height="40">
                                <PathIcon Data="M9 16h6v-6h4l-7-7-7 7h4v6zm-4 2h14v2H5v-2z"
                                          Width="18" Height="18" Foreground="#6C63FF"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Spacing="2">
                                <TextBlock Text="Upload New Firmware" Classes="section-title"/>
                                <TextBlock Text="Upload custom KFT firmware to the cloud"
                                           FontSize="12" Foreground="#6B7280"/>
                            </StackPanel>
                        </StackPanel>

                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto"
                              RowSpacing="14" ColumnSpacing="16">
                            <TextBlock Grid.Column="0" Grid.Row="0" Text="Firmware Name *"
                                       FontWeight="SemiBold" FontSize="12" Foreground="#6B7280"/>
                            <TextBlock Grid.Column="1" Grid.Row="0" Text="Version *"
                                       FontWeight="SemiBold" FontSize="12" Foreground="#6B7280"/>
                            <TextBox Grid.Column="0" Grid.Row="1"
                                     Text="{Binding NewFirmwareName}"
                                     Watermark="e.g., KFT AgriCopter v2"
                                     Height="48" CornerRadius="12"
                                     Background="#F8F7FF" BorderBrush="#DDD8FF"
                                     BorderThickness="1.5" Padding="14,0"/>
                            <TextBox Grid.Column="1" Grid.Row="1"
                                     Text="{Binding NewFirmwareVersion}"
                                     Watermark="e.g., 2.1.0"
                                     Height="48" CornerRadius="12"
                                     Background="#F8F7FF" BorderBrush="#DDD8FF"
                                     BorderThickness="1.5" Padding="14,0"/>
                            <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2" Spacing="6">
                                <TextBlock Text="Description" FontWeight="SemiBold"
                                           FontSize="12" Foreground="#6B7280"/>
                                <TextBox Text="{Binding NewFirmwareDescription}"
                                         Watermark="Optional description..."
                                         Height="48" CornerRadius="12"
                                         Background="#F8F7FF" BorderBrush="#DDD8FF"
                                         BorderThickness="1.5" Padding="14,0"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Firmware File *" FontWeight="SemiBold"
                                       FontSize="12" Foreground="#6B7280"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBox Grid.Column="0"
                                         Text="{Binding SelectedFirmwareFileName}"
                                         IsReadOnly="True"
                                         Watermark="No file selected..."
                                         Height="52" CornerRadius="14,0,0,14"
                                         Background="#F8F7FF" BorderBrush="#DDD8FF"
                                         BorderThickness="1.5,1.5,0,1.5"
                                         Padding="14,0" FontSize="14"
                                         VerticalContentAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Content="Browse"
                                        Height="52" Padding="22,0"
                                        CornerRadius="0,14,14,0"
                                        BorderThickness="0"
                                        FontWeight="Bold" FontSize="13"
                                        Foreground="White"
                                        Background="#3B82F6"
                                        VerticalAlignment="Stretch"
                                        VerticalContentAlignment="Center"
                                        Click="BrowseFirmware_Click"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Spacing="8" IsVisible="{Binding IsUploading}">
                            <ProgressBar Value="{Binding UploadProgress}"
                                         Height="10" CornerRadius="6"
                                         Foreground="#6C63FF" Background="#EDE9FE"/>
                            <TextBlock Text="{Binding UploadStatusText}"
                                       FontSize="12" Foreground="#6B7280"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <Button Classes="clay-primary"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Height="52"
                                Command="{Binding UploadFirmwareCommand}"
                                IsEnabled="{Binding CanUpload}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="M9 16h6v-6h4l-7-7-7 7h4v6zm-4 2h14v2H5v-2z"
                                          Width="16" Height="16" Foreground="White"/>
                                <TextBlock Text="Upload to Cloud" FontSize="14" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- â”€â”€ FIRMWARES LIST CARD â”€â”€ -->
                <Border Classes="clay-card">
                    <StackPanel Spacing="18">

                        <!-- Header row -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                                <Border CornerRadius="12" Background="#E0F2FE" Width="40" Height="40">
                                    <PathIcon Data="M20 6h-2.18c.07-.44.18-.88.18-1.36C18 2.1 15.9 0 13.36 0c-1.46 0-2.73.67-3.6 1.72L9 3.5 8.24 1.72C7.37.67 6.1 0 4.64 0 2.1 0 0 2.1 0 4.64c0 .48.1.92.18 1.36H0l2 4h20l2-4h-4zM4 8h16v12H4V8z"
                                              Width="18" Height="18" Foreground="#0284C7"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Uploaded Firmwares" Classes="section-title"/>
                                    <TextBlock Text="Manage KFT firmwares available in the cloud"
                                               FontSize="12" Foreground="#6B7280"/>
                                </StackPanel>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    CornerRadius="10" Height="42" Padding="16,0"
                                    BorderThickness="0"
                                    FontWeight="SemiBold" FontSize="13"
                                    Foreground="#1E40AF"
                                    Background="#EEF2FF"
                                    Command="{Binding RefreshFirmwaresCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <PathIcon Data="M17.65 6.35A7.958 7.958 0 0 0 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08A5.99 5.99 0 0 1 12 18c-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"
                                              Width="14" Height="14" Foreground="#1E40AF"/>
                                    <TextBlock Text="Refresh"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Search bar -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="0">
                            <Border Grid.Column="0"
                                    CornerRadius="12,0,0,12"
                                    Width="48" Height="44"
                                    Background="#F8F7FF"
                                    BorderBrush="#DDD8FF"
                                    BorderThickness="1.5,1.5,0,1.5">
                                <PathIcon Data="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
                                          Width="15" Height="15" Foreground="#6C63FF"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBox Grid.Column="1"
                                     Text="{Binding FirmwareSearchText}"
                                     Watermark="Search by name or version..."
                                     Height="44" CornerRadius="0,12,12,0"
                                     Background="#F8F7FF"
                                     BorderBrush="#DDD8FF"
                                     BorderThickness="0,1.5,1.5,1.5"
                                     Padding="12,0" FontSize="13"/>
                        </Grid>

                        <!-- Status Message -->
                        <Border Background="#EEF2FF" CornerRadius="10" Padding="14,10"
                                IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBlock Text="{Binding StatusMessage}"
                                       FontSize="13" Foreground="#4338CA" TextWrapping="Wrap"/>
                        </Border>

                        <!-- Loading -->
                        <Border Background="#F5F3FF" CornerRadius="12" Padding="24,16"
                                IsVisible="{Binding IsLoadingFirmwares}">
                            <TextBlock Text="Loading firmwares..."
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="#6C63FF" HorizontalAlignment="Center"/>
                        </Border>

                        <!-- Firmware Cards Grid (bound to FilteredFirmwares) -->
                        <ItemsControl ItemsSource="{Binding FilteredFirmwares}"
                                      IsVisible="{Binding !IsLoadingFirmwares}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="clay-firmware-card" Margin="0,0,0,0">
                                        <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">

                                            <!-- Header: icon + badge -->
                                            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,14">
                                                <Border Width="56" Height="56" CornerRadius="12" Padding="8"
                                                        Background="#EEF2FF">
                                                    <Image Source="{Binding VehicleType, Converter={StaticResource VehicleTypeToIconConverter}}"
                                                           Stretch="Uniform"/>
                                                </Border>
                                                <Border Grid.Column="2"
                                                        Classes="vehicle-badge"
                                                        Background="{Binding VehicleType, Converter={StaticResource VehicleTypeToBadgeColorConverter}}"
                                                        VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding VehicleType}"
                                                               FontSize="11" FontWeight="Bold"
                                                               Foreground="White" LetterSpacing="0.3"/>
                                                </Border>
                                            </Grid>

                                            <!-- Name + Version -->
                                            <StackPanel Grid.Row="1" Spacing="4" Margin="0,0,0,12"
                                                        HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding FirmwareName}"
                                                           FontSize="17" FontWeight="Bold"
                                                           Foreground="#1E1B4B"
                                                           TextTrimming="CharacterEllipsis"
                                                           TextAlignment="Center"
                                                           MaxLines="1"
                                                           ToolTip.Tip="{Binding FirmwareName}"/>
                                                <TextBlock FontSize="13" Foreground="#6B7280"
                                                           TextAlignment="Center">
                                                    <Run Text="Version"/>
                                                    <Run Text="{Binding FirmwareVersion}"
                                                         FontWeight="SemiBold" Foreground="#4338CA"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- Description -->
                                            <TextBlock Grid.Row="2"
                                                       Text="{Binding FirmwareDescription}"
                                                       FontSize="12" LineHeight="18"
                                                       Foreground="#9CA3AF"
                                                       TextWrapping="Wrap" MaxLines="2"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Top" Margin="0,0,0,12"
                                                       IsVisible="{Binding FirmwareDescription, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                                            <!-- Metadata -->
                                            <Grid Grid.Row="3"
                                                  ColumnDefinitions="*,*"
                                                  RowDefinitions="Auto,Auto"
                                                  RowSpacing="10" ColumnSpacing="12"
                                                  Margin="0,0,0,16">
                                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                                                    <TextBlock Text="File Size" Classes="meta-label"/>
                                                    <TextBlock Text="{Binding SizeDisplay}" Classes="meta-value"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                                                    <TextBlock Text="Uploaded" Classes="meta-label"/>
                                                    <TextBlock Text="{Binding LastModified, StringFormat='{}{0:MMM dd, yyyy}'}"
                                                               Classes="meta-value"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Spacing="2">
                                                    <TextBlock Text="File" Classes="meta-label"/>
                                                    <TextBlock Text="{Binding FileName}"
                                                               FontSize="12"
                                                               FontFamily="Consolas, Courier New"
                                                               Foreground="#4338CA"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip.Tip="{Binding FileName}"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Actions: Download + Delete only (no edit) -->
                                            <Grid Grid.Row="4" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                                <Button Grid.Column="0"
                                                        Classes="clay-download"
                                                        Command="{Binding $parent[UserControl].((vm:FirmwareManagementViewModel)DataContext).DownloadFirmwareCommand}"
                                                        CommandParameter="{Binding}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <PathIcon Data="M19 12v7H5v-7H3v7c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2v-7h-2zm-6 .67l2.59-2.58L17 11.5l-5 5-5-5 1.41-1.41L11 12.67V3h2v9.67z"
                                                                  Width="15" Height="15" Foreground="White"/>
                                                        <TextBlock Text="Download" FontWeight="Bold"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Column="1"
                                                        Classes="clay-delete"
                                                        ToolTip.Tip="Delete Firmware"
                                                        Command="{Binding $parent[UserControl].((vm:FirmwareManagementViewModel)DataContext).DeleteFirmwareCommand}"
                                                        CommandParameter="{Binding}">
                                                    <PathIcon Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"
                                                              Width="16" Height="16" Foreground="White"/>
                                                </Button>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty State -->
                        <Border Background="#FFFBEB"
                                BorderBrush="#FDE68A" BorderThickness="1.5"
                                CornerRadius="18" Padding="24,20"
                                IsVisible="{Binding HasNoFirmwares}">
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <TextBlock Text="ðŸ“¦" FontSize="48" HorizontalAlignment="Center"/>
                                <TextBlock Text="No firmwares uploaded yet"
                                           FontSize="16" FontWeight="Bold"
                                           Foreground="#92400E" HorizontalAlignment="Center"/>
                                <TextBlock Text="Upload your first KFT firmware using the form above"
                                           FontSize="13" Foreground="#78716C"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- â”€â”€ USER FIRMWARE ASSIGNMENT CARD â”€â”€ -->
                <Border Classes="clay-card" Margin="0,0,0,0">
                    <StackPanel Spacing="20">

                        <!-- Title -->
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border CornerRadius="12" Background="#FCE7F3" Width="40" Height="40">
                                <PathIcon Data="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"
                                          Width="18" Height="18" Foreground="#DB2777"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Spacing="2">
                                <TextBlock Text="User Firmware Assignment" Classes="section-title"/>
                                <TextBlock Text="Assign specific firmware files to individual users"
                                           FontSize="12" Foreground="#6B7280"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Dropdowns + Assign Button -->
                        <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="16">

                            <!-- User Dropdown -->
                            <StackPanel Grid.Column="0" Spacing="8">
                                <TextBlock Text="Select User"
                                           FontSize="12" FontWeight="SemiBold" Foreground="#6B7280"/>
                                <ComboBox Height="52"
                                          CornerRadius="12"
                                          Background="#F8F7FF"
                                          BorderBrush="#DDD8FF"
                                          BorderThickness="1.5"
                                          HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding Users}"
                                          SelectedItem="{Binding SelectedUser}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding FullName}"
                                                           FontWeight="SemiBold" Foreground="#1E1B4B"/>
                                                <TextBlock Text="{Binding Email}"
                                                           FontSize="12" Foreground="#9CA3AF"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <!-- Firmware Dropdown -->
                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock Text="Select Firmware to Assign"
                                           FontSize="12" FontWeight="SemiBold" Foreground="#6B7280"/>
                                <ComboBox Height="52"
                                          CornerRadius="12"
                                          Background="#F8F7FF"
                                          BorderBrush="#DDD8FF"
                                          BorderThickness="1.5"
                                          HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding Firmwares}"
                                          SelectedItem="{Binding FirmwareToAssign}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding FirmwareName}"
                                                           FontWeight="SemiBold" Foreground="#1E1B4B"/>
                                                <TextBlock Text="{Binding FirmwareVersion}"
                                                           FontSize="12" Foreground="#9CA3AF"
                                                           VerticalAlignment="Center"/>
                                                <Border Background="{Binding VehicleType, Converter={StaticResource VehicleTypeToBadgeColorConverter}}"
                                                        CornerRadius="6" Padding="8,3">
                                                    <TextBlock Text="{Binding VehicleType}"
                                                               FontSize="10" FontWeight="Bold"
                                                               Foreground="White"/>
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <!-- Assign Button (Command handles enable/disable â€” no IsEnabled binding) -->
                            <StackPanel Grid.Column="2" Spacing="8">
                                <TextBlock Text=" " FontSize="12"/>
                                <Button Classes="clay-assign"
                                        Command="{Binding AssignFirmwareToUserCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <PathIcon Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"
                                                  Width="15" Height="15" Foreground="White"/>
                                        <TextBlock Text="Assign" FontWeight="Bold"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- Assign Status -->
                        <Border Background="#EEF2FF" CornerRadius="12" Padding="14,10"
                                IsVisible="{Binding AssignStatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBlock Text="{Binding AssignStatusMessage}"
                                       FontSize="13" Foreground="#4338CA"/>
                        </Border>

                        <!-- Divider -->
                        <Border Background="#EDE9FE" Height="1.5" CornerRadius="1"
                                IsVisible="{Binding SelectedUser, Converter={x:Static ObjectConverters.IsNotNull}}"/>

                        <!-- Assigned firmwares for selected user -->
                        <StackPanel Spacing="12"
                                    IsVisible="{Binding SelectedUser, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Assigned to:"
                                               FontSize="14" Foreground="#6B7280"
                                               VerticalAlignment="Center"/>
                                    <Border CornerRadius="10" Background="#EDE9FE" Padding="14,5">
                                        <TextBlock Text="{Binding SelectedUser.FullName}"
                                                   FontSize="14" FontWeight="Bold"
                                                   Foreground="#4338CA"/>
                                    </Border>
                                </StackPanel>
                                <Border Grid.Column="1"
                                        CornerRadius="10" Background="#FFF8C0" Padding="12,5"
                                        IsVisible="{Binding IsLoadingUserFirmwares}">
                                    <TextBlock Text="Loading..." FontSize="12" Foreground="#856404"/>
                                </Border>
                            </Grid>

                            <!-- No assignments -->
                            <Border Background="#F9FAFB"
                                    BorderBrush="#E5E7EB" BorderThickness="1.5"
                                    CornerRadius="14" Padding="16,14"
                                    IsVisible="{Binding HasNoUserFirmwares}">
                                <TextBlock Text="No firmware assigned to this user yet."
                                           FontSize="13" Foreground="#9CA3AF"
                                           HorizontalAlignment="Center"/>
                            </Border>

                            <!-- Assigned firmware rows -->
                            <ItemsControl ItemsSource="{Binding SelectedUserFirmwares}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Classes="assigned-row">
                                            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                                                <!-- Vehicle badge -->
                                                <Border Grid.Column="0"
                                                        Classes="vehicle-badge"
                                                        Background="{Binding VehicleType, Converter={StaticResource VehicleTypeToBadgeColorConverter}}"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding VehicleType}"
                                                               FontSize="11" FontWeight="Bold"
                                                               Foreground="White"/>
                                                </Border>
                                                <!-- Name + info -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                    <TextBlock Text="{Binding FirmwareName}"
                                                               FontWeight="SemiBold" FontSize="14"
                                                               Foreground="#1E1B4B"/>
                                                    <TextBlock FontSize="12" Foreground="#9CA3AF">
                                                        <Run Text="v"/>
                                                        <Run Text="{Binding FirmwareVersion}"/>
                                                        <Run Text=" Â· "/>
                                                        <Run Text="{Binding FileSizeDisplay}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <!-- Date -->
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding AssignedAt, StringFormat='{}{0:MMM dd, yyyy}'}"
                                                           FontSize="12" Foreground="#9CA3AF"
                                                           VerticalAlignment="Center"/>
                                                <!-- Remove -->
                                                <Button Grid.Column="3"
                                                        Classes="clay-remove"
                                                        ToolTip.Tip="Remove assignment"
                                                        Command="{Binding $parent[UserControl].((vm:FirmwareManagementViewModel)DataContext).RemoveUserFirmwareCommand}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Text="Remove"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

