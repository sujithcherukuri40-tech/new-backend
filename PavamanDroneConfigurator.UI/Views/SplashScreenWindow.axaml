<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="PavamanDroneConfigurator.UI.Views.SplashScreenWindow"
        x:DataType="vm:SplashScreenViewModel"
        Title="Pavaman Aviation Drone Configurator"
        Width="900"
        Height="600"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        ShowInTaskbar="False"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent">

    <Window.Styles>
        <Style Selector="Border.splash-container">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="BoxShadow" Value="0 25 50 -12 #40000000"/>
        </Style>

        <Style Selector="TextBlock.loading-text">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="TextBlock.version-text">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#E0E7FF"/>
        </Style>

        <Style Selector="ProgressBar.splash-progress">
            <Setter Property="Foreground">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                        <GradientStop Color="#3B82F6" Offset="0"/>
                        <GradientStop Color="#60A5FA" Offset="0.5"/>
                        <GradientStop Color="#3B82F6" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Background" Value="#30FFFFFF"/>
            <Setter Property="Height" Value="6"/>
            <Setter Property="CornerRadius" Value="3"/>
        </Style>
    </Window.Styles>

    <Border Classes="splash-container" ClipToBounds="True">
        <Grid>
            <Image Source="avares://PavamanDroneConfigurator.UI/Assets/Images/splash.png" 
                   Stretch="UniformToFill"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
            
            <Border Background="#40000000" CornerRadius="20"/>
            
            <Grid RowDefinitions="*,Auto">
                <Border Grid.Row="1" 
                        Padding="40,20,40,30"
                        CornerRadius="0,0,20,20">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                            <GradientStop Color="#00000000" Offset="0"/>
                            <GradientStop Color="#90000000" Offset="0.3"/>
                            <GradientStop Color="#C0000000" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    
                    <StackPanel Spacing="16" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding LoadingMessage}" 
                                   Classes="loading-text"
                                   HorizontalAlignment="Center"/>

                        <ProgressBar Classes="splash-progress"
                                     Width="400"
                                     IsIndeterminate="{Binding IsIndeterminate}"
                                     Value="{Binding Progress}"
                                     Maximum="100"/>
                        
                        <StackPanel Orientation="Horizontal" 
                                    Spacing="20" 
                                    HorizontalAlignment="Center">
                            <TextBlock Text="{Binding VersionText}" 
                                       Classes="version-text"/>
                            <TextBlock Text="Pavaman Aviation 2025" 
                                       Classes="version-text"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>