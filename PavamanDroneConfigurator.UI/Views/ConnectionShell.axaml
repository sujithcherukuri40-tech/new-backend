<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="550"
        x:Class="PavamanDroneConfigurator.UI.Views.ConnectionShell"
        x:DataType="vm:ConnectionShellViewModel"
        Title="Pavaman Drone Configurator - Connect"
        Width="800"
        Height="550"
        MinWidth="600"
        MinHeight="450"
        CanResize="True"
        WindowStartupLocation="CenterScreen"
        Icon="avares://PavamanDroneConfigurator.UI/Assets/Images/logo.ico"
        Background="#F8FAFC">

    <Window.Styles>
        <Style Selector="Window">
            <Setter Property="FontFamily" Value="Inter, Segoe UI, San Francisco, Helvetica Neue, Arial"/>
        </Style>

        <!-- Back Button Style -->
        <Style Selector="Button.btn-back">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.btn-back:pointerover">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
        </Style>

        <Style Selector="Button.btn-cyan">
            <Setter Property="Background" Value="#38BDF8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.btn-cyan:pointerover">
            <Setter Property="Background" Value="#0EA5E9"/>
        </Style>
        <Style Selector="Button.btn-cyan:disabled">
            <Setter Property="Background" Value="#CBD5E1"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
        </Style>

        <Style Selector="Button.btn-cyan-outline">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#38BDF8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#38BDF8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.btn-cyan-outline:pointerover">
            <Setter Property="Background" Value="#F0F9FF"/>
        </Style>
        <Style Selector="Button.btn-cyan-outline:disabled">
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
        </Style>

        <Style Selector="ComboBox.conn-combo">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="MinHeight" Value="44"/>
        </Style>

        <Style Selector="TextBox.conn-input">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="MinHeight" Value="44"/>
        </Style>

        <Style Selector="TextBlock.section-title-cyan">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#38BDF8"/>
            <Setter Property="LetterSpacing" Value="0.5"/>
        </Style>

        <Style Selector="TextBlock.conn-label">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Card Style -->
        <Style Selector="Border.conn-card">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*">
        
        <!-- Header with Back Button -->
        <Border Grid.Row="0"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="0,0,0,1"
                Padding="24,16">
            <Grid ColumnDefinitions="Auto,*,Auto">
                
                <!-- Back Button -->
                <Button Grid.Column="0"
                        Classes="btn-back"
                        Command="{Binding CancelCommand}"
                        ToolTip.Tip="Return to Entry Page">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"
                                  Width="14" Height="14"
                                  Foreground="#64748B"/>
                        <TextBlock Text="Back" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <!-- Center Title -->
                <StackPanel Grid.Column="1" 
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="12">
                    <Border Width="36"
                            Height="36"
                            CornerRadius="10"
                            Background="#E0F2FE">
                        <Image Source="avares://PavamanDroneConfigurator.UI/Assets/Images/logo.ico"
                               Stretch="Uniform"
                               Margin="6"/>
                    </Border>
                    <TextBlock Text="Connect to Drone"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#0F172A"
                               VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- Placeholder for symmetry -->
                <Border Grid.Column="2" Width="80"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="40,24,40,32">
            
            <StackPanel Spacing="20" MaxWidth="600" HorizontalAlignment="Center">
                
                <!-- Connection Type & Buttons Card -->
                <Border Classes="conn-card">
                    <StackPanel Spacing="16">
                        
                        <!-- Section Title -->
                        <TextBlock Text="COMM LINK SETTINGS" 
                                   Classes="section-title-cyan"/>
                        
                        <!-- Connection Type & Action Buttons -->
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                            <ComboBox Grid.Column="0"
                                      Classes="conn-combo"
                                      Width="140"
                                      SelectedIndex="{Binding ConnectionType, Converter={x:Static vm:ConnectionTypeToIndexConverter.Instance}}"
                                      IsEnabled="{Binding !IsConnected}">
                                <ComboBoxItem Content="Serial"/>
                                <ComboBoxItem Content="TCP"/>
                                <ComboBoxItem Content="Bluetooth"/>
                            </ComboBox>

                            <Border Grid.Column="1"/>

                            <Button Grid.Column="2"
                                    Content="Connect"
                                    Classes="btn-cyan"
                                    Command="{Binding ConnectCommand}"
                                    IsEnabled="{Binding CanConnect}"/>

                            <Button Grid.Column="3"
                                    Content="Disconnect"
                                    Classes="btn-cyan-outline"
                                    Command="{Binding DisconnectCommand}"
                                    IsEnabled="{Binding IsConnected}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Serial Connection Options -->
                <Border Classes="conn-card" IsVisible="{Binding IsSerialConnection}">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Serial Port" Classes="conn-label"/>
                            <ComboBox Classes="conn-combo"
                                      ItemsSource="{Binding AvailableSerialPorts}"
                                      SelectedItem="{Binding SelectedSerialPort}"
                                      IsEnabled="{Binding !IsConnected}"
                                      HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FriendlyName}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Baud Rate" Classes="conn-label"/>
                            <ComboBox Classes="conn-combo"
                                      ItemsSource="{Binding AvailableBaudRates}"
                                      SelectedItem="{Binding SelectedBaudRate}"
                                      IsEnabled="{Binding !IsConnected}"
                                      HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Display}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- TCP Connection Options -->
                <Border Classes="conn-card" IsVisible="{Binding IsTcpConnection}">
                    <Grid ColumnDefinitions="2*,*" ColumnSpacing="16">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="IP Address" Classes="conn-label"/>
                            <TextBox Classes="conn-input"
                                     Text="{Binding IpAddress}"
                                     IsEnabled="{Binding !IsConnected}"
                                     Watermark="192.168.1.100"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="Port" Classes="conn-label"/>
                            <TextBox Classes="conn-input"
                                     Text="{Binding TcpPort}"
                                     IsEnabled="{Binding !IsConnected}"
                                     Watermark="5760"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Bluetooth Connection Options -->
                <Border Classes="conn-card" IsVisible="{Binding IsBluetoothConnection}">
                    <StackPanel Spacing="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" 
                                       Text="Bluetooth Device" 
                                       Classes="conn-label" 
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1" 
                                    Content="Scan Devices" 
                                    Classes="btn-cyan-outline"
                                    Command="{Binding ScanBluetoothDevicesCommand}"
                                    IsEnabled="{Binding !IsConnected}"
                                    Padding="16,8"/>
                        </Grid>
                        <ComboBox Classes="conn-combo"
                                  ItemsSource="{Binding AvailableBluetoothDevices}"
                                  SelectedItem="{Binding SelectedBluetoothDevice}"
                                  IsEnabled="{Binding !IsConnected}"
                                  HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DeviceName}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding DeviceAddress}" FontSize="12" Foreground="#94A3B8"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Parameter Download Progress -->
                <Border Background="#E0F2FE"
                        CornerRadius="12"
                        Padding="20"
                        IsVisible="{Binding IsDownloadingParameters}">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="&#x1F4E5;" FontSize="16"/>
                            <TextBlock Text="Downloading Parameters" 
                                       FontWeight="SemiBold" 
                                       FontSize="14" 
                                       Foreground="#0F172A"/>
                            <TextBlock Text="{Binding ParameterProgressText}" 
                                       FontWeight="Bold" 
                                       FontSize="14" 
                                       Foreground="#0EA5E9"/>
                        </StackPanel>
                        <ProgressBar Value="{Binding ParameterProgressPercentage}" 
                                     Maximum="100" 
                                     Height="8"
                                     CornerRadius="4"
                                     Foreground="#38BDF8"
                                     Background="#BFDBFE"/>
                    </StackPanel>
                </Border>

                <!-- Status Message -->
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="14"
                           Foreground="#64748B"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
