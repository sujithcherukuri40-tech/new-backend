<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels"
             x:Class="PavamanDroneConfigurator.UI.Views.MotorEscPage"
             x:DataType="vm:MotorEscPageViewModel">

    <UserControl.Styles>
        <!-- macOS-Inspired Safety-Critical Design System -->
        
        <!-- Page Title -->
        <Style Selector="TextBlock.page-title">
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1D1D1F"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        
        <!-- Page Subtitle -->
        <Style Selector="TextBlock.page-subtitle">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#86868B"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
        
        <!-- Section Card -->
        <Style Selector="Border.section-card">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D2D2D7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BoxShadow" Value="0 1 2 0 #0A000000"/>
        </Style>
        
        <!-- Section Title -->
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1D1D1F"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        
        <!-- Field Label -->
        <Style Selector="TextBlock.field-label">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#1D1D1F"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="90"/>
        </Style>
        
        <!-- Helper Text -->
        <Style Selector="TextBlock.helper-text">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#86868B"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        
        <!-- Flat Buttons (macOS style) -->
        <Style Selector="Button.flat-button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#0066CC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <Style Selector="Button.flat-button:pointerover">
            <Setter Property="Background" Value="#F5F5F7"/>
        </Style>
        
        <!-- Stop All Button (Red, Critical) -->
        <Style Selector="Button.stop-button">
            <Setter Property="Background" Value="#FF3B30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <Style Selector="Button.stop-button:pointerover">
            <Setter Property="Background" Value="#E02020"/>
        </Style>
        
        <!-- Primary Action Button -->
        <Style Selector="Button.primary-button">
            <Setter Property="Background" Value="#0066CC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <Style Selector="Button.primary-button:pointerover">
            <Setter Property="Background" Value="#0055B3"/>
        </Style>
        
        <!-- Safety Readiness Card -->
        <Style Selector="Border.safety-card">
            <Setter Property="Background" Value="#FFF9ED"/>
            <Setter Property="BorderBrush" Value="#FFCC00"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        
        <!-- Safety Checklist Item -->
        <Style Selector="CheckBox.safety-check">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1D1D1F"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        
        <!-- Armed State Warning -->
        <Style Selector="Border.armed-warning">
            <Setter Property="Background" Value="#FFE5E5"/>
            <Setter Property="BorderBrush" Value="#FF3B30"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,10"/>
        </Style>
        
        <!-- Motor Slider Row -->
        <Style Selector="Border.motor-row">
            <Setter Property="Background" Value="#F5F5F7"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,20"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="MinHeight" Value="56"/>
        </Style>
        
        <Style Selector="Border.motor-row.active">
            <Setter Property="Background" Value="#E8F4FD"/>
            <Setter Property="BorderBrush" Value="#0066CC"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        
        <!-- Slider (macOS style) -->
        <Style Selector="Slider">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        
        <!-- ComboBox (macOS style) -->
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D2D2D7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        
        <!-- NumericUpDown (macOS style) -->
        <Style Selector="NumericUpDown">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        
        <!-- ESC Calibration Step -->
        <Style Selector="Border.esc-step">
            <Setter Property="Background" Value="#F5F5F7"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,32,40,40" MaxWidth="1200" Spacing="24">
            
            <!-- HEADER -->
            <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0" Spacing="0">
                    <TextBlock Classes="page-title" Text="Motor Test &amp; ESC"/>
                    <TextBlock Classes="page-subtitle" Text="Test motors individually and calibrate ESCs"/>
                </StackPanel>
                
                <Button Grid.Column="1" Classes="stop-button" Command="{Binding StopAllMotorsCommand}" Margin="0,0,8,0">
                    <TextBlock Text="STOP ALL"/>
                </Button>
                
                <Button Grid.Column="2" Classes="flat-button" Command="{Binding RefreshCommand}">
                    <TextBlock Text="Refresh"/>
                </Button>
            </Grid>

            <!-- ARMED STATE WARNING (if vehicle is armed) -->
            <Border Classes="armed-warning" IsVisible="{Binding IsVehicleArmed}">
                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#1D1D1F">
                    <Run Text="Motor testing disabled while vehicle is armed"/>
                </TextBlock>
            </Border>

            <!-- SAFETY READINESS CARD (Embedded, Professional) -->
            <Border Classes="section-card">
                <StackPanel Spacing="14">
                    <TextBlock Classes="section-title" Text="Safety Readiness"/>
                    
                    <Border Classes="safety-card">
                        <StackPanel Spacing="10">
                            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#1D1D1F">
                                Confirm safety checks before enabling motor controls:
                            </TextBlock>
                            
                            <CheckBox Classes="safety-check" IsChecked="{Binding PropellersRemoved}">
                                <TextBlock Text="Propellers removed"/>
                            </CheckBox>
                            
                            <CheckBox Classes="safety-check" IsChecked="{Binding VehicleSecured}">
                                <TextBlock Text="Vehicle secured (cannot move or tip)"/>
                            </CheckBox>
                            
                            <CheckBox Classes="safety-check" IsChecked="{Binding TestAreaClear}">
                                <TextBlock Text="Test area clear"/>
                            </CheckBox>
                            
                            <CheckBox Classes="safety-check" IsChecked="{Binding EmergencyStopReady}">
                                <TextBlock Text="Emergency stop accessible"/>
                            </CheckBox>
                        </StackPanel>
                    </Border>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                        <Button Classes="primary-button" 
                                Command="{Binding AcknowledgeSafetyCommand}"
                                IsEnabled="{Binding CanAcknowledgeSafety}">
                            <TextBlock Text="Safety Checks Complete"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- MOTOR TEST SECTION -->
            <Border Classes="section-card">
                <StackPanel Spacing="16">
                    <TextBlock Classes="section-title" Text="Motor Test"/>
                    
                    <!-- Test Duration Control -->
                    <Grid ColumnDefinitions="Auto,*,60,Auto">
                        <TextBlock Grid.Column="0" Classes="field-label" Text="Duration" Width="70" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" 
                                Value="{Binding TestDuration}" 
                                Minimum="0.5" Maximum="5" 
                                TickFrequency="0.5"
                                IsSnapToTickEnabled="True"
                                VerticalAlignment="Center"
                                Margin="8,0,16,0"/>
                        <TextBlock Grid.Column="2" 
                                   Text="{Binding TestDuration, StringFormat={}{0:F1}s}" 
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"
                                   FontSize="13"
                                   Foreground="#1D1D1F"/>
                        
                        <Button Grid.Column="3" 
                                Classes="flat-button" 
                                Command="{Binding TestAllMotorsCommand}"
                                IsEnabled="{Binding SlidersEnabled}"
                                Margin="20,0,0,0">
                            <TextBlock Text="Test All Sequential"/>
                        </Button>
                    </Grid>
                    
                    <!-- Motor Sliders -->
                    <StackPanel Margin="0,8,0,0" IsEnabled="{Binding SlidersEnabled}">
                        
                        <!-- Motor 1 -->
                        <Border Classes="motor-row" Classes.active="{Binding Motor1Testing}">
                            <Grid ColumnDefinitions="80,*,60">
                                <TextBlock Grid.Column="0" Text="Motor 1" FontSize="13" FontWeight="Medium" Foreground="#1D1D1F" VerticalAlignment="Center"/>
                                <Slider Grid.Column="1" 
                                        Value="{Binding Motor1Throttle}" 
                                        Minimum="0" Maximum="20"
                                        VerticalAlignment="Center"
                                        Margin="8,0,16,0"/>
                                <TextBlock Grid.Column="2" 
                                           Text="{Binding Motor1Throttle, StringFormat={}{0:F0}%}" 
                                           VerticalAlignment="Center" 
                                           HorizontalAlignment="Right"
                                           FontSize="13"
                                           Foreground="#1D1D1F"/>
                            </Grid>
                        </Border>
                        
                        <!-- Motor 2 -->
                        <Border Classes="motor-row" Classes.active="{Binding Motor2Testing}">
                            <Grid ColumnDefinitions="80,*,60">
                                <TextBlock Grid.Column="0" Text="Motor 2" FontSize="13" FontWeight="Medium" Foreground="#1D1D1F" VerticalAlignment="Center"/>
                                <Slider Grid.Column="1" 
                                        Value="{Binding Motor2Throttle}" 
                                        Minimum="0" Maximum="20"
                                        VerticalAlignment="Center"
                                        Margin="8,0,16,0"/>
                                <TextBlock Grid.Column="2" 
                                           Text="{Binding Motor2Throttle, StringFormat={}{0:F0}%}" 
                                           VerticalAlignment="Center" 
                                           HorizontalAlignment="Right"
                                           FontSize="13"
                                           Foreground="#1D1D1F"/>
                            </Grid>
                        </Border>
                        
                        <!-- Motor 3 -->
                        <Border Classes="motor-row" Classes.active="{Binding Motor3Testing}">
                            <Grid ColumnDefinitions="80,*,60">
                                <TextBlock Grid.Column="0" Text="Motor 3" FontSize="13" FontWeight="Medium" Foreground="#1D1D1F" VerticalAlignment="Center"/>
                                <Slider Grid.Column="1" 
                                        Value="{Binding Motor3Throttle}" 
                                        Minimum="0" Maximum="20"
                                        VerticalAlignment="Center"
                                        Margin="8,0,16,0"/>
                                <TextBlock Grid.Column="2" 
                                           Text="{Binding Motor3Throttle, StringFormat={}{0:F0}%}" 
                                           VerticalAlignment="Center" 
                                           HorizontalAlignment="Right"
                                           FontSize="13"
                                           Foreground="#1D1D1F"/>
                            </Grid>
                        </Border>
                        
                        <!-- Motor 4 -->
                        <Border Classes="motor-row" Classes.active="{Binding Motor4Testing}">
                            <Grid ColumnDefinitions="80,*,60">
                                <TextBlock Grid.Column="0" Text="Motor 4" FontSize="13" FontWeight="Medium" Foreground="#1D1D1F" VerticalAlignment="Center"/>
                                <Slider Grid.Column="1" 
                                        Value="{Binding Motor4Throttle}" 
                                        Minimum="0" Maximum="20"
                                        VerticalAlignment="Center"
                                        Margin="8,0,16,0"/>
                                <TextBlock Grid.Column="2" 
                                           Text="{Binding Motor4Throttle, StringFormat={}{0:F0}%}" 
                                           VerticalAlignment="Center" 
                                           HorizontalAlignment="Right"
                                           FontSize="13"
                                           Foreground="#1D1D1F"/>
                            </Grid>
                        </Border>
                        
                        <!-- Motor 5 -->
                        <Border Classes="motor-row" Classes.active="{Binding Motor5Testing}">
                            <Grid ColumnDefinitions="80,*,60">
                                <TextBlock Grid.Column="0" Text="Motor 5" FontSize="13" FontWeight="Medium" Foreground="#1D1D1F" VerticalAlignment="Center"/>
                                <Slider Grid.Column="1" 
                                        Value="{Binding Motor5Throttle}" 
                                        Minimum="0" Maximum="20"
                                        VerticalAlignment="Center"
                                        Margin="8,0,16,0"/>
                                <TextBlock Grid.Column="2" 
                                           Text="{Binding Motor5Throttle, StringFormat={}{0:F0}%}" 
                                           VerticalAlignment="Center" 
                                           HorizontalAlignment="Right"
                                           FontSize="13"
                                           Foreground="#1D1D1F"/>
                            </Grid>
                        </Border>
                        
                        <!-- Motor 6 -->
                        <Border Classes="motor-row" Classes.active="{Binding Motor6Testing}">
                            <Grid ColumnDefinitions="80,*,60">
                                <TextBlock Grid.Column="0" Text="Motor 6" FontSize="13" FontWeight="Medium" Foreground="#1D1D1F" VerticalAlignment="Center"/>
                                <Slider Grid.Column="1" 
                                        Value="{Binding Motor6Throttle}" 
                                        Minimum="0" Maximum="20"
                                        VerticalAlignment="Center"
                                        Margin="8,0,16,0"/>
                                <TextBlock Grid.Column="2" 
                                           Text="{Binding Motor6Throttle, StringFormat={}{0:F0}%}" 
                                           VerticalAlignment="Center" 
                                           HorizontalAlignment="Right"
                                           FontSize="13"
                                           Foreground="#1D1D1F"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                    
                    <TextBlock Classes="helper-text" IsVisible="{Binding !SlidersEnabled}">
                        Complete safety checks above to enable motor testing
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- ESC CALIBRATION SECTION (Guided Inline Flow) -->
            <Border Classes="section-card">
                <StackPanel Spacing="16">
                    <TextBlock Classes="section-title" Text="ESC Calibration"/>
                    
                    <!-- Step 1 -->
                    <Border Classes="esc-step">
                        <StackPanel Spacing="6">
                            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#1D1D1F">
                                Step 1: Preparation
                            </TextBlock>
                            <TextBlock Classes="helper-text">
                                Disconnect battery and ensure all propellers are removed
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    
                    <!-- Step 2 -->
                    <Border Classes="esc-step">
                        <StackPanel Spacing="6">
                            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#1D1D1F">
                                Step 2: Start Calibration
                            </TextBlock>
                            <TextBlock Classes="helper-text">
                                Click Calibrate, then disconnect USB. Full throttle will be sent to ESCs.
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    
                    <!-- Step 3 -->
                    <Border Classes="esc-step">
                        <StackPanel Spacing="6">
                            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#1D1D1F">
                                Step 3: Connect Battery
                            </TextBlock>
                            <TextBlock Classes="helper-text">
                                Connect battery. ESCs will detect high throttle and enter calibration mode.
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    
                    <!-- Step 4 -->
                    <Border Classes="esc-step">
                        <StackPanel Spacing="6">
                            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#1D1D1F">
                                Step 4: Complete
                            </TextBlock>
                            <TextBlock Classes="helper-text">
                                ESCs will beep. Disconnect battery, power cycle normally to finish.
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    
                    <!-- Action Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
                        <Button Classes="flat-button" 
                                Command="{Binding CancelEscCalibrationCommand}"
                                IsVisible="{Binding EscCalibrationPending}">
                            <TextBlock Text="Cancel"/>
                        </Button>
                        
                        <Button Classes="primary-button" 
                                Command="{Binding StartEscCalibrationCommand}"
                                IsEnabled="{Binding CanStartEscCalibration}">
                            <TextBlock Text="Calibrate"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- MOTOR SETTINGS SECTION -->
            <Border Classes="section-card">
                <StackPanel Spacing="16">
                    <TextBlock Classes="section-title" Text="Motor Settings"/>
                    
                    <Grid ColumnDefinitions="*,20,*" RowDefinitions="Auto,Auto,Auto,Auto">
                        
                        <!-- Left Column -->
                        <StackPanel Grid.Column="0" Grid.Row="0" Spacing="12">
                            <Grid ColumnDefinitions="120,*">
                                <TextBlock Grid.Column="0" Classes="field-label" Width="120" Text="Output Type"/>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding OutputTypeOptions}"
                                          SelectedItem="{Binding SelectedOutputType}"
                                          DisplayMemberBinding="{Binding Label}"/>
                            </Grid>
                            
                            <Grid ColumnDefinitions="120,*">
                                <TextBlock Grid.Column="0" Classes="field-label" Width="120" Text="PWM Min"/>
                                <NumericUpDown Grid.Column="1"
                                               Value="{Binding PwmMin}"
                                               Minimum="800" Maximum="1500"
                                               Increment="10"
                                               FormatString="F0"/>
                            </Grid>
                            
                            <Grid ColumnDefinitions="120,*">
                                <TextBlock Grid.Column="0" Classes="field-label" Width="120" Text="PWM Max"/>
                                <NumericUpDown Grid.Column="1"
                                               Value="{Binding PwmMax}"
                                               Minimum="1500" Maximum="2200"
                                               Increment="10"
                                               FormatString="F0"/>
                            </Grid>
                        </StackPanel>
                        
                        <!-- Right Column -->
                        <StackPanel Grid.Column="2" Grid.Row="0" Spacing="12">
                            <Grid ColumnDefinitions="120,*">
                                <TextBlock Grid.Column="0" Classes="field-label" Width="120" Text="Spin Armed"/>
                                <NumericUpDown Grid.Column="1"
                                               Value="{Binding SpinArmed}"
                                               Minimum="0" Maximum="0.3"
                                               Increment="0.01"
                                               FormatString="F2"/>
                            </Grid>
                            
                            <Grid ColumnDefinitions="120,*">
                                <TextBlock Grid.Column="0" Classes="field-label" Width="120" Text="Spin Min"/>
                                <NumericUpDown Grid.Column="1"
                                               Value="{Binding SpinMin}"
                                               Minimum="0" Maximum="0.5"
                                               Increment="0.01"
                                               FormatString="F2"/>
                            </Grid>
                            
                            <Grid ColumnDefinitions="120,*">
                                <TextBlock Grid.Column="0" Classes="field-label" Width="120" Text="Thrust Hover"/>
                                <NumericUpDown Grid.Column="1"
                                               Value="{Binding ThrustHover}"
                                               Minimum="0.1" Maximum="0.8"
                                               Increment="0.01"
                                               FormatString="F2"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Validation Message -->
                    <TextBlock Classes="helper-text" 
                               Foreground="#FF3B30"
                               IsVisible="{Binding HasValidationWarnings}">
                        <Run Text="{Binding ValidationMessage}"/>
                    </TextBlock>
                    
                    <!-- Save Button -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                        <Button Classes="primary-button" 
                                Command="{Binding SaveSettingsCommand}"
                                IsEnabled="{Binding CanSaveSettings}">
                            <TextBlock Text="Save Settings"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- RECOMMENDATION (Single Line) -->
            <Border Background="#F5F5F7" BorderBrush="#D2D2D7" BorderThickness="1" CornerRadius="8" Padding="14,10">
                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#1D1D1F">
                    <Run FontWeight="SemiBold">Note:</Run>
                    <Run Text=" Always test motors at low throttle first. If a motor spins incorrectly, swap two motor wires or change direction in ESC configurator."/>
                </TextBlock>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
