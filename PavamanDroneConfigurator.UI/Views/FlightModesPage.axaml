<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels"
             xmlns:converters="using:PavamanDroneConfigurator.UI.Converters"
             x:Class="PavamanDroneConfigurator.UI.Views.FlightModesPage"
             x:DataType="vm:FlightModePageViewModel">

    <UserControl.Styles>
        <!-- macOS-Inspired Design System -->
        
        <!-- Page Title -->
        <Style Selector="TextBlock.page-title">
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1D1D1F"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        
        <!-- Page Subtitle -->
        <Style Selector="TextBlock.page-subtitle">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#86868B"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
        
        <!-- Section Card Container -->
        <Style Selector="Border.section-card">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D2D2D7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BoxShadow" Value="0 1 2 0 #0A000000"/>
        </Style>
        
        <!-- Section Title -->
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1D1D1F"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        
        <!-- Helper Text -->
        <Style Selector="TextBlock.helper-text">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#86868B"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        
        <!-- Field Label -->
        <Style Selector="TextBlock.field-label">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#1D1D1F"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        
        <!-- PWM Range Label -->
        <Style Selector="TextBlock.pwm-range">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#86868B"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        
        <!-- Flat Buttons (macOS style) -->
        <Style Selector="Button.flat-button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#0066CC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <Style Selector="Button.flat-button:pointerover">
            <Setter Property="Background" Value="#F5F5F7"/>
        </Style>
        
        <Style Selector="Button.flat-button:pressed">
            <Setter Property="Background" Value="#E8E8ED"/>
        </Style>
        
        <!-- Primary Button (macOS blue) -->
        <Style Selector="Button.primary-button">
            <Setter Property="Background" Value="#0066CC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <Style Selector="Button.primary-button:pointerover">
            <Setter Property="Background" Value="#0055B3"/>
        </Style>
        
        <Style Selector="Button.primary-button:pressed">
            <Setter Property="Background" Value="#004999"/>
        </Style>
        
        <!-- ComboBox (macOS style) -->
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D2D2D7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        
        <Style Selector="ComboBox:pointerover /template/ Border#Background">
            <Setter Property="BorderBrush" Value="#A1A1A6"/>
        </Style>
        
        <!-- Mode Card -->
        <Style Selector="Border.mode-card">
            <Setter Property="Background" Value="#F5F5F7"/>
            <Setter Property="BorderBrush" Value="#D2D2D7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        
        <!-- Active Mode Card -->
        <Style Selector="Border.mode-card.active">
            <Setter Property="Background" Value="#E8F4FD"/>
            <Setter Property="BorderBrush" Value="#0066CC"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        
        <!-- Status Card -->
        <Style Selector="Border.status-card">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,10"/>
        </Style>
        
        <Style Selector="Border.status-card.success">
            <Setter Property="Background" Value="#D9F4E8"/>
            <Setter Property="BorderBrush" Value="#34C759"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        
        <Style Selector="Border.status-card.warning">
            <Setter Property="Background" Value="#FFF4E5"/>
            <Setter Property="BorderBrush" Value="#FF9500"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        
        <!-- Active Badge -->
        <Style Selector="Border.active-badge">
            <Setter Property="Background" Value="#34C759"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="6,3"/>
        </Style>
        
        <!-- Recommendation Panel -->
        <Style Selector="Border.recommendation">
            <Setter Property="Background" Value="#F5F5F7"/>
            <Setter Property="BorderBrush" Value="#D2D2D7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,10"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,32,40,40" MaxWidth="1200" Spacing="24">
            
            <!-- HEADER -->
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <StackPanel Grid.Column="0" Spacing="0">
                    <TextBlock Classes="page-title" Text="Flight Modes"/>
                    <TextBlock Classes="page-subtitle" Text="Configure 6-position flight mode switch"/>
                </StackPanel>
                
                <Button Grid.Column="1" Classes="flat-button" Command="{Binding RefreshCommand}" Margin="0,0,8,0">
                    <TextBlock Text="Refresh"/>
                </Button>
                
                <Button Grid.Column="2" Classes="flat-button" Command="{Binding ApplyDefaultsCommand}" Margin="0,0,8,0">
                    <TextBlock Text="Apply Defaults"/>
                </Button>
                
                <Button Grid.Column="3" Classes="primary-button" Command="{Binding UpdateCommand}">
                    <TextBlock Text="Update"/>
                </Button>
            </Grid>

            <!-- CHANNEL CONFIGURATION -->
            <Border Classes="section-card">
                <StackPanel Spacing="12">
                    <TextBlock Classes="section-title" Text="Flight Mode Channel"/>
                    
                    <Grid ColumnDefinitions="180,*">
                        <TextBlock Grid.Column="0" Classes="field-label" Text="Channel Selection"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding ChannelOptions}"
                                  SelectedValue="{Binding SelectedChannel}"
                                  SelectedValueBinding="{Binding Channel}"
                                  DisplayMemberBinding="{Binding Label}"
                                  Width="220"
                                  HorizontalAlignment="Left"/>
                    </Grid>
                    
                    <TextBlock Classes="helper-text" Text="Most transmitters use Channel 5 for flight mode switch"/>
                </StackPanel>
            </Border>

            <!-- FLIGHT MODE SLOTS (Clean 2x3 Grid) -->
            <Border Classes="section-card">
                <StackPanel Spacing="16">
                    <TextBlock Classes="section-title" Text="Flight Mode Slots"/>
                    
                    <!-- Row 1: Modes 1-3 -->
                    <Grid ColumnDefinitions="*,14,*,14,*" Margin="0,8,0,0">
                        
                        <!-- Mode 1 -->
                        <Border Grid.Column="0" Classes="mode-card" Classes.active="{Binding IsSlot1Active}">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" 
                                               Text="Flight Mode 1" 
                                               FontWeight="SemiBold" 
                                               FontSize="13" 
                                               Foreground="#1D1D1F"/>
                                    <Border Grid.Column="1" 
                                            Classes="active-badge"
                                            IsVisible="{Binding IsSlot1Active}">
                                        <TextBlock Text="ACTIVE" 
                                                   FontSize="9" 
                                                   Foreground="White" 
                                                   FontWeight="Bold"/>
                                    </Border>
                                </Grid>
                                
                                <ComboBox ItemsSource="{Binding FlightModeOptions}"
                                          SelectedItem="{Binding SelectedMode1}"
                                          DisplayMemberBinding="{Binding Label}"/>
                                
                                <TextBlock Classes="pwm-range" Text="{Binding PwmRange1}"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Mode 2 -->
                        <Border Grid.Column="2" Classes="mode-card" Classes.active="{Binding IsSlot2Active}">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" 
                                               Text="Flight Mode 2" 
                                               FontWeight="SemiBold" 
                                               FontSize="13" 
                                               Foreground="#1D1D1F"/>
                                    <Border Grid.Column="1" 
                                            Classes="active-badge"
                                            IsVisible="{Binding IsSlot2Active}">
                                        <TextBlock Text="ACTIVE" 
                                                   FontSize="9" 
                                                   Foreground="White" 
                                                   FontWeight="Bold"/>
                                    </Border>
                                </Grid>
                                
                                <ComboBox ItemsSource="{Binding FlightModeOptions}"
                                          SelectedItem="{Binding SelectedMode2}"
                                          DisplayMemberBinding="{Binding Label}"/>
                                
                                <TextBlock Classes="pwm-range" Text="{Binding PwmRange2}"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Mode 3 -->
                        <Border Grid.Column="4" Classes="mode-card" Classes.active="{Binding IsSlot3Active}">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" 
                                               Text="Flight Mode 3" 
                                               FontWeight="SemiBold" 
                                               FontSize="13" 
                                               Foreground="#1D1D1F"/>
                                    <Border Grid.Column="1" 
                                            Classes="active-badge"
                                            IsVisible="{Binding IsSlot3Active}">
                                        <TextBlock Text="ACTIVE" 
                                                   FontSize="9" 
                                                   Foreground="White" 
                                                   FontWeight="Bold"/>
                                    </Border>
                                </Grid>
                                
                                <ComboBox ItemsSource="{Binding FlightModeOptions}"
                                          SelectedItem="{Binding SelectedMode3}"
                                          DisplayMemberBinding="{Binding Label}"/>
                                
                                <TextBlock Classes="pwm-range" Text="{Binding PwmRange3}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Row 2: Modes 4-6 -->
                    <Grid ColumnDefinitions="*,14,*,14,*">
                        
                        <!-- Mode 4 -->
                        <Border Grid.Column="0" Classes="mode-card" Classes.active="{Binding IsSlot4Active}">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" 
                                               Text="Flight Mode 4" 
                                               FontWeight="SemiBold" 
                                               FontSize="13" 
                                               Foreground="#1D1D1F"/>
                                    <Border Grid.Column="1" 
                                            Classes="active-badge"
                                            IsVisible="{Binding IsSlot4Active}">
                                        <TextBlock Text="ACTIVE" 
                                                   FontSize="9" 
                                                   Foreground="White" 
                                                   FontWeight="Bold"/>
                                    </Border>
                                </Grid>
                                
                                <ComboBox ItemsSource="{Binding FlightModeOptions}"
                                          SelectedItem="{Binding SelectedMode4}"
                                          DisplayMemberBinding="{Binding Label}"/>
                                
                                <TextBlock Classes="pwm-range" Text="{Binding PwmRange4}"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Mode 5 -->
                        <Border Grid.Column="2" Classes="mode-card" Classes.active="{Binding IsSlot5Active}">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" 
                                               Text="Flight Mode 5" 
                                               FontWeight="SemiBold" 
                                               FontSize="13" 
                                               Foreground="#1D1D1F"/>
                                    <Border Grid.Column="1" 
                                            Classes="active-badge"
                                            IsVisible="{Binding IsSlot5Active}">
                                        <TextBlock Text="ACTIVE" 
                                                   FontSize="9" 
                                                   Foreground="White" 
                                                   FontWeight="Bold"/>
                                    </Border>
                                </Grid>
                                
                                <ComboBox ItemsSource="{Binding FlightModeOptions}"
                                          SelectedItem="{Binding SelectedMode5}"
                                          DisplayMemberBinding="{Binding Label}"/>
                                
                                <TextBlock Classes="pwm-range" Text="{Binding PwmRange5}"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Mode 6 -->
                        <Border Grid.Column="4" Classes="mode-card" Classes.active="{Binding IsSlot6Active}">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" 
                                               Text="Flight Mode 6" 
                                               FontWeight="SemiBold" 
                                               FontSize="13" 
                                               Foreground="#1D1D1F"/>
                                    <Border Grid.Column="1" 
                                            Classes="active-badge"
                                            IsVisible="{Binding IsSlot6Active}">
                                        <TextBlock Text="ACTIVE" 
                                                   FontSize="9" 
                                                   Foreground="White" 
                                                   FontWeight="Bold"/>
                                    </Border>
                                </Grid>
                                
                                <ComboBox ItemsSource="{Binding FlightModeOptions}"
                                          SelectedItem="{Binding SelectedMode6}"
                                          DisplayMemberBinding="{Binding Label}"/>
                                
                                <TextBlock Classes="pwm-range" Text="{Binding PwmRange6}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
