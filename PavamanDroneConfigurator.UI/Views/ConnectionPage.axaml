<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="800"
             x:Class="PavamanDroneConfigurator.UI.Views.ConnectionPage"
             x:DataType="vm:ConnectionPageViewModel"
             Background="{DynamicResource BackgroundBrush}">

    <ScrollViewer>
        <StackPanel Margin="{DynamicResource PagePadding}" Spacing="24" MaxWidth="800">
            
            <!-- PAGE HEADER -->
            <StackPanel Spacing="8">
                <TextBlock Text="Connection" Classes="page-title"/>
                <TextBlock Text="Configure and manage your drone connection" Classes="page-subtitle"/>
            </StackPanel>

            <!-- CONNECTION STATUS CARD -->
            <Border Classes="card-elevated">
                <StackPanel Spacing="20">
                    <TextBlock Text="Connection Status" Classes="section-title"/>
                    
                    <!-- Status Indicator Row -->
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <!-- Status Dot with Glow Effect -->
                            <Grid>
                                <Ellipse Width="14" Height="14" 
                                         Fill="{Binding ConnectionStatusBrush}"
                                         Opacity="0.3"/>
                                <Ellipse Width="10" Height="10" 
                                         Fill="{Binding ConnectionStatusBrush}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="{Binding ConnectionStatusText}" 
                                       FontSize="{DynamicResource FontSizeLG}" 
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        
                        <!-- Connected Badge -->
                        <Border Grid.Column="2" 
                                Classes="badge-success"
                                IsVisible="{Binding IsConnected}">
                            <TextBlock Text="&#x2713; Active" 
                                       FontSize="{DynamicResource FontSizeSM}" 
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource SuccessDarkBrush}"/>
                        </Border>
                    </Grid>

                    <!-- Parameter Download Progress -->
                    <Border Classes="alert-info" IsVisible="{Binding IsDownloadingParameters}">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="&#x2193;" FontSize="16"/>
                                <TextBlock Text="Downloading Parameters" 
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding ParameterProgressText}" 
                                           FontWeight="Bold" 
                                           Foreground="{DynamicResource PrimaryBrush}"
                                           FontFamily="{DynamicResource MonospaceFont}"/>
                            </StackPanel>
                            <ProgressBar Value="{Binding ParameterProgressPercentage}" 
                                         Maximum="100" 
                                         Classes="progress"
                                         Height="8"
                                         CornerRadius="4"/>
                        </StackPanel>
                    </Border>

                    <!-- Status Message -->
                    <TextBlock Text="{Binding StatusMessage}" 
                               Classes="body"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- CONNECTION TYPE SELECTOR (Segmented Control) -->
            <Border Classes="card">
                <StackPanel Spacing="16">
                    <TextBlock Text="Connection Type" Classes="section-title"/>
                    
                    <!-- Segmented Pill Buttons -->
                    <Border Classes="segmented-control" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <RadioButton GroupName="ConnectionType"
                                         IsChecked="{Binding IsSerialConnection}"
                                         IsEnabled="{Binding !IsConnected}">
                                <RadioButton.Template>
                                    <ControlTemplate>
                                        <Border x:Name="PART_Border"
                                                CornerRadius="{DynamicResource RadiusMD}"
                                                Padding="20,10"
                                                Cursor="Hand">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="&#x25B8;" FontSize="14"/>
                                                <TextBlock Text="Serial (USB)" 
                                                           FontWeight="{TemplateBinding FontWeight}"
                                                           Foreground="{TemplateBinding Foreground}"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </RadioButton.Template>
                                <RadioButton.Styles>
                                    <Style Selector="RadioButton">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Setter Property="FontWeight" Value="Medium"/>
                                    </Style>
                                    <Style Selector="RadioButton:checked">
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                    <Style Selector="RadioButton:checked /template/ Border#PART_Border">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                        <Setter Property="BoxShadow" Value="{DynamicResource ShadowSM}"/>
                                    </Style>
                                    <Style Selector="RadioButton:disabled">
                                        <Setter Property="Opacity" Value="0.5"/>
                                    </Style>
                                </RadioButton.Styles>
                            </RadioButton>
                            
                            <RadioButton GroupName="ConnectionType"
                                         IsChecked="{Binding IsTcpConnection}"
                                         IsEnabled="{Binding !IsConnected}">
                                <RadioButton.Template>
                                    <ControlTemplate>
                                        <Border x:Name="PART_Border"
                                                CornerRadius="{DynamicResource RadiusMD}"
                                                Padding="20,10"
                                                Cursor="Hand">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="&#x25CB;" FontSize="14"/>
                                                <TextBlock Text="TCP (Network)" 
                                                           FontWeight="{TemplateBinding FontWeight}"
                                                           Foreground="{TemplateBinding Foreground}"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </RadioButton.Template>
                                <RadioButton.Styles>
                                    <Style Selector="RadioButton">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Setter Property="FontWeight" Value="Medium"/>
                                    </Style>
                                    <Style Selector="RadioButton:checked">
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                    <Style Selector="RadioButton:checked /template/ Border#PART_Border">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                        <Setter Property="BoxShadow" Value="{DynamicResource ShadowSM}"/>
                                    </Style>
                                    <Style Selector="RadioButton:disabled">
                                        <Setter Property="Opacity" Value="0.5"/>
                                    </Style>
                                </RadioButton.Styles>
                            </RadioButton>
                            
                            <RadioButton GroupName="ConnectionType"
                                         IsChecked="{Binding IsBluetoothConnection}"
                                         IsEnabled="{Binding !IsConnected}">
                                <RadioButton.Template>
                                    <ControlTemplate>
                                        <Border x:Name="PART_Border"
                                                CornerRadius="{DynamicResource RadiusMD}"
                                                Padding="20,10"
                                                Cursor="Hand">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="&#x25CF;" FontSize="14"/>
                                                <TextBlock Text="Bluetooth" 
                                                           FontWeight="{TemplateBinding FontWeight}"
                                                           Foreground="{TemplateBinding Foreground}"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </RadioButton.Template>
                                <RadioButton.Styles>
                                    <Style Selector="RadioButton">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Setter Property="FontWeight" Value="Medium"/>
                                    </Style>
                                    <Style Selector="RadioButton:checked">
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                    <Style Selector="RadioButton:checked /template/ Border#PART_Border">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                        <Setter Property="BoxShadow" Value="{DynamicResource ShadowSM}"/>
                                    </Style>
                                    <Style Selector="RadioButton:disabled">
                                        <Setter Property="Opacity" Value="0.5"/>
                                    </Style>
                                </RadioButton.Styles>
                            </RadioButton>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- SERIAL CONFIGURATION -->
            <Border Classes="card" IsVisible="{Binding IsSerialConnection}">
                <StackPanel Spacing="20">
                    <TextBlock Text="Serial Configuration" Classes="section-title"/>
                    
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                        <!-- Serial Port -->
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="Serial Port" Classes="label"/>
                            <ComboBox ItemsSource="{Binding AvailableSerialPorts}"
                                      SelectedItem="{Binding SelectedSerialPort}"
                                      IsEnabled="{Binding !IsConnected}"
                                      Classes="input"
                                      HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Spacing="2" Margin="0,4">
                                            <TextBlock Text="{Binding FriendlyName}" 
                                                       FontWeight="SemiBold"
                                                       FontSize="{DynamicResource FontSizeBase}"/>
                                            <TextBlock Text="{Binding PortName}" 
                                                       FontSize="{DynamicResource FontSizeSM}" 
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       FontFamily="{DynamicResource MonospaceFont}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <!-- Baud Rate -->
                        <StackPanel Grid.Column="1" Spacing="6">
                            <TextBlock Text="Baud Rate" Classes="label"/>
                            <ComboBox ItemsSource="{Binding AvailableBaudRates}"
                                      SelectedItem="{Binding SelectedBaudRate}"
                                      IsEnabled="{Binding !IsConnected}" 
                                      Classes="input"
                                      HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Display}"
                                                   FontFamily="{DynamicResource MonospaceFont}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- TCP CONFIGURATION -->
            <Border Classes="card" IsVisible="{Binding IsTcpConnection}">
                <StackPanel Spacing="20">
                    <TextBlock Text="TCP Configuration" Classes="section-title"/>
                    
                    <Grid ColumnDefinitions="2*,*" ColumnSpacing="16">
                        <!-- IP Address -->
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="IP Address" Classes="label"/>
                            <TextBox Text="{Binding IpAddress}" 
                                     IsEnabled="{Binding !IsConnected}"
                                     Classes="input"
                                     Watermark="192.168.1.100"
                                     FontFamily="{DynamicResource MonospaceFont}"/>
                        </StackPanel>

                        <!-- Port -->
                        <StackPanel Grid.Column="1" Spacing="6">
                            <TextBlock Text="Port" Classes="label"/>
                            <TextBox Text="{Binding TcpPort}" 
                                     IsEnabled="{Binding !IsConnected}"
                                     Classes="input"
                                     Watermark="5760"
                                     FontFamily="{DynamicResource MonospaceFont}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- BLUETOOTH CONFIGURATION -->
            <Border Classes="card" IsVisible="{Binding IsBluetoothConnection}">
                <StackPanel Spacing="20">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Bluetooth Configuration" Classes="section-title" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" 
                                Content="Scan Devices" 
                                Command="{Binding ScanBluetoothDevicesCommand}"
                                IsEnabled="{Binding !IsConnected}"
                                Classes="btn-secondary"
                                Padding="16,8"/>
                    </Grid>
                    
                    <StackPanel Spacing="6">
                        <TextBlock Text="Bluetooth Device" Classes="label"/>
                        <ComboBox ItemsSource="{Binding AvailableBluetoothDevices}"
                                  SelectedItem="{Binding SelectedBluetoothDevice}"
                                  IsEnabled="{Binding !IsConnected}"
                                  Classes="input"
                                  HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*,Auto" Margin="0,4">
                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <TextBlock Text="{Binding DeviceName}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding DeviceAddress}" 
                                                       FontSize="{DynamicResource FontSizeSM}" 
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       FontFamily="{DynamicResource MonospaceFont}"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" 
                                                Classes="badge-info" 
                                                IsVisible="{Binding IsPaired}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="Paired" 
                                                       FontSize="{DynamicResource FontSizeXS}" 
                                                       Foreground="{DynamicResource PrimaryBrush}"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <TextBlock Text="&#x26A0; Ensure your Bluetooth device is powered on and in pairing mode" 
                               Classes="caption"
                               FontStyle="Italic"/>
                </StackPanel>
            </Border>

            <!-- ACTION BUTTONS -->
            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                <Button Content="Connect" 
                        Command="{Binding ConnectCommand}" 
                        IsEnabled="{Binding !IsConnected}"
                        Classes="btn-primary"/>
                <Button Content="Disconnect" 
                        Command="{Binding DisconnectCommand}" 
                        IsEnabled="{Binding IsConnected}"
                        Classes="btn-secondary"/>
            </StackPanel>

            <!-- CONNECTION INFO (when connected) -->
            <Border Classes="card-muted" IsVisible="{Binding IsConnected}">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="&#x2713;" FontSize="16" Foreground="{DynamicResource SuccessBrush}"/>
                        <TextBlock Text="Connection Information" Classes="section-title" Margin="0"/>
                    </StackPanel>
                    
                    <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="24" RowSpacing="12">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="System ID" Classes="caption"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SystemId}" Classes="value" FontFamily="{DynamicResource MonospaceFont}"/>
                        
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Component ID" Classes="caption"/>
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding ComponentId}" Classes="value" FontFamily="{DynamicResource MonospaceFont}"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="FC ID" Classes="caption"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FcId}" Classes="value" FontFamily="{DynamicResource MonospaceFont}"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Parameters" Classes="caption"/>
                        <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding ParameterCount}" Classes="value" FontFamily="{DynamicResource MonospaceFont}"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Bottom Spacing -->
            <Panel Height="24"/>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>
