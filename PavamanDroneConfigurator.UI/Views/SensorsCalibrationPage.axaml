<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels"
             xmlns:converters="using:PavamanDroneConfigurator.UI.Converters"
             x:Class="PavamanDroneConfigurator.UI.Views.SensorsCalibrationPage"
             x:DataType="vm:SensorsCalibrationPageViewModel">

	<UserControl.Resources>
		<converters:BoolToSensorStatusColorConverter x:Key="SensorStatusColorConverter"/>
		<converters:DirectionToColorConverter x:Key="DirectionToColorConverter"/>
		<converters:DirectionToPrefixConverter x:Key="DirectionToPrefixConverter"/>
	</UserControl.Resources>

	<UserControl.Styles>
		<Style Selector="TextBlock.PageTitle">
			<Setter Property="FontSize" Value="24"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Foreground" Value="#0EA5E9"/>
			<Setter Property="Margin" Value="0,0,0,16"/>
		</Style>

		<Style Selector="TextBlock.SectionTitle">
			<Setter Property="FontSize" Value="18"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Foreground" Value="#0EA5E9"/>
			<Setter Property="Margin" Value="0,0,0,8"/>
		</Style>

		<Style Selector="TextBlock.StatusText">
			<Setter Property="FontSize" Value="16"/>
			<Setter Property="Foreground" Value="#0EA5E9"/>
			<Setter Property="Margin" Value="0,16,0,8"/>
		</Style>

		<Style Selector="TextBlock.InstructionsLabel">
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Foreground" Value="#64748B"/>
			<Setter Property="Margin" Value="0,8,0,4"/>
		</Style>

		<Style Selector="TextBlock.Instructions">
			<Setter Property="FontSize" Value="14"/>
			<Setter Property="Foreground" Value="#1E293B"/>
			<Setter Property="TextWrapping" Value="Wrap"/>
		</Style>

		<Style Selector="TextBlock.FieldLabel">
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="Foreground" Value="#64748B"/>
			<Setter Property="Margin" Value="0,0,0,4"/>
		</Style>

		<Style Selector="TextBlock.CompassTitle">
			<Setter Property="FontSize" Value="16"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Foreground" Value="#22D3EE"/>
		</Style>

		<Style Selector="Border.SectionCard">
			<Setter Property="Background" Value="#FFFFFF"/>
			<Setter Property="BorderBrush" Value="#E2E8F0"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="14"/>
			<Setter Property="Padding" Value="24"/>
			<Setter Property="Margin" Value="0,0,0,20"/>
		</Style>

		<Style Selector="Border.TabBar">
			<Setter Property="Background" Value="#F8FAFC"/>
			<Setter Property="CornerRadius" Value="28"/>
			<Setter Property="Padding" Value="6"/>
			<Setter Property="Margin" Value="0,0,0,24"/>
		</Style>

		<!-- CONSOLIDATED TAB BUTTON STYLES - Removed duplication -->
		<Style Selector="Button.TabButton">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="Foreground" Value="#64748B"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="Padding" Value="20,12"/>
			<Setter Property="CornerRadius" Value="22"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="MinWidth" Value="120"/>
		</Style>

		<Style Selector="Button.TabButton:pointerover">
			<Setter Property="Background" Value="#E2F3FF"/>
		</Style>

		<Style Selector="Button.TabButtonActive">
			<Setter Property="Background" Value="#0EA5E9"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="Padding" Value="20,12"/>
			<Setter Property="CornerRadius" Value="22"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="MinWidth" Value="120"/>
		</Style>

		<Style Selector="Button.Primary">
			<Setter Property="Background" Value="#0EA5E9"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Padding" Value="22,12"/>
			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="BorderThickness" Value="0"/>
		</Style>

		<Style Selector="Button.Primary:pointerover">
			<Setter Property="Background" Value="#0284C7"/>
		</Style>

		<Style Selector="Button.Secondary">
			<Setter Property="Background" Value="#0B63E5"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Padding" Value="22,12"/>
			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="BorderThickness" Value="0"/>
		</Style>

		<Style Selector="Button.Secondary:pointerover">
			<Setter Property="Background" Value="#0A4FC2"/>
		</Style>

		<Style Selector="Button.Danger">
			<Setter Property="Background" Value="#EF4444"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Padding" Value="22,12"/>
			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="BorderThickness" Value="0"/>
		</Style>

		<Style Selector="Button.Danger:pointerover">
			<Setter Property="Background" Value="#DC2626"/>
		</Style>

		<Style Selector="ComboBox">
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="MinWidth" Value="140"/>
		</Style>

		<Style Selector="TextBox">
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Padding" Value="12,10"/>
		</Style>

		<Style Selector="Border.CompassRow">
			<Setter Property="BorderBrush" Value="#E2E8F0"/>
			<Setter Property="BorderThickness" Value="0,0,0,1"/>
			<Setter Property="Padding" Value="6,14"/>
		</Style>

		<!-- CONSOLIDATED DIALOG OVERLAY STYLES -->
		<Style Selector="Border.DialogOverlay">
			<Setter Property="Background" Value="#80000000"/>
			<Setter Property="ZIndex" Value="1000"/>
		</Style>

		<Style Selector="Border.DialogContent">
			<Setter Property="Background" Value="White"/>
			<Setter Property="CornerRadius" Value="16"/>
			<Setter Property="Padding" Value="24"/>
			<Setter Property="HorizontalAlignment" Value="Center"/>
			<Setter Property="VerticalAlignment" Value="Center"/>
			<Setter Property="MinWidth" Value="400"/>
			<Setter Property="MaxWidth" Value="500"/>
			<Setter Property="BoxShadow" Value="0 10 40 0 #60000000"/>
		</Style>
	</UserControl.Styles>

	<Grid>
		<ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
			<StackPanel Margin="24" MaxWidth="1200">

				<!-- HEADER -->
				<TextBlock Classes="PageTitle" Text="SENSORS"/>

				<!-- SENSOR STATUS PANEL -->
				<Border Background="#F8FAFC" CornerRadius="8" Padding="16" Margin="0,0,0,16" IsVisible="{Binding IsConnected}">
					<Grid ColumnDefinitions="*,*,*,*">
						<StackPanel Grid.Column="0" HorizontalAlignment="Center">
							<StackPanel Orientation="Horizontal" Spacing="6">
								<Ellipse Width="8" Height="8" Fill="{Binding IsAccelerometerAvailable, Converter={StaticResource SensorStatusColorConverter}}"/>
								<TextBlock Text="Accelerometer" FontWeight="Medium" FontSize="12"/>
							</StackPanel>
							<TextBlock Text="{Binding AccelSensorStatus}" FontSize="11" Foreground="#64748B" HorizontalAlignment="Center"/>
						</StackPanel>
						<StackPanel Grid.Column="1" HorizontalAlignment="Center">
							<StackPanel Orientation="Horizontal" Spacing="6">
								<Ellipse Width="8" Height="8" Fill="{Binding IsGyroscopeAvailable, Converter={StaticResource SensorStatusColorConverter}}"/>
								<TextBlock Text="Gyroscope" FontWeight="Medium" FontSize="12"/>
							</StackPanel>
							<TextBlock Text="{Binding GyroSensorStatus}" FontSize="11" Foreground="#64748B" HorizontalAlignment="Center"/>
						</StackPanel>
						<StackPanel Grid.Column="2" HorizontalAlignment="Center">
							<StackPanel Orientation="Horizontal" Spacing="6">
								<Ellipse Width="8" Height="8" Fill="{Binding IsCompassAvailable, Converter={StaticResource SensorStatusColorConverter}}"/>
								<TextBlock Text="Compass" FontWeight="Medium" FontSize="12"/>
							</StackPanel>
							<TextBlock Text="{Binding CompassSensorStatus}" FontSize="11" Foreground="#64748B" HorizontalAlignment="Center"/>
						</StackPanel>
						<StackPanel Grid.Column="3" HorizontalAlignment="Center">
							<StackPanel Orientation="Horizontal" Spacing="6">
								<Ellipse Width="8" Height="8" Fill="{Binding IsBarometerAvailable, Converter={StaticResource SensorStatusColorConverter}}"/>
								<TextBlock Text="Barometer" FontWeight="Medium" FontSize="12"/>
							</StackPanel>
							<TextBlock Text="{Binding BaroSensorStatus}" FontSize="11" Foreground="#64748B" HorizontalAlignment="Center"/>
						</StackPanel>
					</Grid>
				</Border>

				<!-- TAB BAR -->
				<Border Classes="TabBar">
					<ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
						<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
							<Button Classes.TabButtonActive="{Binding IsAccelerometerTabSelected}"
                                    Classes.TabButton="{Binding !IsAccelerometerTabSelected}"
                                    Content="ACCELEROMETER"
                                    Command="{Binding SelectAccelerometerTabCommand}"/>

							<Button Classes.TabButtonActive="{Binding IsCompassTabSelected}"
                                    Classes.TabButton="{Binding !IsCompassTabSelected}"
                                    Content="COMPASS"
                                    Command="{Binding SelectCompassTabCommand}"/>

							<Button Classes.TabButtonActive="{Binding IsLevelHorizonTabSelected}"
                                    Classes.TabButton="{Binding !IsLevelHorizonTabSelected}"
                                    Content="LEVEL HORIZON"
                                    Command="{Binding SelectLevelHorizonTabCommand}"/>

							<Button Classes.TabButtonActive="{Binding IsPressureTabSelected}"
                                    Classes.TabButton="{Binding !IsPressureTabSelected}"
                                    Content="PRESSURE"
                                    Command="{Binding SelectPressureTabCommand}"/>

							<Button Classes.TabButtonActive="{Binding IsFlowTabSelected}"
                                    Classes.TabButton="{Binding !IsFlowTabSelected}"
                                    Content="FLOW"
                                    Command="{Binding SelectFlowTabCommand}"/>
						</StackPanel>
					</ScrollViewer>
				</Border>

				<!-- ACCELEROMETER TAB -->
				<Border Classes="SectionCard" IsVisible="{Binding IsAccelerometerTabSelected}">
					<StackPanel>
						<!-- Sensor Not Available Warning -->
						<Border Background="#FEF2F2" CornerRadius="8" Padding="12" Margin="0,0,0,16"
                                IsVisible="{Binding !IsAccelerometerAvailable}">
							<StackPanel Orientation="Horizontal" Spacing="8">
								<TextBlock Text="&#x26A0;" FontSize="16" Foreground="#DC2626"/>
								<TextBlock Text="Accelerometer sensor not detected. Check hardware connections."
                                           Foreground="#DC2626" VerticalAlignment="Center"/>
							</StackPanel>
						</Border>

						<!-- Calibration Status Header -->
						<Border Background="#F0F9FF" CornerRadius="8" Padding="16" Margin="0,0,0,16">
							<Grid ColumnDefinitions="*,Auto">
								<StackPanel Grid.Column="0">
									<TextBlock Text="Accelerometer Calibration" FontSize="18" FontWeight="Bold" Foreground="#0369A1"/>
									<TextBlock Text="{Binding AccelCalibrationStatus}" FontSize="14" Foreground="#0EA5E9" Margin="0,4,0,0"/>
								</StackPanel>
								<Border Grid.Column="1" Background="{Binding IsAccelCalibrated, Converter={StaticResource SensorStatusColorConverter}}"
                                        CornerRadius="12" Padding="12,6" VerticalAlignment="Center">
									<TextBlock Text="{Binding AccelCalibrationStatus}"
                                               Foreground="White" FontWeight="Bold" FontSize="12"/>
								</Border>
							</Grid>
						</Border>

						<!-- Instructions Panel -->
						<Border Background="#FFFBEB" CornerRadius="8" Padding="12" Margin="0,0,0,16">
							<StackPanel>
								<TextBlock Text="INSTRUCTIONS" FontSize="11" FontWeight="Bold" Foreground="#92400E" Margin="0,0,0,4"/>
								<TextBlock Text="{Binding AccelInstructions}" FontSize="13" Foreground="#78350F" TextWrapping="Wrap"/>
							</StackPanel>
						</Border>

						<!-- Current Calibration Image - Large display during calibration -->
						<Border Background="#F8FAFC" CornerRadius="12" Padding="20" Margin="0,0,0,16"
                                HorizontalAlignment="Center" IsVisible="{Binding IsAccelCalibrationActive}"
                                BorderBrush="#E2E8F0" BorderThickness="2">
							<StackPanel HorizontalAlignment="Center" Spacing="12">
								<TextBlock Text="CURRENT POSITION" FontSize="12" FontWeight="Bold" Foreground="#64748B" HorizontalAlignment="Center"/>
								<Image Source="{Binding CurrentCalibrationImage}"
                                       Width="240" Height="180"
                                       Stretch="Uniform"/>
								<TextBlock Text="{Binding AccelCurrentStep}"
                                           HorizontalAlignment="Center"
                                           FontWeight="Bold"
                                           FontSize="18"
                                           Foreground="#0EA5E9"/>
							</StackPanel>
						</Border>

						<!-- 6-Axis Position Indicators -->
						<TextBlock Text="CALIBRATION POSITIONS" FontSize="12" FontWeight="Bold" Foreground="#64748B"
                                   HorizontalAlignment="Center" Margin="0,8,0,12"/>
						<ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
							<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16" Margin="0,0,0,20">
								<!-- Step 1: Level -->
								<Border Width="120" Height="130" CornerRadius="12" Padding="10"
                                        Background="{Binding Step1BackgroundColor}"
                                        BorderBrush="{Binding Step1BorderColor}"
                                        BorderThickness="3">
									<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
										<TextBlock Text="LEVEL" FontWeight="Bold" HorizontalAlignment="Center" FontSize="13" Foreground="#1E293B"/>
										<TextBlock Text="Step 1" FontSize="11" Foreground="#64748B" HorizontalAlignment="Center"/>
										<Border Background="White" CornerRadius="6" Padding="4" Margin="0,4,0,0">
											<Image Source="avares://PavamanDroneConfigurator.UI/Assets/Images/Caliberation-images/Level.png"
                                                   Width="70" Height="50" Stretch="Uniform"/>
										</Border>
									</StackPanel>
								</Border>

								<!-- Step 2: Left -->
								<Border Width="120" Height="130" CornerRadius="12" Padding="10"
                                        Background="{Binding Step2BackgroundColor}"
                                        BorderBrush="{Binding Step2BorderColor}"
                                        BorderThickness="3">
									<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
										<TextBlock Text="LEFT SIDE" FontWeight="Bold" HorizontalAlignment="Center" FontSize="13" Foreground="#1E293B"/>
										<TextBlock Text="Step 2" FontSize="11" Foreground="#64748B" HorizontalAlignment="Center"/>
										<Border Background="White" CornerRadius="6" Padding="4" Margin="0,4,0,0">
											<Image Source="avares://PavamanDroneConfigurator.UI/Assets/Images/Caliberation-images/Left-Side.png"
                                                   Width="70" Height="50" Stretch="Uniform"/>
										</Border>
									</StackPanel>
								</Border>

								<!-- Step 3: Right -->
								<Border Width="120" Height="130" CornerRadius="12" Padding="10"
                                        Background="{Binding Step3BackgroundColor}"
                                        BorderBrush="{Binding Step3BorderColor}"
                                        BorderThickness="3">
									<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
										<TextBlock Text="RIGHT SIDE" FontWeight="Bold" HorizontalAlignment="Center" FontSize="13" Foreground="#1E293B"/>
										<TextBlock Text="Step 3" FontSize="11" Foreground="#64748B" HorizontalAlignment="Center"/>
										<Border Background="White" CornerRadius="6" Padding="4" Margin="0,4,0,0">
											<Image Source="avares://PavamanDroneConfigurator.UI/Assets/Images/Caliberation-images/Right-Side.png"
                                                   Width="70" Height="50" Stretch="Uniform"/>
										</Border>
									</StackPanel>
								</Border>

								<!-- Step 4: Nose Down -->
								<Border Width="120" Height="130" CornerRadius="12" Padding="10"
                                        Background="{Binding Step4BackgroundColor}"
                                        BorderBrush="{Binding Step4BorderColor}"
                                        BorderThickness="3">
									<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
										<TextBlock Text="NOSE DOWN" FontWeight="Bold" HorizontalAlignment="Center" FontSize="13" Foreground="#1E293B"/>
										<TextBlock Text="Step 4" FontSize="11" Foreground="#64748B" HorizontalAlignment="Center"/>
										<Border Background="White" CornerRadius="6" Padding="4" Margin="0,4,0,0">
											<Image Source="avares://PavamanDroneConfigurator.UI/Assets/Images/Caliberation-images/Nose-Down.png"
                                                   Width="70" Height="50" Stretch="Uniform"/>
										</Border>
									</StackPanel>
								</Border>

								<!-- Step 5: Nose Up -->
								<Border Width="120" Height="130" CornerRadius="12" Padding="10"
                                        Background="{Binding Step5BackgroundColor}"
                                        BorderBrush="{Binding Step5BorderColor}"
                                        BorderThickness="3">
									<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
										<TextBlock Text="NOSE UP" FontWeight="Bold" HorizontalAlignment="Center" FontSize="13" Foreground="#1E293B"/>
										<TextBlock Text="Step 5" FontSize="11" Foreground="#64748B" HorizontalAlignment="Center"/>
										<Border Background="White" CornerRadius="6" Padding="4" Margin="0,4,0,0">
											<Image Source="avares://PavamanDroneConfigurator.UI/Assets/Images/Caliberation-images/Nose-Up.png"
                                                   Width="70" Height="50" Stretch="Uniform"/>
										</Border>
									</StackPanel>
								</Border>

								<!-- Step 6: Back -->
								<Border Width="120" Height="130" CornerRadius="12" Padding="10"
                                        Background="{Binding Step6BackgroundColor}"
                                        BorderBrush="{Binding Step6BorderColor}"
                                        BorderThickness="3">
									<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
										<TextBlock Text="BACK" FontWeight="Bold" HorizontalAlignment="Center" FontSize="13" Foreground="#1E293B"/>
										<TextBlock Text="Step 6" FontSize="11" Foreground="#64748B" HorizontalAlignment="Center"/>
										<Border Background="White" CornerRadius="6" Padding="4" Margin="0,4,0,0">
											<Image Source="avares://PavamanDroneConfigurator.UI/Assets/Images/Caliberation-images/Back-Side.png"
                                                   Width="70" Height="50" Stretch="Uniform"/>
										</Border>
									</StackPanel>
								</Border>
							</StackPanel>
						</ScrollViewer>

						<!-- Color Legend -->
						<Border Background="#F8FAFC" CornerRadius="8" Padding="12" Margin="0,0,0,16">
							<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="32">
								<StackPanel Orientation="Horizontal" Spacing="8">
									<Border Width="20" Height="20" CornerRadius="4" Background="#FEE2E2" BorderBrush="#EF4444" BorderThickness="2"/>
									<TextBlock Text="Waiting for Position" FontSize="12" Foreground="#64748B" VerticalAlignment="Center" FontWeight="Medium"/>
								</StackPanel>
								<StackPanel Orientation="Horizontal" Spacing="8">
									<Border Width="20" Height="20" CornerRadius="4" Background="#D1FAE5" BorderBrush="#10B981" BorderThickness="2"/>
									<TextBlock Text="Completed" FontSize="12" Foreground="#64748B" VerticalAlignment="Center" FontWeight="Medium"/>
								</StackPanel>
								<StackPanel Orientation="Horizontal" Spacing="8">
									<Border Width="20" Height="20" CornerRadius="4" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="2"/>
									<TextBlock Text="Pending" FontSize="12" Foreground="#64748B" VerticalAlignment="Center" FontWeight="Medium"/>
								</StackPanel>
							</StackPanel>
						</Border>

						<!-- Progress bar with percentage -->
						<Border Background="#E7F3FF" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                                IsVisible="{Binding IsAccelCalibrationActive}">
							<StackPanel Spacing="10">
								<Grid ColumnDefinitions="*,Auto">
									<TextBlock Grid.Column="0"
                                               Text="Calibration Progress"
                                               FontWeight="Bold"
                                               FontSize="14"
                                               Foreground="#0B5ED7"/>
									<TextBlock Grid.Column="1"
                                               Text="{Binding AccelCalibrationProgress, StringFormat='{}{0}%'}"
                                               FontWeight="Bold"
                                               FontSize="18"
                                               Foreground="#0B5ED7"/>
								</Grid>
								<ProgressBar Value="{Binding AccelCalibrationProgress}"
                                             Maximum="100" Height="10"
                                             Foreground="#22D3EE" Background="#CBD5E1"/>
								<TextBlock Text="{Binding AccelStepNumber, StringFormat='Step {0} of 6'}"
                                           FontSize="12" Foreground="#64748B" HorizontalAlignment="Center"/>
							</StackPanel>
						</Border>

						<!-- Action Buttons -->
						<Border Background="#F8FAFC" CornerRadius="8" Padding="16">
							<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16">
								<Button Classes="Primary"
                                        Content="{Binding AccelButtonText}"
                                        Command="{Binding CalibrateAccelerometerCommand}"
                                        IsEnabled="{Binding IsAccelButtonEnabled}"
                                        MinWidth="180"
                                        FontSize="14"
                                        ToolTip.Tip="First click starts calibration. During calibration, click after placing the drone in each position."/>

								<Button Classes="Danger" Content="Cancel Calibration"
                                        Command="{Binding CancelCalibrationCommand}"
                                        IsVisible="{Binding IsAccelCalibrationActive}"
                                        MinWidth="140"/>

								<Button Classes="Secondary" Content="Reboot FC"
                                        Command="{Binding RebootCommand}"
                                        IsEnabled="{Binding IsConnected}"
                                        MinWidth="100"/>
							</StackPanel>
						</Border>
					</StackPanel>
				</Border>

				<!-- COMPASS TAB -->
				<Border Classes="SectionCard" IsVisible="{Binding IsCompassTabSelected}">
					<StackPanel Spacing="14">
						<TextBlock Classes="SectionTitle" Text="Compass Priority"/>
						<TextBlock Text="Set the Compass Priority by reordering the compasses in the table below (Highest at the top). Click 'Update Priority' after reordering."
                                   FontSize="12" Foreground="#475569"/>

						<!-- Compass table -->
						<Border Background="#F8FBFF" CornerRadius="14" Padding="14" BorderBrush="#E2E8F0" BorderThickness="1">
							<Grid RowDefinitions="Auto,*" RowSpacing="8">
								<Border Background="#EEF6FF" CornerRadius="10" Padding="10,8">
									<Grid ColumnDefinitions="50,100,70,50,70,80,60,60,*,44,44">
										<TextBlock Grid.Column="0" Text="Priority" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
										<TextBlock Grid.Column="1" Text="DevID" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
										<TextBlock Grid.Column="2" Text="BusType" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
										<TextBlock Grid.Column="3" Text="Bus" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
										<TextBlock Grid.Column="4" Text="Address" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
										<TextBlock Grid.Column="5" Text="DevType" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
										<TextBlock Grid.Column="6" Text="Missing" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
										<TextBlock Grid.Column="7" Text="External" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
										<TextBlock Grid.Column="8" Text="Orientation" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
										<TextBlock Grid.Column="9" Text="Up" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
										<TextBlock Grid.Column="10" Text="Down" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
									</Grid>
								</Border>

								<ScrollViewer Grid.Row="1" MaxHeight="240" VerticalScrollBarVisibility="Auto">
									<ItemsControl ItemsSource="{Binding Compasses}">
										<ItemsControl.ItemTemplate>
											<DataTemplate>
												<Border Classes="CompassRow">
													<Grid ColumnDefinitions="50,100,70,50,70,80,60,60,*,44,44" VerticalAlignment="Center">
														<TextBlock Grid.Column="0" Text="{Binding Priority}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
														<StackPanel Grid.Column="1" Orientation="Vertical" Spacing="2" HorizontalAlignment="Center">
															<TextBlock Text="{Binding DeviceId}" FontWeight="Medium" HorizontalAlignment="Center"/>
															<CheckBox Content="Use" IsChecked="{Binding IsEnabled}"
                                                                      Command="{Binding $parent[ItemsControl].((vm:SensorsCalibrationPageViewModel)DataContext).SetCompassEnabledCommand}"
                                                                      CommandParameter="{Binding}" FontSize="11" HorizontalAlignment="Center"/>
														</StackPanel>
														<TextBlock Grid.Column="2" Text="{Binding BusTypeName}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
														<TextBlock Grid.Column="3" Text="{Binding BusNumber}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
														<TextBlock Grid.Column="4" Text="{Binding Address}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
														<TextBlock Grid.Column="5" Text="{Binding DeviceTypeHex}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
														<CheckBox Grid.Column="6" IsChecked="{Binding IsMissing}" IsEnabled="False" HorizontalAlignment="Center" VerticalAlignment="Center"/>
														<CheckBox Grid.Column="7" IsChecked="{Binding IsExternal}" IsEnabled="False" HorizontalAlignment="Center" VerticalAlignment="Center"/>
														<ComboBox Grid.Column="8" SelectedItem="{Binding Orientation}" MinWidth="100" HorizontalAlignment="Center" VerticalAlignment="Center">
															<ComboBox.Items>
																<x:String>None</x:String>
																<x:String>Roll 90</x:String>
																<x:String>Roll 180</x:String>
																<x:String>Roll 270</x:String>
																<x:String>Pitch 90</x:String>
																<x:String>Pitch 270</x:String>
															</ComboBox.Items>
														</ComboBox>
														<Button Grid.Column="9"
                                                                Width="36" Height="36"
                                                                Padding="0"
                                                                Background="#E5F3FF"
                                                                CornerRadius="6"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                HorizontalContentAlignment="Center"
                                                                VerticalContentAlignment="Center"
                                                                Command="{Binding $parent[ItemsControl].((vm:SensorsCalibrationPageViewModel)DataContext).MoveCompassUpCommand}"
                                                                CommandParameter="{Binding}"
                                                                ToolTip.Tip="Move up in priority">
															<TextBlock Text="↑" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
														</Button>
														<Button Grid.Column="10"
                                                                Width="36" Height="36"
                                                                Padding="0"
                                                                Background="#E5F3FF"
                                                                CornerRadius="6"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                HorizontalContentAlignment="Center"
                                                                VerticalContentAlignment="Center"
                                                                Command="{Binding $parent[ItemsControl].((vm:SensorsCalibrationPageViewModel)DataContext).MoveCompassDownCommand}"
                                                                CommandParameter="{Binding}"
                                                                ToolTip.Tip="Move down in priority">
															<TextBlock Text="↓" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
														</Button>
													</Grid>
												</Border>
											</DataTemplate>
										</ItemsControl.ItemTemplate>
									</ItemsControl>
								</ScrollViewer>
							</Grid>
						</Border>

						<!-- Update Priority Button and Status -->
						<StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
							<Button Classes="Primary" Content="Update Priority"
                                    Command="{Binding UpdateCompassPriorityCommand}"
                                    IsEnabled="{Binding HasCompassPriorityChanges}"
                                    ToolTip.Tip="Write compass priority changes to the flight controller (COMPASS_PRIOx_ID parameters)"/>
							<TextBlock Text="Priority order changed - click 'Update Priority' to save"
                                       FontSize="12" Foreground="#F59E0B" FontWeight="Medium"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding HasCompassPriorityChanges}"/>
						</StackPanel>

						<!-- Enable/disable quick toggles -->
						<Border Background="#F8FAFC" CornerRadius="10" Padding="12" BorderBrush="#E2E8F0" BorderThickness="1">
							<StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
								<TextBlock Text="Disable any of the first 3 compasses?" VerticalAlignment="Center" FontSize="12"/>
								<ItemsControl ItemsSource="{Binding Compasses}" Margin="8,0">
									<ItemsControl.ItemsPanel>
										<ItemsPanelTemplate>
											<StackPanel Orientation="Horizontal" Spacing="10"/>
										</ItemsPanelTemplate>
									</ItemsControl.ItemsPanel>
									<ItemsControl.ItemTemplate>
										<DataTemplate>
											<CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsEnabled}"
                                                      Command="{Binding $parent[ItemsControl].((vm:SensorsCalibrationPageViewModel)DataContext).SetCompassEnabledCommand}"
                                                      CommandParameter="{Binding}" FontSize="12"/>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
								<Button Content="Remove Missing" Padding="12,8" Background="#CBEA7B" Foreground="#365314"
                                        Command="{Binding RefreshCommand}"/>
								<CheckBox Content="Automatically learn offsets" IsChecked="True" IsEnabled="False"/>
							</StackPanel>
						</Border>

						<StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
							<TextBlock Text="A mag calibration is required to remap the above changes." FontSize="12" Foreground="#475569" VerticalAlignment="Center"/>
							<Button Classes="Secondary" Content="Reboot" Command="{Binding RebootCommand}" IsEnabled="{Binding IsConnected}"/>
						</StackPanel>

						<!-- Onboard Mag Calibration Section -->
						<Border Background="#F8FAFC" CornerRadius="12" Padding="14" BorderBrush="#E2E8F0" BorderThickness="1">
							<StackPanel Spacing="12">
								<TextBlock FontWeight="Bold" Text="Onboard Mag Calibration" FontSize="14" Foreground="#1E293B"/>

								<TextBlock Text="Rotate the vehicle in all directions to achieve full sphere coverage. Progress bars show completion for each compass."
                                           FontSize="12" Foreground="#64748B" TextWrapping="Wrap"/>

								<!-- Control buttons -->
								<StackPanel Orientation="Horizontal" Spacing="12">
									<Button Classes="Primary" Content="Start"
                                            Command="{Binding StartOnboardCompassCalCommand}"
                                            IsVisible="{Binding !IsOnboardCompassCalActive}"
                                            IsEnabled="{Binding CanCalibrateCompass}"/>
									<Button Content="Accept" Padding="16,8" Background="#22C55E" Foreground="White"
                                            Command="{Binding AcceptCompassCalCommand}"
                                            IsVisible="{Binding CanAcceptCompassCal}"/>
									<Button Content="Cancel" Padding="16,8" Background="#FECACA" Foreground="#991B1B"
                                            Command="{Binding CancelCompassCalCommand}"
                                            IsVisible="{Binding CanCancelCompassCal}"/>
								</StackPanel>

								<!-- Status message - visible when calibrating -->
								<Border Background="#FFF7ED" CornerRadius="8" Padding="12" IsVisible="{Binding IsOnboardCompassCalActive}">
									<StackPanel Spacing="8">
										<TextBlock Text="{Binding CompassCalStatus}" FontWeight="Bold" FontSize="14" Foreground="#92400E"/>
										<TextBlock Text="{Binding CompassInstructions}" FontSize="12" Foreground="#78350F" TextWrapping="Wrap"/>

										<!-- Compass 1 Progress -->
										<Grid ColumnDefinitions="80,*,60" Margin="0,8,0,0">
											<TextBlock Grid.Column="0" Text="Compass 1" FontSize="12" FontWeight="Medium" VerticalAlignment="Center"/>
											<ProgressBar Grid.Column="1" Height="16" Maximum="100"
                                                         Value="{Binding Compass1Progress}"
                                                         Foreground="#F59E0B" Background="#FDE68A" Margin="8,0"/>
											<TextBlock Grid.Column="2" Text="{Binding Compass1Progress, StringFormat='{}{0}%'}"
                                                       FontWeight="Bold" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Right"/>
										</Grid>

										<!-- Compass 2 Progress -->
										<Grid ColumnDefinitions="80,*,60">
											<TextBlock Grid.Column="0" Text="Compass 2" FontSize="12" FontWeight="Medium" VerticalAlignment="Center"/>
											<ProgressBar Grid.Column="1" Height="16" Maximum="100"
                                                         Value="{Binding Compass2Progress}"
                                                         Foreground="#F59E0B" Background="#FDE68A" Margin="8,0"/>
											<TextBlock Grid.Column="2" Text="{Binding Compass2Progress, StringFormat='{}{0}%'}"
                                                       FontWeight="Bold" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Right"/>
										</Grid>

										<!-- Compass 3 Progress -->
										<Grid ColumnDefinitions="80,*,60">
											<TextBlock Grid.Column="0" Text="Compass 3" FontSize="12" FontWeight="Medium" VerticalAlignment="Center"/>
											<ProgressBar Grid.Column="1" Height="16" Maximum="100"
                                                         Value="{Binding Compass3Progress}"
                                                         Foreground="#F59E0B" Background="#FDE68A" Margin="8,0"/>
											<TextBlock Grid.Column="2" Text="{Binding Compass3Progress, StringFormat='{}{0}%'}"
                                                       FontWeight="Bold" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Right"/>
										</Grid>
									</StackPanel>
								</Border>

								<!-- Calibration results -->
								<Border Background="#F0FDF4" CornerRadius="8" Padding="12"
                                        IsVisible="{Binding Compass1Result, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
									<StackPanel Spacing="4">
										<TextBlock Text="Calibration Results:" FontWeight="Bold" Foreground="#166534"/>
										<TextBlock Text="{Binding Compass1Result}" FontFamily="Consolas" FontSize="11"
                                                   Foreground="#15803D" IsVisible="{Binding Compass1Result, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
										<TextBlock Text="{Binding Compass2Result}" FontFamily="Consolas" FontSize="11"
                                                   Foreground="#15803D" IsVisible="{Binding Compass2Result, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
										<TextBlock Text="{Binding Compass3Result}" FontFamily="Consolas" FontSize="11"
                                                   Foreground="#15803D" IsVisible="{Binding Compass3Result, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
									</StackPanel>
								</Border>
							</StackPanel>
						</Border>
					</StackPanel>
				</Border>

				<!-- LEVEL HORIZON TAB -->
				<Border Classes="SectionCard" IsVisible="{Binding IsLevelHorizonTabSelected}">
					<StackPanel>
						<!-- Sensor Not Available Warning -->
						<Border Background="#FEF2F2" CornerRadius="8" Padding="12" Margin="0,0,0,16"
                                IsVisible="{Binding !IsAccelerometerAvailable}">
							<StackPanel Orientation="Horizontal" Spacing="8">
								<TextBlock Text="&#x26A0;" FontSize="16" Foreground="#DC2626"/>
								<TextBlock Text="Accelerometer required for level horizon calibration."
                                           Foreground="#DC2626" VerticalAlignment="Center"/>
							</StackPanel>
						</Border>

						<TextBlock Classes="StatusText" Text="{Binding LevelCalibrationStatus}"/>
						<TextBlock Classes="InstructionsLabel" Text="DETAILS"/>
						<TextBlock Classes="Instructions" Text="{Binding LevelInstructions}"/>

						<Border Background="#F8FAFC" CornerRadius="12" Padding="24" Margin="0,16,0,0" HorizontalAlignment="Center">
							<StackPanel HorizontalAlignment="Center">
								<Image Source="avares://PavamanDroneConfigurator.UI/Assets/Images/Caliberation-images/Level.png"
                                       Width="150" Height="100" Stretch="Uniform"/>
								<TextBlock Text="Place on level surface" FontSize="12" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,8,0,0"/>
							</StackPanel>
						</Border>

						<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12" Margin="0,24,0,0">
							<Button Classes="Primary" Content="Calibrate" Command="{Binding CalibrateLevelHorizonCommand}"
                                    IsVisible="{Binding CanCalibrateLevelHorizon}"/>
						</StackPanel>
					</StackPanel>
				</Border>

				<!-- PRESSURE TAB -->
				<Border Classes="SectionCard" IsVisible="{Binding IsPressureTabSelected}">
					<StackPanel>
						<!-- Sensor Not Available Warning -->
						<Border Background="#FEF2F2" CornerRadius="8" Padding="12" Margin="0,0,0,16"
                                IsVisible="{Binding !IsBarometerAvailable}">
							<StackPanel Orientation="Horizontal" Spacing="8">
								<TextBlock Text="!" FontSize="16" FontWeight="Bold" Foreground="#DC2626"/>
								<TextBlock Text="Barometer sensor not detected. Check hardware connections."
                                           Foreground="#DC2626" VerticalAlignment="Center"/>
							</StackPanel>
						</Border>

						<TextBlock Classes="StatusText" Text="{Binding PressureCalibrationStatus}"/>
						<TextBlock Classes="InstructionsLabel" Text="CALIBRATION INFO"/>
						<TextBlock Classes="Instructions" Text="{Binding PressureInstructions}" Margin="0,0,0,16"/>

						<!-- Barometer visualization -->
						<Border Background="#F8FAFC" CornerRadius="12" Padding="32" Margin="0,0,0,16" HorizontalAlignment="Center">
							<StackPanel HorizontalAlignment="Center" Spacing="12">
								<Border Width="80" Height="80" CornerRadius="40"
                                        Background="White"
                                        BorderBrush="#3B82F6"
                                        BorderThickness="4"
                                        HorizontalAlignment="Center">
									<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
										<TextBlock Text="P" FontSize="32" FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#3B82F6"/>
										<TextBlock Text="mbar" FontSize="10"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#3B82F6"/>
									</StackPanel>
								</Border>
								<TextBlock Text="Barometer Sensor"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="#1E293B"
                                           HorizontalAlignment="Center"/>
								<TextBlock Text="Measures atmospheric pressure for altitude"
                                           FontSize="12"
                                           Foreground="#64748B"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="300"
                                           TextAlignment="Center"/>
							</StackPanel>
						</Border>

						<!-- Progress bar - visible during calibration -->
						<Border Background="#E7F3FF" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                                IsVisible="{Binding IsPressureCalibrationActive}">
							<StackPanel Spacing="8">
								<Grid ColumnDefinitions="*,Auto">
									<TextBlock Grid.Column="0"
                                               Text="Calibrating barometer..."
                                               FontWeight="Bold"
                                               Foreground="#0B5ED7"/>
									<TextBlock Grid.Column="1"
                                               Text="{Binding PressureCalibrationProgress, StringFormat='{}{0}%'}"
                                               FontWeight="Bold"
                                               FontSize="16"
                                               Foreground="#0B5ED7"/>
								</Grid>
								<ProgressBar Value="{Binding PressureCalibrationProgress}"
                                             Maximum="100"
                                             Height="10"
                                             Foreground="#3B82F6"
                                             Background="#CBD5E1"/>
								<TextBlock Text="Please keep the vehicle still during calibration"
                                           FontSize="12"
                                           Foreground="#475569"
                                           TextWrapping="Wrap"/>
							</StackPanel>
						</Border>

						<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12" Margin="0,8,0,0">
							<Button Classes="Danger"
                                    Content="Cancel"
                                    Command="{Binding CancelCalibrationCommand}"
                                    IsVisible="{Binding IsPressureCalibrationActive}"/>
							<Button Classes="Primary"
                                    Content="Calibrate"
                                    Command="{Binding CalibratePressureCommand}"
                                    IsVisible="{Binding CanCalibrateBarometer}"/>
						</StackPanel>
					</StackPanel>
				</Border>

				<!-- FLOW TAB -->
				<Border Classes="SectionCard" IsVisible="{Binding IsFlowTabSelected}">
					<ScrollViewer VerticalScrollBarVisibility="Auto">
						<StackPanel>
							<TextBlock Classes="SectionTitle" Text="Flow Settings"/>

							<Grid ColumnDefinitions="*,24,*" RowDefinitions="Auto,16,Auto" Margin="0,16,0,0">
								<StackPanel Grid.Column="0" Grid.Row="0">
									<TextBlock Classes="FieldLabel" Text="Enable"/>
									<ComboBox ItemsSource="{Binding FlowTypeOptions}"
                                              SelectedItem="{Binding SelectedFlowType}"
                                              DisplayMemberBinding="{Binding Label}"
                                              HorizontalAlignment="Stretch"/>
								</StackPanel>

								<StackPanel Grid.Column="2" Grid.Row="0">
									<TextBlock Classes="FieldLabel" Text="X axis Optical Scale Factor"/>
									<TextBox Text="{Binding FlowXAxisScale}"/>
									<TextBlock Text="[Min -200 - Max 200]" FontSize="11" Foreground="#94A3B8"/>
								</StackPanel>

								<StackPanel Grid.Column="0" Grid.Row="2">
									<TextBlock Classes="FieldLabel" Text="Sensor Yaw Alignment"/>
									<TextBox Text="{Binding FlowYawAlignment}"/>
									<TextBlock Text="[Min -180 - Max 180]" FontSize="11" Foreground="#94A3B8"/>
								</StackPanel>

								<StackPanel Grid.Column="2" Grid.Row="2">
									<TextBlock Classes="FieldLabel" Text="Y axis Optical Scale Factor"/>
									<TextBox Text="{Binding FlowYAxisScale}"/>
									<TextBlock Text="[Min -200 - Max 200]" FontSize="11" Foreground="#94A3B8"/>
								</StackPanel>
							</Grid>

							<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
								<Button Classes="Secondary" Content="Update"
                                        Command="{Binding UpdateFlowSettingsCommand}"
                                        IsEnabled="{Binding IsConnected}"/>
							</StackPanel>
						</StackPanel>
					</ScrollViewer>
				</Border>

				<!-- STATUS BAR -->
				<Border Background="#F1F5F9" CornerRadius="8" Padding="16" Margin="0,8,0,0">
					<Grid ColumnDefinitions="Auto,*,Auto">
						<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
							<Ellipse Width="10" Height="10" Fill="{Binding ConnectionStatusColor}"/>
							<TextBlock Text="{Binding ConnectionStatusText}" FontSize="13" VerticalAlignment="Center"/>
						</StackPanel>

						<TextBlock Grid.Column="1" Text="{Binding StatusMessage}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#64748B"/>

						<ProgressBar Grid.Column="2" Width="100" Height="4"
                                     IsIndeterminate="True"
                                     IsVisible="{Binding IsBusy}"
                                     Foreground="#3B82F6"/>
					</Grid>
				</Border>

			</StackPanel>
		</ScrollViewer>

		<!-- ERROR DIALOG OVERLAY -->
		<Border Classes="DialogOverlay"
                IsVisible="{Binding ShowErrorDialog}"
                IsHitTestVisible="{Binding ShowErrorDialog}">
			<Border Classes="DialogContent">
				<StackPanel Spacing="16">
					<Border Width="64" Height="64" CornerRadius="32" Background="#FEE2E2" HorizontalAlignment="Center">
						<TextBlock Text="!" FontSize="32" FontWeight="Bold" Foreground="#EF4444"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
					</Border>

					<TextBlock Text="{Binding ErrorDialogTitle}" FontSize="20" FontWeight="Bold"
                               HorizontalAlignment="Center" Foreground="#111827"/>

					<TextBlock Text="{Binding ErrorDialogMessage}" FontSize="14" TextWrapping="Wrap"
                               HorizontalAlignment="Center" Foreground="#6B7280" TextAlignment="Center"/>

					<Button Content="OK" Classes="Primary" HorizontalAlignment="Center" MinWidth="120"
                            Command="{Binding CloseErrorDialogCommand}"/>
				</StackPanel>
			</Border>
		</Border>

		<!-- REBOOT PROMPT DIALOG OVERLAY -->
		<Border Classes="DialogOverlay"
                IsVisible="{Binding ShowRebootPrompt}"
                IsHitTestVisible="{Binding ShowRebootPrompt}">
			<Border Classes="DialogContent">
				<StackPanel Spacing="16">
					<Border Width="64" Height="64" CornerRadius="32" Background="#D1FAE5" HorizontalAlignment="Center">
						<TextBlock Text="&#x2714;" FontSize="32" FontWeight="Bold" Foreground="#10B981"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
					</Border>

					<TextBlock Text="Calibration Complete!" FontSize="20" FontWeight="Bold"
                               HorizontalAlignment="Center" Foreground="#111827"/>

					<TextBlock Text="{Binding RebootPromptMessage}" FontSize="14" TextWrapping="Wrap"
                               HorizontalAlignment="Center" Foreground="#6B7280" TextAlignment="Center"/>

					<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">
						<Button Content="Later" Padding="24,10" Background="#E2E8F0" Foreground="#475569"
                                CornerRadius="8" Command="{Binding CloseRebootPromptCommand}"/>
						<Button Content="Reboot Now" Classes="Primary" MinWidth="120"
                                Command="{Binding RebootFromPromptCommand}"/>
					</StackPanel>
				</StackPanel>
			</Border>
		</Border>

		<!-- CALIBRATION FAILED DIALOG OVERLAY -->
		<Border Classes="DialogOverlay"
                IsVisible="{Binding ShowCalibrationFailedDialog}"
                IsHitTestVisible="{Binding ShowCalibrationFailedDialog}">
			<Border Classes="DialogContent">
				<StackPanel Spacing="16">
					<Border Width="64" Height="64" CornerRadius="32" Background="#FEE2E2" HorizontalAlignment="Center">
						<TextBlock Text="&#x2718;" FontSize="32" FontWeight="Bold" Foreground="#EF4444"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
					</Border>

					<TextBlock Text="Calibration Failed" FontSize="20" FontWeight="Bold"
                               HorizontalAlignment="Center" Foreground="#DC2626"/>

					<TextBlock Text="{Binding CalibrationFailedMessage}" FontSize="14" TextWrapping="Wrap"
                               HorizontalAlignment="Center" Foreground="#6B7280" TextAlignment="Center"/>

					<Border Background="#FEF2F2" CornerRadius="8" Padding="12" Margin="0,8,0,0">
						<StackPanel Spacing="4">
							<TextBlock Text="Troubleshooting Tips:" FontWeight="Bold" FontSize="12" Foreground="#991B1B"/>
							<TextBlock Text="&#x2022; Ensure the vehicle is held steady in each position" FontSize="11" Foreground="#7F1D1D"/>
							<TextBlock Text="&#x2022; Keep the vehicle away from magnetic interference" FontSize="11" Foreground="#7F1D1D"/>
							<TextBlock Text="&#x2022; Check sensor connections and try again" FontSize="11" Foreground="#7F1D1D"/>
						</StackPanel>
					</Border>

					<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">
						<Button Content="Close" Padding="24,10" Background="#E2E8F0" Foreground="#475569"
                                CornerRadius="8" Command="{Binding CloseCalibrationFailedDialogCommand}"/>
						<Button Content="Retry Calibration" Classes="Primary" MinWidth="140"
                                Command="{Binding RetryCalibrationCommand}"/>
					</StackPanel>
				</StackPanel>
			</Border>
		</Border>
	</Grid>
</UserControl>
