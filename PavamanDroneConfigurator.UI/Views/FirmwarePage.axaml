<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels"
             xmlns:converters="using:PavamanDroneConfigurator.UI.Converters"
             x:Class="PavamanDroneConfigurator.UI.Views.FirmwarePage"
             x:DataType="vm:FirmwarePageViewModel">

    <UserControl.Resources>
        <converters:BoolToStringConverter x:Key="BoolToStringConverter"/>
    </UserControl.Resources>
    
    <UserControl.Styles>
        <!-- Professional firmware page styles using theme colors -->
        <Style Selector="Border.mp-background">
            <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
        </Style>
        
        <!-- Vehicle Card Style - Enhanced with hover effects -->
        <Style Selector="Button.firmware-card">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="155"/>
            <Setter Property="Height" Value="175"/>
            <Setter Property="Margin" Value="6"/>
        </Style>
        
        <Style Selector="Button.firmware-card:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
        </Style>
        
        <Style Selector="Button.firmware-card:pressed">
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHoverBrush}"/>
        </Style>
        
        <Style Selector="Button.firmware-card-selected">
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
        </Style>
        
        <!-- Status Bar Button Style -->
        <Style Selector="Button.status-btn">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="4,0"/>
        </Style>
        
        <Style Selector="Button.status-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
        </Style>
        
        <!-- Progress Bar Style -->
        <Style Selector="ProgressBar.mp-progress">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SecondaryLightBrush}"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        
        <!-- Availability Badge -->
        <Style Selector="Border.availability-badge">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8,3"/>
        </Style>
        
        <!-- Section Header -->
        <Style Selector="TextBlock.section-header">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,8,0,12"/>
        </Style>
        
        <!-- Control Bar -->
        <Style Selector="Border.control-bar">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="24,16"/>
        </Style>
        
        <!-- Dialog Overlay -->
        <Style Selector="Border.dialog-overlay">
            <Setter Property="Background" Value="{DynamicResource OverlayBrush}"/>
        </Style>
        
        <!-- Dialog Box -->
        <Style Selector="Border.dialog-box">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="32"/>
            <Setter Property="MinWidth" Value="420"/>
            <Setter Property="MaxWidth" Value="520"/>
        </Style>
        
        <!-- Log Panel -->
        <Style Selector="Border.log-panel">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto,Auto" Classes="mp-background">
        
        <!-- Top Control Bar -->
        <Border Grid.Row="0" Classes="control-bar">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                <!-- Firmware Source Dropdown -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Source" 
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontWeight="Medium"/>
                    <ComboBox ItemsSource="{Binding FirmwareSources}"
                              SelectedItem="{Binding SelectedFirmwareSource}"
                              Width="180"
                              CornerRadius="20"
                              Padding="12,8">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                
                <!-- Refresh Button -->
                <Button Grid.Column="1" 
                        Classes="status-btn"
                        Margin="12,0,0,0"
                        Command="{Binding RefreshFirmwareVersionsCommand}"
                        IsEnabled="{Binding !IsLoadingManifest}"
                        ToolTip.Tip="Refresh firmware list">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="M17.65 6.35A7.958 7.958 0 0 0 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08A5.99 5.99 0 0 1 12 18c-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"
                                  Width="14" Height="14"
                                  Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="Refresh" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </Button>
                
                <!-- Connection Status -->
                <StackPanel Grid.Column="3" 
                            Orientation="Horizontal" 
                            Spacing="8"
                            VerticalAlignment="Center">
                    <Border Width="10" Height="10" CornerRadius="5">
                        <Border.Background>
                            <SolidColorBrush Color="{Binding ConnectionStatusColor}"/>
                        </Border.Background>
                    </Border>
                    <StackPanel Spacing="0">
                        <TextBlock Text="{Binding ConnectionStatusText}"
                                   FontWeight="Medium"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Firmware data synced from ArduPilot"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Main Content Area - Vehicle Type Grid -->
        <ScrollViewer Grid.Row="1" 
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Padding="24,16">
            
            <StackPanel Spacing="16">
                
                <!-- Loading Skeleton -->
                <StackPanel IsVisible="{Binding IsLoadingManifest}" Spacing="16">
                    <TextBlock Text="Fetching latest firmware metadata..."
                               FontSize="14"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,16"/>
                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Border Background="{DynamicResource SecondaryLightBrush}" CornerRadius="12" 
                                Width="155" Height="175" Margin="6" Opacity="0.7"/>
                        <Border Background="{DynamicResource SecondaryLightBrush}" CornerRadius="12" 
                                Width="155" Height="175" Margin="6" Opacity="0.5"/>
                        <Border Background="{DynamicResource SecondaryLightBrush}" CornerRadius="12" 
                                Width="155" Height="175" Margin="6" Opacity="0.3"/>
                        <Border Background="{DynamicResource SecondaryLightBrush}" CornerRadius="12" 
                                Width="155" Height="175" Margin="6" Opacity="0.2"/>
                    </WrapPanel>
                </StackPanel>
                
                <!-- Status Message Banner -->
                <Border Background="{DynamicResource InfoLightBrush}"
                        CornerRadius="8"
                        Padding="16,12"
                        IsVisible="{Binding !IsOperationInProgress}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <PathIcon Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"
                                  Width="20" Height="20"
                                  Foreground="{DynamicResource InfoBrush}"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>
                
                <!-- Success Banner -->
                <Border Background="{DynamicResource SuccessLightBrush}"
                        CornerRadius="8"
                        Padding="16,12"
                        IsVisible="{Binding IsSuccess}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <PathIcon Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"
                                  Width="20" Height="20"
                                  Foreground="{DynamicResource SuccessBrush}"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SuccessDarkBrush}"/>
                    </StackPanel>
                </Border>
                
                <!-- Error Banner -->
                <Border Background="{DynamicResource ErrorLightBrush}"
                        CornerRadius="8"
                        Padding="16,12"
                        IsVisible="{Binding IsError}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <PathIcon Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"
                                  Width="20" Height="20"
                                  Foreground="{DynamicResource ErrorBrush}"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource ErrorDarkBrush}"/>
                    </StackPanel>
                </Border>
                
                <!-- Firmware Groups (Collapsible Sections) -->
                <ItemsControl ItemsSource="{Binding VehicleGroups}"
                              IsVisible="{Binding !IsLoadingManifest}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:VehicleTypeGroup">
                            <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
                                      Margin="0,0,0,16">
                                <Expander.Header>
                                    <TextBlock Text="{Binding Name}"
                                               Classes="section-header"/>
                                </Expander.Header>
                                
                                <WrapPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="vm:VehicleTypeItem">
                                                <Button Classes="firmware-card"
                                                        Classes.firmware-card-selected="{Binding IsSelected}"
                                                        Command="{Binding $parent[ItemsControl].((vm:FirmwarePageViewModel)DataContext).SelectVehicleTypeCommand, FallbackValue={x:Null}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip.Tip="{Binding Description}">
                                                    <Grid RowDefinitions="Auto,*,Auto,Auto">
                                                        
                                                        <!-- Availability Badge -->
                                                        <Border Grid.Row="0"
                                                                Classes="availability-badge"
                                                                HorizontalAlignment="Right"
                                                                Margin="0,0,0,4">
                                                            <Border.Background>
                                                                <SolidColorBrush Color="{Binding AvailabilityBadgeColor}"/>
                                                            </Border.Background>
                                                            <TextBlock Text="{Binding AvailabilityText}"
                                                                       FontSize="9"
                                                                       FontWeight="Medium"
                                                                       Foreground="White"/>
                                                        </Border>
                                                        
                                                        <!-- Vehicle Image -->
                                                        <Border Grid.Row="1" 
                                                                Background="{DynamicResource SecondaryLightBrush}"
                                                                CornerRadius="8"
                                                                Padding="8"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center">
                                                            <Image Source="{Binding ImagePath}"
                                                                   Width="75"
                                                                   Height="60"
                                                                   Stretch="Uniform"/>
                                                        </Border>
                                                        
                                                        <!-- Vehicle Name -->
                                                        <TextBlock Grid.Row="2"
                                                                   Text="{Binding Description}"
                                                                   FontWeight="Medium"
                                                                   FontSize="12"
                                                                   HorizontalAlignment="Center"
                                                                   TextAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   Margin="0,8,0,2"/>
                                                        
                                                        <!-- Version Text -->
                                                        <TextBlock Grid.Row="3"
                                                                   Text="{Binding VersionText}"
                                                                   FontSize="10"
                                                                   HorizontalAlignment="Center"
                                                                   TextAlignment="Center"
                                                                   Foreground="{DynamicResource TextMutedBrush}"/>
                                                        
                                                        <!-- Selected Checkmark -->
                                                        <Border Grid.Row="0" Grid.RowSpan="4"
                                                                HorizontalAlignment="Left"
                                                                VerticalAlignment="Top"
                                                                Margin="-2,-2,0,0"
                                                                IsVisible="{Binding IsSelected}">
                                                            <Ellipse Width="22" Height="22"
                                                                     Fill="{DynamicResource PrimaryBrush}"/>
                                                        </Border>
                                                        <PathIcon Grid.Row="0" Grid.RowSpan="4"
                                                                  Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"
                                                                  Width="12" Height="12"
                                                                  Foreground="White"
                                                                  HorizontalAlignment="Left"
                                                                  VerticalAlignment="Top"
                                                                  Margin="3,3,0,0"
                                                                  IsVisible="{Binding IsSelected}"/>
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </WrapPanel>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                
                <!-- Detected Board Panel -->
                <Border Background="#80000000"
                        IsVisible="{Binding ShowConfirmationDialog}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
                    <Border Background="#3E3E42"
                            CornerRadius="8"
                            Padding="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MinWidth="400"
                            MaxWidth="500">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Confirm Firmware Installation"
                                       Foreground="#FFFFFF"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding ConfirmationMessage}"
                                       Foreground="#CCCCCC"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" 
                                        HorizontalAlignment="Center" 
                                        Spacing="16"
                                        Margin="0,8,0,0">
                                <Button Content="Yes"
                                        Width="100"
                                        Background="#0E639C"
                                        Foreground="White"
                                        Command="{Binding ConfirmInstallationCommand}"/>
                                <Button Content="No"
                                        Width="100"
                                        Classes="status-btn"
                                        Command="{Binding CancelConfirmationCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>
                
                <!-- Platform Selection Dialog Overlay -->
                <Border Background="#80000000"
                        IsVisible="{Binding ShowPlatformSelectionDialog}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
                    <Border Background="#3E3E42"
                            CornerRadius="8"
                            Padding="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MinWidth="450"
                            MaxWidth="550">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Select Firmware Variant"
                                       Foreground="#FFFFFF"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding PlatformSelectionMessage}"
                                       Foreground="#CCCCCC"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding AvailablePlatformVariants}"
                                      SelectedItem="{Binding SelectedPlatformVariant}"
                                      HorizontalAlignment="Stretch"
                                      Margin="0,8,0,0"
                                      Background="#252526"
                                      Foreground="#CCCCCC"/>
                            <StackPanel Orientation="Horizontal" 
                                        HorizontalAlignment="Center" 
                                        Spacing="16"
                                        Margin="0,8,0,0">
                                <Button Content="Install"
                                        Width="100"
                                        Background="#0E639C"
                                        Foreground="White"
                                        Command="{Binding ConfirmPlatformSelectionCommand}"/>
                                <Button Content="Cancel"
                                        Width="100"
                                        Classes="status-btn"
                                        Command="{Binding CancelPlatformSelectionCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>
                
                <!-- Reconnect Prompt Dialog Overlay -->
                <Border Background="#80000000"
                        IsVisible="{Binding ShowReconnectPromptDialog}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
                    <Border Background="#3E3E42"
                            CornerRadius="8"
                            Padding="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MinWidth="400"
                            MaxWidth="500">
                        <StackPanel Spacing="16">
                            <PathIcon Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"
                                      Foreground="#4CAF50" Width="48" Height="48"
                                      HorizontalAlignment="Center"/>
                            <TextBlock Text="Installation Complete"
                                       Foreground="#FFFFFF"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding ReconnectPromptMessage}"
                                       Foreground="#CCCCCC"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"/>
                            <Button Content="OK"
                                    Width="120"
                                    Background="#0E639C"
                                    Foreground="White"
                                    HorizontalAlignment="Center"
                                    Margin="0,8,0,0"
                                    Command="{Binding AcknowledgeReconnectPromptCommand}"/>
                        </StackPanel>
                    </Border>
                </Border>
                
                <!-- Bootloader Mode Dialog Overlay - Mission Planner equivalent "Please unplug and plug back in" -->
                <Border Background="#80000000"
                        IsVisible="{Binding ShowBootloaderModeDialog}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
                    <Border Background="#3E3E42"
                            CornerRadius="8"
                            Padding="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MinWidth="450"
                            MaxWidth="550">
                        <StackPanel Spacing="16">
                            <!-- Warning/Info icon instead of checkmark -->
                            <PathIcon Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"
                                      Foreground="#FFA500" Width="48" Height="48"
                                      HorizontalAlignment="Center"/>
                            <TextBlock Text="Bootloader Mode Required"
                                       Foreground="#FFFFFF"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding BootloaderModeMessage}"
                                       Foreground="#CCCCCC"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" 
                                        HorizontalAlignment="Center" 
                                        Spacing="16"
                                        Margin="0,8,0,0">
                                <Button Content="OK"
                                        Width="100"
                                        Background="#0E639C"
                                        Foreground="White"
                                        Command="{Binding ConfirmBootloaderModeCommand}"/>
                                <Button Content="Cancel"
                                        Width="100"
                                        Classes="status-btn"
                                        Command="{Binding CancelBootloaderModeCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>
                
                <!-- Detected Board Panel (shown when board detected) -->
                <Border Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="20"
                        Margin="0,16,0,0"
                        IsVisible="{Binding IsBoardDetected}">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Detected Board"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="12"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding DetectedBoardName}"
                                           Foreground="{DynamicResource PrimaryBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="16"/>
                                <TextBlock Text="on"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding DetectedBoardPort}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Refresh"
                                Classes="status-btn"
                                Command="{Binding DetectBoardCommand}"/>
                    </Grid>
                </Border>
                
                <!-- Manual Mode Panel -->
                <Border Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="20"
                        Margin="0,16,0,0"
                        IsVisible="{Binding IsManualMode}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Load Custom Firmware"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="16"/>
                        <TextBlock Text="Select a .apj or .px4 firmware file to flash"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13"/>
                        <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                            <TextBox Grid.Column="0"
                                     Text="{Binding SelectedFileName}"
                                     IsReadOnly="True"
                                     Watermark="No file selected..."
                                     Classes="input"
                                     CornerRadius="8,0,0,8"/>
                            <Button Grid.Column="1"
                                    Content="Browse..."
                                    Classes="status-btn"
                                    CornerRadius="0,8,8,0"
                                    Click="BrowseFirmwareFile_Click"/>
                        </Grid>
                        <Button Content="Flash Custom Firmware"
                                Classes="btn-primary"
                                HorizontalAlignment="Left"
                                Command="{Binding FlashCustomFirmwareCommand}"
                                IsEnabled="{Binding SelectedFilePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>
                </Border>
                
                <!-- Console Log (collapsible) -->
                <Expander IsExpanded="{Binding IsLogPanelExpanded}" 
                          Margin="0,16,0,0">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Status Log"
                                       FontWeight="Medium"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <Border Background="{DynamicResource SecondaryLightBrush}"
                                    CornerRadius="10"
                                    Padding="8,2">
                                <TextBlock Text="{Binding LogMessages.Count}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"/>
                            </Border>
                        </StackPanel>
                    </Expander.Header>
                    <Border Classes="log-panel"
                            Padding="12"
                            Height="180">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding LogMessages}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" 
                                                   Foreground="#80CBC4"
                                                   FontFamily="JetBrains Mono, Cascadia Code, Consolas, monospace"
                                                   FontSize="11"
                                                   Margin="0,1"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Expander>
                
            </StackPanel>
        </ScrollViewer>
        
        <!-- Mode Toggle Bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,10">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <RadioButton Content="Automatic"
                             IsChecked="{Binding IsAutomaticMode}"
                             GroupName="UpgradeMode"/>
                <RadioButton Content="Manual"
                             IsChecked="{Binding IsManualMode}"
                             GroupName="UpgradeMode"/>
            </StackPanel>
        </Border>
        
        <!-- Bottom Status Bar -->
        <Border Grid.Row="3"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,10">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Status Text -->
                <TextBlock Grid.Column="0"
                           Text="Status"
                           Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center"/>
                
                <!-- Action Buttons -->
                <StackPanel Grid.Column="2" 
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="8">
                    
                    <Button Content="Bootloader Update"
                            Classes="status-btn"
                            Command="{Binding UpdateBootloaderCommand}"
                            IsEnabled="{Binding !IsOperationInProgress}"/>
                    
                    <Button Content="Force Bootloader"
                            Classes="status-btn"
                            Command="{Binding ForceBootloaderCommand}"
                            IsEnabled="{Binding !IsOperationInProgress}"/>
                    
                    <Button Content="{Binding ShowBetaFirmware, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Official Only|Show Beta'}"
                            Classes="status-btn"
                            Command="{Binding ToggleBetaFirmwareCommand}"/>
                    
                    <Button Content="Cancel"
                            Classes="btn-danger"
                            Padding="16,8"
                            Command="{Binding CancelOperationCommand}"
                            IsVisible="{Binding IsOperationInProgress}"/>
                    
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
