<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels"
             xmlns:converters="using:PavamanDroneConfigurator.UI.Converters"
             x:Class="PavamanDroneConfigurator.UI.Views.FirmwarePage"
             x:DataType="vm:FirmwarePageViewModel">

	<UserControl.Resources>
		<converters:BoolToStringConverter x:Key="BoolToStringConverter"/>
		<converters:VehicleTypeToIconConverter x:Key="VehicleTypeToIconConverter"/>
		<converters:VehicleTypeToBadgeColorConverter x:Key="VehicleTypeToBadgeColorConverter"/>
	</UserControl.Resources>

	<UserControl.Styles>
		<!-- Professional firmware page styles with smooth animations -->
		<Style Selector="Border.mp-background">
			<Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
		</Style>

		<!-- Mode Selection Card Style with Smooth Transitions -->
		<Style Selector="Button.mode-selection-card">
			<Setter Property="Background" Value="{DynamicResource CardBrush}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="20"/>
			<Setter Property="Padding" Value="36,28"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="MinWidth" Value="340"/>
			<Setter Property="MinHeight" Value="200"/>
			<Setter Property="Margin" Value="16"/>
			<Setter Property="HorizontalContentAlignment" Value="Stretch"/>
			<Setter Property="VerticalContentAlignment" Value="Stretch"/>
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.3"/>
					<BrushTransition Property="BorderBrush" Duration="0:0:0.3"/>
					<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.3" Easing="CubicEaseOut"/>
				</Transitions>
			</Setter>
		</Style>

		<Style Selector="Button.mode-selection-card:pointerover">
			<Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
			<Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
			<Setter Property="RenderTransform" Value="translateY(-8px) scale(1.02)"/>
		</Style>

		<Style Selector="Button.mode-selection-card:pressed">
			<Setter Property="BorderBrush" Value="{DynamicResource PrimaryHoverBrush}"/>
			<Setter Property="RenderTransform" Value="translateY(-4px) scale(1.0)"/>
		</Style>

		<Style Selector="Button.mode-selection-card.selected">
			<Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
			<Setter Property="BorderThickness" Value="2"/>
			<Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
		</Style>

		<!-- Vehicle Card Style - Enhanced with smooth hover effects -->
		<Style Selector="Button.firmware-card">
			<Setter Property="Background" Value="{DynamicResource CardBrush}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="14"/>
			<Setter Property="Padding" Value="12"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Width" Value="160"/>
			<Setter Property="Height" Value="180"/>
			<Setter Property="Margin" Value="8"/>
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.3"/>
					<BrushTransition Property="BorderBrush" Duration="0:0:0.3"/>
					<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.3" Easing="CubicEaseOut"/>
				</Transitions>
			</Setter>
		</Style>

		<Style Selector="Button.firmware-card:pointerover">
			<Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
			<Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
			<Setter Property="RenderTransform" Value="translateY(-6px) scale(1.03)"/>
		</Style>

		<Style Selector="Button.firmware-card:pressed">
			<Setter Property="BorderBrush" Value="{DynamicResource PrimaryHoverBrush}"/>
			<Setter Property="RenderTransform" Value="translateY(-3px) scale(1.01)"/>
		</Style>

		<Style Selector="Button.firmware-card.firmware-card-selected">
			<Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
			<Setter Property="BorderThickness" Value="2"/>
			<Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
		</Style>

		<!-- Status Bar Button Style with Smooth Transitions -->
		<Style Selector="Button.status-btn">
			<Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
			<Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Padding" Value="18,10"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Margin" Value="4,0"/>
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.3"/>
					<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
				</Transitions>
			</Setter>
		</Style>

		<Style Selector="Button.status-btn:pointerover">
			<Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
			<Setter Property="RenderTransform" Value="scale(1.05)"/>
		</Style>

		<Style Selector="Button.status-btn:pressed">
			<Setter Property="RenderTransform" Value="scale(0.98)"/>
		</Style>

		<!-- Progress Bar Style -->
		<Style Selector="ProgressBar.mp-progress">
			<Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
			<Setter Property="Background" Value="{DynamicResource SecondaryLightBrush}"/>
			<Setter Property="Height" Value="8"/>
			<Setter Property="CornerRadius" Value="4"/>
		</Style>

		<!-- Availability Badge -->
		<Style Selector="Border.availability-badge">
			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="Padding" Value="8,3"/>
		</Style>

		<!-- Section Header -->
		<Style Selector="TextBlock.section-header">
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="FontSize" Value="15"/>
			<Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
			<Setter Property="Margin" Value="0,8,0,12"/>
		</Style>

		<!-- Control Bar -->
		<Style Selector="Border.control-bar">
			<Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
			<Setter Property="BorderThickness" Value="0,0,0,1"/>
			<Setter Property="Padding" Value="24,16"/>
		</Style>

		<!-- Dialog Overlay -->
		<Style Selector="Border.dialog-overlay">
			<Setter Property="Background" Value="{DynamicResource OverlayBrush}"/>
		</Style>

		<!-- Dialog Box -->
		<Style Selector="Border.dialog-box">
			<Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
			<Setter Property="CornerRadius" Value="16"/>
			<Setter Property="Padding" Value="32"/>
			<Setter Property="MinWidth" Value="420"/>
			<Setter Property="MaxWidth" Value="520"/>
		</Style>

		<!-- Log Panel -->
		<Style Selector="Border.log-panel">
			<Setter Property="Background" Value="#1E1E1E"/>
			<Setter Property="CornerRadius" Value="8"/>
		</Style>
		
		<!-- Dialog Button Styles -->
		<Style Selector="Button.dialog-btn-primary">
			<Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="Padding" Value="24,12"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="BorderThickness" Value="0"/>
		</Style>
		
		<Style Selector="Button.dialog-btn-secondary">
			<Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
			<Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Padding" Value="24,12"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Cursor" Value="Hand"/>
		</Style>
	</UserControl.Styles>

	<Grid RowDefinitions="Auto,*" Classes="mp-background">

		<!-- MODE SELECTION VIEW (Initial Screen) -->
		<Grid Grid.Row="1"
              VerticalAlignment="Center"
              HorizontalAlignment="Center">
			<Grid.IsVisible>
				<MultiBinding Converter="{x:Static BoolConverters.And}">
					<Binding Path="!IsAutomaticMode"/>
					<Binding Path="!IsManualMode"/>
				</MultiBinding>
			</Grid.IsVisible>

			<StackPanel Spacing="40" MaxWidth="1000">

				<!-- Page Title -->
				<StackPanel Spacing="12" HorizontalAlignment="Center">
					<TextBlock Text="KFT Firmware Upgrade"
                               FontSize="42"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"
                               HorizontalAlignment="Center"/>
					<TextBlock Text="Choose your firmware upload method"
                               FontSize="16"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Opacity="0.9"/>
				</StackPanel>

				<!-- Two Upload Option Buttons -->
				<Grid ColumnDefinitions="*,*" ColumnSpacing="32" Margin="0,40,0,0">

					<!-- Upload from Cloud Button -->
					<Button Grid.Column="0"
                            Classes="mode-selection-card"
                            Command="{Binding SelectAutomaticModeCommand}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
						<Grid RowDefinitions="Auto,Auto,*">
							<!-- Icon -->
							<Border Grid.Row="0"
                                    Background="{DynamicResource PrimaryLightBrush}"
                                    CornerRadius="16"
                                    Width="80" Height="80"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,24">
								<PathIcon Data="M19.35 10.04C18.67 6.59 15.64 4 12 4c-1.48 0-2.85.43-4.01 1.17l1.46 1.46C10.21 6.23 11.08 6 12 6c3.04 0 5.5 2.46 5.5 5.5v.5H19c1.66 0 3 1.34 3 3 0 1.13-.64 2.11-1.56 2.62l1.45 1.45C23.16 18.16 24 16.68 24 15c0-2.64-2.05-4.78-4.65-4.96zM3 5.27l2.75 2.74C2.56 8.15 0 10.77 0 14c0 3.31 2.69 6 6 6h11.73l2 2L21 20.73 4.27 4 3 5.27zM7.73 10l8 8H6c-2.21 0-4-1.79-4-4s1.79-4 4-4h1.73z"
                                          Width="40" Height="40"
                                          Foreground="{DynamicResource PrimaryBrush}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
							</Border>

							<!-- Title & Badge -->
							<StackPanel Grid.Row="1" Spacing="12">
								<TextBlock Text="Upload from Cloud"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center"/>
								<Border Background="{DynamicResource SuccessLightBrush}"
                                        CornerRadius="16"
                                        Padding="16,6"
                                        HorizontalAlignment="Center">
									<TextBlock Text="&#x2714; Recommended"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource SuccessDarkBrush}"/>
								</Border>
							</StackPanel>

							<!-- Description -->
							<TextBlock Grid.Row="2"
                                       Text="Download and install firmware directly from ArduPilot servers via HTTP"
                                       FontSize="15"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Opacity="0.9"
                                       Margin="0,20,0,0"/>
						</Grid>
					</Button>

					<!-- Upload Locally Button -->
					<Button Grid.Column="1"
                            Classes="mode-selection-card"
                            Command="{Binding SelectManualModeCommand}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
						<Grid RowDefinitions="Auto,Auto,*">
							<!-- Icon -->
							<Border Grid.Row="0"
                                    Background="{DynamicResource AccentLightBrush}"
                                    CornerRadius="16"
                                    Width="80" Height="80"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,24">
								<PathIcon Data="M9 16h6v-6h4l-7-7-7 7h4zm-4 2h14v2H5z"
                                          Width="40" Height="40"
                                          Foreground="{DynamicResource AccentBrush}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
							</Border>

							<!-- Title & Badge -->
							<StackPanel Grid.Row="1" Spacing="12">
								<TextBlock Text="Load Custom Firmware"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"/>
								<Border Background="{DynamicResource SecondaryLightBrush}"
                                        CornerRadius="16"
                                        Padding="16,6"
                                        HorizontalAlignment="Center">
									<TextBlock Text="&#x2699; Advanced"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryBrush}"/>
								</Border>
							</StackPanel>

							<!-- Description -->
							<TextBlock Grid.Row="2"
                                       Text="Upload and flash custom firmware files from your local computer"
                                       FontSize="15"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Opacity="0.9"
                                       Margin="0,20,0,0"/>
						</Grid>
					</Button>

				</Grid>

			</StackPanel>

		</Grid>

		<!-- AUTOMATIC MODE VIEW (Cloud Upload) -->
		<ScrollViewer Grid.Row="1"
                      IsVisible="{Binding IsAutomaticMode}"
                      Padding="32,24">
			<StackPanel Spacing="20">

				<!-- Control Bar -->
				<Border Background="{DynamicResource SurfaceLightBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="20,16"
                        Margin="0,0,0,8">
					<Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">

						<!-- Firmware Source Selector -->
						<StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    Spacing="10"
                                    VerticalAlignment="Center"
                                    Margin="0,0,16,0">
							<TextBlock Text="Source:"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
							<ComboBox ItemsSource="{Binding FirmwareSources}"
                                      SelectedItem="{Binding SelectedFirmwareSource}"
                                      MinWidth="200"
                                      Height="36"
                                      CornerRadius="8"
                                      Padding="12,8">
								<ComboBox.ItemTemplate>
									<DataTemplate>
										<TextBlock Text="{Binding DisplayName}" FontSize="13"/>
									</DataTemplate>
								</ComboBox.ItemTemplate>
							</ComboBox>
						</StackPanel>

						<!-- Spacer -->
						<Border Grid.Column="2"/>

						<!-- Refresh Button -->
						<Button Grid.Column="3"
                                Classes="status-btn"
                                Command="{Binding RefreshFirmwareVersionsCommand}"
                                IsEnabled="{Binding !IsLoadingManifest}"
                                Margin="0,0,12,0"
                                ToolTip.Tip="Refresh firmware list">
							<StackPanel Orientation="Horizontal" Spacing="6">
								<PathIcon Data="M17.65 6.35A7.958 7.958 0 0 0 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08A5.99 5.99 0 0 1 12 18c-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"
                                          Width="14" Height="14"/>
								<TextBlock Text="Refresh" FontSize="13"/>
							</StackPanel>
						</Button>

						<!-- Beta Toggle Button -->
						<Button Grid.Column="4"
                                Classes="status-btn"
                                Command="{Binding ToggleBetaFirmwareCommand}">
							<StackPanel Orientation="Horizontal" Spacing="6">
								<Border Background="{DynamicResource WarningLightBrush}"
                                        CornerRadius="4"
                                        Padding="6,3"
                                        IsVisible="{Binding ShowBetaFirmware}">
									<TextBlock Text="BETA"
                                               FontSize="9"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource WarningBrush}"/>
								</Border>
								<TextBlock Text="Show Beta" FontSize="13"/>
							</StackPanel>
						</Button>

					</Grid>
				</Border>

				<!-- Back Button -->
				<Button Classes="status-btn"
                        HorizontalAlignment="Left"
                        Click="BackToModeSelection_Click">
					<StackPanel Orientation="Horizontal" Spacing="6">
						<PathIcon Data="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"
                                  Width="14" Height="14"/>
						<TextBlock Text="Back to Mode Selection"/>
					</StackPanel>
				</Button>

				<!-- Page Title -->
				<StackPanel Spacing="8" Margin="0,16,0,24">
					<TextBlock Text="Download from Cloud"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"/>
					<TextBlock Text="Select a vehicle type to download and install firmware"
                               FontSize="14"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
				</StackPanel>

				<!-- Loading State -->
				<Border Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="40,32"
                        Margin="0,0,0,24"
                        IsVisible="{Binding IsLoadingManifest}">
					<StackPanel Spacing="20" HorizontalAlignment="Center">
						<TextBlock Text="&#x26A1; Loading Firmware Data..."
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   HorizontalAlignment="Center"/>
						<TextBlock Text="Fetching your assigned firmware from KFT cloud"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
						<!-- Loading skeleton -->
						<UniformGrid Rows="2" Columns="4" HorizontalAlignment="Center" Margin="0,20,0,0">
							<Border Background="{DynamicResource SecondaryLightBrush}"
                                    CornerRadius="12"
                                    Width="140" Height="160"
                                    Margin="8"
                                    Opacity="0.7"/>
							<Border Background="{DynamicResource SecondaryLightBrush}"
                                    CornerRadius="12"
                                    Width="140" Height="160"
                                    Margin="8"
                                    Opacity="0.5"/>
							<Border Background="{DynamicResource SecondaryLightBrush}"
                                    CornerRadius="12"
                                    Width="140" Height="160"
                                    Margin="8"
                                    Opacity="0.3"/>
							<Border Background="{DynamicResource SecondaryLightBrush}"
                                    CornerRadius="12"
                                    Width="140" Height="160"
                                    Margin="8"
                                    Opacity="0.2"/>
						</UniformGrid>
					</StackPanel>
				</Border>

				<!-- Vehicle Selection Grid -->
				<StackPanel Spacing="24" IsVisible="{Binding !IsLoadingManifest}">

					<!-- Status Message -->
					<Border Background="{DynamicResource InfoLightBrush}"
                            BorderBrush="{DynamicResource InfoBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="16,12"
                            IsVisible="{Binding !IsOperationInProgress}">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<PathIcon Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"
                                      Width="20" Height="20"
                                      Foreground="{DynamicResource InfoBrush}"/>
							<TextBlock Text="{Binding StatusMessage}"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
						</StackPanel>
					</Border>

					<!-- Vehicle Categories (for Web sources) -->
					<ItemsControl ItemsSource="{Binding VehicleGroups}"
								  IsVisible="{Binding !IsInAppSource}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<StackPanel Margin="0,0,0,32">
									<!-- Category Header -->
									<Border Background="{DynamicResource SecondaryLightBrush}"
                                            CornerRadius="8"
                                            Padding="16,12"
                                            Margin="0,0,0,16">
										<TextBlock Text="{Binding Name}"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource PrimaryBrush}"/>
									</Border>

									<!-- Responsive Vehicle Grid -->
									<ItemsControl ItemsSource="{Binding Items}">
										<ItemsControl.ItemsPanel>
											<ItemsPanelTemplate>
												<UniformGrid Columns="5"
                                                           HorizontalAlignment="Left"/>
											</ItemsPanelTemplate>
										</ItemsControl.ItemsPanel>
										<ItemsControl.ItemTemplate>
											<DataTemplate>
												<!-- Vehicle Card -->
												<Button Classes="firmware-card"
                                                        Classes.firmware-card-selected="{Binding IsSelected}"
                                                        Command="{Binding $parent[ItemsControl].((vm:FirmwarePageViewModel)DataContext).SelectVehicleTypeCommand}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip.Tip="{Binding Description}"
                                                        Margin="6"
                                                        Padding="8">
													<Grid RowDefinitions="Auto,*,Auto,Auto">

														<!-- Availability Badge -->
														<Border Grid.Row="0"
                                                                CornerRadius="4"
                                                                Padding="6,3"
                                                                HorizontalAlignment="Right"
                                                                Margin="0,0,0,8">
															<Border.Background>
																<SolidColorBrush Color="{Binding AvailabilityBadgeColor}"/>
															</Border.Background>
															<TextBlock Text="{Binding AvailabilityText}"
                                                                       FontSize="9"
                                                                       FontWeight="Bold"
                                                                       Foreground="White"/>
														</Border>

														<!-- Vehicle Image/Icon -->
														<Border Grid.Row="1"
                                                                Background="{DynamicResource SecondaryLightBrush}"
                                                                CornerRadius="10"
                                                                Padding="12"
                                                                Margin="0,0,0,12"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center">
															<Image Source="{Binding ImagePath}"
                                                                   Width="80"
                                                                   Height="65"
                                                                   Stretch="Uniform"/>
														</Border>

														<!-- Vehicle Name -->
														<TextBlock Grid.Row="2"
                                                                   Text="{Binding Description}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="13"
                                                                   HorizontalAlignment="Center"
                                                                   TextAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   Margin="0,0,0,4"
                                                                   MaxWidth="120"/>

														<!-- Version -->
														<TextBlock Grid.Row="3"
                                                                   Text="{Binding VersionText}"
                                                                   FontSize="10"
                                                                   HorizontalAlignment="Center"
                                                                   TextAlignment="Center"
                                                                   Foreground="{DynamicResource TextMutedBrush}"/>

														<!-- Selected Indicator -->
														<Border Grid.Row="0" Grid.RowSpan="4"
                                                                Background="{DynamicResource PrimaryBrush}"
                                                                CornerRadius="24"
                                                                Width="28" Height="28"
                                                                HorizontalAlignment="Left"
                                                                VerticalAlignment="Top"
                                                                Margin="-8,-8,0,0"
                                                                IsVisible="{Binding IsSelected}">
															<PathIcon Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"
                                                                      Width="14" Height="14"
                                                                      Foreground="White"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
														</Border>
													</Grid>
												</Button>
											</DataTemplate>
										</ItemsControl.ItemTemplate>
									</ItemsControl>
								</StackPanel>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
					
					<!-- Assigned Firmware List (for In-App / KFT Cloud source) -->
					<StackPanel Spacing="16" IsVisible="{Binding IsInAppSource}">

						<!-- Section header row -->
						<Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
							<StackPanel Grid.Column="0" Spacing="4">
								<TextBlock Text="Admin-Assigned Firmware"
										   FontSize="22" FontWeight="Bold"
										   Foreground="{DynamicResource TextPrimaryBrush}"/>
								<TextBlock Text="These firmware files have been approved and assigned by your administrator."
										   FontSize="13"
										   Foreground="{DynamicResource TextSecondaryBrush}"/>
							</StackPanel>
							<!-- Firmware count badge -->
							<Border Grid.Column="1"
									Background="{DynamicResource PrimaryLightBrush}"
									CornerRadius="20"
									Padding="14,6"
									VerticalAlignment="Center"
									IsVisible="{Binding !HasNoCustomFirmwares}">
								<StackPanel Orientation="Horizontal" Spacing="6">
									<PathIcon Data="M20 6h-2.18c.07-.44.18-.88.18-1.35C18 2.53 15.48 0 12.35 0c-1.7 0-3.23.72-4.35 1.86L6 4 3.65 1.86C2.53.72 1 0-.65 0-3.48 0-6 2.53-6 5.35c0 .47.1.91.18 1.35H-8v14h28V6zM12 2c1.1 0 2 .9 2 2s-.9 2-2 2-2-.9-2-2 .9-2 2-2z"
											  Width="13" Height="13"
											  Foreground="{DynamicResource PrimaryBrush}"/>
									<TextBlock Text="{Binding CustomFirmwares.Count, StringFormat='{}{0} available'}"
											   FontSize="13" FontWeight="SemiBold"
											   Foreground="{DynamicResource PrimaryBrush}"/>
								</StackPanel>
							</Border>
						</Grid>

						<!-- Column headers -->
						<Border Background="#F8F9FA"
								BorderBrush="#E8EAED"
								BorderThickness="1,1,1,0"
								CornerRadius="12,12,0,0"
								Padding="20,10"
								IsVisible="{Binding !HasNoCustomFirmwares}">
							<Grid ColumnDefinitions="52,*,160,110,130,140">
								<TextBlock Grid.Column="1" Text="FIRMWARE" FontSize="11" FontWeight="Bold" Foreground="#80868B" LetterSpacing="0.8"/>
								<TextBlock Grid.Column="2" Text="VEHICLE TYPE" FontSize="11" FontWeight="Bold" Foreground="#80868B" LetterSpacing="0.8"/>
								<TextBlock Grid.Column="3" Text="VERSION" FontSize="11" FontWeight="Bold" Foreground="#80868B" LetterSpacing="0.8"/>
								<TextBlock Grid.Column="4" Text="SIZE / UPDATED" FontSize="11" FontWeight="Bold" Foreground="#80868B" LetterSpacing="0.8"/>
								<TextBlock Grid.Column="5" Text="" FontSize="11" FontWeight="Bold" Foreground="#80868B"/>
							</Grid>
						</Border>

						<!-- Firmware rows -->
						<Border BorderBrush="#E8EAED"
								BorderThickness="1"
								CornerRadius="0,0,12,12"
								Background="{DynamicResource CardBrush}"
								IsVisible="{Binding !HasNoCustomFirmwares}">
							<ItemsControl ItemsSource="{Binding CustomFirmwares}">
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Border BorderBrush="#F1F3F4"
												BorderThickness="0,0,0,1"
												Padding="0">
											<Border.Styles>
												<Style Selector="Border.fw-row">
													<Setter Property="Background" Value="Transparent"/>
													<Setter Property="Transitions">
														<Transitions>
															<BrushTransition Property="Background" Duration="0:0:0.15"/>
														</Transitions>
													</Setter>
												</Style>
												<Style Selector="Border.fw-row:pointerover">
													<Setter Property="Background" Value="#F8FAFF"/>
												</Style>
												<Style Selector="Border.fw-row.fw-selected">
													<Setter Property="Background" Value="#EEF4FD"/>
												</Style>
											</Border.Styles>
											<Border Classes="fw-row"
													Classes.fw-selected="{Binding IsSelected}"
													Padding="20,14">
												<Grid ColumnDefinitions="52,*,160,110,130,140" VerticalAlignment="Center">

													<!-- Vehicle icon -->
													<Border Grid.Column="0"
															Width="40" Height="40"
															CornerRadius="10"
															VerticalAlignment="Center">
														<Border.Background>
															<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
																<GradientStop Color="#EEF2FF" Offset="0"/>
																<GradientStop Color="#E0E7FF" Offset="1"/>
															</LinearGradientBrush>
														</Border.Background>
														<Image Source="{Binding VehicleType, Converter={StaticResource VehicleTypeToIconConverter}}"
															   Width="26" Height="26"
															   Stretch="Uniform"
															   HorizontalAlignment="Center"
															   VerticalAlignment="Center"/>
													</Border>

													<!-- Name + filename -->
													<StackPanel Grid.Column="1"
																Spacing="3"
																VerticalAlignment="Center"
																Margin="12,0,12,0">
														<TextBlock Text="{Binding DisplayName}"
																   FontSize="14"
																   FontWeight="SemiBold"
																   Foreground="{DynamicResource TextPrimaryBrush}"
																   TextTrimming="CharacterEllipsis"
																   ToolTip.Tip="{Binding DisplayName}"/>
														<StackPanel Orientation="Horizontal" Spacing="6">
															<PathIcon Data="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm4 18H6V4h7v5h5v11z"
																	  Width="11" Height="11"
																	  Foreground="{DynamicResource TextMutedBrush}"/>
															<TextBlock Text="{Binding FileName}"
																	   FontSize="11"
																	   FontFamily="Consolas, Courier New"
																	   Foreground="{DynamicResource TextMutedBrush}"
																	   TextTrimming="CharacterEllipsis"
																	   ToolTip.Tip="{Binding FileName}"/>
														</StackPanel>
													</StackPanel>

													<!-- Vehicle type badge -->
													<Border Grid.Column="2"
															CornerRadius="8"
															Padding="12,5"
															HorizontalAlignment="Left"
															VerticalAlignment="Center"
															Background="{Binding VehicleType, Converter={StaticResource VehicleTypeToBadgeColorConverter}}">
														<TextBlock Text="{Binding VehicleType}"
																   FontSize="12"
																   FontWeight="SemiBold"
																   Foreground="White"/>
													</Border>

													<!-- Version -->
													<TextBlock Grid.Column="3"
															   VerticalAlignment="Center"
															   FontSize="13"
															   FontFamily="Consolas, Courier New"
															   FontWeight="SemiBold"
															   Foreground="{DynamicResource PrimaryBrush}"
															   Text="{Binding FirmwareVersion}"
															   TextTrimming="CharacterEllipsis"/>

													<!-- Size + date stacked -->
													<StackPanel Grid.Column="4"
																Spacing="3"
																VerticalAlignment="Center">
														<StackPanel Orientation="Horizontal" Spacing="5">
															<PathIcon Data="M4 20h16V8l-6-6H4v18zm9-17l5 5h-5V3z"
																	  Width="11" Height="11"
																	  Foreground="{DynamicResource SuccessBrush}"/>
															<TextBlock Text="{Binding SizeDisplay}"
																	   FontSize="12"
																	   FontWeight="SemiBold"
																	   Foreground="{DynamicResource SuccessBrush}"/>
														</StackPanel>
														<TextBlock Text="{Binding LastModified, StringFormat='{}{0:MMM dd, yyyy}'}"
																   FontSize="11"
																   Foreground="{DynamicResource TextMutedBrush}"/>
													</StackPanel>

													<!-- Select + Flash button -->
													<StackPanel Grid.Column="5"
																Orientation="Horizontal"
																Spacing="8"
																VerticalAlignment="Center"
																HorizontalAlignment="Right">

														<!-- Selected check badge -->
														<Border Width="26" Height="26"
																CornerRadius="13"
																Background="{DynamicResource PrimaryBrush}"
																VerticalAlignment="Center"
																IsVisible="{Binding IsSelected}">
															<PathIcon Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"
																	  Width="13" Height="13"
																	  Foreground="White"
																	  HorizontalAlignment="Center"
																	  VerticalAlignment="Center"/>
														</Border>

														<!-- Flash button -->
														<Button Background="{DynamicResource PrimaryBrush}"
																Foreground="White"
																CornerRadius="8"
																Padding="18,9"
																BorderThickness="0"
																FontSize="13"
																FontWeight="SemiBold"
																Cursor="Hand"
																Command="{Binding $parent[ItemsControl].((vm:FirmwarePageViewModel)DataContext).SelectCustomFirmwareCommand}"
																CommandParameter="{Binding}"
																ToolTip.Tip="Select and flash this firmware">
															<StackPanel Orientation="Horizontal" Spacing="6">
																<PathIcon Data="M13 3c-4.97 0-9 4.03-9 9H1l3.89 3.89.07.14L9 12H6c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7c-1.93 0-3.68-.79-4.94-2.06l-1.42 1.42C8.27 19.99 10.51 21 13 21c4.97 0 9-4.03 9-9s-4.03-9-9-9zm-1 5v5l4.28 2.54.72-1.21-3.5-2.08V8H12z"
																		  Width="13" Height="13"
																		  Foreground="White"/>
																<TextBlock Text="{Binding IsSelected, StringFormat={}{0:}}"
																		   IsVisible="False"/>
																<TextBlock Text="Flash"/>
															</StackPanel>
														</Button>
													</StackPanel>

												</Grid>
											</Border>
										</Border>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</Border>

						<!-- Empty state -->
						<Border Background="#FFFBF0"
								BorderBrush="#F59E0B"
								BorderThickness="1"
								CornerRadius="12"
								Padding="48,40"
								IsVisible="{Binding HasNoCustomFirmwares}">
							<StackPanel Spacing="16" HorizontalAlignment="Center">
								<Border Width="72" Height="72"
										CornerRadius="36"
										Background="#FEF3C7"
										HorizontalAlignment="Center">
									<PathIcon Data="M20 6h-2.18c.07-.44.18-.88.18-1.35C18 2.53 15.48 0 12.35 0c-1.7 0-3.23.72-4.35 1.86L6 4 3.65 1.86C2.53.72 1 0-.65 0-3.48 0-6 2.53-6 5.35c0 .47.1.91.18 1.35H-8v14h28V6z"
											  Width="32" Height="32"
											  Foreground="#D97706"
											  HorizontalAlignment="Center"
											  VerticalAlignment="Center"/>
								</Border>
								<TextBlock Text="No Firmware Assigned"
										   FontSize="20" FontWeight="Bold"
										   Foreground="#92400E"
										   HorizontalAlignment="Center"/>
								<TextBlock Text="Your administrator has not assigned any firmware yet. Contact your KFT admin to have firmware uploaded and assigned to your account."
										   FontSize="13"
										   Foreground="{DynamicResource TextSecondaryBrush}"
										   HorizontalAlignment="Center"
										   TextAlignment="Center"
										   TextWrapping="Wrap"
										   MaxWidth="440"/>
							</StackPanel>
						</Border>

					</StackPanel>

					<!-- Detected Board Info -->
					<Border Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource SuccessBrush}"
                            BorderThickness="2"
                            CornerRadius="12"
                            Padding="24,20"
                            IsVisible="{Binding IsBoardDetected}">
						<Grid ColumnDefinitions="Auto,*,Auto">
							<Border Grid.Column="0"
                                    Background="{DynamicResource SuccessLightBrush}"
                                    CornerRadius="8"
                                    Width="48" Height="48"
                                    Margin="0,0,16,0">
								<PathIcon Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"
                                          Width="24" Height="24"
                                          Foreground="{DynamicResource SuccessBrush}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
							</Border>

							<StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
								<TextBlock Text="Board Detected"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="12"/>
								<StackPanel Orientation="Horizontal" Spacing="8">
									<TextBlock Text="{Binding DetectedBoardName}"
                                               Foreground="{DynamicResource SuccessBrush}"
                                               FontWeight="Bold"
                                               FontSize="16"/>
									<TextBlock Text="on"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               VerticalAlignment="Center"
                                               FontSize="13"/>
									<TextBlock Text="{Binding DetectedBoardPort}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               FontSize="13"/>
								</StackPanel>
							</StackPanel>

							<Button Grid.Column="2"
                                    Content="Refresh"
                                    Classes="status-btn"
                                    Command="{Binding DetectBoardCommand}"/>
						</Grid>
					</Border>

				</StackPanel>

			</StackPanel>
		</ScrollViewer>

		<!-- MANUAL MODE VIEW (Local Upload) -->
		<ScrollViewer Grid.Row="1"
                      IsVisible="{Binding IsManualMode}"
                      Padding="32,24">
			<StackPanel Spacing="20" MaxWidth="800" HorizontalAlignment="Center">

				<!-- Back Button -->
				<Button Classes="status-btn"
                        HorizontalAlignment="Left"
                        Click="BackToModeSelection_Click">
					<StackPanel Orientation="Horizontal" Spacing="6">
						<PathIcon Data="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"
                                  Width="14" Height="14"/>
						<TextBlock Text="Back to Mode Selection"/>
					</StackPanel>
				</Button>

				<!-- Page Title -->
				<StackPanel Spacing="8" Margin="0,16,0,32">
					<TextBlock Text="Load Custom Firmware"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"/>
					<TextBlock Text="Select a firmware file from your computer to flash"
                               FontSize="14"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
				</StackPanel>

				<!-- File Upload Card -->
				<Border Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="40,36">
					<StackPanel Spacing="28">

						<!-- Header -->
						<StackPanel Spacing="10">
							<StackPanel Orientation="Horizontal" Spacing="12">
								<Border Background="{DynamicResource AccentLightBrush}"
                                        CornerRadius="10"
                                        Width="48" Height="48">
									<PathIcon Data="M9 16h6v-6h4l-7-7-7 7h4zm-4 2h14v2H5z"
                                              Width="24" Height="24"
                                              Foreground="{DynamicResource AccentBrush}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
								</Border>
								<StackPanel VerticalAlignment="Center" Spacing="4">
									<TextBlock Text="Load Custom Firmware"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
									<TextBlock Text="Supports .apj, .px4, .bin, and .hex formats"
                                               FontSize="13"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
								</StackPanel>
							</StackPanel>
						</StackPanel>

						<!-- File Selector -->
						<StackPanel Spacing="12">
							<TextBlock Text="Select Firmware File"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
							<Grid ColumnDefinitions="*,Auto">
								<TextBox Grid.Column="0"
                                         Text="{Binding SelectedFileName}"
                                         IsReadOnly="True"
                                         Watermark="No file selected..."
                                         CornerRadius="8,0,0,8"
                                         Height="52"
                                         VerticalContentAlignment="Center"
                                         Padding="18,0"
                                         FontSize="14"
                                         BorderBrush="{DynamicResource BorderBrush}"/>
								<Button Grid.Column="1"
                                        Content="Browse Files"
                                        Background="{DynamicResource PrimaryBrush}"
                                        Foreground="White"
                                        CornerRadius="0,8,8,0"
                                        Height="52"
                                        Padding="32,0"
                                        BorderThickness="0"
                                        FontWeight="Bold"
                                        FontSize="14"
                                        VerticalContentAlignment="Center"
                                        HorizontalContentAlignment="Center"
                                        Click="BrowseFirmwareFile_Click"/>
							</Grid>
						</StackPanel>

						<!-- Flash Button -->
						<Button Content="Flash Custom Firmware"
                                Background="{DynamicResource PrimaryBrush}"
                                Foreground="White"
                                HorizontalAlignment="Stretch"
                                Height="56"
                                CornerRadius="12"
                                FontSize="16"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Command="{Binding FlashCustomFirmwareCommand}"
                                IsEnabled="{Binding SelectedFilePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
							<StackPanel Orientation="Horizontal" Spacing="10">
								<PathIcon Data="M13 3c-4.97 0-9 4.03-9 9H1l3.89 3.89.07.14L9 12H6c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7c-1.93 0-3.68-.79-4.94-2.06l-1.42 1.42C8.27 19.99 10.51 21 13 21c4.97 0 9-4.03 9-9s-4.03-9-9-9zm-1 5v5l4.28 2.54.72-1.21-3.5-2.08V8H12z"
                                          Width="20" Height="20"
                                          Foreground="White"/>
								<TextBlock Text="Flash Firmware" VerticalAlignment="Center"/>
							</StackPanel>
						</Button>

						<!-- Info Panel -->
						<Border Background="{DynamicResource InfoLightBrush}"
                                BorderBrush="{DynamicResource InfoBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="16">
							<Grid ColumnDefinitions="Auto,*">
								<PathIcon Grid.Column="0"
                                          Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"
                                          Width="22" Height="22"
                                          Foreground="{DynamicResource InfoBrush}"
                                          Margin="0,0,14,0"
                                          VerticalAlignment="Top"/>
								<StackPanel Grid.Column="1" Spacing="6">
									<TextBlock Text="Important Information"
                                               FontWeight="Bold"
                                               FontSize="13"
                                               Foreground="{DynamicResource InfoDarkBrush}"/>
									<TextBlock TextWrapping="Wrap"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               LineHeight="18">
										<Run Text="• Ensure your flight controller is properly connected"/>
										<LineBreak/>
										<Run Text="• Firmware file size should not exceed 50MB"/>
										<LineBreak/>
										<Run Text="• Do not disconnect during flashing process"/>
										<LineBreak/>
										<Run Text="• Backup your current parameters before flashing"/>
									</TextBlock>
								</StackPanel>
							</Grid>
						</Border>
					</StackPanel>
				</Border>

				<!-- Detected Board Info for Manual Mode -->
				<Border Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource SuccessBrush}"
                        BorderThickness="2"
                        CornerRadius="12"
                        Padding="24,20"
                        IsVisible="{Binding IsBoardDetected}">
					<Grid ColumnDefinitions="Auto,*,Auto">
						<Border Grid.Column="0"
                                Background="{DynamicResource SuccessLightBrush}"
                                CornerRadius="8"
                                Width="48" Height="48"
                                Margin="0,0,16,0">
							<PathIcon Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"
                                      Width="24" Height="24"
                                      Foreground="{DynamicResource SuccessBrush}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
						</Border>

						<StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
							<TextBlock Text="Board Detected"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="12"/>
							<StackPanel Orientation="Horizontal" Spacing="8">
								<TextBlock Text="{Binding DetectedBoardName}"
                                               Foreground="{DynamicResource SuccessBrush}"
                                               FontWeight="Bold"
                                               FontSize="16"/>
								<TextBlock Text="on"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               VerticalAlignment="Center"
                                               FontSize="13"/>
								<TextBlock Text="{Binding DetectedBoardPort}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               FontSize="13"/>
							</StackPanel>
						</StackPanel>

						<Button Grid.Column="2"
                                Content="Refresh"
                                Classes="status-btn"
                                Command="{Binding DetectBoardCommand}"/>
					</Grid>
				</Border>

			</StackPanel>
		</ScrollViewer>

		<!-- ============================================ -->
		<!-- DIALOG OVERLAYS -->
		<!-- ============================================ -->

		<!-- Confirmation Dialog -->
		<Border Grid.Row="0" Grid.RowSpan="2"
		        Classes="dialog-overlay"
		        IsVisible="{Binding ShowConfirmationDialog}"
		        ZIndex="100">
			<Border Classes="dialog-box"
			        VerticalAlignment="Center"
			        HorizontalAlignment="Center">
				<StackPanel Spacing="24">
					<!-- Header -->
					<StackPanel Spacing="12">
						<Border Background="{DynamicResource WarningLightBrush}"
						        CornerRadius="12"
						        Width="64" Height="64"
						        HorizontalAlignment="Center">
							<PathIcon Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"
							          Width="32" Height="32"
							          Foreground="{DynamicResource WarningBrush}"
							          HorizontalAlignment="Center"
							          VerticalAlignment="Center"/>
						</Border>
						<TextBlock Text="Confirm Installation"
						           FontSize="22"
						           FontWeight="Bold"
						           HorizontalAlignment="Center"
						           Foreground="{DynamicResource TextPrimaryBrush}"/>
					</StackPanel>
					
					<!-- Message -->
					<TextBlock Text="{Binding ConfirmationMessage}"
					           TextWrapping="Wrap"
					           TextAlignment="Center"
					           FontSize="14"
					           LineHeight="22"
					           Foreground="{DynamicResource TextSecondaryBrush}"/>
					
					<!-- Buttons -->
					<StackPanel Orientation="Horizontal" 
					            Spacing="12" 
					            HorizontalAlignment="Center">
						<Button Classes="dialog-btn-secondary"
						        Content="Cancel"
						        Command="{Binding CancelConfirmationCommand}"
						        MinWidth="120"/>
						<Button Classes="dialog-btn-primary"
						        Content="Install Firmware"
						        Command="{Binding ConfirmInstallationCommand}"
						        MinWidth="160"/>
					</StackPanel>
				</StackPanel>
			</Border>
		</Border>

		<!-- Platform Selection Dialog -->
		<Border Grid.Row="0" Grid.RowSpan="2"
		        Classes="dialog-overlay"
		        IsVisible="{Binding ShowPlatformSelectionDialog}"
		        ZIndex="100">
			<Border Classes="dialog-box"
			        VerticalAlignment="Center"
			        HorizontalAlignment="Center">
				<StackPanel Spacing="24">
					<!-- Header -->
					<StackPanel Spacing="12">
						<Border Background="{DynamicResource InfoLightBrush}"
						        CornerRadius="12"
						        Width="64" Height="64"
						        HorizontalAlignment="Center">
							<PathIcon Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z"
							          Width="32" Height="32"
							          Foreground="{DynamicResource InfoBrush}"
							          HorizontalAlignment="Center"
							          VerticalAlignment="Center"/>
						</Border>
						<TextBlock Text="Select Firmware Variant"
						           FontSize="22"
						           FontWeight="Bold"
						           HorizontalAlignment="Center"
						           Foreground="{DynamicResource TextPrimaryBrush}"/>
					</StackPanel>
					
					<!-- Message -->
					<TextBlock Text="{Binding PlatformSelectionMessage}"
					           TextWrapping="Wrap"
					           TextAlignment="Center"
					           FontSize="14"
					           Foreground="{DynamicResource TextSecondaryBrush}"/>
					
					<!-- Platform List -->
					<ListBox ItemsSource="{Binding AvailablePlatformVariants}"
					         SelectedItem="{Binding SelectedPlatformVariant}"
					         MaxHeight="200"
					         CornerRadius="8"
					         Padding="4">
						<ListBox.ItemTemplate>
							<DataTemplate>
								<Border Padding="12,8">
									<TextBlock Text="{Binding}" FontSize="14"/>
								</Border>
							</DataTemplate>
						</ListBox.ItemTemplate>
					</ListBox>
					
					<!-- Buttons -->
					<StackPanel Orientation="Horizontal" 
					            Spacing="12" 
					            HorizontalAlignment="Center">
						<Button Classes="dialog-btn-secondary"
						        Content="Cancel"
						        Command="{Binding CancelPlatformSelectionCommand}"
						        MinWidth="120"/>
						<Button Classes="dialog-btn-primary"
						        Content="Continue"
						        Command="{Binding ConfirmPlatformSelectionCommand}"
						        IsEnabled="{Binding SelectedPlatformVariant, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
						        MinWidth="140"/>
					</StackPanel>
				</StackPanel>
			</Border>
		</Border>

		<!-- Bootloader Mode Dialog -->
		<Border Grid.Row="0" Grid.RowSpan="2"
		        Classes="dialog-overlay"
		        IsVisible="{Binding ShowBootloaderModeDialog}"
		        ZIndex="100">
			<Border Classes="dialog-box"
			        VerticalAlignment="Center"
			        HorizontalAlignment="Center">
				<StackPanel Spacing="24">
					<!-- Header -->
					<StackPanel Spacing="12">
						<Border Background="{DynamicResource PrimaryLightBrush}"
						        CornerRadius="12"
						        Width="64" Height="64"
						        HorizontalAlignment="Center">
							<PathIcon Data="M9 16h6v-6h4l-7-7-7 7h4zm-4 2h14v2H5z"
							          Width="32" Height="32"
							          Foreground="{DynamicResource PrimaryBrush}"
							          HorizontalAlignment="Center"
							          VerticalAlignment="Center"/>
						</Border>
						<TextBlock Text="Enter Bootloader Mode"
						           FontSize="22"
						           FontWeight="Bold"
						           HorizontalAlignment="Center"
						           Foreground="{DynamicResource TextPrimaryBrush}"/>
					</StackPanel>
					
					<!-- Message -->
					<TextBlock Text="{Binding BootloaderModeMessage}"
					           TextWrapping="Wrap"
					           TextAlignment="Center"
					           FontSize="14"
					           LineHeight="22"
					           Foreground="{DynamicResource TextSecondaryBrush}"/>
					
					<!-- Visual Instructions -->
					<Border Background="{DynamicResource SurfaceBrush}"
					        CornerRadius="10"
					        Padding="20">
						<StackPanel Spacing="12">
							<StackPanel Orientation="Horizontal" Spacing="12">
								<Border Background="{DynamicResource PrimaryBrush}" CornerRadius="12" Width="24" Height="24">
									<TextBlock Text="1" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
								</Border>
								<TextBlock Text="Unplug the USB cable from the flight controller" VerticalAlignment="Center"/>
							</StackPanel>
							<StackPanel Orientation="Horizontal" Spacing="12">
								<Border Background="{DynamicResource PrimaryBrush}" CornerRadius="12" Width="24" Height="24">
									<TextBlock Text="2" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
								</Border>
								<TextBlock Text="Press and hold the BOOT button on the board" VerticalAlignment="Center"/>
							</StackPanel>
							<StackPanel Orientation="Horizontal" Spacing="12">
								<Border Background="{DynamicResource PrimaryBrush}" CornerRadius="12" Width="24" Height="24">
									<TextBlock Text="3" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
								</Border>
								<TextBlock Text="While holding BOOT, plug the USB cable back in" VerticalAlignment="Center"/>
							</StackPanel>
							<StackPanel Orientation="Horizontal" Spacing="12">
								<Border Background="{DynamicResource PrimaryBrush}" CornerRadius="12" Width="24" Height="24">
									<TextBlock Text="4" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
								</Border>
								<TextBlock Text="Release the BOOT button after 2 seconds" VerticalAlignment="Center"/>
							</StackPanel>
						</StackPanel>
					</Border>
					
					<!-- Buttons -->
					<StackPanel Orientation="Horizontal" 
					            Spacing="12" 
					            HorizontalAlignment="Center">
						<Button Classes="dialog-btn-secondary"
						        Content="Cancel"
						        Command="{Binding CancelBootloaderModeCommand}"
						        MinWidth="120"/>
						<Button Classes="dialog-btn-primary"
						        Content="OK, Board is Ready"
						        Command="{Binding ConfirmBootloaderModeCommand}"
						        MinWidth="180"/>
					</StackPanel>
				</StackPanel>
			</Border>
		</Border>

		<!-- Reconnect Prompt Dialog -->
		<Border Grid.Row="0" Grid.RowSpan="2"
		        Classes="dialog-overlay"
		        IsVisible="{Binding ShowReconnectPromptDialog}"
		        ZIndex="100">
			<Border Classes="dialog-box"
			        VerticalAlignment="Center"
			        HorizontalAlignment="Center">
				<StackPanel Spacing="24">
					<!-- Header with Success Icon -->
					<StackPanel Spacing="12">
						<Border Background="{DynamicResource SuccessLightBrush}"
						        CornerRadius="12"
						        Width="64" Height="64"
						        HorizontalAlignment="Center">
							<PathIcon Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"
							          Width="32" Height="32"
							          Foreground="{DynamicResource SuccessBrush}"
							          HorizontalAlignment="Center"
							          VerticalAlignment="Center"/>
						</Border>
						<TextBlock Text="Installation Complete!"
						           FontSize="22"
						           FontWeight="Bold"
						           HorizontalAlignment="Center"
						           Foreground="{DynamicResource SuccessBrush}"/>
					</StackPanel>
					
					<!-- Message -->
					<TextBlock Text="{Binding ReconnectPromptMessage}"
					           TextWrapping="Wrap"
					           TextAlignment="Center"
					           FontSize="14"
					           LineHeight="22"
					           Foreground="{DynamicResource TextSecondaryBrush}"/>
					
					<!-- OK Button -->
					<Button Classes="dialog-btn-primary"
					        Content="OK"
					        Command="{Binding AcknowledgeReconnectPromptCommand}"
					        HorizontalAlignment="Center"
					        MinWidth="160"/>
				</StackPanel>
			</Border>
		</Border>

		<!-- Flashing Progress Dialog -->
		<Border Grid.Row="0" Grid.RowSpan="2"
		        Classes="dialog-overlay"
		        IsVisible="{Binding IsOperationInProgress}"
		        ZIndex="100">
			<Border Classes="dialog-box"
			        VerticalAlignment="Center"
			        HorizontalAlignment="Center"
			        MinWidth="480">
				<StackPanel Spacing="28">
					<!-- Header -->
					<StackPanel Spacing="12">
						<TextBlock Text="Installing Firmware"
						           FontSize="24"
						           FontWeight="Bold"
						           HorizontalAlignment="Center"
						           Foreground="{DynamicResource TextPrimaryBrush}"/>
						<TextBlock Text="{Binding StatusMessage}"
						           FontSize="14"
						           HorizontalAlignment="Center"
						           Foreground="{DynamicResource TextSecondaryBrush}"/>
					</StackPanel>
					
					<!-- Progress Bar -->
					<StackPanel Spacing="8">
						<ProgressBar Value="{Binding ProgressPercent}"
						             Maximum="100"
						             Height="12"
						             CornerRadius="6"
						             Classes="mp-progress"/>
						<Grid>
							<TextBlock Text="{Binding ProgressPercent, StringFormat={}{0:F0}%}"
							           HorizontalAlignment="Left"
							           FontSize="13"
							           FontWeight="SemiBold"
							           Foreground="{DynamicResource PrimaryBrush}"/>
							<TextBlock Text="{Binding EstimatedTimeRemaining}"
							           HorizontalAlignment="Right"
							           FontSize="12"
							           Foreground="{DynamicResource TextMutedBrush}"/>
						</Grid>
					</StackPanel>
					
					<!-- Step Indicators -->
					<Border Background="{DynamicResource SurfaceBrush}"
					        CornerRadius="10"
					        Padding="20,16">
						<StackPanel Spacing="12">
							<!-- Downloading Step -->
							<StackPanel Orientation="Horizontal" Spacing="12">
								<Border Width="28" Height="28" CornerRadius="14"
								        Background="{Binding CurrentFlashingStep, Converter={x:Static converters:FlashingStepConverters.StepToBackground}, ConverterParameter=Downloading}">
									<TextBlock Text="1" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="12"/>
								</Border>
								<TextBlock Text="Downloading firmware" 
								           VerticalAlignment="Center"
								           Opacity="{Binding CurrentFlashingStep, Converter={x:Static converters:FlashingStepConverters.StepToOpacity}, ConverterParameter=Downloading}"/>
							</StackPanel>
							
							<!-- Verifying Step -->
							<StackPanel Orientation="Horizontal" Spacing="12">
								<Border Width="28" Height="28" CornerRadius="14"
								        Background="{Binding CurrentFlashingStep, Converter={x:Static converters:FlashingStepConverters.StepToBackground}, ConverterParameter=Verifying}">
									<TextBlock Text="2" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="12"/>
								</Border>
								<TextBlock Text="Verifying firmware" 
								           VerticalAlignment="Center"
								           Opacity="{Binding CurrentFlashingStep, Converter={x:Static converters:FlashingStepConverters.StepToOpacity}, ConverterParameter=Verifying}"/>
							</StackPanel>
							
							<!-- Uploading Step -->
							<StackPanel Orientation="Horizontal" Spacing="12">
								<Border Width="28" Height="28" CornerRadius="14"
								        Background="{Binding CurrentFlashingStep, Converter={x:Static converters:FlashingStepConverters.StepToBackground}, ConverterParameter=Uploading}">
									<TextBlock Text="3" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="12"/>
								</Border>
								<TextBlock Text="Uploading to board" 
								           VerticalAlignment="Center"
								           Opacity="{Binding CurrentFlashingStep, Converter={x:Static converters:FlashingStepConverters.StepToOpacity}, ConverterParameter=Uploading}"/>
							</StackPanel>
							
							<!-- Finalizing Step -->
							<StackPanel Orientation="Horizontal" Spacing="12">
								<Border Width="28" Height="28" CornerRadius="14"
								        Background="{Binding CurrentFlashingStep, Converter={x:Static converters:FlashingStepConverters.StepToBackground}, ConverterParameter=Finalizing}">
									<TextBlock Text="4" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="12"/>
								</Border>
								<TextBlock Text="Finalizing installation" 
								           VerticalAlignment="Center"
								           Opacity="{Binding CurrentFlashingStep, Converter={x:Static converters:FlashingStepConverters.StepToOpacity}, ConverterParameter=Finalizing}"/>
							</StackPanel>
						</StackPanel>
					</Border>
					
					<!-- Detail Message -->
					<TextBlock Text="{Binding DetailMessage}"
					           FontSize="13"
					           HorizontalAlignment="Center"
					           Foreground="{DynamicResource TextMutedBrush}"
					           IsVisible="{Binding DetailMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
					
					<!-- Cancel Button -->
					<Button Classes="dialog-btn-secondary"
					        Content="Cancel"
					        Command="{Binding CancelOperationCommand}"
					        HorizontalAlignment="Center"
					        MinWidth="140"
					        IsEnabled="{Binding CanCancelFlashing}"/>
				</StackPanel>
			</Border>
		</Border>

		<!-- Failure Dialog -->
		<Border Grid.Row="0" Grid.RowSpan="2"
		        Classes="dialog-overlay"
		        IsVisible="{Binding ShowFailureDialog}"
		        ZIndex="100">
			<Border Classes="dialog-box"
			        VerticalAlignment="Center"
			        HorizontalAlignment="Center">
				<StackPanel Spacing="24">
					<!-- Header with Error Icon -->
					<StackPanel Spacing="12">
						<Border Background="{DynamicResource ErrorLightBrush}"
						        CornerRadius="12"
						        Width="64" Height="64"
						        HorizontalAlignment="Center">
							<PathIcon Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"
							          Width="32" Height="32"
							          Foreground="{DynamicResource ErrorBrush}"
							          HorizontalAlignment="Center"
							          VerticalAlignment="Center"/>
						</Border>
						<TextBlock Text="Installation Failed"
						           FontSize="22"
						           FontWeight="Bold"
						           HorizontalAlignment="Center"
						           Foreground="{DynamicResource ErrorBrush}"/>
					</StackPanel>
					
					<!-- Error Message -->
					<TextBlock Text="{Binding FailureMessage}"
					           TextWrapping="Wrap"
					           TextAlignment="Center"
					           FontSize="14"
					           Foreground="{DynamicResource TextSecondaryBrush}"/>
					
					<!-- Suggestion -->
					<Border Background="{DynamicResource InfoLightBrush}"
					        CornerRadius="8"
					        Padding="16"
					        IsVisible="{Binding FailureSuggestion, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<PathIcon Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"
							          Width="18" Height="18"
							          Foreground="{DynamicResource InfoBrush}"/>
							<TextBlock Text="{Binding FailureSuggestion}"
							           TextWrapping="Wrap"
							           FontSize="13"
							           Foreground="{DynamicResource TextSecondaryBrush}"/>
						</StackPanel>
					</Border>
					
					<!-- Buttons -->
						<StackPanel Orientation="Horizontal" 
					            Spacing="12" 
					            HorizontalAlignment="Center">
						<Button Classes="dialog-btn-secondary"
						        Content="Close"
						        Command="{Binding CloseFailureDialogCommand}"
						        MinWidth="120"/>
						<Button Classes="dialog-btn-primary"
						        Content="Retry"
						        Command="{Binding RetryFlashingCommand}"
						        MinWidth="120"/>
					</StackPanel>
				</StackPanel>
			</Border>
		</Border>

		<!-- Log Panel (Collapsible at bottom) -->
		<Border Grid.Row="1"
		        Classes="log-panel"
		        VerticalAlignment="Bottom"
		        HorizontalAlignment="Stretch"
		        Margin="20"
		        MaxHeight="300"
		        IsVisible="{Binding IsLogPanelExpanded}">
			<Grid RowDefinitions="Auto,*">
				<!-- Log Header -->
				<Border Grid.Row="0" 
				        Background="#2D2D2D" 
				        Padding="16,10"
				        CornerRadius="8,8,0,0">
					<Grid ColumnDefinitions="*,Auto,Auto">
						<TextBlock Text="Operation Log"
						           FontWeight="SemiBold"
						           Foreground="White"
						           VerticalAlignment="Center"/>
						<Button Grid.Column="1"
						        Content="Clear"
						        Background="Transparent"
						        Foreground="#888"
						        Padding="12,4"
						        Command="{Binding ClearLogCommand}"
						        Margin="0,0,8,0"/>
						<Button Grid.Column="2"
						        Content="✕"
						        Background="Transparent"
						        Foreground="#888"
						        Padding="8,4"
						        Command="{Binding ToggleLogPanelCommand}"/>
					</Grid>
				</Border>
				
				<!-- Log Content -->
				<ScrollViewer Grid.Row="1" 
				              Padding="12"
				              VerticalScrollBarVisibility="Auto">
					<ItemsControl ItemsSource="{Binding LogMessages}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<TextBlock Text="{Binding}"
								           FontFamily="Consolas, Monaco, monospace"
								           FontSize="12"
								           Foreground="#A0A0A0"
								           Margin="0,2"/>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</ScrollViewer>
			</Grid>
		</Border>

		<!-- Log Toggle Button (Floating) -->
		<Button Grid.Row="1"
		        VerticalAlignment="Bottom"
		        HorizontalAlignment="Right"
		        Margin="20"
		        Background="{DynamicResource SurfaceBrush}"
		        BorderBrush="{DynamicResource BorderBrush}"
		        BorderThickness="1"
		        CornerRadius="20"
		        Padding="16,10"
		        Command="{Binding ToggleLogPanelCommand}"
		        IsVisible="{Binding !IsLogPanelExpanded}"
		        ZIndex="50">
			<StackPanel Orientation="Horizontal" Spacing="8">
				<PathIcon Data="M4 6h16M4 12h16M4 18h7"
				          Width="16" Height="16"
				          Foreground="{DynamicResource TextSecondaryBrush}"/>
				<TextBlock Text="Show Log"
				           FontSize="13"
				           Foreground="{DynamicResource TextSecondaryBrush}"/>
				<Border Background="{DynamicResource PrimaryBrush}"
				        CornerRadius="10"
				        Padding="6,2"
				        IsVisible="{Binding LogMessages.Count}">
					<TextBlock Text="{Binding LogMessages.Count}"
					           FontSize="10"
					           FontWeight="Bold"
					           Foreground="White"/>
				</Border>
			</StackPanel>
		</Button>

	</Grid>
</UserControl>
