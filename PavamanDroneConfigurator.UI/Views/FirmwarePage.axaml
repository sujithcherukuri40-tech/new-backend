<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels"
             x:Class="PavamanDroneConfigurator.UI.Views.FirmwarePage"
             x:DataType="vm:FirmwarePageViewModel">

    <UserControl.Styles>
        <!-- Dark theme for firmware page (Mission Planner style) -->
        <Style Selector="Border.mp-background">
            <Setter Property="Background" Value="#2D2D30"/>
        </Style>
        
        <!-- Vehicle Card Style (Mission Planner grid item) -->
        <Style Selector="Button.vehicle-card">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="140"/>
            <Setter Property="Height" Value="160"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        
        <Style Selector="Button.vehicle-card:pointerover">
            <Setter Property="BorderBrush" Value="#007ACC"/>
        </Style>
        
        <Style Selector="Button.vehicle-card:pressed">
            <Setter Property="BorderBrush" Value="#0E639C"/>
        </Style>
        
        <!-- Status Bar Button Style -->
        <Style Selector="Button.status-btn">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="4,0"/>
        </Style>
        
        <Style Selector="Button.status-btn:pointerover">
            <Setter Property="Background" Value="#505050"/>
        </Style>
        
        <!-- Progress Bar Style -->
        <Style Selector="ProgressBar.mp-progress">
            <Setter Property="Foreground" Value="#0E639C"/>
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="*,Auto,Auto" Classes="mp-background">
        
        <!-- Main Content Area - Vehicle Type Grid -->
        <ScrollViewer Grid.Row="0" 
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Padding="16">
            
            <StackPanel Spacing="12">
                
                <!-- Source selection row -->
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="Source" Foreground="#CCCCCC" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding FirmwareSources}"
                              SelectedItem="{Binding SelectedFirmwareSource}"
                              Width="200"
                              HorizontalAlignment="Left">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Content="Refresh"
                            Classes="status-btn"
                            Command="{Binding RefreshFirmwareVersionsCommand}"/>
                </StackPanel>
                
                <!-- Status Message -->
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#CCCCCC"
                           FontSize="14"
                           Margin="8,0,0,8"
                           IsVisible="{Binding !IsOperationInProgress}"/>
                
                <!-- Progress Panel -->
                <Border Background="#3E3E42"
                        CornerRadius="8"
                        Padding="16"
                        IsVisible="{Binding IsOperationInProgress}"
                        Margin="8,0,8,16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#FFFFFF"
                                   FontSize="14"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding DetailMessage}"
                                   Foreground="#AAAAAA"
                                   FontSize="12"
                                   IsVisible="{Binding DetailMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        <ProgressBar Value="{Binding ProgressPercent}"
                                     Maximum="100"
                                     Classes="mp-progress"/>
                        <TextBlock Text="{Binding ProgressPercent, StringFormat={}{0:F0}%}"
                                   Foreground="#CCCCCC"
                                   FontSize="12"
                                   HorizontalAlignment="Right"/>
                    </StackPanel>
                </Border>
                
                <!-- Success/Error Banner -->
                <Border Background="#2E7D32"
                        CornerRadius="4"
                        Padding="12"
                        IsVisible="{Binding IsSuccess}"
                        Margin="8,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"
                                  Foreground="White" Width="20" Height="20"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                
                <Border Background="#C62828"
                        CornerRadius="4"
                        Padding="12"
                        IsVisible="{Binding IsError}"
                        Margin="8,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"
                                  Foreground="White" Width="20" Height="20"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                
                <!-- Vehicle Type Grid (Mission Planner Style) -->
                <ItemsControl ItemsSource="{Binding VehicleTypes}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" 
                                       HorizontalAlignment="Center"
                                       Margin="8"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:VehicleTypeItem">
                            <Button Classes="vehicle-card"
                                    Command="{Binding $parent[ItemsControl].((vm:FirmwarePageViewModel)DataContext).SelectVehicleTypeCommand}"
                                    CommandParameter="{Binding}"
                                    ToolTip.Tip="{Binding Description}">
                                <StackPanel Spacing="6" HorizontalAlignment="Center">
                                    <!-- Vehicle Image -->
                                    <Border Background="#252526" 
                                            CornerRadius="4"
                                            Width="100"
                                            Height="80">
                                        <Image Source="{Binding ImagePath}"
                                               Width="80"
                                               Height="70"
                                               Stretch="Uniform"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    </Border>
                                    <!-- Vehicle Name -->
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="#CCCCCC"
                                               FontSize="11"
                                               FontWeight="Medium"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"/>
                                    <!-- Version Text -->
                                    <TextBlock Text="{Binding VersionText}"
                                               Foreground="#888888"
                                               FontSize="9"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                
                <!-- Detected Board Panel (shown when board detected) -->
                <Border Background="#3E3E42"
                        CornerRadius="8"
                        Padding="16"
                        Margin="8,16,8,0"
                        IsVisible="{Binding IsBoardDetected}">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel>
                            <TextBlock Text="Detected Board"
                                       Foreground="#888888"
                                       FontSize="11"/>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <TextBlock Text="{Binding DetectedBoardName}"
                                           Foreground="#80CBC4"
                                           FontWeight="SemiBold"
                                           FontSize="14"/>
                                <TextBlock Text="on"
                                           Foreground="#888888"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding DetectedBoardPort}"
                                           Foreground="#CCCCCC"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Refresh"
                                Classes="status-btn"
                                Command="{Binding DetectBoardCommand}"/>
                    </Grid>
                </Border>
                
                <!-- Manual Mode Panel -->
                <Border Background="#3E3E42"
                        CornerRadius="8"
                        Padding="16"
                        Margin="8,16,8,0"
                        IsVisible="{Binding IsManualMode}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Load Custom Firmware"
                                   Foreground="#CCCCCC"
                                   FontWeight="SemiBold"
                                   FontSize="14"/>
                        <TextBlock Text="Select a .apj or .px4 firmware file to flash"
                                   Foreground="#888888"
                                   FontSize="12"/>
                        <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                            <TextBox Grid.Column="0"
                                     Text="{Binding SelectedFileName}"
                                     IsReadOnly="True"
                                     Watermark="No file selected..."
                                     Background="#252526"
                                     Foreground="#CCCCCC"
                                     BorderBrush="#3E3E42"
                                     Padding="12,8"
                                     CornerRadius="4 0 0 4"/>
                            <Button Grid.Column="1"
                                    Content="Browse..."
                                    Classes="status-btn"
                                    CornerRadius="0 4 4 0"
                                    Click="BrowseFirmwareFile_Click"/>
                        </Grid>
                        <Button Content="Flash Custom Firmware"
                                Classes="status-btn"
                                HorizontalAlignment="Left"
                                Command="{Binding FlashCustomFirmwareCommand}"
                                IsEnabled="{Binding SelectedFilePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- Console Log (collapsible) -->
                <Expander Header="Status" 
                          IsExpanded="True"
                          Margin="8,16,8,0">
                    <Expander.Styles>
                        <Style Selector="Expander">
                            <Setter Property="Foreground" Value="#CCCCCC"/>
                        </Style>
                    </Expander.Styles>
                    <Border Background="#1E1E1E" 
                            CornerRadius="4" 
                            Padding="8"
                            Height="120">
                        <ScrollViewer>
                            <ItemsControl ItemsSource="{Binding LogMessages}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" 
                                                   Foreground="#80CBC4"
                                                   FontFamily="Consolas, monospace"
                                                   FontSize="11"
                                                   Margin="0,1"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Expander>
                
            </StackPanel>
        </ScrollViewer>
        
        <!-- Mode Toggle Bar -->
        <Border Grid.Row="1"
                Background="#252526"
                BorderBrush="#3E3E42"
                BorderThickness="0,1,0,0"
                Padding="16,8">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <RadioButton Content="Automatic"
                             IsChecked="{Binding IsAutomaticMode}"
                             Foreground="#CCCCCC"
                             GroupName="UpgradeMode"/>
                <RadioButton Content="Manual"
                             IsChecked="{Binding IsManualMode}"
                             Foreground="#CCCCCC"
                             GroupName="UpgradeMode"/>
            </StackPanel>
        </Border>
        
        <!-- Bottom Status Bar (Mission Planner style) -->
        <Border Grid.Row="2"
                Background="#252526"
                BorderBrush="#3E3E42"
                BorderThickness="0,1,0,0"
                Padding="8">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Status Text -->
                <TextBlock Grid.Column="0"
                           Text="Status"
                           Foreground="#888888"
                           VerticalAlignment="Center"
                           Margin="8,0"/>
                
                <!-- Action Buttons (Mission Planner style) -->
                <StackPanel Grid.Column="2" 
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    
                    <Button Content="All Options"
                            Classes="status-btn"
                            Command="{Binding ToggleAllOptionsCommand}"/>
                    
                    <Button Content="Bootloader Update"
                            Classes="status-btn"
                            Command="{Binding UpdateBootloaderCommand}"
                            IsEnabled="{Binding !IsOperationInProgress}"/>
                    
                    <Button Content="Force Bootloader"
                            Classes="status-btn"
                            Command="{Binding ForceBootloaderCommand}"
                            IsEnabled="{Binding !IsOperationInProgress}"/>
                    
                    <Button Content="Load custom firmware"
                            Classes="status-btn"
                            Command="{Binding SelectManualModeCommand}"/>
                    
                    <Button Content="{Binding ShowBetaFirmware, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Official firmwares|Beta firmwares'}"
                            Classes="status-btn"
                            Command="{Binding ToggleBetaFirmwareCommand}"/>
                    
                    <Button Content="Cancel"
                            Classes="status-btn"
                            Command="{Binding CancelOperationCommand}"
                            IsVisible="{Binding IsOperationInProgress}"/>
                    
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
