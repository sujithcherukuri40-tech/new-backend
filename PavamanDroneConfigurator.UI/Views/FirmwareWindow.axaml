<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels"
        xmlns:views="using:PavamanDroneConfigurator.UI.Views"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="750"
        x:Class="PavamanDroneConfigurator.UI.Views.FirmwareWindow"
        x:DataType="vm:FirmwarePageViewModel"
        Title="Pavaman Drone Configurator - Firmware"
        Width="1100"
        Height="750"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Icon="avares://PavamanDroneConfigurator.UI/Assets/Images/logo.ico"
        Background="#F5F6F7">

    <Window.Styles>
        <Style Selector="Window">
            <Setter Property="FontFamily" Value="Inter, Segoe UI, San Francisco, Helvetica Neue, Arial"/>
        </Style>
        
        <!-- Back Button Style -->
        <Style Selector="Button.btn-back">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.btn-back:pointerover">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*">
        
        <!-- Header with Back Button -->
        <Border Grid.Row="0"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="0,0,0,1"
                Padding="24,16">
            <Grid ColumnDefinitions="Auto,*,Auto">
                
                <!-- Back Button -->
                <Button Grid.Column="0"
                        Classes="btn-back"
                        Click="BackButton_Click"
                        ToolTip.Tip="Return to Entry Page">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"
                                  Width="16" Height="16"
                                  Foreground="#64748B"/>
                        <TextBlock Text="Back to Entry" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <!-- Title -->
                <StackPanel Grid.Column="1" 
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="Firmware Flasher"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#0F172A"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="No MAVLink connection required"
                               FontSize="12"
                               Foreground="#94A3B8"
                               HorizontalAlignment="Center"/>
                </StackPanel>
                
                <!-- Logo -->
                <Border Grid.Column="2"
                        Width="40"
                        Height="40"
                        CornerRadius="10"
                        Background="#F0F9FF">
                    <Image Source="avares://PavamanDroneConfigurator.UI/Assets/Images/logo.ico"
                           Stretch="Uniform"
                           Margin="6"/>
                </Border>
            </Grid>
        </Border>
        
        <!-- Firmware Page Content -->
        <views:FirmwarePage Grid.Row="1"/>
        
    </Grid>
</Window>
