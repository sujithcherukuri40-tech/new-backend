<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels"
        xmlns:converters="using:PavamanDroneConfigurator.UI.Converters"
        xmlns:infra="using:PavamanDroneConfigurator.Infrastructure.Services"
        mc:Ignorable="d"
        d:DesignWidth="820" d:DesignHeight="600"
        x:Class="PavamanDroneConfigurator.UI.Views.MavlinkLogsWindow"
        x:DataType="vm:MavlinkLogsViewModel"
        Title="MAVLink Message Logs"
        Width="820" Height="600"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="#0A0E1A">

    <Window.Resources>
        <converters:BoolToStringConverter x:Key="BoolToStringConverter"/>
        <converters:DirectionToPrefixConverter x:Key="DirectionToPrefixConverter"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.toolbar-btn">
            <Setter Property="Background" Value="#1E2433"/>
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2D3748"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
        <Style Selector="Button.toolbar-btn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#2D3748"/>
        </Style>
        <Style Selector="TextBlock.col-header">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.entry-time">
            <Setter Property="FontFamily" Value="Consolas, Cascadia Code, monospace"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.entry-type">
            <Setter Property="FontFamily" Value="Consolas, Cascadia Code, monospace"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#38BDF8"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.entry-details">
            <Setter Property="FontFamily" Value="Consolas, Cascadia Code, monospace"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
        </Style>
        <Style Selector="TextBox.filter-box">
            <Setter Property="Background" Value="#1E2433"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#2D3748"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="#E2E8F0"/>
        </Style>
    </Window.Styles>

    <DockPanel>

        <!-- ── Toolbar ── -->
        <Border DockPanel.Dock="Top"
                Background="#111827"
                BorderBrush="#1E2433"
                BorderThickness="0,0,0,1"
                Padding="14,10">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="📊 MAVLink Message Logs"
                               FontSize="15" FontWeight="Bold"
                               Foreground="#E2E8F0"/>
                    <Border Background="#1E2433" CornerRadius="12" Padding="8,3">
                        <TextBlock Text="{Binding TotalMessageCount, StringFormat='{}{0} msgs'}"
                                   FontSize="11" Foreground="#94A3B8"/>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Classes="toolbar-btn"
                            Command="{Binding ToggleLoggingCommand}"
                            Content="{Binding IsLoggingEnabled,
                                     Converter={StaticResource BoolToStringConverter},
                                     ConverterParameter='⏸ Pause|▶ Resume'}"
                            ToolTip.Tip="Pause / resume logging"/>
                    <Button Classes="toolbar-btn"
                            Command="{Binding ClearLogCommand}"
                            Content="🗑 Clear"
                            ToolTip.Tip="Clear all log entries"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Filter bar ── -->
        <Border DockPanel.Dock="Top"
                Background="#0D1117"
                Padding="14,8"
                BorderBrush="#1E2433"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0"
                           Text="Filter: "
                           VerticalAlignment="Center"
                           Foreground="#64748B"
                           FontSize="12"
                           Margin="0,0,8,0"/>
                <TextBox Grid.Column="1"
                         Classes="filter-box"
                         Text="{Binding FilterText}"
                         Watermark="Filter by message type or content…"/>
            </Grid>
        </Border>

        <!-- ── Column headers ── -->
        <Border DockPanel.Dock="Top"
                Background="#111827"
                BorderBrush="#1E2433"
                BorderThickness="0,0,0,1"
                Padding="14,7">
            <Grid ColumnDefinitions="140,80,110,*">
                <TextBlock Grid.Column="0" Classes="col-header" Text="Time"/>
                <TextBlock Grid.Column="1" Classes="col-header" Text="Dir"/>
                <TextBlock Grid.Column="2" Classes="col-header" Text="Message Type"/>
                <TextBlock Grid.Column="3" Classes="col-header" Text="Details"/>
            </Grid>
        </Border>

        <!-- ── Status bar ── -->
        <Border DockPanel.Dock="Bottom"
                Background="#111827"
                BorderBrush="#1E2433"
                BorderThickness="0,1,0,0"
                Padding="14,7">
            <TextBlock Text="{Binding StatusText}"
                       FontSize="11"
                       Foreground="#64748B"/>
        </Border>

        <!-- ── Log entries (scrollable) ── -->
        <ScrollViewer x:Name="LogScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding FilteredEntries}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="infra:MavLinkLogEntry">
                        <Border Padding="14,4"
                                BorderBrush="#1A2030"
                                BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="140,80,110,*">
                                <!-- Timestamp -->
                                <TextBlock Grid.Column="0"
                                           Classes="entry-time"
                                           Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss.fff}'}"/>
                                <!-- Direction prefix -->
                                <TextBlock Grid.Column="1"
                                           Classes="entry-type"
                                           Text="{Binding Direction,
                                                  Converter={StaticResource DirectionToPrefixConverter}}"/>
                                <!-- Message type -->
                                <TextBlock Grid.Column="2"
                                           Classes="entry-type"
                                           Text="{Binding MessageType}"/>
                                <!-- Details -->
                                <TextBlock Grid.Column="3"
                                           Classes="entry-details"
                                           Text="{Binding Details}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</Window>
