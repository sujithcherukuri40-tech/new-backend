<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels"
             x:Class="PavamanDroneConfigurator.UI.Views.CalibrationPage"
             x:DataType="vm:CalibrationPageViewModel">

    <ScrollViewer>
        <StackPanel Margin="20" Spacing="15">
            <TextBlock Text="Calibration" FontSize="24" FontWeight="Bold" />

            <TextBlock Text="{Binding StatusMessage}" FontSize="16" />

            <!-- IMU Calibration Section - Implementation Pending -->
            <Border BorderBrush="Orange" BorderThickness="2" Padding="15" Margin="0,10,0,0" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="IMU Calibration (6-Position)" FontSize="18" FontWeight="SemiBold" />
                    
                    <TextBlock Text="IMU calibration implementation pending - feature being rewritten."
                               TextWrapping="Wrap" Foreground="Orange" FontSize="12" />
                    
                    <TextBlock Text="Please use the Sensors Calibration page for now."
                               TextWrapping="Wrap" Foreground="Gray" FontSize="12" />
                </StackPanel>
            </Border>

            <!-- Compass Calibration Section - Implementation Pending -->
            <Border BorderBrush="Orange" BorderThickness="2" Padding="15" Margin="0,10,0,0" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="Compass Calibration" FontSize="18" FontWeight="SemiBold" />
                    
                    <TextBlock Text="Compass calibration implementation pending - feature being rewritten."
                               TextWrapping="Wrap" Foreground="Orange" FontSize="12" />
                    
                    <TextBlock Text="Please use the Sensors Calibration page for now."
                               TextWrapping="Wrap" Foreground="Gray" FontSize="12" />
                </StackPanel>
            </Border>

            <!-- Calibration Instructions -->
            <Border Background="#1E1E1E" Padding="15" CornerRadius="8" Margin="0,10,0,0"
                    IsVisible="{Binding CalibrationInstructions, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <StackPanel>
                    <TextBlock Text="Instructions" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding CalibrationInstructions}" 
                               TextWrapping="Wrap" FontSize="14" />
                </StackPanel>
            </Border>

            <!-- Other Calibration Buttons -->
            <TextBlock Text="Other Calibrations" FontSize="18" FontWeight="SemiBold" Margin="0,20,0,10" />
            
            <StackPanel Spacing="10">
                <Button Content="Calibrate Gyroscope" Command="{Binding CalibrateGyroscopeCommand}" />
                <Button Content="Level Horizon" Command="{Binding CalibrateLevelHorizonCommand}" />
                <Button Content="Calibrate Barometer" Command="{Binding CalibrateBarometerCommand}" />
                <Button Content="Cancel Calibration" Command="{Binding CancelCalibrationCommand}" />
                <Button Content="Reboot Flight Controller" Command="{Binding RebootFlightControllerCommand}" />
            </StackPanel>

            <!-- Progress Display -->
            <StackPanel IsVisible="{Binding IsCalibrating}" Spacing="5" Margin="0,20,0,0">
                <TextBlock Text="Calibration in Progress..." FontWeight="SemiBold" />
                <TextBlock Text="{Binding CalibrationProgress, StringFormat='Progress: {0}%'}" />
                <ProgressBar Value="{Binding CalibrationProgress}" Maximum="100" Height="10" />
            </StackPanel>

            <!-- Detailed State Display -->
            <Border BorderBrush="Gray" BorderThickness="1" Padding="10" Margin="0,20,0,0" 
                    IsVisible="{Binding CurrentState, Converter={x:Static ObjectConverters.IsNotNull}}">
                <StackPanel Spacing="5">
                    <TextBlock Text="Calibration State Details" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding CurrentState.Type, StringFormat='Type: {0}'}" />
                    <TextBlock Text="{Binding CurrentState.State, StringFormat='State: {0}'}" />
                    <ProgressBar Value="{Binding CurrentState.Progress}" Maximum="100" Height="20" />
                    <TextBlock Text="{Binding CurrentState.Message}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
