<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels"
             x:Class="PavamanDroneConfigurator.UI.Views.ResetParametersPage"
             x:DataType="vm:ResetParametersPageViewModel"
             Background="#F9FAFB">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32" MaxWidth="800" Spacing="24">
            
            <!-- Header -->
            <StackPanel Spacing="8">
                <TextBlock Text="Factory Reset"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#111827"/>
                <TextBlock Text="Reset all parameters to factory defaults"
                           FontSize="14"
                           Foreground="#6B7280"/>
            </StackPanel>

            <!-- Connection Status -->
            <Border Background="#EEF2FF" CornerRadius="8" Padding="16">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Ellipse Width="10" Height="10" Fill="#10B981" IsVisible="{Binding IsConnected}"/>
                    <Ellipse Width="10" Height="10" Fill="#F59E0B" IsVisible="{Binding IsDisconnected}"/>
                    <TextBlock Text="Connected" FontWeight="SemiBold" IsVisible="{Binding IsConnected}"/>
                    <TextBlock Text="Not Connected" FontWeight="SemiBold" IsVisible="{Binding IsDisconnected}"/>
                </StackPanel>
            </Border>

            <!-- Warning Card -->
            <Border Background="#FFFBEB" 
                    CornerRadius="12" 
                    Padding="20"
                    BorderBrush="#F59E0B"
                    BorderThickness="0,0,0,3">
                <StackPanel Spacing="12">
                    <TextBlock Text="?? Warning" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="#92400E"/>
                    <TextBlock Text="This will reset ALL parameters to factory defaults. All custom configurations will be permanently lost."
                               TextWrapping="Wrap"
                               Foreground="#78350F"/>
                </StackPanel>
            </Border>

            <!-- Step 1: Reset -->
            <Border Background="White" 
                    CornerRadius="12" 
                    Padding="20"
                    BoxShadow="0 2 8 0 #10000000">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Border Width="40" Height="40" CornerRadius="20" Background="#FEE2E2">
                        <TextBlock Text="1" FontSize="18" FontWeight="Bold" Foreground="#DC2626"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="16,0" VerticalAlignment="Center">
                        <TextBlock Text="Reset Parameters" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Text="Send reset command" Foreground="#6B7280" FontSize="13"/>
                    </StackPanel>
                    <Button Grid.Column="2" 
                            Content="Reset to Defaults"
                            Background="#EF4444"
                            Foreground="White"
                            Padding="20,10"
                            CornerRadius="8"
                            Command="{Binding ResetParametersCommand}"
                            IsEnabled="{Binding IsConnected}"/>
                </Grid>
            </Border>

            <!-- Step 2: Reboot -->
            <Border Background="White" 
                    CornerRadius="12" 
                    Padding="20"
                    BoxShadow="0 2 8 0 #10000000">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Border Width="40" Height="40" CornerRadius="20" Background="#E5E7EB">
                        <TextBlock Text="2" FontSize="18" FontWeight="Bold" Foreground="#6B7280"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="16,0" VerticalAlignment="Center">
                        <TextBlock Text="Reboot Controller" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Text="Restart to apply reset" Foreground="#6B7280" FontSize="13"/>
                    </StackPanel>
                    <Button Grid.Column="2" 
                            Content="Reboot"
                            Background="#6B7280"
                            Foreground="White"
                            Padding="20,10"
                            CornerRadius="8"
                            Command="{Binding RebootDroneCommand}"
                            IsEnabled="{Binding IsConnected}"/>
                </Grid>
            </Border>

            <!-- Step 3: Refresh -->
            <Border Background="White" 
                    CornerRadius="12" 
                    Padding="20"
                    BoxShadow="0 2 8 0 #10000000">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Border Width="40" Height="40" CornerRadius="20" Background="#DBEAFE">
                        <TextBlock Text="3" FontSize="18" FontWeight="Bold" Foreground="#3B82F6"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="16,0" VerticalAlignment="Center">
                        <TextBlock Text="Refresh Parameters" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Text="Download new parameters" Foreground="#6B7280" FontSize="13"/>
                    </StackPanel>
                    <Button Grid.Column="2" 
                            Content="Refresh"
                            Background="#3B82F6"
                            Foreground="White"
                            Padding="20,10"
                            CornerRadius="8"
                            Command="{Binding RefreshParametersCommand}"
                            IsEnabled="{Binding IsConnected}"/>
                </Grid>
            </Border>

            <!-- Status Message -->
            <Border Background="White" 
                    CornerRadius="12" 
                    Padding="20"
                    BoxShadow="0 2 8 0 #10000000">
                <StackPanel Spacing="12">
                    <TextBlock Text="Status" FontWeight="SemiBold" FontSize="16"/>
                    <TextBlock Text="{Binding StatusMessage}" 
                               TextWrapping="Wrap"
                               Foreground="#374151"/>
                </StackPanel>
            </Border>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>
