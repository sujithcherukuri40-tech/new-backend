<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels"
             x:Class="PavamanDroneConfigurator.UI.Views.ResetParametersPage"
             x:DataType="vm:ResetParametersPageViewModel"
             Background="#F9FAFB">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32" MaxWidth="800" Spacing="24">
            
            <!-- Header -->
            <StackPanel Spacing="8">
                <TextBlock Text="Factory Reset"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#111827"/>
                <TextBlock Text="Reset all parameters to factory defaults"
                           FontSize="14"
                           Foreground="#6B7280"/>
            </StackPanel>

            <!-- Connection Status -->
            <Border Background="#EEF2FF" CornerRadius="8" Padding="16">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Ellipse Width="10" Height="10" Fill="#10B981" IsVisible="{Binding IsConnected}"/>
                    <Ellipse Width="10" Height="10" Fill="#F59E0B" IsVisible="{Binding IsDisconnected}"/>
                    <TextBlock Text="Connected" FontWeight="SemiBold" IsVisible="{Binding IsConnected}"/>
                    <TextBlock Text="Not Connected" FontWeight="SemiBold" IsVisible="{Binding IsDisconnected}"/>
                </StackPanel>
            </Border>

            <!-- WARNING SECTION (Refined & Calm with enhanced styling) -->
            <Border Classes="WarningCard"
                    Background="#FFFBEB" 
                    CornerRadius="12" 
                    Padding="20"
                    BorderBrush="#F59E0B"
                    BorderThickness="0,0,0,3">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <!-- Left Accent Bar -->
                        <Border Classes="AccentBar Warning"/>
                        
                        <StackPanel Spacing="12">
                            <TextBlock Text="&#x26A0; Factory Reset Warning" 
                                       FontSize="16" 
                                       FontWeight="600" 
                                       Foreground="#92400E"/>
                            
                            <TextBlock FontSize="13" 
                                       FontWeight="400" 
                                       Foreground="#78350F" 
                                       TextWrapping="Wrap"
                                       LineHeight="20"
                                       Text="This operation resets all flight controller parameters to factory defaults. All custom configurations will be permanently lost."/>
                            
                            <!-- Compact Bullet List -->
                            <StackPanel Spacing="6" Margin="0,4,0,0">
                                <TextBlock FontSize="13" Foreground="#78350F">
                                    &#x2022; PID tuning and flight modes
                                </TextBlock>
                                <TextBlock FontSize="13" Foreground="#78350F">
                                    &#x2022; Safety settings and failsafes
                                </TextBlock>
                                <TextBlock FontSize="13" Foreground="#78350F">
                                    &#x2022; Sensor calibration offsets
                                </TextBlock>
                                <TextBlock FontSize="13" Foreground="#78350F">
                                    &#x2022; Motor and ESC configurations
                                </TextBlock>
                            </StackPanel>
                            
                            <TextBlock FontSize="12" 
                                       FontWeight="500" 
                                       Foreground="#92400E" 
                                       Margin="0,8,0,0"
                                       Text="Recommendation: Export current parameters before proceeding."/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- RESET WORKFLOW (Step Cards - Combined Design) -->
            <StackPanel Spacing="16">
                
                <!-- Step 1: Reset Parameters -->
                <Border Classes="StepCard"
                        Background="White" 
                        CornerRadius="12" 
                        Padding="20"
                        BoxShadow="0 2 8 0 #10000000">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <!-- Step Number (Combined both designs) -->
                            <Border Classes="StepNumber Step1"
                                    Width="40" 
                                    Height="40" 
                                    CornerRadius="20" 
                                    Background="#FEE2E2">
                                <TextBlock Classes="StepNumberText Step1" 
                                           Text="1"
                                           FontSize="18" 
                                           FontWeight="Bold" 
                                           Foreground="#DC2626"
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            
                            <!-- Step Info -->
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Classes="StepTitle" 
                                           Text="Reset Parameters"
                                           FontWeight="SemiBold" 
                                           FontSize="16"/>
                                <TextBlock Classes="StepDescription" 
                                           Text="Send reset command to prepare for factory reset"
                                           Foreground="#6B7280" 
                                           FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Action Button -->
                        <Button Classes="StepButton Danger"
                                Content="Reset to Factory Defaults"
                                Background="#EF4444"
                                Foreground="White"
                                Padding="20,10"
                                CornerRadius="8"
                                Command="{Binding ResetParametersCommand}"
                                IsEnabled="{Binding IsConnected}"
                                HorizontalAlignment="Right"/>
                    </StackPanel>
                </Border>
                
                <!-- Step 2: Reboot Flight Controller -->
                <Border Classes="StepCard"
                        Background="White" 
                        CornerRadius="12" 
                        Padding="20"
                        BoxShadow="0 2 8 0 #10000000">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <!-- Step Number -->
                            <Border Classes="StepNumber Step2"
                                    Width="40" 
                                    Height="40" 
                                    CornerRadius="20" 
                                    Background="#E5E7EB">
                                <TextBlock Classes="StepNumberText Step2" 
                                           Text="2"
                                           FontSize="18" 
                                           FontWeight="Bold" 
                                           Foreground="#6B7280"
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            
                            <!-- Step Info -->
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Classes="StepTitle" 
                                           Text="Reboot Flight Controller"
                                           FontWeight="SemiBold" 
                                           FontSize="16"/>
                                <TextBlock Classes="StepDescription" 
                                           Text="Restart to apply the reset operation"
                                           Foreground="#6B7280" 
                                           FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Action Button -->
                        <Button Classes="StepButton Neutral"
                                Content="Reboot Controller"
                                Background="#6B7280"
                                Foreground="White"
                                Padding="20,10"
                                CornerRadius="8"
                                Command="{Binding RebootDroneCommand}"
                                IsEnabled="{Binding IsConnected}"
                                HorizontalAlignment="Right"/>
                    </StackPanel>
                </Border>
                
                <!-- Step 3: Reload Parameters -->
                <Border Classes="StepCard"
                        Background="White" 
                        CornerRadius="12" 
                        Padding="20"
                        BoxShadow="0 2 8 0 #10000000">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <!-- Step Number -->
                            <Border Classes="StepNumber Step3"
                                    Width="40" 
                                    Height="40" 
                                    CornerRadius="20" 
                                    Background="#DBEAFE">
                                <TextBlock Classes="StepNumberText Step3" 
                                           Text="3"
                                           FontSize="18" 
                                           FontWeight="Bold" 
                                           Foreground="#3B82F6"
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            
                            <!-- Step Info -->
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Classes="StepTitle" 
                                           Text="Reload Parameters"
                                           FontWeight="SemiBold" 
                                           FontSize="16"/>
                                <TextBlock Classes="StepDescription" 
                                           Text="Download reset parameters after reconnection"
                                           Foreground="#6B7280" 
                                           FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Action Button -->
                        <Button Classes="StepButton Primary"
                                Content="Reload Parameters"
                                Background="#3B82F6"
                                Foreground="White"
                                Padding="20,10"
                                CornerRadius="8"
                                Command="{Binding RefreshParametersCommand}"
                                IsEnabled="{Binding IsConnected}"
                                HorizontalAlignment="Right"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Status Message -->
            <Border Background="White" 
                    CornerRadius="12" 
                    Padding="20"
                    BoxShadow="0 2 8 0 #10000000">
                <StackPanel Spacing="12">
                    <TextBlock Text="Status" FontWeight="SemiBold" FontSize="16"/>
                    <TextBlock Text="{Binding StatusMessage}" 
                               TextWrapping="Wrap"
                               Foreground="#374151"/>
                </StackPanel>
            </Border>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>
