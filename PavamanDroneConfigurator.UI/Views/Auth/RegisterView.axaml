<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels.Auth"
             mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="750"
             x:Class="PavamanDroneConfigurator.UI.Views.Auth.RegisterView"
             x:DataType="vm:RegisterViewModel">

    <UserControl.Styles>
        <!-- macOS-style Input -->
        <Style Selector="TextBox.auth-input">
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="#1F2937"/>
        </Style>

        <Style Selector="TextBox.auth-input:focus">
            <Setter Property="BorderBrush" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>

        <Style Selector="TextBox.auth-input:pointerover">
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
        </Style>

        <Style Selector="TextBox.auth-input-error">
            <Setter Property="BorderBrush" Value="#EF4444"/>
        </Style>

        <!-- Primary Button -->
        <Style Selector="Button.auth-primary">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="48"/>
        </Style>

        <Style Selector="Button.auth-primary:pointerover">
            <Setter Property="Background" Value="#2563EB"/>
        </Style>

        <Style Selector="Button.auth-primary:pressed">
            <Setter Property="Background" Value="#1D4ED8"/>
        </Style>

        <Style Selector="Button.auth-primary:disabled">
            <Setter Property="Background" Value="#9CA3AF"/>
            <Setter Property="Opacity" Value="0.7"/>
            <Setter Property="Cursor" Value="Arrow"/>
        </Style>

        <!-- Link Button -->
        <Style Selector="Button.auth-link">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.auth-link:pointerover">
            <Setter Property="Foreground" Value="#2563EB"/>
        </Style>

        <!-- Error Alert -->
        <Style Selector="Border.auth-error">
            <Setter Property="Background" Value="#FEF2F2"/>
            <Setter Property="BorderBrush" Value="#FECACA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,12"/>
        </Style>

        <!-- Field Label -->
        <Style Selector="TextBlock.field-label">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Field Error -->
        <Style Selector="TextBlock.field-error">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#EF4444"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="0" 
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center"
                        Width="360"
                        Margin="40">

                <!-- Logo & Branding -->
                <StackPanel Spacing="12" Margin="0,0,0,32" HorizontalAlignment="Center">
                    <Border Width="72"
                            Height="72"
                            CornerRadius="18"
                            Background="#EEF2FF"
                            HorizontalAlignment="Center">
                        <Image Source="avares://PavamanDroneConfigurator.UI/Assets/Images/logo.ico"
                               Stretch="Uniform"
                               Margin="12"/>
                    </Border>
                    
                    <TextBlock Text="Create your account"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#111827"
                               HorizontalAlignment="Center"/>
                    
                    <TextBlock Text="Register to access Pavaman Drone Configurator"
                               FontSize="15"
                               Foreground="#6B7280"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </StackPanel>

                <!-- General Error Message -->
                <Border Classes="auth-error"
                        IsVisible="{Binding HasError}"
                        Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="?"
                                   FontSize="16"
                                   Foreground="#DC2626"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   FontSize="14"
                                   Foreground="#DC2626"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Form Fields -->
                <StackPanel Spacing="16">
                    <!-- Full Name -->
                    <StackPanel Spacing="0">
                        <TextBlock Text="Full Name" Classes="field-label"/>
                        <TextBox Classes="auth-input"
                                 Text="{Binding FullName, Mode=TwoWay}"
                                 Watermark="Enter your full name"
                                 IsEnabled="{Binding !IsLoading}"/>
                        <TextBlock Classes="field-error"
                                   Text="{Binding FullNameError}"
                                   IsVisible="{Binding FullNameError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>

                    <!-- Email -->
                    <StackPanel Spacing="0">
                        <TextBlock Text="Email" Classes="field-label"/>
                        <TextBox Classes="auth-input"
                                 Text="{Binding Email, Mode=TwoWay}"
                                 Watermark="you@example.com"
                                 IsEnabled="{Binding !IsLoading}"/>
                        <TextBlock Classes="field-error"
                                   Text="{Binding EmailError}"
                                   IsVisible="{Binding EmailError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>

                    <!-- Password -->
                    <StackPanel Spacing="0">
                        <TextBlock Text="Password" Classes="field-label"/>
                        <TextBox Classes="auth-input"
                                 PasswordChar="?"
                                 Text="{Binding Password, Mode=TwoWay}"
                                 Watermark="Minimum 8 characters"
                                 IsEnabled="{Binding !IsLoading}"/>
                        <TextBlock Classes="field-error"
                                   Text="{Binding PasswordError}"
                                   IsVisible="{Binding PasswordError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>

                    <!-- Confirm Password -->
                    <StackPanel Spacing="0">
                        <TextBlock Text="Confirm Password" Classes="field-label"/>
                        <TextBox Classes="auth-input"
                                 PasswordChar="?"
                                 Text="{Binding ConfirmPassword, Mode=TwoWay}"
                                 Watermark="Re-enter your password"
                                 IsEnabled="{Binding !IsLoading}"/>
                        <TextBlock Classes="field-error"
                                   Text="{Binding ConfirmPasswordError}"
                                   IsVisible="{Binding ConfirmPasswordError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Register Button -->
                <Button Classes="auth-primary"
                        Command="{Binding RegisterCommand}"
                        Margin="0,28,0,0">
                    <Panel>
                        <TextBlock Text="Create Account"
                                   IsVisible="{Binding !IsLoading}"
                                   HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" 
                                    Spacing="8"
                                    IsVisible="{Binding IsLoading}"
                                    HorizontalAlignment="Center">
                            <ProgressBar IsIndeterminate="True"
                                         Width="16"
                                         Height="16"
                                         Foreground="White"/>
                            <TextBlock Text="Creating account..."
                                       Foreground="White"/>
                        </StackPanel>
                    </Panel>
                </Button>

                <!-- Login Link -->
                <StackPanel Orientation="Horizontal" 
                            Spacing="4"
                            HorizontalAlignment="Center"
                            Margin="0,24,0,0">
                    <TextBlock Text="Already have an account?"
                               FontSize="14"
                               Foreground="#6B7280"/>
                    <Button Classes="auth-link"
                            Content="Sign in"
                            Command="{Binding NavigateToLoginCommand}"
                            IsEnabled="{Binding !IsLoading}"/>
                </StackPanel>

                <!-- Approval Notice -->
                <Border Background="#FEF3C7"
                        BorderBrush="#FCD34D"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16"
                        Margin="0,24,0,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="?? Administrator Approval Required"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#92400E"/>
                        <TextBlock Text="After registration, an administrator will review and approve your account. You'll receive access once approved."
                                   FontSize="12"
                                   Foreground="#92400E"
                                   TextWrapping="Wrap"
                                   LineHeight="18"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
