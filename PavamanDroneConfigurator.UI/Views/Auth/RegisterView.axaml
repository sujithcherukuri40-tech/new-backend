<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels.Auth"
             mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="850"
             x:Class="PavamanDroneConfigurator.UI.Views.Auth.RegisterView"
             x:DataType="vm:RegisterViewModel">

    <UserControl.Styles>
        <!-- macOS-style Input -->
        <Style Selector="TextBox.auth-input">
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="#1F2937"/>
        </Style>

        <Style Selector="TextBox.auth-input:focus">
            <Setter Property="BorderBrush" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>

        <Style Selector="TextBox.auth-input:pointerover">
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
        </Style>

        <Style Selector="TextBox.auth-input-error">
            <Setter Property="BorderBrush" Value="#EF4444"/>
        </Style>

        <!-- Primary Button -->
        <Style Selector="Button.auth-primary">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="48"/>
        </Style>

        <Style Selector="Button.auth-primary:pointerover">
            <Setter Property="Background" Value="#2563EB"/>
        </Style>

        <Style Selector="Button.auth-primary:pressed">
            <Setter Property="Background" Value="#1D4ED8"/>
        </Style>

        <Style Selector="Button.auth-primary:disabled">
            <Setter Property="Background" Value="#9CA3AF"/>
            <Setter Property="Opacity" Value="0.7"/>
            <Setter Property="Cursor" Value="Arrow"/>
        </Style>

        <!-- Link Button -->
        <Style Selector="Button.auth-link">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.auth-link:pointerover">
            <Setter Property="Foreground" Value="#2563EB"/>
        </Style>

        <!-- Error Alert -->
        <Style Selector="Border.auth-error">
            <Setter Property="Background" Value="#FEF2F2"/>
            <Setter Property="BorderBrush" Value="#FECACA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,12"/>
        </Style>

        <!-- Field Label -->
        <Style Selector="TextBlock.field-label">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Field Error -->
        <Style Selector="TextBlock.field-error">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#EF4444"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="0" 
                        HorizontalAlignment="Stretch" 
                        VerticalAlignment="Center"
                        MaxWidth="380"
                        Margin="24">

                <!-- Logo & Branding - Increased logo size -->
                <StackPanel Spacing="12" Margin="0,0,0,32" HorizontalAlignment="Center">
                    <Border Width="100"
                            Height="100"
                            CornerRadius="24"
                            Background="#EEF2FF"
                            HorizontalAlignment="Center">
                        <Image Source="avares://PavamanDroneConfigurator.UI/Assets/Images/KFT Logo.png"
                               Stretch="Uniform"
                               Margin="16"/>
                    </Border>
                    
                    <TextBlock Text="Create your account"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#111827"
                               HorizontalAlignment="Center"/>
                    
                    <TextBlock Text="Register to access KFT Drone Configurator"
                               FontSize="15"
                               Foreground="#6B7280"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </StackPanel>

                <!-- General Error Message - Fixed Unicode -->
                <Border Classes="auth-error"
                        IsVisible="{Binding HasError}"
                        Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="?"
                                   FontSize="16"
                                   Foreground="#DC2626"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   FontSize="14"
                                   Foreground="#DC2626"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Form Fields -->
                <StackPanel Spacing="16">
                    <!-- Full Name -->
                    <StackPanel Spacing="0">
                        <TextBlock Text="Full Name" Classes="field-label"/>
                        <TextBox Classes="auth-input"
                                 Text="{Binding FullName, Mode=TwoWay}"
                                 Watermark="Enter your full name"
                                 IsEnabled="{Binding !IsLoading}"/>
                        <TextBlock Classes="field-error"
                                   Text="{Binding FullNameError}"
                                   IsVisible="{Binding FullNameError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>

                    <!-- Email -->
                    <StackPanel Spacing="0">
                        <TextBlock Text="Email" Classes="field-label"/>
                        <TextBox Classes="auth-input"
                                 Text="{Binding Email, Mode=TwoWay}"
                                 Watermark="you@example.com"
                                 IsEnabled="{Binding !IsLoading}"/>
                        <TextBlock Classes="field-error"
                                   Text="{Binding EmailError}"
                                   IsVisible="{Binding EmailError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>

                    <!-- Password -->
                    <StackPanel Spacing="0">
                        <TextBlock Text="Password" Classes="field-label"/>
                        <Grid>
                            <TextBox x:Name="RegPasswordTextBox"
                                     Classes="auth-input"
                                     Text="{Binding Password, Mode=TwoWay}"
                                     Watermark="Minimum 8 characters"
                                     IsEnabled="{Binding !IsLoading}"
                                     IsVisible="{Binding #RegShowPasswordToggle.IsChecked}"/>
                            <TextBox x:Name="RegPasswordMaskedBox"
                                     Classes="auth-input"
                                     PasswordChar="*"
                                     Text="{Binding Password, Mode=TwoWay}"
                                     Watermark="Minimum 8 characters"
                                     IsEnabled="{Binding !IsLoading}"
                                     IsVisible="{Binding !#RegShowPasswordToggle.IsChecked}"/>
                            <ToggleButton x:Name="RegShowPasswordToggle"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Margin="0,0,12,0"
                                          Padding="8"
                                          ToolTip.Tip="Show/Hide Password">
                                <Panel>
                                    <Path Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z"
                                          Fill="#6B7280"
                                          Width="18"
                                          Height="18"
                                          Stretch="Uniform"
                                          IsVisible="{Binding !#RegShowPasswordToggle.IsChecked}"/>
                                    <Path Data="M11.83,9L15,12.16C15,12.11 15,12.05 15,12A3,3 0 0,0 12,9C11.94,9 11.89,9 11.83,9M7.53,9.8L9.08,11.35C9.03,11.56 9,11.77 9,12A3,3 0 0,0 12,15C12.22,15 12.44,14.97 12.65,14.92L14.2,16.47C13.53,16.8 12.79,17 12,17A5,5 0 0,1 7,12C7,11.21 7.2,10.47 7.53,9.8M2,4.27L4.28,6.55L4.73,7C3.08,8.3 1.78,10 1,12C2.73,16.39 7,19.5 12,19.5C13.55,19.5 15.03,19.2 16.38,18.66L16.81,19.08L19.73,22L21,20.73L3.27,3M12,7A5,5 0 0,1 17,12C17,12.64 16.87,13.26 16.64,13.82L19.57,16.75C21.07,15.5 22.27,13.86 23,12C21.27,7.61 17,4.5 12,4.5C10.6,4.5 9.26,4.75 8,5.2L10.17,7.35C10.74,7.13 11.35,7 12,7Z"
                                          Fill="#6B7280"
                                          Width="18"
                                          Height="18"
                                          Stretch="Uniform"
                                          IsVisible="{Binding #RegShowPasswordToggle.IsChecked}"/>
                                </Panel>
                            </ToggleButton>
                        </Grid>
                        <TextBlock Classes="field-error"
                                   Text="{Binding PasswordError}"
                                   IsVisible="{Binding PasswordError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        <TextBlock Text="Must be at least 8 characters with uppercase, lowercase, and a number."
                                   FontSize="11"
                                   Foreground="#6B7280"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Confirm Password -->
                    <StackPanel Spacing="0">
                        <TextBlock Text="Confirm Password" Classes="field-label"/>
                        <Grid>
                            <TextBox x:Name="ConfirmPasswordTextBox"
                                     Classes="auth-input"
                                     Text="{Binding ConfirmPassword, Mode=TwoWay}"
                                     Watermark="Re-enter your password"
                                     IsEnabled="{Binding !IsLoading}"
                                     IsVisible="{Binding #ConfirmShowPasswordToggle.IsChecked}"/>
                            <TextBox x:Name="ConfirmPasswordMaskedBox"
                                     Classes="auth-input"
                                     PasswordChar="*"
                                     Text="{Binding ConfirmPassword, Mode=TwoWay}"
                                     Watermark="Re-enter your password"
                                     IsEnabled="{Binding !IsLoading}"
                                     IsVisible="{Binding !#ConfirmShowPasswordToggle.IsChecked}"/>
                            <ToggleButton x:Name="ConfirmShowPasswordToggle"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Margin="0,0,12,0"
                                          Padding="8"
                                          ToolTip.Tip="Show/Hide Password">
                                <Panel>
                                    <Path Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z"
                                          Fill="#6B7280"
                                          Width="18"
                                          Height="18"
                                          Stretch="Uniform"
                                          IsVisible="{Binding !#ConfirmShowPasswordToggle.IsChecked}"/>
                                    <Path Data="M11.83,9L15,12.16C15,12.11 15,12.05 15,12A3,3 0 0,0 12,9C11.94,9 11.89,9 11.83,9M7.53,9.8L9.08,11.35C9.03,11.56 9,11.77 9,12A3,3 0 0,0 12,15C12.22,15 12.44,14.97 12.65,14.92L14.2,16.47C13.53,16.8 12.79,17 12,17A5,5 0 0,1 7,12C7,11.21 7.2,10.47 7.53,9.8M2,4.27L4.28,6.55L4.73,7C3.08,8.3 1.78,10 1,12C2.73,16.39 7,19.5 12,19.5C13.55,19.5 15.03,19.2 16.38,18.66L16.81,19.08L19.73,22L21,20.73L3.27,3M12,7A5,5 0 0,1 17,12C17,12.64 16.87,13.26 16.64,13.82L19.57,16.75C21.07,15.5 22.27,13.86 23,12C21.27,7.61 17,4.5 12,4.5C10.6,4.5 9.26,4.75 8,5.2L10.17,7.35C10.74,7.13 11.35,7 12,7Z"
                                          Fill="#6B7280"
                                          Width="18"
                                          Height="18"
                                          Stretch="Uniform"
                                          IsVisible="{Binding #ConfirmShowPasswordToggle.IsChecked}"/>
                                </Panel>
                            </ToggleButton>
                        </Grid>
                        <TextBlock Classes="field-error"
                                   Text="{Binding ConfirmPasswordError}"
                                   IsVisible="{Binding ConfirmPasswordError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>

                    <!-- Terms and Conditions Checkbox -->
                    <StackPanel Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <CheckBox IsChecked="{Binding AcceptedTerms, Mode=TwoWay}"
                                      IsEnabled="{Binding !IsLoading}"
                                      VerticalAlignment="Top"
                                      Margin="0,2,0,0"/>
                            <WrapPanel VerticalAlignment="Center">
                                <TextBlock Text="I accept the "
                                           FontSize="14"
                                           Foreground="#6B7280"
                                           VerticalAlignment="Center"/>
                                <Button Classes="auth-link"
                                        Content="Terms and Conditions"
                                        Command="{Binding ViewTermsCommand}"
                                        FontWeight="SemiBold"
                                        VerticalAlignment="Center"/>
                            </WrapPanel>
                        </StackPanel>
                        <!-- Terms Error Message -->
                        <TextBlock Classes="field-error"
                                   Text="{Binding AcceptedTermsError}"
                                   IsVisible="{Binding AcceptedTermsError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                   Margin="28,4,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Register Button -->
                <Button Classes="auth-primary"
                        Command="{Binding RegisterCommand}"
                        Margin="0,28,0,0">
                    <Panel>
                        <TextBlock Text="Create Account"
                                   IsVisible="{Binding !IsLoading}"
                                   HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" 
                                    Spacing="8"
                                    IsVisible="{Binding IsLoading}"
                                    HorizontalAlignment="Center">
                            <!-- Simple Spinner using ProgressBar -->
                            <ProgressBar Width="16" Height="16"
                                         IsIndeterminate="True"
                                         Foreground="White"
                                         Background="Transparent"
                                         VerticalAlignment="Center"/>
                            <TextBlock Text="Creating account..."
                                       Foreground="White"/>
                        </StackPanel>
                    </Panel>
                </Button>

                <!-- Login Link -->
                <StackPanel Orientation="Horizontal" 
                            Spacing="4"
                            HorizontalAlignment="Center"
                            Margin="0,24,0,0">
                    <TextBlock Text="Already have an account?"
                               FontSize="14"
                               Foreground="#6B7280"/>
                    <Button Classes="auth-link"
                            Content="Sign in"
                            Command="{Binding NavigateToLoginCommand}"
                            IsEnabled="{Binding !IsLoading}"/>
                </StackPanel>

                <!-- Approval Notice - Fixed Unicode -->
                <Border Background="#FEF3C7"
                        BorderBrush="#FCD34D"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16"
                        Margin="0,24,0,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="? Administrator Approval Required"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#92400E"/>
                        <TextBlock Text="After registration, an administrator will review and approve your account. You'll receive access once approved."
                                   FontSize="12"
                                   Foreground="#92400E"
                                   TextWrapping="Wrap"
                                   LineHeight="18"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
