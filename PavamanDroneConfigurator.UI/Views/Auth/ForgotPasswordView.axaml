<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels.Auth"
             mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="620"
             x:Class="PavamanDroneConfigurator.UI.Views.Auth.ForgotPasswordView"
             x:DataType="vm:ForgotPasswordViewModel"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        MaxWidth="380"
                        Margin="24">

                <!-- LOGO & BRANDING -->
                <StackPanel Spacing="16" Margin="0,0,0,40" HorizontalAlignment="Center">
                    <Border Width="96"
                            Height="96"
                            CornerRadius="20"
                            Background="{DynamicResource PrimaryLightBrush}"
                            BoxShadow="{DynamicResource ShadowMD}"
                            HorizontalAlignment="Center">
                        <Image Source="avares://PavamanDroneConfigurator.UI/Assets/Images/KFT Logo.png"
                               Stretch="Uniform"
                               Margin="14"/>
                    </Border>
                    <TextBlock Text="Forgot Password"
                               FontSize="{DynamicResource FontSize3XL}"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontFamily="{DynamicResource PrimaryFont}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="We'll send a reset code to your inbox"
                               FontSize="{DynamicResource FontSizeMD}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontFamily="{DynamicResource PrimaryFont}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>
                </StackPanel>

                <!-- ══════════════════════════════
                     STEP 1: Enter Email
                ════════════════════════════════ -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="{DynamicResource RadiusXL}"
                        Padding="32"
                        BoxShadow="{DynamicResource ShadowLG}"
                        IsVisible="{Binding IsStep1}">
                    <StackPanel Spacing="24">

                        <!-- Error -->
                        <Border Classes="alert-error" IsVisible="{Binding HasError}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="⚠" FontSize="16" Foreground="{DynamicResource ErrorBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ErrorMessage}"
                                           FontSize="{DynamicResource FontSizeBase}"
                                           Foreground="{DynamicResource ErrorDarkBrush}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Email Field -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="Email address" Classes="label"/>
                            <TextBox Classes="input"
                                     Text="{Binding Email, Mode=TwoWay}"
                                     Watermark="you@example.com"
                                     IsEnabled="{Binding !IsLoading}"/>
                        </StackPanel>

                        <!-- Send Code Button -->
                        <Button Classes="btn-primary"
                                Command="{Binding SendCodeCommand}"
                                HorizontalAlignment="Stretch"
                                Padding="24,14">
                            <Panel>
                                <TextBlock Text="Send Reset Code"
                                           IsVisible="{Binding !IsLoading}"
                                           HorizontalAlignment="Center"
                                           FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal"
                                            Spacing="10"
                                            IsVisible="{Binding IsLoading}"
                                            HorizontalAlignment="Center">
                                    <ProgressBar Width="18" Height="18"
                                                 IsIndeterminate="True"
                                                 Foreground="White"
                                                 Background="Transparent"
                                                 VerticalAlignment="Center"/>
                                    <TextBlock Text="Sending..." Foreground="White" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Panel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- ══════════════════════════════
                     STEP 2: Enter Code + New Password
                ════════════════════════════════ -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="{DynamicResource RadiusXL}"
                        Padding="32"
                        BoxShadow="{DynamicResource ShadowLG}"
                        IsVisible="{Binding IsStep2}">
                    <StackPanel Spacing="20">

                        <!-- Info banner -->
                        <Border Background="#EFF6FF" CornerRadius="10" Padding="14,10"
                                IsVisible="{Binding IsSuccess}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="📧" FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding SuccessMessage}"
                                           FontSize="13"
                                           Foreground="#1E40AF"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Error -->
                        <Border Classes="alert-error" IsVisible="{Binding HasError}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="⚠" FontSize="16" Foreground="{DynamicResource ErrorBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ErrorMessage}"
                                           FontSize="{DynamicResource FontSizeBase}"
                                           Foreground="{DynamicResource ErrorDarkBrush}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- 6-digit Code Field -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="6-digit reset code" Classes="label"/>
                            <TextBox Classes="input"
                                     Text="{Binding Code, Mode=TwoWay}"
                                     Watermark="Enter the code from your email"
                                     MaxLength="6"
                                     IsEnabled="{Binding !IsLoading}"
                                     FontSize="20"
                                     FontWeight="Bold"
                                     TextAlignment="Center"
                                     LetterSpacing="6"/>
                        </StackPanel>

                        <!-- New Password -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="New password" Classes="label"/>
                            <Grid>
                                <TextBox x:Name="NewPwdVisible"
                                         Classes="input"
                                         Text="{Binding NewPassword, Mode=TwoWay}"
                                         Watermark="At least 8 characters"
                                         IsEnabled="{Binding !IsLoading}"
                                         IsVisible="{Binding #ShowNewPwd.IsChecked}"/>
                                <TextBox x:Name="NewPwdMasked"
                                         Classes="input"
                                         PasswordChar="*"
                                         Text="{Binding NewPassword, Mode=TwoWay}"
                                         Watermark="At least 8 characters"
                                         IsEnabled="{Binding !IsLoading}"
                                         IsVisible="{Binding !#ShowNewPwd.IsChecked}"/>
                                <ToggleButton x:Name="ShowNewPwd"
                                              Background="Transparent" BorderThickness="0"
                                              HorizontalAlignment="Right" VerticalAlignment="Center"
                                              Margin="0,0,10,0" Padding="8" ToolTip.Tip="Show/Hide">
                                    <TextBlock Text="👁" FontSize="14"/>
                                </ToggleButton>
                            </Grid>
                        </StackPanel>

                        <!-- Confirm Password -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="Confirm password" Classes="label"/>
                            <TextBox Classes="input"
                                     PasswordChar="*"
                                     Text="{Binding ConfirmPassword, Mode=TwoWay}"
                                     Watermark="Re-enter new password"
                                     IsEnabled="{Binding !IsLoading}"/>
                        </StackPanel>

                        <!-- Reset Button -->
                        <Button Classes="btn-primary"
                                Command="{Binding ResetPasswordCommand}"
                                HorizontalAlignment="Stretch"
                                Padding="24,14">
                            <Panel>
                                <TextBlock Text="Reset Password"
                                           IsVisible="{Binding !IsLoading}"
                                           HorizontalAlignment="Center"
                                           FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal"
                                            Spacing="10"
                                            IsVisible="{Binding IsLoading}"
                                            HorizontalAlignment="Center">
                                    <ProgressBar Width="18" Height="18"
                                                 IsIndeterminate="True"
                                                 Foreground="White"
                                                 Background="Transparent"
                                                 VerticalAlignment="Center"/>
                                    <TextBlock Text="Resetting..." Foreground="White" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Panel>
                        </Button>

                        <!-- Resend / Go Back -->
                        <Button Classes="btn-ghost"
                                Content="← Try a different email"
                                Command="{Binding GoBackToStep1Command}"
                                HorizontalAlignment="Center"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                Padding="8,4"/>
                    </StackPanel>
                </Border>

                <!-- BACK TO LOGIN LINK -->
                <StackPanel Orientation="Horizontal"
                            Spacing="6"
                            HorizontalAlignment="Center"
                            Margin="0,28,0,0">
                    <TextBlock Text="Remember your password?"
                               FontSize="{DynamicResource FontSizeMD}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <Button Classes="btn-ghost"
                            Content="Sign in"
                            Command="{Binding NavigateToLoginCommand}"
                            IsEnabled="{Binding !IsLoading}"
                            Foreground="{DynamicResource PrimaryBrush}"
                            FontWeight="SemiBold"
                            Padding="4,0"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
