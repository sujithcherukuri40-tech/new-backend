<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels.Auth"
             mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="600"
             x:Class="PavamanDroneConfigurator.UI.Views.Auth.LoginView"
             x:DataType="vm:LoginViewModel"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="0" 
                        HorizontalAlignment="Stretch" 
                        VerticalAlignment="Center"
                        MaxWidth="380"
                        Margin="24">

                <!-- LOGO & BRANDING -->
                <StackPanel Spacing="16" Margin="0,0,0,48" HorizontalAlignment="Center">
                    <Border Width="120"
                            Height="120"
                            CornerRadius="24"
                            Background="{DynamicResource PrimaryLightBrush}"
                            BoxShadow="{DynamicResource ShadowMD}"
                            HorizontalAlignment="Center">
                        <Image Source="avares://PavamanDroneConfigurator.UI/Assets/Images/KFT Logo.png"
                               Stretch="Uniform"
                               Margin="16"/>
                    </Border>
                    
                    <TextBlock Text="Welcome back"
                               FontSize="{DynamicResource FontSize3XL}"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontFamily="{DynamicResource PrimaryFont}"
                               HorizontalAlignment="Center"/>
                    
                    <TextBlock Text="Sign in to Kapil Future Tech Drone Configurator"
                               FontSize="{DynamicResource FontSizeMD}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontFamily="{DynamicResource PrimaryFont}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- LOGIN CARD -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="{DynamicResource RadiusXL}"
                        Padding="32"
                        BoxShadow="{DynamicResource ShadowLG}">
                    <StackPanel Spacing="24">
                        
                        <!-- Error Message -->
                        <Border Classes="alert-error"
                                IsVisible="{Binding HasError}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="?"
                                           FontSize="16"
                                           Foreground="{DynamicResource ErrorBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ErrorMessage}"
                                           FontSize="{DynamicResource FontSizeBase}"
                                           Foreground="{DynamicResource ErrorDarkBrush}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Email Field -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="Email" Classes="label"/>
                            <TextBox Classes="input"
                                     Text="{Binding Email, Mode=TwoWay}"
                                     Watermark="you@example.com"
                                     IsEnabled="{Binding !IsLoading}"/>
                        </StackPanel>

                        <!-- Password Field -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="Password" Classes="label"/>
                            <Grid>
                                <TextBox x:Name="PasswordTextBox"
                                         Classes="input"
                                         Text="{Binding Password, Mode=TwoWay}"
                                         Watermark="Enter your password"
                                         IsEnabled="{Binding !IsLoading}"
                                         IsVisible="{Binding #ShowPasswordToggle.IsChecked}"/>
                                <TextBox x:Name="PasswordMaskedBox"
                                         Classes="input"
                                         PasswordChar="*"
                                         Text="{Binding Password, Mode=TwoWay}"
                                         Watermark="Enter your password"
                                         IsEnabled="{Binding !IsLoading}"
                                         IsVisible="{Binding !#ShowPasswordToggle.IsChecked}"/>
                                <ToggleButton x:Name="ShowPasswordToggle"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center"
                                              Margin="0,0,12,0"
                                              Padding="8"
                                              ToolTip.Tip="Show/Hide Password">
                                    <Panel>
                                        <!-- Eye Icon (Show) -->
                                        <Path Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z"
                                              Fill="{DynamicResource TextSecondaryBrush}"
                                              Width="20"
                                              Height="20"
                                              Stretch="Uniform"
                                              IsVisible="{Binding !#ShowPasswordToggle.IsChecked}"/>
                                        <!-- Eye Off Icon (Hide) -->
                                        <Path Data="M11.83,9L15,12.16C15,12.11 15,12.05 15,12A3,3 0 0,0 12,9C11.94,9 11.89,9 11.83,9M7.53,9.8L9.08,11.35C9.03,11.56 9,11.77 9,12A3,3 0 0,0 12,15C12.22,15 12.44,14.97 12.65,14.92L14.2,16.47C13.53,16.8 12.79,17 12,17A5,5 0 0,1 7,12C7,11.21 7.2,10.47 7.53,9.8M2,4.27L4.28,6.55L4.73,7C3.08,8.3 1.78,10 1,12C2.73,16.39 7,19.5 12,19.5C13.55,19.5 15.03,19.2 16.38,18.66L16.81,19.08L19.73,22L21,20.73L3.27,3M12,7A5,5 0 0,1 17,12C17,12.64 16.87,13.26 16.64,13.82L19.57,16.75C21.07,15.5 22.27,13.86 23,12C21.27,7.61 17,4.5 12,4.5C10.6,4.5 9.26,4.75 8,5.2L10.17,7.35C10.74,7.13 11.35,7 12,7Z"
                                              Fill="{DynamicResource TextSecondaryBrush}"
                                              Width="20"
                                              Height="20"
                                              Stretch="Uniform"
                                              IsVisible="{Binding #ShowPasswordToggle.IsChecked}"/>
                                    </Panel>
                                </ToggleButton>
                            </Grid>
                        </StackPanel>

                        <!-- Terms and Conditions Checkbox -->
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <CheckBox IsChecked="{Binding AcceptedTerms, Mode=TwoWay}"
                                          IsEnabled="{Binding !IsLoading}"
                                          VerticalAlignment="Top"
                                          Margin="0,2,0,0"/>
                                <WrapPanel VerticalAlignment="Center">
                                    <TextBlock Text="I accept the "
                                               FontSize="14"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <Button Classes="btn-ghost"
                                            Content="Terms and Conditions"
                                            Command="{Binding ViewTermsCommand}"
                                            Foreground="{DynamicResource PrimaryBrush}"
                                            FontWeight="SemiBold"
                                            FontSize="14"
                                            Padding="0"
                                            VerticalAlignment="Center"
                                            Cursor="Hand"/>
                                </WrapPanel>
                            </StackPanel>
                            <!-- Terms Error Message -->
                            <TextBlock Text="{Binding AcceptedTermsError}"
                                       FontSize="12"
                                       Foreground="#EF4444"
                                       TextWrapping="Wrap"
                                       IsVisible="{Binding AcceptedTermsError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       Margin="28,4,0,0"/>
                        </StackPanel>

                        <!-- Login Button -->
                        <Button Classes="btn-primary"
                                Command="{Binding LoginCommand}"
                                HorizontalAlignment="Stretch"
                                Padding="24,14">
                            <Panel>
                                <TextBlock Text="Sign In"
                                           IsVisible="{Binding !IsLoading}"
                                           HorizontalAlignment="Center"
                                           FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal" 
                                            Spacing="10"
                                            IsVisible="{Binding IsLoading}"
                                            HorizontalAlignment="Center">
                                    <!-- Simple Spinner using ProgressBar -->
                                    <ProgressBar Width="18" Height="18"
                                                 IsIndeterminate="True"
                                                 Foreground="White"
                                                 Background="Transparent"
                                                 VerticalAlignment="Center"/>
                                    <TextBlock Text="Signing in..."
                                               Foreground="White"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Panel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- REGISTER LINK -->
                <StackPanel Orientation="Horizontal" 
                            Spacing="6"
                            HorizontalAlignment="Center"
                            Margin="0,28,0,0">
                    <TextBlock Text="Don't have an account?"
                               FontSize="{DynamicResource FontSizeMD}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <Button Classes="btn-ghost"
                            Content="Create one"
                            Command="{Binding NavigateToRegisterCommand}"
                            IsEnabled="{Binding !IsLoading}"
                            Foreground="{DynamicResource PrimaryBrush}"
                            FontWeight="SemiBold"
                            Padding="4,0"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
