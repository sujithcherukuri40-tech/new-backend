<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PavamanDroneConfigurator.UI.ViewModels.Auth"
             mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="600"
             x:Class="PavamanDroneConfigurator.UI.Views.Auth.LoginView"
             x:DataType="vm:LoginViewModel"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="0" 
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center"
                        Width="380"
                        Margin="40">

                <!-- ???????????????????????????????????????????????????????????????????????????????????
                     LOGO & BRANDING
                ??????????????????????????????????????????????????????????????????????????????????? -->
                <StackPanel Spacing="16" Margin="0,0,0,48" HorizontalAlignment="Center">
                    <Border Width="80"
                            Height="80"
                            CornerRadius="{DynamicResource RadiusXL}"
                            Background="{DynamicResource PrimaryLightBrush}"
                            BoxShadow="{DynamicResource ShadowMD}"
                            HorizontalAlignment="Center">
                        <Image Source="avares://PavamanDroneConfigurator.UI/Assets/Images/logo.ico"
                               Stretch="Uniform"
                               Margin="14"/>
                    </Border>
                    
                    <TextBlock Text="Welcome back"
                               FontSize="{DynamicResource FontSize3XL}"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontFamily="{DynamicResource PrimaryFont}"
                               HorizontalAlignment="Center"/>
                    
                    <TextBlock Text="Sign in to Pavaman Drone Configurator"
                               FontSize="{DynamicResource FontSizeMD}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontFamily="{DynamicResource PrimaryFont}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- ???????????????????????????????????????????????????????????????????????????????????
                     LOGIN CARD
                ??????????????????????????????????????????????????????????????????????????????????? -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="{DynamicResource RadiusXL}"
                        Padding="32"
                        BoxShadow="{DynamicResource ShadowLG}">
                    <StackPanel Spacing="24">
                        
                        <!-- Error Message -->
                        <Border Classes="alert-error"
                                IsVisible="{Binding HasError}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="?"
                                           FontSize="16"
                                           Foreground="{DynamicResource ErrorBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ErrorMessage}"
                                           FontSize="{DynamicResource FontSizeBase}"
                                           Foreground="{DynamicResource ErrorDarkBrush}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Email Field -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="Email" Classes="label"/>
                            <TextBox Classes="input"
                                     Text="{Binding Email, Mode=TwoWay}"
                                     Watermark="you@example.com"
                                     IsEnabled="{Binding !IsLoading}"/>
                        </StackPanel>

                        <!-- Password Field -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="Password" Classes="label"/>
                            <TextBox Classes="input"
                                     PasswordChar="•"
                                     Text="{Binding Password, Mode=TwoWay}"
                                     Watermark="Enter your password"
                                     IsEnabled="{Binding !IsLoading}"/>
                        </StackPanel>

                        <!-- Login Button -->
                        <Button Classes="btn-primary"
                                Command="{Binding LoginCommand}"
                                HorizontalAlignment="Stretch"
                                Padding="24,14">
                            <Panel>
                                <TextBlock Text="Sign In"
                                           IsVisible="{Binding !IsLoading}"
                                           HorizontalAlignment="Center"
                                           FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal" 
                                            Spacing="10"
                                            IsVisible="{Binding IsLoading}"
                                            HorizontalAlignment="Center">
                                    <ProgressBar IsIndeterminate="True"
                                                 Width="18"
                                                 Height="18"
                                                 Foreground="White"/>
                                    <TextBlock Text="Signing in..."
                                               Foreground="White"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Panel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- ???????????????????????????????????????????????????????????????????????????????????
                     REGISTER LINK
                ??????????????????????????????????????????????????????????????????????????????????? -->
                <StackPanel Orientation="Horizontal" 
                            Spacing="6"
                            HorizontalAlignment="Center"
                            Margin="0,28,0,0">
                    <TextBlock Text="Don't have an account?"
                               FontSize="{DynamicResource FontSizeMD}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <Button Classes="btn-ghost"
                            Content="Create one"
                            Command="{Binding NavigateToRegisterCommand}"
                            IsEnabled="{Binding !IsLoading}"
                            Foreground="{DynamicResource PrimaryBrush}"
                            FontWeight="SemiBold"
                            Padding="4,0"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
