# ==============================================
# SECURITY: Sensitive Configuration Files
# ==============================================

# Environment files (NEVER commit these - they contain secrets)
.env
.env.local
.env.*.local

# AWS credentials
**/.aws/credentials
**/.aws/config

# User secrets
**/secrets.json

# Certificate files
**/*.pfx
**/*.p12
**/*.pem
**/*.key

# Database files
**/*.db
**/*.db-*
**/*.sqlite
**/*.sqlite3

# Log files with potential sensitive data
**/logs/*.log

# Protect sensitive configuration files
appsettings.Development.LOCAL.json
appsettings.*.LOCAL.json
*.LOCAL.json
.env.local
.env.*.local
